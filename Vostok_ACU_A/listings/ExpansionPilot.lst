     18          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     19          //! Tracks the number of expansion  pilot allocations.
     20          static uint8 Expansion_Pilot_Allocation;
     21          
     22          //! Expansion pilot parameters type definition.
     23          typedef struct EXPANSION_PILOT_DATA_STRUCT
     24          {
     25              uint8 Requested;
     26              uint8 Processed;
     27          } EXPANSION_PILOT_DATA_TYPE;
     28          
     29          //! Expansion pilot data array. One entry per expansion pilot instance.
     30          static EXPANSION_PILOT_DATA_TYPE Expansion_Pilot_Data[HBL_PILOT_NUM_EXPANSION];
     31          
     32          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     33          static uint8 GetExpansionLoadIndex(HBL_LOAD_TYPE *load);
     34          
     35          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     36          
     37          //=====================================================================================================================
     38          //-------------------------------------- Public Functions -------------------------------------------------------------
     39          //=====================================================================================================================
     40          //---------------------------------------------------------------------------------------------------------------------
     41          /**
     42           *  @brief       It Initializes the module ExpansionPilot and its variables.
     43           */
     44          void ExpansionPilot__Initialize(void)
     45          {
     46              Expansion_Pilot_Allocation = 0;
     47              memset(&Expansion_Pilot_Data, 0, sizeof(Expansion_Pilot_Data));
     48          }
     49          
     50          //---------------------------------------------------------------------------------------------------------------------
     51          /**
     52           *  @brief      Allocate instance for expansion pilot.
     53           *
     54           *  @return     uint8 retval - Allocation result.
     55           *  @retval     0-254 - Pilot allocation instance.
     56           *  @retval     0xFF - Allocation failed.
     57           */
     58          uint8 ExpansionPilot__Allocate(void)
     59          {
     60              uint8 retval;
     61          
     62              retval = 0xFF;
     63          
     64              if (Expansion_Pilot_Allocation < HBL_PILOT_NUM_EXPANSION)
     65              {
     66                  retval = Expansion_Pilot_Allocation;
     67                  Expansion_Pilot_Allocation++;
     68              }
     69          
     70              return (retval);
     71          }
     72          
     73          //---------------------------------------------------------------------------------------------------------------------
     74          /**
     75           *  @brief      Initialize expansion pilot instance.
     76           *
     77           *  @param      HBL_LOAD_TYPE *load - Pointer to associated expansion load instance.
     78           *
     79           *  @return     PASS_FAIL_TYPE result - Result of expansion pilot instance initialization.
     80           *  @retval     PASS - Instance initialization succeeded.
     81           *  @retval     FAIL - Instance initialization failed.
     82           */
     83          PASS_FAIL_TYPE ExpansionPilot__InitializeInstance(HBL_LOAD_TYPE *load)
     84          {
     85              PASS_FAIL_TYPE result;
     86          
     87              result = FAIL;
     88          
     89              if (load != NULL)
     90              {
     91                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
     92                  {
     93                      result = PASS;
     94                  }
     95              }
     96          
     97              return (result);
     98          }
     99          
    100          //---------------------------------------------------------------------------------------------------------------------
    101          /**
    102            *  @brief     Set expansion pilot instance request.
    103           *
    104           *  @param      HBL_LOAD_TYPE *load - Pointer to associated expansion load instance.
    105           *
    106           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    107           *
    108           *  @return     PASS_FAIL_TYPE result - Result of expansion pilot request.
    109           *  @retval     PASS - Instance request succeeded.
    110           *  @retval     FAIL - Instance request failed.
    111          */
    112          PASS_FAIL_TYPE ExpansionPilot__Request(HBL_LOAD_TYPE *load, void *data)
    113          {
    114              PASS_FAIL_TYPE result;
    115          
    116              result = FAIL;
    117          
    118              if ((load != NULL) && (data != NULL))
    119              {
    120                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
    121                  {
    122                      Expansion_Pilot_Data[load->Pilot_Data_Index].Requested = *((uint8 *)data);
    123                      result = PASS;
    124                  }
    125              }
    126          
    127              return (result);
    128          }
    129          
    130          //---------------------------------------------------------------------------------------------------------------------
    131          /**
    132           *  @brief      Process expansion pilot instance.
    133           *
    134           *  @param      HBL_LOAD_TYPE *load - Pointer to expansion load instance.
    135           *
    136           *  @return     PASS_FAIL_TYPE result - Result of expansion pilot instance process.
    137           *  @retval     PASS - Instance process succeeded.
    138           *  @retval     FAIL - Instance process failed.
    139           */
    140          PASS_FAIL_TYPE ExpansionPilot__Process(HBL_LOAD_TYPE *load)
    141          {
    142              PASS_FAIL_TYPE result;
    143              uint8 expansion_load_index;
    144          
    145              result = FAIL;
    146          
    147              if (load != NULL)
    148              {
    149                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
    150                  {
    151                      Expansion_Pilot_Data[load->Pilot_Data_Index].Processed =
    152                          Expansion_Pilot_Data[load->Pilot_Data_Index].Requested;
    153          
    154                      expansion_load_index = GetExpansionLoadIndex(load);
    155                      API012Exp__SetExpansionLoad(expansion_load_index, Expansion_Pilot_Data[load->Pilot_Data_Index].Processed);
    156          
    157                      result = PASS;
    158                  }
    159              }
    160          
    161              return (result);
    162          }
    163          
    164          //---------------------------------------------------------------------------------------------------------------------
    165          /**
    166           *  @brief      Get current expansion pilot instance request.
    167           *
    168           *  @param      HBL_LOAD_TYPE *load - Pointer to associated expansion load instance.
    169           *
    170           *  @return     void *requested - Requested instance data.
    171           *  @retval     Address of requested instance data. Cast it using *((uint8 *)ptr) to get values.
    172           *  @retval     NULL - Invalid load index.
    173           */
    174          void * ExpansionPilot__GetRequested(HBL_LOAD_TYPE *load)
    175          {
    176              void *requested;
    177          
    178              requested = NULL;
    179          
    180              if (load != NULL)
    181              {
    182                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
    183                  {
    184                      requested = &(Expansion_Pilot_Data[load->Pilot_Data_Index].Requested);
    185                  }
    186              }
    187          
    188              return (requested);
    189          }
