    333          
    334          //---------------------------------------------------------------------------------------------------------------------
    335          /**
    336           * @brief   Class B Data Integrity check handler
    337           * It should be run on Application thread before SRHbl__Process()
    338           * It checks SRUMRelayPilot_Allocation and SRUMRelayPilot_Data integrity
    339           * It marks SRTASKSEQUENCE_APPL_SRUMRELAYPILOT_CHECK step on SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    340           */
    341          void SRUMRelayPilot__Handler(void)
    342          {
    343          
    344              if (SRDATA_OK != SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation))
    345              {
    346                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0x00, 0xAB);
    347                  // System will reset after this exception occurs
    348              }
    349              else
    350              {
    351                  for (uint8 index = 0; index < HBL_PILOT_NUM_SRUMRELAY; index++)
    352                  {
    353                      if (SRData__CheckArrayNonBlocking((uint8 *)(void *)&SRUMRelayPilot_Data[index],
    354                          (uint8 *)(void *)&N_SRUMRelayPilot_Data[index], sizeof(SRUMRELAYPILOT_DATA_TYPE)) != SRDATA_OK)
    355                      {
    356                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0x01, index);
    357                          // System will reset after this exception occurs
    358                      }
    359                  }
    360              }
    361          
    362              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    363                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRUMRELAYPILOT_CHECK);
    364              #endif
    365          
    366          }
    367          
    368          //---------------------------------------------------------------------------------------------------------------------
    369          /**
    370           *  @brief      ZeroCross event processing for SRUMRelayPilot.
    371           *
    372           *  @details     ZeroCross process handles Triac activation (if requested) and ZeroCross sequence counter
    373           *
    374           *  @param      load - Pointer to SRUMRelayPilot instance.
    375           *
    376           *  @return     PASS_FAIL_TYPE result - Result of SRUMRelayPilot asynch execution.
    377           *  @retval     PASS - Execution succeeded.
    378           *  @retval     FAIL - Execution failed.
    379           */
    380          PASS_FAIL_TYPE  SRUMRelayPilot__ZcProcess(HBL_LOAD_TYPE *load)
    381          {
    382              PASS_FAIL_TYPE ret_val = FAIL;
    383          
    384              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    385                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    386              {
    387                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    388                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    389          
    390                  if ((SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr,(void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE))) &&
    391                      (data_ptr->State != SRUMRELAYPILOT_INITALIZE))
    392                  {
    393                      ZEROCROSS_EVENT_TYPE last_event = ZeroCross__GetLastEvent();
    394                      BOOL_TYPE firing_triac = FALSE;
    395          
    396                      // Update ZeroCross_Sequence
    397                      if(last_event != ZEROCROSS_BLACKOUT_EVENT)
    398                      {
    399                          uint8 zc_next_seq = data_ptr->ZeroCross_Sequence + 1;
    400                          if (zc_next_seq == 0)
    401                          {
    402                              zc_next_seq++;
    403                          }
    404                          SRData__UpdateByte(&data_ptr->ZeroCross_Sequence, &n_data_ptr->ZeroCross_Sequence, zc_next_seq);
    405                      }
    406          
    407                      if((last_event != ZEROCROSS_BLACKOUT_EVENT) &&
    408                          (data_ptr->Enable_Triac == TRUE))
    409                      {
    410                          uint32 zc_half_period = ZeroCross__GetCycleCount()/2;
    411                          uint16 zc_latency = ZeroCross__GetTimeFromLastEvent();
    412                          ret_val = PASS;
    413          
    414                          #if (ZC_HANDLER_TIMING_US > 0) && (ZC_NUM_GPIO_REQUESTS > 0) && (SRUMRELAYPILOT_FORCE_OC == DISABLED)
    415                              uint16 angle = (data_ptr->Status.Firing_Angle_S15 * zc_half_period) >> 15;
    416                              ZEROCROSS_GPIO_REQUEST_TYPE triac_req;
    417          
    418                              angle -= zc_latency;
    419                              triac_req.Active_Degree = (uint8) ((angle * ZEROCROSS_HALF_WAVE_ANGLE) / zc_half_period);
    420                              angle += PULSE_WIDTH_US;
    421                              triac_req.Deactive_Degree = (uint8) ((angle * ZEROCROSS_HALF_WAVE_ANGLE) / zc_half_period);
    422                              triac_req.Active_value = (BOOL_TYPE) (load->Hi_Low_Activation_Bitmap & 0x01);
    423                              triac_req.Gpio_Id = data_ptr->Triac_Id;
    424                              ZeroCross__RequestGpioActivity(&triac_req);
    425                          #else
    426                              sint32 oc_timeout = (zc_half_period * data_ptr->Status.Firing_Angle_S15  + 16384) >> 15;
    427                              TIMER_ONCOMPARE_TYPE oc_type = (load->Hi_Low_Activation_Bitmap & 0x01) ? TIMER_ONCOMPARE_PIN_HIGH_INTERRUPT : TIMER_ONCOMPARE_PIN_LOW_INTERRUPT;
    428          
    429                              if ((data_ptr->Status.Firing_Angle_S15 < MIN_ANGLE) ||
    430                                  (oc_timeout < zc_latency))
    431                              {
    432                                  oc_timeout =  (zc_half_period*MIN_ANGLE)>>15;
    433                              }
    434                              else
    435                              {
    436                                  if (data_ptr->Status.Firing_Angle_S15 > MAX_ANGLE)
    437                                  {
    438                                      oc_timeout = (zc_half_period * MAX_ANGLE)>>15;
    439                                  }
    440                                  oc_timeout -= zc_latency;
    441                              }
    442          
    443                              ret_val &= Timer__ConfigCheck(&data_ptr->OC_Timer_Config);
    444                              SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Mode,
    445                                  (void *) &n_data_ptr->OC_Timer_Config.Mode, TIMER_MODE_OUTPUT_COMPARE);
    446                              ret_val &= Timer__Config(&data_ptr->OC_Timer_Config);
    447                              Timer__OutputCompareStart(&data_ptr->OC_Timer_Config, oc_type, oc_timeout);
    448                          #endif
    449                          firing_triac = TRUE;
    450                      }
    451                      else
    452                      {
    453                          uint8 *pin_ptr = load->Pin_Ptr;
    454                          uint8 hi_lo_bitmap = load->Hi_Low_Activation_Bitmap;
    455                          uint8 new_debounce_counter = data_ptr->Triac_Check_Debounce+1;
    456          
    457                          ret_val = CheckPin(pin_ptr[0], OFF, hi_lo_bitmap & 0x01, new_debounce_counter);
    458                          if (ret_val == PASS)
    459                          {
    460                              #if (ZC_HANDLER_TIMING_US == 0) || (ZC_NUM_GPIO_REQUESTS == 0) || (SRUMRELAYPILOT_FORCE_OC == ENABLED)
    461                                  // Keep Timer disabled
    462                                  ret_val &= Timer__ConfigCheck(&data_ptr->OC_Timer_Config);
    463                                  if(data_ptr->OC_Timer_Config.Mode != TIMER_MODE_DISABLE)
    464                                  {
    465                                      SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Mode,
    466                                          (void *) &n_data_ptr->OC_Timer_Config.Mode, TIMER_MODE_DISABLE);
    467                                      ret_val &= Timer__Config(&data_ptr->OC_Timer_Config);
    468                                  }
    469                              #endif
    470                              UpdatePin(pin_ptr[0], OFF, hi_lo_bitmap & 0x01);
    471                              new_debounce_counter = 0;
    472                          }
    473          
    474                          SRData__UpdateByte((void *) &data_ptr->Triac_Check_Debounce,
    475                              (void *) &n_data_ptr->Triac_Check_Debounce, new_debounce_counter);
    476                      }
    477          
    478                      SRData__UpdateByte((void *) &data_ptr->Status.Is_Triac_Firing,
    479                          (void *) &n_data_ptr->Status.Is_Triac_Firing, firing_triac);
    480                  }
    481              }
    482              return(ret_val);
    483          }
    484          
    485          //---------------------------------------------------------------------------------------------------------------------
    486          /**
    487           *  @brief      Asynchronous process for SRUMRelayPilot.
    488           *
    489           *  @details    Asynchronous process handles motor pilot state machine and sequences between Relays and Triac
    490           *
    491           *  @param      load - Pointer to SRUMRelayPilot instance.
    492           *
    493           *  @return     PASS_FAIL_TYPE result - Result of SRUMRelayPilot asynch execution.
    494           *  @retval     PASS - Execution succeeded.
    495           *  @retval     FAIL - Execution failed.
    496           */
    497          PASS_FAIL_TYPE  SRUMRelayPilot__AsyncProcess(HBL_LOAD_TYPE *load)
    498          {
    499              PASS_FAIL_TYPE ret_val = FAIL;
    500          
    501              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    502                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    503              {
    504                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    505                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    506          
    507                  if (SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr,(void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE)))
    508                  {
    509                      SRUMRELAYPILOT_SF_PARAM_TYPE *param_ptr = (void *)load->Parameter_Ptr.Data;
    510                      uint8 hi_lo_bitmap = load->Hi_Low_Activation_Bitmap;
    511                      uint8 *pin_ptr = load->Pin_Ptr;
    512                      BOOL_TYPE enable_triac = FALSE;
    513                      SRUMRELAYPILOT_CONTROL_STATUS_TYPE control_status;
    514                      SRUMRELAYPILOT_CONTROL_PARAM_TYPE control_param;
    515                      HBL_LOAD_STATUS_TYPE current_load_status;
    516                      HBL_CONSISTENCY_TYPE own_consistency;
    517          
    518                      // Initialize local variables
    519                      current_load_status.Load.Cur_Reg = OFF;
    520                      current_load_status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    521                      own_consistency.Consistency.Table = HBL_CONSISTENCY_TABLE_INVALID;
    522                      own_consistency.Consistency.Value = HBL_CONSISTENCY_INVALID_VALUE;
    523                      memset(&control_status, 0, sizeof(control_status));
    524          
    525                      #ifdef SRUMRELAYPILOT_FALLBACK_SF_PARAMS
    526                          if (param_ptr == NULL)
    527                          {
    528                              param_ptr = (void *) &SRUMRelayPilot_Default_SF_Params;
    529                          }
    530                      #endif
    531                      if((data_ptr->State != SRUMRELAYPILOT_INITALIZE) &&
    532                          (PASS == CheckPin(pin_ptr[1], data_ptr->Status.Cw_Relay, (hi_lo_bitmap >> 1) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT)) &&
    533                          (PASS == CheckPin(pin_ptr[2], data_ptr->Status.Ccw_Relay, (hi_lo_bitmap >> 2) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT)) &&
    534                          (PASS == CheckPin(pin_ptr[3], data_ptr->Status.Tapped_Field_Relay, (hi_lo_bitmap >> 3) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT)))
    535                      {
    536                          uint16 tacho_cnt = data_ptr->Tacho_Cnt;
    537                          uint8 tacho_index = param_ptr->Tacho_Fb_Index;
    538                          uint8 tacho_seq_id;
    539          
    540                          #ifdef SRUMRELAYPILOT__GET_CSTM_TACHO_INDEX
    541                              if (tacho_index >= Hbl__GetNumLLI())
    542                              {
    543                                  tacho_index = SRUMRELAYPILOT__GET_CSTM_TACHO_INDEX(load);
    544                              }
    545                          #endif
    546          
    547                          // Decrement Feedback / Suspend time counter
    548                          if (data_ptr->Time_Cnt > 0)
    549                          {
    550                              SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    551                                  (void *)&n_data_ptr->Time_Cnt, data_ptr->Time_Cnt-1);
    552                          }
    553          
    554                          // Check Tacho signal
    555                          tacho_seq_id = Hbl__GetLLISequenceIDByIndex(tacho_index);
    556                          if(data_ptr->Tacho_Seq_Id == tacho_seq_id)
    557                          {
    558                              if (tacho_cnt > 0)
    559                              {
    560                                  tacho_cnt--;
    561                              }
    562                          }
    563                          else
    564                          {
    565                              tacho_cnt = param_ptr->Tacho_Timeout * TACHO_TIMING_SCALE;
    566                              SRData__UpdateByte(&data_ptr->Tacho_Seq_Id, &n_data_ptr->Tacho_Seq_Id, tacho_seq_id);
    567                          }
    568                          SRData__UpdateShort(&data_ptr->Tacho_Cnt, &n_data_ptr->Tacho_Cnt, tacho_cnt);
    569          
    570                          if ((data_ptr->State != SRUMRELAYPILOT_IDLE) &&
    571                              (data_ptr->State != SRUMRELAYPILOT_STOP))
    572                          {
    573                              current_load_status.Load.Cur_Reg = ON;
    574                              if ((data_ptr->State == SRUMRELAYPILOT_RUN) &&
    575                                  (data_ptr->Status.Firing_Angle_S15 < param_ptr->Angle_Fbk_Threshold))
    576                              {
    577                                  current_load_status.Load.Status = HBL_LOAD_STATUS_TARGET_ALT_TABLE;
    578                              }
    579                          }
    580                          own_consistency.Byte = Hbl__GetOwnLoadConsistency(load, current_load_status.Byte);
    581          
    582                          // Execute Control Handler
    583                          control_param.Processed = data_ptr->Processed;
    584                          control_param.State = data_ptr->State;
    585                          control_param.Tacho_Index = tacho_index;
    586                          control_param.ZeroCross_Sequence = data_ptr->ZeroCross_Sequence;
    587                          control_param.Is_Triac_Firing = data_ptr->Status.Is_Triac_Firing;
    588                          control_param.Is_Running = data_ptr->Status.Is_Running;
    589                          control_param.Is_Tacho_Signal = (BOOL_TYPE) (data_ptr->Tacho_Cnt != 0);
    590          
    591                          if(SRUMRELAYPILOT__CONTROL_HANDLER(load, &control_param, &control_status) == PASS)
    592                          {
    593                              SRData__UpdateLong((void *)&data_ptr->Status.Motor_Speed_S15,
    594                                  (void *)&n_data_ptr->Status.Motor_Speed_S15, control_status.Motor_Speed_S15);
    595                              SRData__UpdateLong((void *)&data_ptr->Status.Motor_Speed_Ref_S15,
    596                                  (void *)&n_data_ptr->Status.Motor_Speed_Ref_S15, control_status.Motor_Speed_Ref_S15);
    597                              SRData__UpdateByte((void *) &data_ptr->Status.Fault,
    598                                  (void *)  &n_data_ptr->Status.Fault, control_status.Fault);
    599                              SRData__UpdateByte((void *) &data_ptr->Status.Has_Start_Failed,
    600                                  (void *) &n_data_ptr->Status.Has_Start_Failed, control_status.Has_Start_Failed);
    601                              SRData__UpdateByte((void *) &data_ptr->Status.Is_Speed_Reached,
    602                                  (void *) &n_data_ptr->Status.Is_Speed_Reached, control_status.Is_Speed_Reached);
    603                              SRData__UpdateByte((void *) &data_ptr->Status.Is_Running,
    604                                  (void *) &n_data_ptr->Status.Is_Running, control_status.Is_Running);
    605          
    606                              if (data_ptr->Processed.Custom_Param.Data.Force_Tap_Field_On == ON)
    607                              {
    608                                  control_status.Tapped_Field_Relay = ON;
    609                              }
    610                          }
    611                          else
    612                          {
    613                              SRData__UpdateLong((void *)&data_ptr->Status.Motor_Speed_S15,
    614                                  (void *)&n_data_ptr->Status.Motor_Speed_S15, 0);
    615                              SRData__UpdateLong((void *)&data_ptr->Status.Motor_Speed_Ref_S15,
    616                                  (void *)&n_data_ptr->Status.Motor_Speed_Ref_S15, 0);
    617                              SRData__UpdateByte((void *) &data_ptr->Status.Fault,
    618                                  (void *) &n_data_ptr->Status.Fault, TRUE);
    619                              SRData__UpdateByte((void *) &data_ptr->Status.Has_Start_Failed,
    620                                  (void *) &n_data_ptr->Status.Has_Start_Failed, FALSE);
    621                              SRData__UpdateByte((void *) &data_ptr->Status.Is_Speed_Reached,
    622                                  (void *) &n_data_ptr->Status.Is_Speed_Reached, TRUE);
    623                              SRData__UpdateByte((void *) &data_ptr->Status.Is_Running,
    624                                  (void *) &data_ptr->Status.Is_Running, FALSE);
    625                              StopMotor(data_ptr, n_data_ptr, param_ptr);
    626                          }
    627          
    628                          ret_val = PASS;
    629                      }
    630                      else
    631                      {
    632                          HBL_LOAD_STATUS_TYPE load_status;
    633                          load_status.Load.Cur_Reg = OFF;
    634                          load_status.Load.Status = HBL_LOAD_STATUS_FAILURE;
    635                          SRData__UpdateByte((void *) &data_ptr->Status.Load.Byte,
    636                              (void *) &n_data_ptr->Status.Load.Byte, load_status.Byte);
    637                      }
    638          
    639                      switch (data_ptr->State)
    640                      {
    641                          case SRUMRELAYPILOT_IDLE:
    642                              current_load_status.Load.Cur_Reg = OFF;
    643                              SRData__UpdateByte((void *)&data_ptr->Status.Tapped_Field_Relay,
    644                                  (void *)&n_data_ptr->Status.Tapped_Field_Relay, OFF);
    645                              SRData__UpdateByte((void *)&data_ptr->Status.Is_Triac_Firing,
    646                                  (void *)&n_data_ptr->Status.Is_Triac_Firing, FALSE);
    647                              SRData__UpdateByte((void *)&data_ptr->Status.Is_Running,
    648                                  (void *)&n_data_ptr->Status.Is_Running, FALSE);
    649          
    650                              if (IsConsistencyOK(own_consistency) != TRUE)
    651                              {
    652                                  SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    653                                      (void *)&n_data_ptr->Time_Cnt, param_ptr->Fbk_Debounce_Time);
    654                              }
    655          
    656                              // New command will start if Consistency is OK, one direction relay is set and tacho is lost
    657                              if ((control_status.Cw_Relay != control_status.Ccw_Relay) &&
    658                                  (control_status.Firing_Angle_S15 >= param_ptr->Angle_Fbk_Threshold) &&
    659                                  (data_ptr->Time_Cnt == 0) &&
    660                                  (data_ptr->Tacho_Cnt == 0))
    661                              {
    662                                  SRData__UpdateByte((void *)&data_ptr->Status.Cw_Relay,
    663                                      (void *)&n_data_ptr->Status.Cw_Relay, control_status.Cw_Relay);
    664                                  SRData__UpdateByte((void *)&data_ptr->Status.Ccw_Relay,
    665                                      (void *)&n_data_ptr->Status.Ccw_Relay, control_status.Ccw_Relay);
    666                                  SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_START);
    667                                  current_load_status.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    668                                  SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    669                                      (void *)&n_data_ptr->Time_Cnt, param_ptr->Fbk_Debounce_Time);
    670                                  SRData__UpdateByte((void *) &data_ptr->Status.Is_Speed_Reached,
    671                                      (void *) &n_data_ptr->Status.Is_Speed_Reached, FALSE);
    672                              }
    673                              else
    674                              {
    675                                  SRData__UpdateByte((void *)&data_ptr->Status.Cw_Relay,
    676                                      (void *)&n_data_ptr->Status.Cw_Relay, data_ptr->Processed.Custom_Param.Data.Idle_Relays_On);
    677                                  SRData__UpdateByte((void *)&data_ptr->Status.Ccw_Relay,
    678                                      (void *)&n_data_ptr->Status.Ccw_Relay, data_ptr->Processed.Custom_Param.Data.Idle_Relays_On);
    679                                  SRData__UpdateByte((void *)&data_ptr->Status.Is_Speed_Reached,
    680                                      (void *)&n_data_ptr->Status.Is_Speed_Reached, (BOOL_TYPE)((data_ptr->Status.Fault == 0) &&
    681                                          (data_ptr->Tacho_Cnt == 0)));
    682                                  current_load_status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    683                              }
    684                              SRData__UpdateByte((void *)&data_ptr->Status.Load.Byte,
    685                                  (void *)&n_data_ptr->Status.Load.Byte, current_load_status.Byte);
    686                              break;
    687          
    688                          case SRUMRELAYPILOT_START:
    689                             if(IsStopCommand(data_ptr) ||
    690                                 (control_status.Firing_Angle_S15 < param_ptr->Angle_Fbk_Threshold) ||
    691                                 (control_status.Cw_Relay != data_ptr->Status.Cw_Relay) ||
    692                                 (control_status.Ccw_Relay != data_ptr->Status.Ccw_Relay))
    693                              {
    694                                  StopMotor(data_ptr, n_data_ptr, param_ptr);
    695                              }
    696                             else if (IsConsistencyOK(own_consistency) == TRUE)
    697                             {
    698                                  if ((data_ptr->Time_Cnt == 0) &&
    699                                      (data_ptr->Tacho_Cnt == 0))
    700                                  {
    701                                      enable_triac = TRUE;
    702                                      SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_RUN);
    703                                  }
    704                             }
    705                             else
    706                             {
    707                                 SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    708                                     (void *)&n_data_ptr->Time_Cnt, param_ptr->Fbk_Debounce_Time);
    709                             }
    710                             break;
    711          
    712                          case SRUMRELAYPILOT_RUN:
    713                              if(IsStopCommand(data_ptr) ||
    714                                   (control_status.Cw_Relay != data_ptr->Status.Cw_Relay) ||
    715                                   (control_status.Ccw_Relay != data_ptr->Status.Ccw_Relay))
    716                              {
    717                                  StopMotor(data_ptr, n_data_ptr, param_ptr);
    718                              }
    719                              else if (data_ptr->Status.Tapped_Field_Relay != control_status.Tapped_Field_Relay)
    720                              {
    721                                  if (data_ptr->Status.Is_Triac_Firing == TRUE)
    722                                  {
    723                                      SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_SUSPEND);
    724                                      SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    725                                          (void *)&n_data_ptr->Time_Cnt, param_ptr->Tapfield_Suspend_Time);
    726                                  }
    727                                  else
    728                                  {
    729                                      SRData__UpdateByte((void *)&data_ptr->Status.Tapped_Field_Relay,
    730                                          (void *)&n_data_ptr->Status.Tapped_Field_Relay, control_status.Tapped_Field_Relay);
    731                                  }
    732                              }
    733                              else
    734                              {
    735                                  enable_triac = TRUE;
    736                                  current_load_status.Load.Cur_Reg = ON;
    737                                  SRData__UpdateByte((void *)&data_ptr->Status.Load.Byte,
    738                                      (void *)&n_data_ptr->Status.Load.Byte, current_load_status.Byte);
    739                              }
    740                              break;
    741          
    742                          case SRUMRELAYPILOT_SUSPEND:
    743                              if(IsStopCommand(data_ptr) ||
    744                                  (control_status.Cw_Relay != data_ptr->Status.Cw_Relay) ||
    745                                  (control_status.Ccw_Relay != data_ptr->Status.Ccw_Relay))
    746                              {
    747                                  StopMotor(data_ptr, n_data_ptr, param_ptr);
    748                              }
    749                              else if ((data_ptr->Status.Tapped_Field_Relay == control_status.Tapped_Field_Relay) &&
    750                                  (IsConsistencyOK(own_consistency) == FALSE))
    751                              {
    752                                  SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    753                                      (void *)&n_data_ptr->Time_Cnt, param_ptr->Fbk_Debounce_Time);
    754                              }
    755                              else if (data_ptr->Time_Cnt == 0)
    756                              {
    757                                  if ((data_ptr->Status.Is_Triac_Firing == FALSE) &&
    758                                      (data_ptr->Status.Tapped_Field_Relay != control_status.Tapped_Field_Relay))
    759                                  {
    760                                      SRData__UpdateByte((void *)&data_ptr->Status.Tapped_Field_Relay,
    761                                          (void *)&n_data_ptr->Status.Tapped_Field_Relay, control_status.Tapped_Field_Relay);
    762                                      SRData__UpdateShort((void *)&data_ptr->Time_Cnt,
    763                                          (void *)&n_data_ptr->Time_Cnt, param_ptr->Tapfield_Suspend_Time);
    764                                  }
    765                                  else
    766                                  {
    767                                      enable_triac = TRUE;
    768                                      SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_RUN);
    769                                  }
    770                              }
    771                              break;
    772          
    773                          case SRUMRELAYPILOT_STOP:
    774                              if ((data_ptr->Time_Cnt == 0) &&
    775                                  (data_ptr->Status.Is_Triac_Firing == FALSE))
    776                              {
    777                                  SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_IDLE);
    778                                  SRData__UpdateShort((void *)&data_ptr->Time_Cnt, (void *)&n_data_ptr->Time_Cnt, param_ptr->Fbk_Debounce_Time);
    779                              }
    780                              break;
    781          
    782                          default:
    783                              ret_val = FAIL;
    784                              break;
    785                      }
    786          
    787                      if (ret_val == PASS)
    788                      {
    789                          // Configure Relay Pin status
    790                          UpdatePin(pin_ptr[1], data_ptr->Status.Cw_Relay, (hi_lo_bitmap >> 1) & 0x01);
    791                          UpdatePin(pin_ptr[2], data_ptr->Status.Ccw_Relay, (hi_lo_bitmap >> 2) & 0x01);
    792                          UpdatePin(pin_ptr[3], data_ptr->Status.Tapped_Field_Relay, (hi_lo_bitmap >> 3) & 0x01);
    793          
    794                          // Set Triac Firing
    795                          if((data_ptr->Processed.Custom_Param.Data.Disable_Triac != OFF) ||
    796                              (control_status.Firing_Angle_S15 >= MAX_ANGLE_VALUE))
    797                          {
    798                              enable_triac = FALSE;
    799                          }
    800                          SRData__UpdateByte((void *)&data_ptr->Enable_Triac, (void *)&n_data_ptr->Enable_Triac, enable_triac);
    801                          SRData__UpdateShort((void *)&data_ptr->Status.Firing_Angle_S15, (void *)&n_data_ptr->Status.Firing_Angle_S15,
    802                              ((enable_triac == TRUE) ? control_status.Firing_Angle_S15 : MAX_ANGLE_VALUE));
    803                      }
    804                  }
    805              }
    806          
    807          
    808              return(ret_val);
    809          }
    810          
    811          //---------------------------------------------------------------------------------------------------------------------
    812          /**
    813           *  @brief      Output compare event processing for SRUMRelayPilot.
    814           *
    815           *  @details    Output compare process handles Triac deactivation (if it has been activated)
    816           *
    817           *  @param      load - Pointer to SRUMRelayPilot instance.
    818           *
    819           *  @return     PASS_FAIL_TYPE result - Result of SRUMRelayPilot asynch execution.
    820           *  @retval     PASS - Execution succeeded.
    821           *  @retval     FAIL - Execution failed.
    822           */
    823          PASS_FAIL_TYPE  SRUMRelayPilot__OCProcess(HBL_LOAD_TYPE *load)
    824          {
    825              PASS_FAIL_TYPE ret_val = FAIL;
    826          
    827          #if (ZC_HANDLER_TIMING_US == 0) || (ZC_NUM_GPIO_REQUESTS == 0) || (SRUMRELAYPILOT_FORCE_OC == ENABLED)
    828              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    829                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    830              {
    831                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    832                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    833          
    834                  if ((SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr,(void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE))) &&
    835                      (data_ptr->State != SRUMRELAYPILOT_INITALIZE))
    836                  {
    837                      uint8 *pin_ptr = load->Pin_Ptr;
    838                      uint8 hi_lo_bitmap = load->Hi_Low_Activation_Bitmap;
    839                      uint8 new_debounce_counter = data_ptr->Triac_Check_Debounce + 1;
    840          
    841                      if (PASS == CheckPin(pin_ptr[0], ON, hi_lo_bitmap & 0x01, new_debounce_counter))
    842                      {
    843                          uint32 zc_half_period = ZeroCross__GetCycleCount()/2;
    844                          sint32 angle_us = (zc_half_period * data_ptr->Status.Firing_Angle_S15  + 16384) >> 15;
    845                          uint32 pulse = PULSE_WIDTH_US;
    846          
    847                          if(angle_us < zc_half_period/2)
    848                          {
    849                              pulse = zc_half_period/2 - angle_us + PULSE_WIDTH_US;
    850                          }
    851          
    852                          uint8 hi_lo_bitmap = load->Hi_Low_Activation_Bitmap;
    853                          TIMER_ONCOMPARE_TYPE oc_type;
    854          
    855                          (void) Timer__ConfigCheck(&data_ptr->OC_Timer_Config);
    856                          oc_type = (hi_lo_bitmap & 0x01) ? TIMER_ONCOMPARE_PIN_LOW : TIMER_ONCOMPARE_PIN_HIGH;
    857                          Timer__Config(&data_ptr->OC_Timer_Config);
    858                          Timer__OutputCompareStart(&data_ptr->OC_Timer_Config, oc_type, pulse);
    859                          new_debounce_counter = 0;
    860                          ret_val = PASS;
    861                      }
    862                      SRData__UpdateByte((void *) &data_ptr->Triac_Check_Debounce,
    863                          (void *) &n_data_ptr->Triac_Check_Debounce, new_debounce_counter);
    864                  }
    865              }
    866          #endif
    867              return(ret_val);
    868          }
