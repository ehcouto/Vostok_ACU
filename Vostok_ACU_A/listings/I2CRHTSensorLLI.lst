    304          /**
    305           * @brief   It Initializes the module I2CRHTSensor LLI and its variables
    306           */
    307          void I2CRHTSensorLLI__Initialize(void)
    308          {
    309          	#if ((SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0) || (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0))
    310          		// Initialization of the device related variables
    311          		SHT2X_Instance_Handler_ID = NULL;
    312          		SHT2X_State_Delay_Counter = 0;
    313          		SHT2X_Total_Sensor = 0;
    314          		SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    315          		SHT2XI2C_Retry = 0;
    316          		SHT2XI2C_TimeOut = 0;
    317          		SHT2XI2C_Forced_Reset = FALSE;
    318          		SHT2X_Reset_Counter = SHT2X_I2C_RESET_TIME_TIMEOUT;
    319          		SHT2X_Powerup_Stable_Counter = SHT2X_I2C_POWERUP_STABLE_TIME;
    320          		SHT2X_After_Reset_Stable_Counter = 0;
    321          		Temperature_Q15_Format = TEMPERATURE_INVALID_VALUE;
    322              #if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    323          		SHT2XHumidity_Allocation = 0;
    324              #endif
    325              #if (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    326          		SHT2XTemperature_Allocation = 0;
    327              #endif
    328          
    329          		#if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    330          			for (uint8 index = 0; index < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR; index++)
    331          			{
    332          				memset(&SHT2XHumidity_Data[index],0,sizeof(SHT2XHumidity_Data[0]));
    333          			}
    334          			I2CHumidity_Allocation = 0;
    335          		#endif
    336          
    337          		#if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
    338          		   for (uint8 index = 0; index < HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR; index++)
    339          		   {
    340          			   memset(&SHT2XTemperature_Data[index],0,sizeof(SHT2XTemperature_Data[0]));
    341          		   }
    342          		   I2CTemperature_Allocation = 0;
    343          		#endif
    344          	#endif
    345          
    346          }
    347          
    348          //---------------------------------------------------------------------------------------------------------------------
    349          /**
    350           * @brief   Determines the destination (index) of the data for the LLI.
    351           * @return  Index to a local buffer where the data will reside.
    352           */
    353          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    354          uint8 I2CRHTSensorLLI__AllocateHumidity(void)
    355          {
    356              uint8 retval = 0xFF;
    357          
    358              if (I2CHumidity_Allocation < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR)
    359              {
    360                  retval = I2CHumidity_Allocation;
    361                  I2CHumidity_Allocation++;
    362              }
    363              return (retval);
    364          }
    365          #endif
    366          
    367          //---------------------------------------------------------------------------------------------------------------------
    368          /**
    369           * @brief   Determines the destination (index) of the data for the LLI.
    370           * @return  Index to a local buffer where the data will reside.
    371           */
    372          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
    373          uint8 I2CRHTSensorLLI__AllocateTemperature(void)
    374          {
    375              uint8 retval = 0xFF;
    376          
    377              if (I2CTemperature_Allocation < HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR)
    378              {
    379                  retval = I2CTemperature_Allocation;
    380                  I2CTemperature_Allocation++;
    381              }
    382              return (retval);
    383          }
    384          #endif
