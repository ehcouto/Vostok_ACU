    922              if(INPUT_LEN > (MC_U8)MC_COMM_BUFFER_SIZE)
    923              {
    924                  return MC_ConstToBuffer8(pResponse, MC_STC_RSPBUFFOVF);
    925              }
    926          
    927              /* success  */
    928              pResponse = MC_ConstToBuffer8(pResponse, MC_STS_OK);
    929          
