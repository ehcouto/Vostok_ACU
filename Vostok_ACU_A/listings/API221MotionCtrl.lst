    314          // -- Private Flash-Based Constant Definitions --
    315          
    316          #if (API221_SERVER_FEATURE == ENABLED)
    317              //! This table is used to convert bits that represent the previous and current motor status into
    318              //! events. The key (used as an index into the array) consists of the following bits:
    319              //!     bit 3 = Was previously reached target
    320              //!     bit 2 = Was previously stopped
    321              //!     bit 1 = Is currently reached target
    322              //!     bit 0 = Is currently stopped
    323              //! For the two bits 'Reached Target' and 'Stopped', the following is assumed:
    324              //!     Reached Target   and   Stopped  results in   State
    325              //!     --------------         -------              -------
    326              //!         False               False               Ramping
    327              //!         False               True                Stopped
    328              //!         True                False               Plateau
    329              //!         True                True                Stopped
    330              static const API221_MOTOR_EVENT_TYPE KEY_TO_EVENT[] =
    331              {
    332                  API221_EVENT_NONE,                      //!< Was ramping and is ramping
    333                  API221_EVENT_STOPPED,                   //!< Was ramping and is stopped
    334                  API221_EVENT_REACHED_TARGET,            //!< Was ramping and is plateau
    335                  API221_EVENT_STOPPED,                   //!< Was ramping and is stopped
    336                  API221_EVENT_RAMP_STARTED,              //!< Was stopped and is ramping
    337                  API221_EVENT_NONE,                      //!< Was stopped and is stopped
    338                  API221_EVENT_REACHED_TARGET,            //!< Was stopped and is plateau
    339                  API221_EVENT_NONE,                      //!< Was stopped and is stopped
    340                  API221_EVENT_RAMP_STARTED,              //!< Was plateau and is ramping
    341                  API221_EVENT_STOPPED,                   //!< Was plateau and is stopped
    342                  API221_EVENT_NONE,                      //!< Was plateau and is plateau
    343                  API221_EVENT_STOPPED,                   //!< Was plateau and is stopped
    344                  API221_EVENT_RAMP_STARTED,              //!< Was stopped and is ramping
    345                  API221_EVENT_NONE,                      //!< Was stopped and is stopped
    346                  API221_EVENT_REACHED_TARGET,            //!< Was stopped and is plateau
    347                  API221_EVENT_NONE                       //!< Was stopped and is stopped
    348              };
    349          #endif      // #if (API221_SERVER_FEATURE == ENABLED)
    350          
