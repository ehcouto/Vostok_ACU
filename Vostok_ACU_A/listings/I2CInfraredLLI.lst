    595          //---------------------------------------------------------------------------------------------------------------------
    596          /**
    597           * Read the configuration register and confirm that it was written correctly.
    598           * This function reads and processes the received data.
    599           * It assumes that the read request was already made.
    600           */
    601          static void DoConfigRead(void)
    602          {
    603              I2c_Infrared_Lli.Sensor.Resolution = IR_RESOLUTION_15_BIT;
    604              if (IsI2cIdle() == TRUE)
    605              {
    606                  uint16 value;
    607                  if (I2c__Read(I2c_Infrared_Lli.Sf->I2c_Channel, (void*)&value, sizeof(value)) == TRUE)
    608                  {
    609                      value &= CONFIG_VERIFIABLE_FIELDS_MASK;
    610                      if (value == (I2c_Infrared_Lli.Config.Cfg_Reg.Whole & CONFIG_VERIFIABLE_FIELDS_MASK))
    611                      {
    612                          I2c_Infrared_Lli.Sensor.Resolution = (IR_BIT_RESOLUTION_TYPE)I2c_Infrared_Lli.Config.Cfg_Reg.Field.Bit_Resolution;
    613                          EventReadComplete();
    614                      }
    615                      else
    616                      {
    617                          EventFail();
    618                      }
    619                  }
    620                  else
    621                  {
    622                      EventFail();
    623                  }
    624              }
    625              else if (GetMilliseconds() >= I2C_NOT_IDLE_MS_TIMEOUT)
    626              {
    627                  EventFail();
    628              }
    629          }
    630          
    631          
    632          //---------------------------------------------------------------------------------------------------------------------
    633          /**
    634           * Copy the next block of data received on I2C into the RAM copy of the Melexis 90621 Sensor EEPROM.
    635           * This function reads and processes the received data.
    636           * It assumes that the read request was already made.
    637           */
    638          static void DoEepromRead(void)
    639          {
    640              if (IsI2cIdle() == TRUE)
    641              {
    642                  // Get the pointer to the RAM copy of the Melexis 90621 EEPROM.
    643                  uint8* destination = I2C_READ_INSTRUCTIONS[I2c_Infrared_Lli.Transfer_Step].Destination;
    644                  uint8 read_size = I2C_READ_INSTRUCTIONS[I2c_Infrared_Lli.Transfer_Step].Read_Size;
    645                  if (I2c__Read(I2c_Infrared_Lli.Sf->I2c_Channel, destination, read_size) == TRUE)
    646                  {
    647                      I2c_Infrared_Lli.Transfer_Step++;
    648                      if (I2c_Infrared_Lli.Transfer_Step >= ELEMENTS_IN_ARRAY(I2C_READ_INSTRUCTIONS))
    649                      {
    650                          EventReadComplete();
    651                      }
    652                      else
    653                      {
    654                          EventReadNextSection();
    655                      }
    656                  }
    657                  else
    658                  {
    659                      EventFail();
    660                  }
    661              }
    662              else if (GetMilliseconds() >= I2C_NOT_IDLE_MS_TIMEOUT)
    663              {
    664                  EventFail();
    665              }
    666          }
    667          
    668          
    669          //---------------------------------------------------------------------------------------------------------------------
    670          /**
    671           * Read the oscillator trim value and confirm that it was written correctly.
    672           * This function reads and processes the received data.
    673           * It assumes that the read request was already made.
    674           */
    675          static void DoOscTrimRead(void)
    676          {
    677              if (IsI2cIdle() == TRUE)
    678              {
    679                  uint16 value = 0;
    680                  if (I2c__Read(I2c_Infrared_Lli.Sf->I2c_Channel, (void*)&value, sizeof(value)) == TRUE)
    681                  {
    682                      if (value == I2c_Infrared_Lli.Config.Osc_Trim)
    683                      {
    684                          EventReadComplete();
    685                      }
    686                      else
    687                      {
    688                          EventFail();
    689                      }
    690                  }
    691                  else
    692                  {
    693                      EventFail();
    694                  }
    695              }
    696              else if (GetMilliseconds() >= I2C_NOT_IDLE_MS_TIMEOUT)
    697              {
    698                  EventFail();
    699              }
    700          }
