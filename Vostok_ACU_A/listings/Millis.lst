      1          /**
      2           * @file
      3           * @brief       A module to create and manage timers
      4           *
      5           * @details     Each timer can measure up to about 12.4 days.
      6           *              Non-volatile timers can be used by storing the timer data structure in non-volatile
      7           *              memory.
      8           *
      9           *              Millis automatically supports non-volatile timers on ACU project types. For Millis
     10           *              to support non-volatile timers on other project types, the following macros must be
     11           *              defined.
     12           *                  RESTORE_INIT()
     13           *                  RESTORE_HANDLER()
     14           *                  STORE_HANDLER()
     15           *              Refer to the Millis_prv.h file for details.
     16           *
     17           *              Usage Example 1: Measure seconds
     18           *                  MILLIS_TIMER_TYPE my_timer;
     19           *                  Millis__Start(&my_timer);
     20           *                  ...
     21           *                  uint32 Seconds = Millis__ElapsedSeconds(&my_timer);
     22           *
     23           *              Usage Example 2: Check for a timeout
     24           *                  MILLIS_TIMER_TYPE my_timer;
     25           *                  Millis__Start(&my_timer);
     26           *                  ...
     27           *                  if (Millis__ReachedTargetSeconds(&my_timer, TARGET_SECONDS) == TRUE)
     28           *                  {
     29           *                      // Timer reached TARGET_SECONDS.
     30           *                  }
     31           *
     32           *              Usage Example 3: Pause & resume timer
     33           *                  MILLIS_TIMER_TYPE my_timer;
     34           *                  Millis__Start(&my_timer);
     35           *                  ...
     36           *                  Millis__Pause(&my_timer);
     37           *                  ...
     38           *                  Millis__Resume(&my_timer);
     39           *
     40           *              Usage Example 4: Reset timer
     41           *                  MILLIS_TIMER_TYPE my_timer;
     42           *                  Millis__Reset(&my_timer);
     43           *
     44           *              Usage Example 5: Restore a non-volatile timer (on non-ACU project types)
     45           *                  MILLIS_TIMER_TYPE My_Timer;     // Definition of non-volatile timer RAM
     46           *                  // Arrange to call this function once after non-volatile data is restored.
     47           *                  void Module__NVDataIsRestored(void)
     48           *                  {
     49           *                      Millis__RestoreTimer(&My_Timer);
     50           *                  }
     51           *
     52           *              Millis calls functions for SystemTimers module. When SystemTimers module is deprecated,
     53           *              it will be removed from this module and replaced by Millis.
     54           *
     55           * @copyright   Copyright 2021 Whirlpool Corporation.  All rights reserved - CONFIDENTIAL.
     56           */
