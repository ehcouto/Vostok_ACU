    471          //---------------------------------------------------------------------------------------------------------------------
    472          /**
    473           *  @brief      Asynchronous process for DoorLockEMPilot.
    474           *
    475           *	@detail     Asynchronous process handles status transition and consistency check for door lock status
    476           *
    477           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    478           *
    479           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot asynch execution.
    480           *  @retval     PASS - Execution succeeded.
    481           *  @retval     FAIL - Execution failed.
    482           */
    483          PASS_FAIL_TYPE SRDoorLockEMPilot__AsynchProcess(HBL_LOAD_TYPE * load )
    484          {
    485              SRDOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    486              SRDOORLOCKEMPILOT_DATA_TYPE *ptr;
    487              SRDOORLOCKEMPILOT_DATA_TYPE *n_ptr;
    488              HBL_LOAD_STATUS_TYPE tmp_load;
    489              PASS_FAIL_TYPE retval;
    490              BOOL_TYPE pin_val;
    491              uint8 index;
    492              HBL_CONSISTENCY_TYPE lock_feedback;
    493              HBL_LOAD_STATUS_TYPE target_status;
    494          
    495              retval = FAIL;
    496              pin_val = FALSE;
    497              index = load->Pilot_Data_Index;
    498          
    499              if (CheckItem(index))
    500              {
    501                  param_ptr = (SRDOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    502                  ptr = &SRDoorLockEMPilot_Data[index];
    503                  n_ptr = &N_SRDoorLockEMPilot_Data[index];
    504          
    505                  target_status.Load.Cur_Reg = ptr->Processed;
    506                  // Prevent use of TRN table when DoorLock status is OFF;
    507                  // during INITIALIZE consider Processed target like it has been already reached
    508                  if ((ptr->Processed != 0) && (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE))
    509                  {
    510                      target_status.Load.Status = ptr->PilotStatus.Load.Status;
    511                  }
    512                  else
    513                  {
    514                      target_status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    515                  }
    516                  lock_feedback.Byte = Hbl__GetOwnLoadConsistency(load, target_status.Byte);
    517                  retval = PASS;
    518          
    519                  switch (ptr->Status)
    520                  {
    521                      case SRDOORLOCKEM_STATUS_DOOR_LOCKING:
    522                          if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK)
    523                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_OFF))
    524                          {
    525                              SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    526                              SRDOORLOCKEM_STATUS_DOOR_LOCKED);
    527                              SRData__UpdateByte(&ptr->Retries, &n_ptr->Retries, 0);
    528                          }
    529                          else if ((ptr->Retries == 0) &&
    530                              (ptr->Retries_Counter >= (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS)))
    531                          {
    532                              SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    533                              SRDOORLOCKEM_STATUS_DOOR_LOCKING_FAILED);
    534                          }
    535                          break;
    536          
    537                      case SRDOORLOCKEM_STATUS_DOOR_UNLOCKING:
    538                          if ((   (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    539                                  (lock_feedback.Consistency.Value == HBL_CONSISTENCY_DISCONNECTED))
    540                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON)
    541                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON_ALTERNATE))
    542                          {
    543                              SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    544                              SRDOORLOCKEM_STATUS_DOOR_UNLOCKED);
    545                              SRData__UpdateByte(&ptr->Retries, &n_ptr->Retries, 0);
    546                          }
    547                          else if ((ptr->Retries == 0) &&
    548                              (ptr->Retries_Counter >= (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS)))
    549                          {
    550                              SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    551                              SRDOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED);
    552                          }
    553                          break;
    554          
    555                      case SRDOORLOCKEM_STATUS_DOOR_LOCKED:
    556                      case SRDOORLOCKEM_STATUS_DOOR_UNLOCKED:
    557                      case SRDOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    558                      case SRDOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    559                          break;
    560          
    561                      default:
    562                          // Consistency detects door is locked/unlocked properly, according to acutal set point
    563                          if ((ptr->Requested == ptr->Processed) &&
    564                              (   (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    565                                  (lock_feedback.Consistency.Value == HBL_CONSISTENCY_DISCONNECTED)) )
    566                          {
    567                              uint16 duration = param_ptr->Num_Pulses;
    568          
    569                              if (duration == 0)
    570                              {
    571                                  duration = SRDOORLOCKEM_DEFAULT_PULSES;
    572                              }
    573                              duration *= ptr->Period;
    574          
    575                              if (lock_feedback.Consistency.Table == HBL_CONSISTENCY_TABLE_OFF)
    576                              {
    577                                  // Door already unlocked
    578                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    579                                  SRDOORLOCKEM_STATUS_DOOR_UNLOCKED);
    580                                  if(ptr->Retries_Counter < duration)
    581                                  {
    582                                      SRData__UpdateShort(&ptr->Retries_Counter, &n_ptr->Retries_Counter, duration);
    583                                  }
    584                              }
    585                              else if (lock_feedback.Consistency.Table == HBL_CONSISTENCY_TABLE_ON)
    586                              {
    587                                  // Door already locked
    588                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    589                                  SRDOORLOCKEM_STATUS_DOOR_LOCKED);
    590                                  if(ptr->Retries_Counter < duration)
    591                                  {
    592                                      SRData__UpdateShort(&ptr->Retries_Counter, &n_ptr->Retries_Counter, duration);
    593                                  }
    594                              }
    595                          }
    596                          else
    597                          {
    598                              SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, SRDOORLOCKEM_STATUS_INIT); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    599                              // Wait for Time between pulses
    600                              if (ptr->Retries_Counter >= (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS))
    601                              {
    602                                  if (ptr->Processed == OFF)
    603                                  {
    604                                      // Door is assumed to be locked
    605                                      SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    606                                      SRDOORLOCKEM_STATUS_DOOR_LOCKED);
    607                                      SRData__UpdateByte((uint8 *) &ptr->Processed, (uint8 *) &n_ptr->Processed, ON); //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    608                                  }
    609                                  else
    610                                  {
    611                                      // Door is assumed to be unlocked
    612                                      SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    613                                      SRDOORLOCKEM_STATUS_DOOR_UNLOCKED);
    614                                      SRData__UpdateByte((uint8 *) &ptr->Processed, (uint8 *) &n_ptr->Processed, OFF); //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    615                                  }
    616                              }
    617                          }
    618                          break;
    619          
    620                  }
    621          
    622                  switch (ptr->Status)
    623                  {
    624                      case SRDOORLOCKEM_STATUS_DOOR_LOCKED:
    625                      case SRDOORLOCKEM_STATUS_DOOR_UNLOCKED:
    626                          tmp_load.Load.Status = ((pin_val == TRUE) ? HBL_LOAD_STATUS_TARGET_ALT_TABLE : HBL_LOAD_STATUS_TARGET_COMPLETED);
    627                          tmp_load.Load.Cur_Reg = ptr->Processed;
    628                          SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    629                          break;
    630          
    631                      case SRDOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    632                      case SRDOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    633                          tmp_load.Load.Status = HBL_LOAD_STATUS_FAILURE;
    634                          tmp_load.Load.Cur_Reg = ptr->Processed;
    635                          SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    636                          break;
    637          
    638                      default:
    639                          if (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE)
    640                          {
    641                              tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    642                              tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    643                              SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    644                          }
    645                  }
    646              }
    647          
    648              return (retval);
    649          }
    650          
    651          //---------------------------------------------------------------------------------------------------------------------
    652          /**
    653           *  @brief      One millisecond process for DoorLockEMPilot.
    654           *
    655           *	@detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    656           *
    657           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    658           *
    659           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot 1ms execution.
    660           *  @retval     PASS - Execution succeeded.
    661           *  @retval     FAIL - Execution failed.
    662           */
    663          PASS_FAIL_TYPE SRDoorLockEMPilot__Handler1ms(HBL_LOAD_TYPE * load )
    664          {
    665              SRDOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    666              SRDOORLOCKEMPILOT_DATA_TYPE *n_ptr;
    667              SRDOORLOCKEMPILOT_DATA_TYPE *ptr;
    668              PASS_FAIL_TYPE retval;
    669              BOOL_TYPE pin_val;
    670              BOOL_TYPE pin_fbk_val;
    671              uint8 virtual_pin;
    672              uint8 index;
    673          
    674              retval = FAIL;
    675              pin_val = FALSE;
    676              pin_fbk_val = FALSE;
    677              index = load->Pilot_Data_Index;
    678          
    679              if (CheckItem(index))
    680              {
    681                  param_ptr = (SRDOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    682                  ptr = &SRDoorLockEMPilot_Data[index];
    683                  n_ptr = &N_SRDoorLockEMPilot_Data[index];
    684          
    685                  if (ptr->Fbk_Pin < VirtualPin__GetNumOf())
    686                  {
    687                      pin_fbk_val = Gpio__PinRead(VIRTUALPIN_TABLE[ptr->Fbk_Pin].port, VIRTUALPIN_TABLE[ptr->Fbk_Pin].pin);
    688                  }
    689          
    690                  if (pin_fbk_val != ptr->Fbk_Last_Pin_Value)
    691                  {
    692                      if (pin_fbk_val == TRUE)
    693                      {
    694                          if ((ptr->Fbk_Counter >= SRDOORLOCKEM_MIN_PERIOD_MS) &&
    695                              (ptr->Fbk_Counter <= SRDOORLOCKEM_MAX_PERIOD_MS))
    696                          {
    697                              uint8 new_period = (ptr->Period + ptr->Fbk_Counter + 1) >> 1;
    698                              sint8 tmp_offset = (ptr->Fbk_Counter - (2 * ptr->Fbk_Last_Counter )) / 4;
    699                              if (tmp_offset < 0)
    700                              {
    701                                  tmp_offset += (ptr->Period / 2);
    702                              }
    703                              SRData__UpdateByte(&ptr->Period, &n_ptr->Period, new_period);
    704                              SRData__UpdateByte((uint8 *) &ptr->Cycle_Counter, (uint8 *) &n_ptr->Cycle_Counter, (uint8) tmp_offset); //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    705                          }
    706                          SRData__UpdateByte(&ptr->Fbk_Counter, &n_ptr->Fbk_Counter, 0);
    707                      }
    708                      else
    709                      {
    710                          SRData__UpdateByte(&ptr->Fbk_Last_Counter, &n_ptr->Fbk_Last_Counter, ptr->Fbk_Counter);
    711                      }
    712          
    713                      SRData__UpdateByte(&ptr->Fbk_Last_Pin_Value, &n_ptr->Fbk_Last_Pin_Value, pin_fbk_val);
    714                  }
    715          
    716                  if(ptr->Cycle_Counter >= ptr->Period)
    717                  {
    718                      SRData__UpdateByte(&ptr->Cycle_Counter, &n_ptr->Cycle_Counter, 0);
    719                  }
    720          
    721                  if (ptr->Retries_Counter < (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS))
    722                  {
    723                      SRData__UpdateShort(&ptr->Retries_Counter, &n_ptr->Retries_Counter, ptr->Retries_Counter + 1);
    724                  }
    725          
    726                  if (ptr->Status != SRDOORLOCKEM_STATUS_INIT)
    727                  {
    728                      uint16 pulse_duration;
    729                      BOOL_TYPE force_pin = (BOOL_TYPE) ptr->Keep_Triac_On;
    730                      uint8 num_pulses = param_ptr->Num_Pulses;
    731          
    732                      if (num_pulses == 0)
    733                      {
    734                          num_pulses = SRDOORLOCKEM_DEFAULT_PULSES;
    735                      }
    736          
    737                      if ((ptr->Cycle_Counter == 0) ||
    738                          (ptr->Cycle_Counter == (ptr->Period/2)))
    739                      {
    740                          if ((ptr->Retries > 0) &&
    741                              (ptr->Retries_Counter >= (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS)))
    742                          {
    743                              SRData__UpdateShort(&ptr->Retries_Counter, &n_ptr->Retries_Counter, 0);
    744                              SRData__UpdateByte(&ptr->Retries, &n_ptr->Retries, ptr->Retries-1);
    745                          }
    746                          else if (ptr->Process_Triac_On)
    747                          {
    748                              force_pin = TRUE;
    749                          }
    750                      }
    751          
    752                      if (!ptr->Process_Triac_On)
    753                      {
    754                          force_pin = FALSE;
    755                      }
    756                      SRData__UpdateByte(&ptr->Keep_Triac_On, &n_ptr->Keep_Triac_On, (uint8) force_pin);
    757          
    758                      pulse_duration = num_pulses * ptr->Period;
    759                      pulse_duration /= 2;
    760                      // Pulse duration is reduced by 1/4 period to ensure triac can switch OFF
    761                      pulse_duration -= (ptr->Period/4);
    762          
    763                      if ((force_pin == TRUE) ||
    764                          (ptr->Retries_Counter < pulse_duration))
    765                      {
    766                          pin_val = TRUE;
    767                      }
    768          
    769                  }
    770          
    771                  virtual_pin = (*load->Pin_Ptr);
    772          
    773                  if ((Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin,
    774                  VIRTUALPIN_TABLE[virtual_pin].pin_config, (BOOL_TYPE) ptr->Last_Pin_Out_Value)) == TRUE)
    775                  {
    776                      pin_val ^= (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    777                      pin_val &= TRUE;
    778                      Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    779                      SRData__UpdateByte(&ptr->Last_Pin_Out_Value, &n_ptr->Last_Pin_Out_Value, pin_val);
    780                      retval = PASS;
    781                  }
    782                  else
    783                  {
    784                      SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, index);
    785                  }
    786          
    787                  SRData__UpdateByte(&ptr->Cycle_Counter, &n_ptr->Cycle_Counter, ptr->Cycle_Counter+1);
    788                  if (ptr->Fbk_Counter < SRDOORLOCKEM_FBK_TIMEOUT)
    789                  {
    790                      SRData__UpdateByte(&ptr->Fbk_Counter, &n_ptr->Fbk_Counter, ptr->Fbk_Counter+1);
    791                  }
    792              }
    793          
    794              return (retval);
    795          }
    796          
    797          //---------------------------------------------------------------------------------------------------------------------
    798          /**
    799           * @brief	Handler for DoorLockEMPilot execution
    800           *
    801           * It checks SRDoorLockEMPilot_Allocation integrity and all SRDoorLockEMPilot_Data instances allocated
    802           * It sets SRTASKSEQUENCE_APPL_SRDOORLOCKEMPILOT_CHECKS step in SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    803           *
    804           */
    805          void SRDoorLockEMPilot__Handler(void )
    806          {
    807              if (SRData__CheckByte(&SRDoorLockEMPilot_Allocation, &N_SRDoorLockEMPilot_Allocation) != SRDATA_OK)
    808              {
    809                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, 0xFF);
    810              }
    811              else
    812              {
    813                  uint8 index;
    814          
    815                  for (index = 0; index < HBL_PILOT_NUM_SRDOORLOCKEM; index++)
    816                  {
    817                      if (SRData__CheckArray(&SRDoorLockEMPilot_Data[index], &N_SRDoorLockEMPilot_Data[index],
    818                      sizeof(SRDOORLOCKEMPILOT_DATA_TYPE)) != SRDATA_OK)
    819                      {
    820                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, index);
    821                          break;
    822                      }
    823                  }
    824              }
    825          
    826          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    827              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRDOORLOCKEMPILOT_CHECKS);
    828          #endif
    829          
    830          }
    831          
    832          //=====================================================================================================================
    833          //-------------------------------------- Private Functions ------------------------------------------------------------
    834          //=====================================================================================================================
    835          
    836          /**
    837           * @brief   Function to perform data integrity of a SRDoorlockEM instance
    838           *
    839           * It checks SRDoorLockEMPilot_Allocation integrity and all SRDoorLockEMPilot_Data instances allocated
    840           * It sets SRTASKSEQUENCE_APPL_SRDOORLOCKEMPILOT_CHECKS step in SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    841           *
    842           *  @param      uint8 index - Instance index
    843           *
    844           *  @return     BOOL_TYPE result - Result of DoorLockEMPilot instance data integrity check
    845           *  @retval     TRUE - Data integrity check succeded
    846           *  @retval     FAIL - Data integrity check failed
    847           *
    848           */
    849          BOOL_TYPE CheckItem(uint8 index )
    850          {
    851              BOOL_TYPE retval = FALSE;
    852          
    853              if (SRData__CheckByte(&SRDoorLockEMPilot_Allocation, &N_SRDoorLockEMPilot_Allocation) != SRDATA_OK)
    854              {
    855                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, 0xFF);
    856              }
    857              else
    858              {
    859                  if (index < SRDoorLockEMPilot_Allocation)
    860                  {
    861                      if (SRData__CheckArray(&SRDoorLockEMPilot_Data[index], &N_SRDoorLockEMPilot_Data[index],
    862                      sizeof(SRDOORLOCKEMPILOT_DATA_TYPE)) != SRDATA_OK)
    863                      {
    864                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, index);
    865                      }
    866                      else
    867                      {
    868                          retval = TRUE;
    869                      }
    870                  }
    871              }
    872          
    873              return (retval);
    874          }
