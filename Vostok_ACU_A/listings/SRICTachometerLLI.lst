     20          //-------------------------------------- Include Files ----------------------------------------------------------------
     21          #include "SRICTachometerLLI.h"
     22          
     23          #if (HBL_LLI_NUM_SRICTACHOMETER > 0)
     24          #include "Crc8.h"
     25          #include "Timer.h"
     26          #include "SRData.h"
     27          #include "SRException.h"
     28          #include "SRMicro.h"
     29          #include "SRTaskSequence.h"
     30          #include <string.h>
     31          #include "VirtualPin.h"
     32          
     33          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     34          
     35          //!Parameter hardcoded as it is fundamental for the SR
     36          #define SRICTACHOMETER_COUNT_TO_DETECT_0Hz      1000// 1s of non IC detection It assumes Zero RPM
     37          
     38          //! Counts to 1000 rpm
     39          #define TACHO_MINUMUM_COUNT_VALUE               468
     40          
     41          //! Defines the data for an instance of an SRICTachometer LLI
     42          PACKED typedef struct
     43          {
     44              SRICTACHOMETER_PUBLIC_TYPE Public_Data;		//!< Holds the public data of this module. It can be accessed by the "Get" function
     45              TIMER_PARAMETER_TYPE Timer_Parameter;		//!< Holds the parameters of this module.
     46              uint32 Timer_Counter;						//!< Used to detect zero RPM. It increments every 1ms and gets reset once an IC happens.
     47              uint32 Accumulator;							//!< Accumulate the last 5 samples to average it. The result of the average is at "Filtered_Period" variable.
     48              uint8  Samples_Counter;						//!< Holds the numember of samples to take the average.
     49          }SRICTACHOMETER_DATA_TYPE;
     50          
     51          //! Module data for each instance of an SRICTachometer LLI
     52          static SRICTACHOMETER_DATA_TYPE SRICTachometerLLI_Data[HBL_LLI_NUM_SRICTACHOMETER];
     53          
     54          //! Holds a CRC for data in SRICTachometerLLI_Data variable)
     55          static uint8 SRICTachometerLLI_Data_Crc[HBL_LLI_NUM_SRICTACHOMETER];
     56          
     57          //! Keeps track of how many SRICTachometer LLIs have been allocated by the application (based on setting file configuration)
     58          static uint8 SRICTachometerLLI_Allocation;
     59          //! Inverted memory for the Class B variable
     60          static uint8 N_SRICTachometerLLI_Allocation;
     61          
     62          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     63          
     64          
     65          //=====================================================================================================================
     66          //-------------------------------------- Public Functions -------------------------------------------------------------
     67          //=====================================================================================================================
     68          
     69          //---------------------------------------------------------------------------------------------------------------------
     70          /**
     71           *  @brief      It Initializes the module SRICTachometerLLI and its variables.
     72           *
     73           */
     74          void SRICTachometerLLI__Initialize(void)
     75          {
     76              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
     77          
     78              for (uint8 index = 0; index < HBL_LLI_NUM_SRICTACHOMETER; index++)
     79              {
     80                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
     81                  memset(&SRICTachometerLLI_Data[index],0,sizeof(SRICTachometerLLI_Data[0]));
     82          
     83                  SRICTachometerLLI_Data[index].Public_Data.Filtered_Period = TACHO_ZERO_RPM_TIMER_COUNTS;
     84                  SRICTachometerLLI_Data[index].Public_Data.Raw_Period = TACHO_ZERO_RPM_TIMER_COUNTS;
     85          
     86                  SRICTachometerLLI_Data_Crc[index] = Crc8(0xFF,(uint8 *)(void *)&SRICTachometerLLI_Data[index], sizeof(SRICTachometerLLI_Data[0]));
     87                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
     88              }
     89              SR_SET_BYTE(SRICTachometerLLI_Allocation, 0);
     90          
     91          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     92              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRICTACHOMETER_LLI);
     93          #endif
     94          }
     95          
     96          //---------------------------------------------------------------------------------------------------------------------
     97          /**
     98           * @brief  It allocates the index for the SRICTachometer.
     99           *
    100           * @return SRICTachometerLLI_Allocation
    101           */
    102          uint8 SRICTachometerLLI__Allocate(void)
    103          {
    104              uint8 retval = HBL_ALLOCATION_INVALID;
    105          
    106              if ((SR_CHECK_BYTE(SRICTachometerLLI_Allocation) == SRDATA_OK) &&
    107                  (SRICTachometerLLI_Allocation < HBL_LLI_NUM_SRICTACHOMETER))
    108              {
    109                  retval = SRICTachometerLLI_Allocation;
    110                  SR_SET_BYTE(SRICTachometerLLI_Allocation, SRICTachometerLLI_Allocation+1);
    111              }
    112          
    113              return (retval);
    114          }
    115          
    116          //---------------------------------------------------------------------------------------------------------------------
    117          /**
    118           *  @brief It initialize the instance of the SRICTachometer module.
    119           *
    120           *  @details A timer is used as InputCapture. The configuration comes from the virtual pin table.
    121           */
    122          PASS_FAIL_TYPE SRICTachometerLLI__InitializeInstance(HBL_LLI_TYPE * input)
    123          {
    124              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    125              PASS_FAIL_TYPE ret_status;
    126              uint8 virtual_pin;
    127              SRICTACHOMETER_DATA_TYPE *data;
    128          
    129              ret_status = FAIL;
    130          
    131              if ((SR_CHECK_BYTE(SRICTachometerLLI_Allocation) == SRDATA_OK) &&
    132                  (input->Data_Index < SRICTachometerLLI_Allocation) &&
    133                  (Crc8(0xFF, (uint8 *)(void *)&SRICTachometerLLI_Data[input->Data_Index], sizeof(SRICTachometerLLI_Data[0])) == SRICTachometerLLI_Data_Crc[input->Data_Index]))
    134              {
    135                  data = (SRICTACHOMETER_DATA_TYPE *)(void *)&SRICTachometerLLI_Data[input->Data_Index];
    136          
    137                  virtual_pin = input->Pin_Ptr[0];
    138                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    139          
    140                  //configure timer for Input Capture
    141                  data->Timer_Parameter.Timer       =   (TIMER_TYPE)VIRTUALPIN_TABLE[virtual_pin].device;
    142                  data->Timer_Parameter.Channel     =   (TIMER_CHANNEL_TYPE)VIRTUALPIN_TABLE[virtual_pin].param0;
    143                  data->Timer_Parameter.Mode        =   TIMER_MODE_INPUT_CAPTURE;
    144                  data->Timer_Parameter.Port        =   VIRTUALPIN_TABLE[virtual_pin].port;
    145                  data->Timer_Parameter.Pin         =   VIRTUALPIN_TABLE[virtual_pin].pin;
    146                  data->Timer_Parameter.Pin_ReMap   =   VIRTUALPIN_TABLE[virtual_pin].pin_remap;
    147                  data->Timer_Parameter.Polarity    =   TIMER_POLARITY_ACTIVE_HIGH;
    148          
    149                  //Configure Continuous reading
    150                  ret_status =  Timer__Config(&data->Timer_Parameter);
    151                  ret_status |= Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    152          
    153                  SRICTachometerLLI_Data_Crc[input->Data_Index] = Crc8(0xFF, (uint8 *)(void *)data, sizeof(SRICTachometerLLI_Data[0]));
    154                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    155              }
    156          
    157              return (ret_status);
    158          }
    159          
    160          //---------------------------------------------------------------------------------------------------------------------
    161          /**
    162           * @brief   One ms Handler of SRICTachometer module.
    163           *
    164           * @details This method handles the zero rpm detection. An internal counter is used to detect It.
    165           *
    166           * @param   input
    167           *
    168           * @return  BOOL_TYPE
    169           */
    170          BOOL_TYPE SRICTachometerLLI__OneMsProcess(HBL_LLI_TYPE * input)
    171          {
    172              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    173              SRICTACHOMETER_DATA_TYPE *data;
    174              BOOL_TYPE crc_check;
    175              PASS_FAIL_TYPE config_check;
    176              BOOL_TYPE ret_val;
    177          
    178              ret_val = FALSE; // Always return FALSE to avoid any unexpected sequence updated. The LLI sequence gets updated by the ICPorcess.
    179          
    180              if ((SR_CHECK_BYTE(SRICTachometerLLI_Allocation) == SRDATA_OK) &&
    181                  (input->Data_Index < SRICTachometerLLI_Allocation))
    182              {
    183                  data = (SRICTACHOMETER_DATA_TYPE *)(void *)&SRICTachometerLLI_Data[input->Data_Index];
    184                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    185                  crc_check = (BOOL_TYPE) (Crc8(0xFF, (uint8 *)(void *)data, sizeof(SRICTachometerLLI_Data[0])) == SRICTachometerLLI_Data_Crc[input->Data_Index]);
    186                  config_check = Timer__ConfigCheck(&data->Timer_Parameter);
    187                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    188          
    189                  if ( (TRUE == crc_check) &&
    190                       (PASS == config_check) )
    191                  {
    192                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    193                      //Zero RPM
    194          
    195                      if (data->Timer_Counter >= SRICTACHOMETER_COUNT_TO_DETECT_0Hz)
    196                      {
    197                          data->Public_Data.Filtered_Period = TACHO_ZERO_RPM_TIMER_COUNTS;    // reset filtered period variable
    198                          data->Public_Data.Raw_Period = TACHO_ZERO_RPM_TIMER_COUNTS;    		// reset raw period variable
    199                      }
    200                      else
    201                      {
    202                          data->Timer_Counter++;
    203                      }
    204          
    205                      SRICTachometerLLI_Data_Crc[input->Data_Index] = Crc8(0xFF,(uint8 *)(void *)&SRICTachometerLLI_Data[input->Data_Index], sizeof(SRICTachometerLLI_Data[0]));
    206                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    207          
    208                  }
    209              }
    210          
    211              return (ret_val);
    212          }
    213          
    214          //---------------------------------------------------------------------------------------------------------------------
    215          /**
    216           * @brief    Performs periodic check on the integrity of the RAM variables used in this module
    217           * @details  This function shall be called from HBL__PREPROCESSLOADS() in Hbl module
    218           */
    219          void SRICTachometerLLI__Handler(void)
    220          {
    221              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    222              BOOL_TYPE retval = (BOOL_TYPE) (SR_CHECK_BYTE(SRICTachometerLLI_Allocation) == SRDATA_OK);
    223          
    224              for (uint8 index = 0; index < HBL_LLI_NUM_SRICTACHOMETER; index++)
    225              {
    226                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    227                  retval &= (BOOL_TYPE) (Crc8(0xFF, (uint8 *)(void *)&SRICTachometerLLI_Data[index], sizeof(SRICTachometerLLI_Data[0])) == SRICTachometerLLI_Data_Crc[index]);
    228                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    229                  if (retval == FALSE)
    230                  {
    231                      SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0, index);
    232                      break;
    233                  }
    234              }
    235          
    236          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    237              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRICTACHOMETERLLI_CHECKS);
    238          #endif
    239          
    240          }
    241          
    242          //---------------------------------------------------------------------------------------------------------------------
    243          /**
    244           * @brief   Getter of SRICTachometer module.
    245           *
    246           * @details It return the SRICTachometerLLI data. It contains a buffer with the raw counts from the IC, as the Zero rpm detection.
    247           *          No integrity checks on RAM variables performed in this function since returning bad data is no different
    248           *          than returning NULL. The Handler() function will ensure a safe reaction when the integrity check fails.
    249           *
    250           * @param  input
    251           *
    252           * @return SRICTachometerLLI_Data[index]
    253           */
    254          void *SRICTachometerLLI__Get(HBL_LLI_TYPE * input)
    255          {
    256              void *ret_val = NULL;
    257          
    258              if (input->Data_Index < SRICTachometerLLI_Allocation)
    259              {
    260                  ret_val = ((void *)&SRICTachometerLLI_Data[input->Data_Index]);
    261              }
    262          
    263              return(ret_val);
    264          }
    265          //---------------------------------------------------------------------------------------------------------------------
    266          
    267          /**
    268           * @brief   Input Capture of SRICTachometer module.
    269           *
    270           * @details It works as a callback from IntMgr. It fills the SRICTachometer buffer with the capture durations (in counts).
    271           *
    272           * @param   HBL_LLI_TYPE * input
    273           *
    274           * @return  Returns TRUE once it gets a valid sample. It can be tracked by the sequence at HBL.
    275           */
    276          BOOL_TYPE SRICTachometerLLI__ICProcess(HBL_LLI_TYPE * input)
    277          {
    278          
    279              SRICTACHOMETER_DATA_TYPE *data;
    280              BOOL_TYPE crc_check;
    281              BOOL_TYPE retval;
    282              uint32 captured_duration;
    283              uint32 lower_limit;
    284              uint32 upper_limit;
    285          
    286              retval = FALSE;
    287          
    288              if ((SR_CHECK_BYTE(SRICTachometerLLI_Allocation) == SRDATA_OK)
    289                  && (input->Data_Index < SRICTachometerLLI_Allocation))
    290              {
    291                  data = (SRICTACHOMETER_DATA_TYPE *)(void *)&SRICTachometerLLI_Data[input->Data_Index];
    292          
    293                  crc_check = (BOOL_TYPE) (Crc8(0xFF, (uint8 *)(void *)data, sizeof(SRICTachometerLLI_Data[0])) == SRICTachometerLLI_Data_Crc[input->Data_Index]);
    294          
    295                  if (crc_check)
    296                  {
    297                      //Read the current captured duration and duty
    298                      captured_duration = Timer__GetCaptureDuration(&data->Timer_Parameter);
    299                      if (captured_duration >= TACHO_MINUMUM_COUNT_VALUE)
    300                      {
    301                          // The limit is: previous_speed/8 (Delta of 25%).
    302                          lower_limit = data->Public_Data.Raw_Period - (data->Public_Data.Raw_Period >> 3);
    303                          upper_limit = data->Public_Data.Raw_Period + (data->Public_Data.Raw_Period >> 3);
    304          
    305                          if ((captured_duration <= upper_limit) &&
    306                              (captured_duration >= lower_limit))
    307                          {
    308                              //Store the captured duration at the current buffer position
    309                              data->Public_Data.Raw_Period = captured_duration;
    310                          }
    311                          else
    312                          {
    313                              // if speed is above upper limit
    314                              if (captured_duration >= upper_limit)
    315                              {
    316                                  // Set period buffer to upper_limit
    317                                  data->Public_Data.Raw_Period = upper_limit;
    318                              }
    319                              else
    320                              {
    321                                  // Set period buffer to lower_limit
    322                                  data->Public_Data.Raw_Period = lower_limit;
    323                              }
    324                          }
    325          
    326                          data->Accumulator += data->Public_Data.Raw_Period;
    327                          data->Samples_Counter++;
    328          
    329                          if (data->Samples_Counter >= SRICTACHOMETERLLI_AVERAGE_SAMPLES)
    330                          {
    331                          	// Take the average of raw period
    332                              data->Public_Data.Filtered_Period = data->Accumulator / SRICTACHOMETERLLI_AVERAGE_SAMPLES;
    333          
    334                              // Reset the variables
    335                          	data->Samples_Counter = 0;
    336                          	data->Accumulator = 0;
    337                          }
    338          
    339                          retval = TRUE; // Once it returns TRUE the Sequence gets updated.
    340          
    341                      }
    342          
    343                      // Reset the timer counting while IC is processing
    344                      data->Timer_Counter = 0;
    345          
    346                      //Update CRC
    347                      SRICTachometerLLI_Data_Crc[input->Data_Index] = Crc8(0xFF, (uint8 *)(void *)data, sizeof(SRICTachometerLLI_Data[0]));
    348                  }
    349              }
    350              return (retval);
    351          }
    352          
