C:\Data\Nucleus_Dev\Vostok_ACU_A\source\XCategory\Hbl\all\LLIHandler\AbsoluteHumidityLLI\AbsoluteHumidityLLI.c
      1          /**
      2           *  @file       AbsoluteHumidityLLI.c
      3           *
      4           *  @brief      Module for AbsoluteHumidityLLI readings
      5           *
      6           *  @details    This module perform reading of Absolute humidity and perform some filters.
      7           *
      8           *              Measuring principle:
      9           *
     10           *              The absolute humidity sensor consists of two thermistors which are coupled in series,  when LLI enable pin is high, it will be fed with a
     11           *              current of approximately 30 mA, which heat them to a working temperature of around 150C.
     12           *
     13           *              These two thermistors are mounted in two separate cavities, and connected to a measuring bridge. One cavity is hermetically sealed, while
     14           *              the other is open to a surrounding air. Humid air going past this cavity will cool the thermistor, causing its resistance to increase and
     15           *              changing the bridge balance. The bridge has a feedback output connected to LLI feedback pin so that LLI can detect the bridge balance,and
     16           *              a pulse input connected to  LLI PWM pin so that  LLI can adjust the PWM output to pulse the bridge's resistor  and compensate the voltage
     17           *              difference to get the bridge balance.
     18           *
     19           *              Constantly adjusting PWM output,so that the bridge is always in balance,and the duty can be used to reflect the change of air humidity.
     20           *
     21                @startuml{AbsoluteHumidityLLI_SM.png}
     22                  title AbsoluteHumidityLLI State Machine
     23          
     24                  ' Use State = Absolute_Humidity_LLI_Data[LLI_Index].State
     25                  [*] --> HEATING
     26          
     27                  ' HEATING State - request LLI heating state on entry and wait for event in do
     28                      HEATING: entry /\t CounterInitialize() \n\t\t ErrorStatusInitialize() \n\t\t AbsoluteHumidityHeatingOn() \n\t\t AbsoluteHumidityPWMStartForHeating()
     29                      HEATING: do /\t\t MonitorHeating()
     30                      HEATING --> BALANCING: evBalancing
     31          
     32                  ' BALANCING State - request LLI balancing state on entry and wait for event in do
     33                      BALANCING: entry /\t CounterInitialize() \n\t\t AbsoluteHumidityPWMStartForBalancing()
     34                      BALANCING: do /\t\t ExecuteSuccessiveApproximation()
     35                      BALANCING --> REGULATING: evRegulating
     36          
     37                  ' REGULATING State - request LLI regulating state on entry and wait for event in do
     38                      REGULATING: entry / CounterInitialize()
     39                      REGULATING: do /\t ExecuteFineTuning() \n\t MonitorUnbalanced()
     40                      REGULATING --> BALANCED: evBalanced
     41                      REGULATING --> BALANCING: evBalancing
     42          
     43                  ' BALANCED State - request LLI balanced state on entry and wait for event in do
     44                      BALANCED: entry / CounterInitialize()
     45                      BALANCED: do /\t ExecuteFineTuning() \n\t MonitorBalanced()
     46                      BALANCED --> BALANCING: evBalancing
     47          
     48              @enduml
     49           *
     50           *
     51           *  @copyright  Copyright 2018 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     52           */
