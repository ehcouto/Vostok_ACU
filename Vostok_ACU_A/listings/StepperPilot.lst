    366          //=====================================================================================================================
    367          //-------------------------------------- Private Functions ------------------------------------------------------------
    368          //=====================================================================================================================
    369          //---------------------------------------------------------------------------------------------------------------------
    370          /**
    371           *  @brief      Read parameters from setting file.
    372           *
    373           *  @param      HBL_LOAD_TYPE *load - Pointer to stepper load instance.
    374           *
    375           */
    376          static void StepperPilotReadParameters(HBL_LOAD_TYPE * load)
    377          {
    378              STEPPER_PARAMETERS_TYPE *params;
    379          
    380              params = &(Stepper_Pilot_Data[load->Pilot_Data_Index].Parameters);
    381          
    382              params->Number_Of_Sequences = (load->Parameter_Ptr.Data[5]) & 0x0F;
    383          
    384              params->Sequences[0] = load->Parameter_Ptr.Data[6] >> 4;
    385              params->Sequences[1] = load->Parameter_Ptr.Data[6] & 0x0F;
    386              params->Sequences[2] = load->Parameter_Ptr.Data[7] >> 4;
    387              params->Sequences[3] = load->Parameter_Ptr.Data[7] & 0x0F;
    388          
    389              if (params->Number_Of_Sequences == 8)
    390              {
    391                  params->Sequences[4] = load->Parameter_Ptr.Data[8] >> 4;
    392                  params->Sequences[5] = load->Parameter_Ptr.Data[8] & 0x0F;
    393                  params->Sequences[6] = load->Parameter_Ptr.Data[9] >> 4;
    394                  params->Sequences[7] = load->Parameter_Ptr.Data[9] & 0x0F;
    395              }
    396          }
