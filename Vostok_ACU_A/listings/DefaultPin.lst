      1          /**
      2           *  @file       DefaultPin.c
      3           *
      4           *  @brief      Hbl Acu/Hmi module to refresh default configuration of unused pins from Setting file
      5           *
      6           *  @details    This module gets a list of pins and their configuration to be applied.
      7           *                  TO ENABLE THIS FEATURE apply these changes in SRMain_prv.h:
      8           *                  - Include DefaultPin.h
      9           *                  - Add DefaultPin__Initialize in SRMainNormalInitialization_Tasks function list, e.g. after Hbl__Initialize
     10           *                  - Add DefaultPin__Handler in SRMain_AppMgr_Handler function list
     11           *  			Compile time parameters (it can bel placed on SystemConfig_prm.h):
     12           *  			- DEFAULTPIN_REFRESH_COUNT: if set, pin refresh is performed after DEFAULTPIN_REFRESH_COUNT*100ms time.
     13           *  			    Default is 0 (100ms)
     14           *  			- DEFAULTPIN_ACU_EXP_SECTION: it should be defined explicitly if SYSTEM_ACU_EXPANSION_HANDLING is ENABLED and
     15           *  			    SFUPDATER_ACU_SECTION_ID is not defined; if SYSTEM_ACU_EXPANSION_HANDLING is DISABLED this feature is disabled.
     16           *                  If DEFAULTPIN_ACU_EXP_SECTION is not defined and SFUPDATER_ACU_SECTION_ID is, feature is enabled using SFUPDATER_ACU_SECTION_ID value.
     17           *  			    If both DEFAULTPIN_ACU_EXP_SECTION and SFUPDATER_ACU_SECTION_ID are not defined, this feature is disabled.
     18           *              - DEFAULTPIN_HMI_EXP_SECTION: it should be defined explicitly if SYSTEM_HMI_EXPANSION_HANDLING is ENABLED and
     19           *                  SFUPDATER_HMI_SECTION_ID is not defined; if SYSTEM_HMI_EXPANSION_HANDLING is DISABLED this feature is disabled.
     20           *                  If DEFAULTPIN_HMI_EXP_SECTION is not defined and SFUPDATER_HMI_SECTION_ID is, feature is enabled using SFUPDATER_HMISECTION_ID value.
     21           *                  If both DEFAULTPIN_HMI_EXP_SECTION and SFUPDATER_HMI_SECTION_ID are not defined, this feature is disabled.
     22           *
     23           *  @copyright  Copyright 2019 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     24           */
