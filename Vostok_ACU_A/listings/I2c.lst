   1293          /**
   1294           *    @brief    It defines ISR for I2C interrupt
   1295           *
   1296           *    @details  This method defines ISR for I2C interrupt whenever data byte is available in I2C_DR register & any event
   1297           *              occurs during I2C bus communication
   1298           */

   \                                 In section .text, align 2, keep-with-next
   1299          void I2c1__InterruptHandler(void)
   1300          {
   1301              #if (I2C1_SLAVE_FEATURE == DISABLED)
   1302                  #if (I2C1_FEATURE == ENABLED)
   1303                      //Handle Error Events
   1304                      if (((I2C_1.ISR & (I2C_ISR_BERR | I2C_ISR_ARLO | I2C_ISR_OVR | I2C_ISR_PECERR | I2C_ISR_TIMEOUT | I2C_ISR_ALERT | I2C_ISR_NACKF)) != FALSE))
   1305                      {
   1306                          if ((I2C_1.ISR & I2C_ISR_ARLO) != FALSE)
   1307                          {
   1308                              //Set the error flag
   1309                              I2c1_Ack_Error = I2C_ERROR_BUS_LOCKED;
   1310                          }
   1311                          else
   1312                          {
   1313                              I2c1_Ack_Error = I2C_ERROR_ACK;
   1314                          }
   1315          
   1316                          //Clear the error to accommodate the new errors
   1317                          I2C_1.ICR = (I2C_ICR_NACKCF | I2C_ICR_BERRCF | I2C_ICR_ARLOCF | I2C_ICR_OVRCF | I2C_ICR_PECCF | I2C_ICR_TIMOUTCF | I2C_ICR_ALERTCF);
   1318                      }
   1319                      else
   1320                      {
   1321                          //Handle Write data
   1322                          if (I2C_1.ISR & I2C_ISR_TXIS)
   1323                          {
   1324                              I2C_1.TXDR = I2c1_Buffer_Out[I2c1_TxPointer];
   1325                              I2c1_TxPointer++;
   1326                          }
   1327                          //Handle Read data
   1328                          else if (I2C_1.ISR & I2C_ISR_RXNE)
   1329                          {
   1330                              I2c1_Buffer_In[I2c1_RxPointer] = I2C_1.RXDR;
   1331                              I2c1_RxPointer++;
   1332                          }
   1333                      }
   1334                  #else
   1335                  #endif
   1336              #else
   1337                  //Slave mode
   1338          
   1339                      //Address matched
   1340                      if ((I2C_1.ISR & I2C_ISR_ADDR) != FALSE)
   1341                      {
   1342                          //Clear NACK
   1343                          I2C_1.CR2 &= ~I2C_CR2_NACK;
   1344          
   1345                          if (I2C_1.ISR & I2C_ISR_DIR)
   1346                          {
   1347                              if (I2c1_Slave_TxSize != 0)
   1348                              {
   1349                                  //Clear the index to accommodate the new write
   1350                                  I2c1_TxPointer = 0;
   1351          
   1352                                  //Read transfer, Slave enters transmitter mode
   1353                                  I2C_1.CR1 |= I2C_CR1_TXIE | I2C_CR1_NACKIE;
   1354                              }
