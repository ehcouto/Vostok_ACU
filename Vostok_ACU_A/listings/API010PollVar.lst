    224              BOOL_TYPE On_Change;                            //!< Also selected for publication on change.
    225              BOOL_TYPE Changed;                              //!< A change was detected in this variable.
    226          #endif
    227          } API010_DATA_CONTROL_TYPE;
    228          
    229          //! The first part of the payload when publishing API010 periodic data.
    230          typedef uint16 API010_STREAM_INDEX_TYPE;
    231          
    232          //! A structure for all the variables used by API010.
    233          typedef struct API010_RAM_DATA_STRUCT
    234          {
    235              //! The period of time between publication of API010 data.
    236              uint16 Publication_Period;
    237          
    238              //! The number of bytes in the Stream_Buffer[] array that must be published.
    239              API010_STREAM_INDEX_TYPE Stream_Length;
    240          
    241              //! The number of bytes in the Stream_Buffer[] array that have already been published.
    242              API010_STREAM_INDEX_TYPE Stream_Index;
    243          
    244              #if (API010_MMAP_VARS_COUNT > 0U)
    245                  //! An array of configuration structures for potential memory-mapped variables.
