     43          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     44          
     45          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     46          
     47          #define INPUTCAPTURELLI_AUTO_FEATURE_MIN_FREQUENCY          2
     48          #define INPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY          150
     49          
     50          #define INPUTCAPTURELLI_AUTO_FEATURE_FREQUENCY_HYS          30 //SSS_ frequency hysteresis value[Hz]
     51          #define INPUTCAPTURELLI_AUTO_FEATURE_DOWN_PERIOD_HYS       (1000000 / (INPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY))
     52          #define INPUTCAPTURELLI_AUTO_FEATURE_UP_PERIOD_HYS         (1000000 / (INPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY-INPUTCAPTURELLI_AUTO_FEATURE_FREQUENCY_HYS))
     53          #define MAX_INVALID_SAMPLE_COUNT                            255
     54          #define DEFAULT_SAMPLING_MODE                               1 //continue mode=1 don't change
     55          
     56          PACKED typedef struct
     57          {
     58              uint8 N_Read:3;
     59              uint8 Unused_1:5;
     60              uint8 Delta:4;
     61              uint8 Unused_2:4;
     62              uint8 Time_Out;
     63              uint8 Sampling_Time;
     64              uint16 Minimum_Period;
     65              uint16 Maximum_Period;
     66              uint16 Minimum_Duty;
     67              uint16 Maximum_Duty;
     68              uint16 Filter_Period;
     69              uint16 Filter_Duty;
     70              uint8 Base_Period;
     71          } INPUTCAPTURELLI_PARAMETERS_TYPE;
     72          
     73          typedef struct
     74          {
     75              INPUTCAPTURE_PUBLIC_TYPE Public_Data;
     76              IIR_FILTER_MEASURE_TYPE Private_Period;
     77              IIR_FILTER_MEASURE_TYPE Private_Duty;
     78              BOOL_TYPE Continue_mode;
     79              BOOL_TYPE Filter_Initialized;
     80              uint8 Private_Valid_Sample_Count;
     81              uint8 Private_Invalid_Sample_Count;
     82              uint8 Private_Current_Count;
     83              MILLIS_TIMER_TYPE Timer_Sampling;
     84              MILLIS_TIMER_TYPE Timer_Timeout;
     85              TIMER_PARAMETER_TYPE Timer_Parameter;
     86          }INPUTCAPTURE_DATA_TYPE;
     87          
     88          static INPUTCAPTURE_DATA_TYPE InputCaptureLLI_Data[HBL_LLI_NUM_INPUTCAPTURE];
     89          static uint8 InputCaptureLLI_Allocation;
     90          
     91          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     92          
     93          //=====================================================================================================================
     94          //-------------------------------------- Public Functions -------------------------------------------------------------
