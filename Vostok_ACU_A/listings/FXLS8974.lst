   1099          /**
   1100           * Send a log message to indicate that at least one XYZ data point was lost.
   1101           * This message will occur when the data is received faster than the application can process it.
   1102           */
   1103          static void ReportTooMuchData(void)
   1104          {
   1105              LOG_ADD_EXCEPTION(TOO_MUCH_DATA, FXLS8974_MAX_POINTS);
   1106              ACCELEROMETER_DATA_OVERFLOW();
   1107          }
