      1          /**
      2           *  @file       AnalogOutputPilot.c
      3           *
      4           *  @brief      Implements AnalogOutputPilot module.
      5           *
      6           *  @details    This module translates a percentage level to Dtoa
      7           *  			Load parameter value is represented as Q15 (0-32767)
      8           *  			Setting parameters:
      9           *  				- Minimum and Maximum values as two digits percentage (0-100.00%)
     10           *  				- High-Low Activation pin shall be used to set reference value to GND (if set, values are increasing) or VCC (if not set, values are decreasing)
     11           *  			Dtoa value would depend on Dtoa resolution avaliable - it can be configured on VirtualPin table
     12           *
     13           *  @copyright  Copyright 2015-$Date: 2015/07/14 17:37:54EDT $. Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     14           */
     15          //---------------------------------------------------------------------------------------------------------------------
     16          
     17          //-------------------------------------- Include Files ----------------------------------------------------------------
     18          // -- This Module --
     19          #include "SystemConfig.h"
     20          #include "AnalogOutputPilot.h"
     21          
     22          // -- Other Modules --
     23          #if (HBL_PILOT_NUM_ANALOGOUTPUT > 0)
     24          #include "Dtoa.h"
     25          #include "VirtualPin.h"
     26          
     27          #include <String.h>
     28          
     29          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     30          #define	ANALOGOUTPUTPILOT_PARAM_MAX			32768
     31          #define PARAM_MAX_PERCENT					10000
     32          
     33          //! Tracks the number of Analog output pilot allocations.
     34          static uint8 AnalogOutputPilot_Allocation;
     35          
     36          //! Analog output pilot data type definition.
     37          typedef PACKED struct
     38          {
     39          	uint16 Requested;
     40          	uint16 Processed;
     41              uint16 Max_Percent;
     42              uint16 Min_Percent;
     43              HBL_LOAD_STATUS_TYPE Status;
     44          } ANALOGOUTPUTPILOT_DATA_TYPE;
     45          
     46          typedef PACKED struct
     47          {
     48          	uint16 Min_Percent;
     49          	uint16 Max_Percent;
     50          } ANALOGOUTPUTPILOT_PARAM_TYPE;
     51          
     52          //! Analog output pilot data array. One entry per pilot instance.
     53          static ANALOGOUTPUTPILOT_DATA_TYPE AnalogOutputPilot_Data[HBL_PILOT_NUM_ANALOGOUTPUT];
     54          
     55          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     56          static uint16 DtoaValueFromPercent(uint16 percent, uint16 max_value);
     57          
     58          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     59          
     60          //=====================================================================================================================
     61          //-------------------------------------- Public Functions -------------------------------------------------------------
     62          //=====================================================================================================================
     63          //---------------------------------------------------------------------------------------------------------------------
     64          /**
     65           *  @brief      It Initializes the module StepperPilot and its variables
     66           */
     67          void AnalogOutputPilot__Initialize(void)
     68          {
     69              AnalogOutputPilot_Allocation = 0;
     70              memset(AnalogOutputPilot_Data,0,sizeof(AnalogOutputPilot_Data));
     71              Dtoa__Initialize();
     72          }
     73          
     74          
     75          //---------------------------------------------------------------------------------------------------------------------
     76          /**
     77           *  @brief      Allocate pilot instance for Analog output.
     78           *
     79           *  @return     uint8 result - Allocation result.
     80           *  @retval     0-254 - Pilot allocation instance.
     81           *  @retval     0xFF - Allocation failed.
     82           */
     83          uint8 AnalogOutputPilot__Allocate(void)
     84          {
     85              uint8 retval = 0xFF;
     86          
     87              if (AnalogOutputPilot_Allocation < HBL_PILOT_NUM_ANALOGOUTPUT)
     88              {
     89                  retval = AnalogOutputPilot_Allocation;
     90                  AnalogOutputPilot_Allocation++;
     91              }
     92          
     93              return (retval);
     94          }
     95          
     96          //---------------------------------------------------------------------------------------------------------------------
     97          /**
     98           *  @brief      Initialize Analog output pilot instance.
     99           *
    100           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Analog output load instance.
    101           *
    102           *  @return     PASS_FAIL_TYPE result - Result of Analog output pilot instance initialization.
    103           *  @retval     PASS - Instance initialization succeeded.
    104           *  @retval     FAIL - Instance initialization failed.
    105           */
    106          PASS_FAIL_TYPE AnalogOutputPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    107          {
    108              PASS_FAIL_TYPE retval = FAIL;
    109          
    110              if (load->Pilot_Data_Index < AnalogOutputPilot_Allocation)
    111              {
    112                  uint8 virtual_pin = load->Pin_Ptr[0];
    113          
    114              	if ( (virtual_pin < VirtualPin__GetNumOf())
    115              		&& (VIRTUALPIN_TABLE[virtual_pin].port != PORT_NULL) )
    116              	{
    117                  	ANALOGOUTPUTPILOT_DATA_TYPE *data_ptr = &AnalogOutputPilot_Data[load->Pilot_Data_Index];
    118                  	ANALOGOUTPUTPILOT_PARAM_TYPE *param_ptr = (ANALOGOUTPUTPILOT_PARAM_TYPE *)load->Parameter_Ptr.Data;
    119                  	uint32 max_value = (1 << VIRTUALPIN_TABLE[virtual_pin].param0);
    120          
    121                  	if (param_ptr != NULL)
    122                      {
    123                      	data_ptr->Max_Percent = ENDIANU16_STON(param_ptr->Max_Percent);
    124                      	data_ptr->Min_Percent = ENDIANU16_STON(param_ptr->Min_Percent);
    125          
    126                      	if (data_ptr->Max_Percent > data_ptr->Min_Percent)
    127                      	{
    128                      		retval = PASS;
    129                      	}
    130          
    131                      }
    132          
    133                  	// Initialization succeeded
    134                      if (retval == PASS)
    135                      {
    136                          uint32 start_value = 0;
    137          
    138                          // Invert DAC logic if Hi_Low_Activation_Bitmap is not set
    139                          if ((load->Hi_Low_Activation_Bitmap & 0x01) == 0)
    140                          {
    141                          	start_value = max_value - 1;
    142                          }
    143          
    144                          Dtoa__Convert((DTOA_CHANNEL_DEF ) VIRTUALPIN_TABLE[virtual_pin].device, (DTOA_CHANNEL_RESOLUTION_DEF) VIRTUALPIN_TABLE[virtual_pin].param0, 0,
    145                  				(uint32) &start_value, 1); //lint !e923 Suppress Info:  cast from pointer to unsigned long [Encompasses MISRA 2004 Rule 11.1], [MISRA 2004 Rule 11.3]
    146                          data_ptr->Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    147                      }
    148                      else
    149                      {
    150                          data_ptr->Status.Load.Status = HBL_LOAD_STATUS_FAILURE;
    151                      }
    152              	}
    153              }
    154          
    155              return (retval);
    156          }
    157          
    158          //---------------------------------------------------------------------------------------------------------------------
    159          /**
    160           *  @brief      Set Analog output pilot instance request.
    161           *
    162           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Analog output load instance.
    163           *
    164           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    165           *
    166           *  @return     PASS_FAIL_TYPE result - Result of Analog output pilot request.
    167           *  @retval     PASS - Instance request succeeded.
    168           *  @retval     FAIL - Instance request failed.
    169           */
    170          PASS_FAIL_TYPE AnalogOutputPilot__Request(HBL_LOAD_TYPE * load, void * data)
    171          {
    172              PASS_FAIL_TYPE result = FAIL;
    173          
    174              if (load->Pilot_Data_Index < AnalogOutputPilot_Allocation)
    175              {
    176              	uint16 new_value = *((PACKED uint16 *)data);
    177              	if (new_value >= ANALOGOUTPUTPILOT_PARAM_MAX)
    178              	{
    179              		new_value = ANALOGOUTPUTPILOT_PARAM_MAX - 1;
    180              	}
    181                  AnalogOutputPilot_Data[load->Pilot_Data_Index].Requested = new_value;
    182                  result = PASS;
    183              }
    184          
    185              return (result);
    186          }
    187          
    188          //---------------------------------------------------------------------------------------------------------------------
    189          /**
    190           *  @brief      Process Analog output pilot instance.
    191           *
    192           *  @param      HBL_LOAD_TYPE *load - Pointer to Analog output load instance.
    193           *
    194           *  @return     PASS_FAIL_TYPE result - Result of Analog output pilot instance process.
    195           *  @retval     PASS - Instance process succeeded.
    196           *  @retval     FAIL - Instance process failed.
    197           */
    198          PASS_FAIL_TYPE AnalogOutputPilot__Process(HBL_LOAD_TYPE * load)
    199          {
    200              PASS_FAIL_TYPE retval = FAIL;
    201          
    202              if (load->Pilot_Data_Index < AnalogOutputPilot_Allocation)
    203              {
    204              	ANALOGOUTPUTPILOT_DATA_TYPE *data_ptr = &AnalogOutputPilot_Data[load->Pilot_Data_Index];
    205                  data_ptr->Processed = data_ptr->Requested;
    206                  data_ptr->Status.Load.Cur_Reg = (data_ptr->Processed != 0);
    207                  if (data_ptr->Status.Load.Status != HBL_LOAD_STATUS_FAILURE)
    208                  {
    209                      data_ptr->Status.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    210                  }
    211                  retval = PASS;
    212              }
    213          
    214              return (retval);
    215          }
    216          
    217          //---------------------------------------------------------------------------------------------------------------------
    218          /**
    219           *  @brief      Asynchronous process for AnalogOutputPilot.
    220           *
    221           *	@detail     Asynchronous process handles update do Dtoa driver
    222           *
    223           *  @param      HBL_LOAD_TYPE *load - Pointer to AnalogOutputPilot instance.
    224           *
    225           *  @return     PASS_FAIL_TYPE result - Result of AnalogOutputPilot asynch execution.
    226           *  @retval     PASS - Execution succeeded.
    227           *  @retval     FAIL - Execution failed.
    228           */
    229          PASS_FAIL_TYPE AnalogOutputPilot__AsynchProcess(HBL_LOAD_TYPE * load)
    230          {
    231              PASS_FAIL_TYPE retval = FAIL;
    232          
    233              if (load->Pilot_Data_Index < AnalogOutputPilot_Allocation)
    234              {
    235                  uint8 virtual_pin = load->Pin_Ptr[0];
    236          
    237                  if (virtual_pin < VirtualPin__GetNumOf())
    238                  {
    239                  	ANALOGOUTPUTPILOT_DATA_TYPE *data_ptr = &AnalogOutputPilot_Data[load->Pilot_Data_Index];
    240                      if(data_ptr->Status.Load.Status == HBL_LOAD_STATUS_WAITING_TARGET)
    241                      {
    242                          uint32 max_adc_value = (1 << VIRTUALPIN_TABLE[virtual_pin].param0);
    243                      	uint32 new_target = (data_ptr->Max_Percent - data_ptr->Min_Percent) * data_ptr->Processed;
    244          				new_target += (ANALOGOUTPUTPILOT_PARAM_MAX / 2);
    245          				new_target >>= 15; // Divide by 32768
    246          				new_target += data_ptr->Min_Percent;
    247          				new_target = DtoaValueFromPercent(new_target, max_adc_value);
    248          
    249          				// Invert DAC logic if Hi_Low_Activation_Bitmap is not set
    250          				if ((load->Hi_Low_Activation_Bitmap & 0x01) == 0)
    251          				{
    252          					new_target = max_adc_value - new_target - 1;
    253          				}
    254          
    255          				Dtoa__Convert((DTOA_CHANNEL_DEF ) VIRTUALPIN_TABLE[virtual_pin].device, (DTOA_CHANNEL_RESOLUTION_DEF) VIRTUALPIN_TABLE[virtual_pin].param0, 0,
    256          						(uint32) &new_target, 1); //lint !e923 Suppress Info:  cast from pointer to unsigned long [Encompasses MISRA 2004 Rule 11.1], [MISRA 2004 Rule 11.3]
    257          
    258                  		data_ptr->Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    259                  	}
    260                      retval = PASS;
    261                  }
    262              }
    263              return(retval);
    264          }
    265          
