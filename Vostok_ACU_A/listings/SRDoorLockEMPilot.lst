     37          
     38          #define SRDOORLOCKEM_DEFAULT_PULSES           (3)
     39          #define SRDOORLOCKEM_INITIAL_PERIOD           (18)
     40          #define SRDOORLOCKEM_TIME_SPACING_UNIT_MS     (100)
     41          #define SRDOORLOCKEM_FBK_TIMEOUT              (SRDOORLOCKEM_TIME_SPACING_UNIT_MS)
     42          
     43          #define ZC_ALLOWED_MIN_FREQUENCY            45
     44          #define ZC_ALLOWED_MAX_FREQUENCY            65
     45          
     46          // Minimum and maximum period from ZeroCross frequency boundaries set - Round to near
     47          #define SRDOORLOCKEM_MIN_PERIOD_MS		((2000+ZC_ALLOWED_MAX_FREQUENCY)/(ZC_ALLOWED_MAX_FREQUENCY*2))
     48          #define SRDOORLOCKEM_MAX_PERIOD_MS		((2000+ZC_ALLOWED_MIN_FREQUENCY)/(ZC_ALLOWED_MIN_FREQUENCY*2))
     49          
     50          typedef enum SRDOORLOCKEM_STATUS_ENUM
     51          {
     52              SRDOORLOCKEM_STATUS_INIT,
     53              SRDOORLOCKEM_STATUS_DOOR_UNLOCKED,
     54              SRDOORLOCKEM_STATUS_DOOR_LOCKING,
     55              SRDOORLOCKEM_STATUS_DOOR_LOCKING_FAILED,
     56              SRDOORLOCKEM_STATUS_DOOR_LOCKED,
     57              SRDOORLOCKEM_STATUS_DOOR_UNLOCKING,
     58              SRDOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED
     59          } SRDOORLOCKEM_STATUS_TYPE;
     60          
     61          PACKED typedef struct
     62          {
     63              uint16 Retries_Counter;
     64              uint8 Fbk_Counter;
     65              uint8 Fbk_Last_Counter;
     66              uint8 Period;
     67              uint8 Cycle_Counter;
     68              uint8 Fbk_Last_Pin_Value;
     69              uint8 Last_Pin_Out_Value;
     70              uint8 Fbk_Pin;
     71              uint8 Requested;
     72              uint8 Processed;
     73              HBL_LOAD_STATUS_TYPE PilotStatus;
     74              SRDOORLOCKEM_STATUS_TYPE Status;
     75              uint8 Request_Triac_On;
     76              uint8 Process_Triac_On;
     77              uint8 Keep_Triac_On;
     78              uint8 Retries;
     79          } SRDOORLOCKEMPILOT_DATA_TYPE;
     80          
     81          typedef struct
     82          {
     83              uint8 Max_Retries :4;
     84              uint8 Num_Pulses  :4;
     85              uint8 Time_Spacing;
     86          } SRDOORLOCKEMPILOT_PARAM_TYPE;
     87          
     88          static uint8 SRDoorLockEMPilot_Allocation;
     89          static SRDOORLOCKEMPILOT_DATA_TYPE SRDoorLockEMPilot_Data[HBL_PILOT_NUM_SRDOORLOCKEM];
     90          static uint8 N_SRDoorLockEMPilot_Allocation;
     91          static SRDOORLOCKEMPILOT_DATA_TYPE N_SRDoorLockEMPilot_Data[HBL_PILOT_NUM_SRDOORLOCKEM];
