    363          /**
    364           *  @brief      Background thread function that waits and run requests
    365           *
    366           *  @param data_ptr    - Pointer to the function data to handle
    367           *
    368           */
    369          void BackgroundThreadsExec(void *data_ptr)
    370          {
    371              OS_TASK_EVENT my_event;
    372              while(1)
    373              {
    374                  my_event = OS_WaitEvent(BACKGROUNDTHREADS_EVENT);
    375                  if((my_event == BACKGROUNDTHREADS_EVENT) &&
    376                      (data_ptr != NULL) &&
    377                      (((BACKGROUNDTHREADS_DATA_TYPE *)data_ptr)->Running_Func != NULL))
    378                  {
    379                      ((BACKGROUNDTHREADS_DATA_TYPE *)data_ptr)->Timestamp = OS_GetTime32();
    380                      ((FUNCTION_TYPE) ((BACKGROUNDTHREADS_DATA_TYPE *)data_ptr)->Running_Func)();
    381                      ((BACKGROUNDTHREADS_DATA_TYPE *)data_ptr)->Running_Func = NULL;
    382                  }
    383              }
    384          }
    385          
    386          //---------------------------------------------------------------------------------------------------------------------
    387          /**
    388           *  @brief      This function will return a free thread to run a requested function
    389           *
    390           *  @param function_ptr    - Pointer to the function to run
    391           *  @param stack_required  - Minimum stack size required by the function to run
    392           *                            Not used if function has a reserved thread
    393           *
    394           *  @return
    395           *  found_index if a free or already reserved thread has been found
    396           *  NUM_BG_THREADS (out of index) if no free threads have been found
    397           *
    398           */
    399          uint8 GetFreeBackgroundIndex(void *function_ptr, uint16 stack_required)
    400          {
    401              uint8 found_index = NUM_BG_THREADS;
    402              uint8 index;
    403          
    404              for(index = 0; index < NUM_BG_THREADS; index++)
    405              {
    406                  BACKGROUNDTHREADS_DATA_TYPE *data_ptr = &BackgroundThreads_Data[index];
    407          
    408                  if(data_ptr->Assigned_Func == function_ptr)
    409                  {
    410                      // Assigned thread: exit loop; if not running, save index to return
    411                      if(data_ptr->Running_Func == NULL)
    412                      {
    413                          found_index = index;
    414                      }
    415                      else
    416                      {
    417                          found_index = NUM_BG_THREADS;
    418                      }
    419                      break;
    420                  }
    421                  else if((data_ptr->Assigned_Func == NULL) &&
    422                      (data_ptr->Running_Func == NULL) &&
    423                      (stack_required <= BACKGROUNDTHREADS_THREADS_STACKS[index]) &&
    424                      (found_index >= NUM_BG_THREADS))
    425                  {
    426                      // First free thread found: don't exit to find if there is an assigned thread
    427                      found_index = index;
    428                  }
    429              }
    430          
    431              return(found_index);
    432          }
    433          
