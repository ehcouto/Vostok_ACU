     40          /**
     41           * Function which setups periodic timer interrupt and enables it.
     42           *
     43           * @param freq  - interrupt frequency
     44           */

   \                                 In section .text, align 2, keep-with-next
     45          void TimerInterruptExt__SetupPerInt(unsigned short freq, unsigned char preemption_priority, unsigned char sub_priority)
     46          {
     47          #if(TIM6_FOR_MC_HANDLER == ENABLED)
     48              TIM_DEF_TYPE * tim6;
     49              tim6 = (TIM_DEF_TYPE *) TIM6_BASE;
     50          
     51              //Setup configuration of TIM6 for interrupt generation
     52              RCC.APBENR1 |= RCC_APBENR1_TIM6EN;
     53          
     54              tim6->CR1 &= (uint16)(~TIM_CR1_CEN);
     55              tim6->CR1 |= TIM_CR1_ARPE;
     56              tim6->CR1 |= TIM_CR1_URS;
     57              tim6->PSC = 0;
     58          
     59              // Setup pwm frequency
     60              tim6->ARR = (unsigned short)((Micro__GetClock()->PCLK1_Frequency) / (unsigned long)freq)-1;
     61          
     62              Micro__NVICEnableIRQ(TIM6_DAC_LPTIM1_IRQ_CHANNEL,preemption_priority);
     63              // Enable the TIM6_IRQ @ the peripheral level
     64              tim6->DIER |= TIM_DIER_UIE;                                    // Update update interrupt enable @ peripheral level
     65              tim6->CR1  |= TIM_CR1_CEN;
     66          #endif
     67          }
   \                     TimerInterruptExt__SetupPerInt: (+1)
   \   00000000   0x4770             BX       LR               ;; return
