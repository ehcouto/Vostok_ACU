     89          typedef PACKED struct
     90          {
     91              uint32 Sum;                     /* A/D samples's sum */
     92              uint16 Value;                   /* A/D current sample */
     93              uint16 Raw_Sample;              /* A/D raw sample */
     94              uint16 Last_Sample;             /* A/D old sample */
     95              uint16 Lower_Value;             /* A/D current min value */
     96              uint16 Higher_Value;            /* A/D current max value */
     97              uint8  Sample_Counter;          /* Number of Samples collected */
     98              uint8  Fast_Sample_Counter;     /* Number of Samples collected */
     99              uint8  Sync_Counter;            /* Counter used for max. variation between two samples */
    100              uint8  Fast_Sync_Counter;       /* Number of considered invalid value during 1ms process ATOD */
    101          } SRANALOGLLI_DATA_TYPE;
    102          
    103          // SRAnalogLLI Parameter table
    104          typedef PACKED struct
    105          {
    106          	union
    107          	{
    108          		uint16 Complete;
    109          		struct
    110          		{
    111          			uint8 N_Read:3;
    112          			uint8 Unused:5;
    113          			uint8 Filter_Reading:4;
    114          			uint8 Channel_Discharge:1;
    115          			uint8 Compensation:1;
    116          			uint8 Reference:1;
    117          			uint8 Ac_Line:1;
    118          		};
    119          	} Config;
    120          	union
    121          	{
    122          		struct
    123          		{
    124          			uint16 Min;
    125          			uint16 Max;
    126          			uint16 Nominal;
    127          			sint8 Pre_Offset;
    128          			uint8 Hysteresis;
    129          		} Reference;
    130          		struct
    131          		{
    132          			sint8 Comp_Pre_Offset;
    133          			sint8 Comp_Post_Offset;
    134          			uint16 Zero_Level_Ref;
    135          			uint16 unused[2];
    136          		} Compensated;
    137          	} Config_param;
    138          } SRANALOGLLI_PARAM_TYPE;
    139          
    140          typedef PACKED struct
    141          {
    142          	uint16 Reference_Value;
    143          	uint16 Nominal_Value;
    144          	sint8 Nominal_Offset;
    145          } SRANALOGLLI_COMP_TYPE;
    146          
