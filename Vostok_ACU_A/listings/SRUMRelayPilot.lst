    871          /**
    872           *  @brief      Get current SRUMRelayPilot instance request.
    873           *
    874           *  @param      load - Pointer to associated SRUMRelayPilot instance.
    875           *
    876           *  @return     void *requested - Requested instance data.
    877           *  @retval     Address of requested instance data. Cast it using *((uint8 *)ptr) to get values.
    878           *  @retval     NULL - Invalid load index.
    879           */
    880          void *SRUMRelayPilot__GetRequested(HBL_LOAD_TYPE *load)
    881          {
    882              void *requested = NULL;
    883          
    884              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    885                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    886              {
    887                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    888                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    889                  if (SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr, (void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE)))
    890                  {
    891                      requested =  &data_ptr->Requested;
    892                  }
    893              }
    894          
    895              return (requested);
    896          }
