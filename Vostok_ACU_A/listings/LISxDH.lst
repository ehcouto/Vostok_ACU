    229          // The temperature sensor can be used to measure temperature variations. The output value represents a difference with respect to an unspecified reference value.
    230          // Calibration is required to determine the reference temperature.
    231          #if (SPI_ENABLED == 1)
    232          typedef struct ACCEL_READ_TEMPERATURE_STRUCT
    233          {
    234              uint8 Junk;                 // Return data from the byte of command data (can be ignored)
