    433          
    434          //=====================================================================================================================
    435          //  --- Private Functions ---------------------------------------------------------------------------------------------
    436          //=====================================================================================================================
    437          
    438          
    439          //---------------------------------------------------------------------------------------------------------------------
    440          /**
    441           * Get the size of the referenced command.
    442           * @param cmd = A command for the external motor controller.
    443           * @return The size of the referenced command.
    444           */
    445          static uint8 GetCommandSize(uint8 command)
    446          {
    447              uint8 size = 0;
    448              switch (command)
    449              {
    450                  case EXTERNAL_MOTOR_NO_COMMAND:
    451                  case EXTERNAL_MOTOR_NO_CHANGE:
    452                      size = 1;
    453                      break;
    454          
    455                  case EXTERNAL_MOTOR_STOP:
    456                      size = 1 + sizeof(EMP_STOP_PARAM_TYPE);
    457                      break;
    458          
    459                  case EXTERNAL_MOTOR_RUN:
    460                      size = 1 + sizeof(EMP_RUN_PARAM_TYPE);
    461                      break;
    462          
    463                  case EXTERNAL_MOTOR_WASH:
    464                      size = 1 + sizeof(EMP_WASH_PARAM_TYPE);
    465                      break;
    466          
    467                  case EXTERNAL_MOTOR_ROTATE_X_DEGREES:
    468                      size = 1 + sizeof(EMP_ROTATE_PARAM_TYPE);
    469                      break;
    470          
    471                  case EXTERNAL_MOTOR_PULSE_IMMEDIATE:
    472                  case EXTERNAL_MOTOR_PULSE_MODIFY:
    473                  case EXTERNAL_MOTOR_PULSE_QUEUE:
    474                      size = 1 + sizeof(EMP_PULSE_PARAM_TYPE);
    475                      break;
    476          
    477                  default:
    478                      if (BIT_TEST(command, 7) == 1)
    479                      {
    480                          size = command & 0x7F;
    481                          if (size > EXTERNAL_MOTOR_MAX_COMMAND_SIZE)
    482                          {
    483                              size = 0;
    484                          }
    485                      }
    486                      break;
    487              }
    488          
    489              return size;
    490          }
    491          
    492          
    493          //=====================================================================================================================
    494          //  --- Private State Machine Customization Functions -----------------------------------------------------------------
    495          //=====================================================================================================================
    496          
    497          
    498          //---------------------------------------------------------------------------------------------------------------------
    499          /**
    500           * Wait for Reveal to detect the MCU node on the communications bus.
    501           */
    502          static void CheckForMcuConnect(void)
    503          {
    504              if (API221MotionCtrl__IsMotorPresentOnBus(EMP_MOTOR_INDEX()) == TRUE)
    505              {
    506                  EventMcuConnected();
    507              }
    508          }
    509          
    510          
    511          //---------------------------------------------------------------------------------------------------------------------
    512          /**
    513           * Check that the MCU is still connected on the communications bus.
    514           */
    515          static void CheckForMcuDisconnect(void)
    516          {
    517              API221_CLIENT_MOTOR_INDEX_TYPE motor_index = EMP_MOTOR_INDEX();
    518              if (API221MotionCtrl__IsMotorPresentOnBus(motor_index) == FALSE)
    519              {
    520                  LOG_ADD_EVENT(DETECTED_DISCONNECTED_MOTOR_NODE, motor_index);
    521                  EventMcuDisconnected();
    522              }
    523          }
    524          
    525          
    526          //---------------------------------------------------------------------------------------------------------------------
    527          /**
    528           * Process the command for the currently running pilot by sending an API221 command.
    529           * If no command has been processed since reset, then no API221 command is sent.
    530           */
    531          static void SendProcessed(void)
    532          {
    533              // Get the size of the command.
    534              uint8 size = GetCommandSize(Emp_This->Processed.Common.Command);
    535              if (size > 0)
    536              {
    537                  switch (Emp_This->Processed.Common.Command)
    538                  {
    539                      case EXTERNAL_MOTOR_NO_COMMAND:
    540                          // This is a simple stop command.
    541                          // This is also the default command if no command is provided to HBL.
    542                          API221MotionCtrl__DeviceStop(EMP_MOTOR_INDEX(), EMP_DECELERATION());
    543                          break;
    544          
    545                      case EXTERNAL_MOTOR_NO_CHANGE:
    546                          // The EXTERNAL_MOTOR_NO_CHANGE value will only be in the Processed structure
    547                          // immediately after initialization. After that, maintaining the previous
    548                          // command is done by not doing anything at all. The previous command was
    549                          // already sent and is still the active command.
    550                          break;
    551          
    552                      case EXTERNAL_MOTOR_STOP:
    553                          API221MotionCtrl__DeviceStop(EMP_MOTOR_INDEX(),
    554                                                       Emp_This->Processed.Standard.Params.Stop.Deceleration);
    555                          break;
    556          
    557                      case EXTERNAL_MOTOR_RUN:
    558                          API221MotionCtrl__DeviceRun(EMP_MOTOR_INDEX(),
    559                                                      Emp_This->Processed.Standard.Params.Run.Velocity,
    560                                                      Emp_This->Processed.Standard.Params.Run.Acceleration);
    561                          break;
    562          
    563                      case EXTERNAL_MOTOR_WASH:
    564                          API221MotionCtrl__DeviceWash(EMP_MOTOR_INDEX(),
    565                                                       &Emp_This->Processed.Standard.Params.Wash);
    566                          break;
    567          
    568                      case EXTERNAL_MOTOR_ROTATE_X_DEGREES:
    569                          API221MotionCtrl__DeviceRotate(EMP_MOTOR_INDEX(),
    570                                                         &Emp_This->Processed.Standard.Params.Rotate);
    571                          break;
    572          
    573                      case EXTERNAL_MOTOR_PULSE_IMMEDIATE:
    574                      case EXTERNAL_MOTOR_PULSE_MODIFY:
