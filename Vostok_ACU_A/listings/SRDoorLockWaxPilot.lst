    396          //---------------------------------------------------------------------------------------------------------------------
    397          /**
    398           *  @brief      Asynchronous process for DoorLockWaxPilot.
    399           *
    400           *	@detail     Asynchronous process handles status transition and consistency check for door lock status
    401           *
    402           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    403           *
    404           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot asynch execution.
    405           *  @retval     PASS - Execution succeeded.
    406           *  @retval     FAIL - Execution failed.
    407           */
    408          PASS_FAIL_TYPE SRDoorLockWaxPilot__AsynchProcess(HBL_LOAD_TYPE * load)
    409          {
    410          	SRDOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    411          	SRDOORLOCKWAXPILOT_DATA_TYPE *ptr;
    412          	SRDOORLOCKWAXPILOT_DATA_TYPE *n_ptr;
    413          	HBL_CONSISTENCY_TYPE lock_feedback;
    414          	HBL_LOAD_STATUS_TYPE tmp_load;
    415          	PASS_FAIL_TYPE retval = FAIL;
    416          	BOOL_TYPE pin_val = FALSE;
    417          	uint8 index = load->Pilot_Data_Index;
    418          
    419              if (CheckItem(index))
    420              {
    421              	ptr = &SRDoorLockWaxPilot_Data[index];
    422              	n_ptr = &N_SRDoorLockWaxPilot_Data[index];
    423              	param_ptr = (SRDOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    424              	tmp_load.Load.Cur_Reg = ptr->Processed;
    425              	// Prevent use of TRN table when DoorLock status is OFF;
    426              	// during INITIALIZE consider Processed target like it has been already reached
    427              	if ( (ptr->Processed != 0) &&
    428              		(ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE))
    429              	{
    430              		tmp_load.Load.Status = ptr->PilotStatus.Load.Status;
    431              	}
    432              	else
    433              	{
    434              		tmp_load.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    435              	}
    436              	lock_feedback.Byte = Hbl__GetOwnLoadConsistency(load, tmp_load.Byte);
    437              	retval = PASS;
    438          
    439              	switch(ptr->Status)
    440              	{
    441              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKING:
    442              		pin_val = TRUE;
    443              		if (ptr->Counter == 0)
    444              		{
    445          		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    446              		}
    447              		else
    448              		{
    449                  		if ( (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) &&
    450                  				(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_OFF))
    451                  		{
    452              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_LOCKED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    453              		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, (param_ptr->Duty_On + param_ptr->Duty_Off) * 10);
    454                  		}
    455          
    456              		}
    457              		break;
    458          
    459          
    460              	case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING:
    461              		if (ptr->Counter == 0)
    462              		{
    463          		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    464              		}
    465              		else
    466              		{
    467                  		if ( (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) &&
    468                  			(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON) &&
    469          					(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON_ALTERNATE) )
    470                  		{
    471              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    472              		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, 0);
    473                  		}
    474          
    475              		}
    476              		break;
    477          
    478              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKED:
    479              		if (param_ptr->Duty_On == 0)
    480              		{
    481          				pin_val = TRUE;
    482              		}
    483              		else
    484              		{
    485                  		if (ptr->Counter == 0)
    486                  		{
    487              		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, (param_ptr->Duty_On + param_ptr->Duty_Off) * 10);
    488                  		}
    489                  		else if (ptr->Counter >= (param_ptr->Duty_Off * 10))
    490              			{
    491              				pin_val = TRUE;
    492              			}
    493              		}
    494          
    495              		break;
    496          
    497              	case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    498              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED:
    499              	case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED:
    500              		break;
    501          
    502              	default:
    503              		if (ptr->Counter == 0)
    504              		{
    505              			if (ptr->Processed == OFF)
    506              			{
    507              				// Check if door feedback value is fine
    508                      		if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    509                      				(lock_feedback.Byte == HBL_CONSISTENCY_TABLE_INVALID))
    510                      		{
    511                      			// Door already unlocked
    512                  		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    513                  		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, 0);
    514                      		}
    515                      		else
    516                      		{
    517                      			// Door is going to be unlocked
    518                  		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    519                  		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, ENDIANS16_STON(param_ptr->Unlock_Timeout));
    520                      		}
    521              			}
    522              			else
    523              			{
    524              				// Check if door feedback value is fine
    525                      		if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    526                      				(lock_feedback.Byte == HBL_CONSISTENCY_TABLE_INVALID))
    527                      		{
    528                      			// Door already locked
    529                  		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_LOCKED); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    530                  		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, (param_ptr->Duty_On + param_ptr->Duty_Off) * 10);
    531                      		}
    532                      		else
    533                      		{
    534                      			// Door is going to be locked
    535                  		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_LOCKING); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    536                  		    	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, ENDIANS16_STON(param_ptr->Lock_Timeout));
    537                      		}
    538              			}
    539              		}
    540              		break;
    541          
    542              	}
    543          
    544              	switch(ptr->Status)
    545              	{
    546              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKED:
    547              	case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    548              		tmp_load.Load.Status = ((pin_val == TRUE) ? HBL_LOAD_STATUS_TARGET_ALT_TABLE : HBL_LOAD_STATUS_TARGET_COMPLETED);
    549              		tmp_load.Load.Cur_Reg = ptr->Processed;
    550              		SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    551              		break;
    552          
    553              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED:
    554              	case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED:
    555              		tmp_load.Load.Status = HBL_LOAD_STATUS_FAILURE;
    556              		tmp_load.Load.Cur_Reg = ptr->Processed;
    557              		SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    558              		break;
    559          
    560              	default:
    561              		if (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE)
    562              		{
    563                  		tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    564                  		tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    565                  		SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    566              		}
    567              	}
    568              }
    569          
    570          	return(retval);
    571          }
    572          
    573          //---------------------------------------------------------------------------------------------------------------------
    574          /**
    575           *  @brief      One millisecond process for DoorLockWaxPilot.
    576           *
    577           *	@detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    578           *
    579           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    580           *
    581           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot 1ms execution.
    582           *  @retval     PASS - Execution succeeded.
    583           *  @retval     FAIL - Execution failed.
    584           */
    585          PASS_FAIL_TYPE SRDoorLockWaxPilot__Handler1ms(HBL_LOAD_TYPE * load)
    586          {
    587          	SRDOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    588          	SRDOORLOCKWAXPILOT_DATA_TYPE *ptr;
    589          	SRDOORLOCKWAXPILOT_DATA_TYPE *n_ptr;
    590          	uint8 virtual_pin;
    591          	PASS_FAIL_TYPE retval = FAIL;
    592          	BOOL_TYPE pin_val = FALSE;
    593          	BOOL_TYPE pin_fbk_val = FALSE;
    594          	uint8 index = load->Pilot_Data_Index;
    595          
    596              if (CheckItem(index))
    597              {
    598              	param_ptr = (SRDOORLOCKWAXPILOT_PARAM_TYPE *)(load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    599              	ptr = &SRDoorLockWaxPilot_Data[index];
    600              	n_ptr = &N_SRDoorLockWaxPilot_Data[index];
    601              	retval = PASS;
    602          
    603              	if (ptr->Fbk_Pin < VirtualPin__GetNumOf())
    604              	{
    605              		pin_fbk_val = Gpio__PinRead(VIRTUALPIN_TABLE[ptr->Fbk_Pin].port, VIRTUALPIN_TABLE[ptr->Fbk_Pin].pin);
    606              	}
    607          
    608              	if (pin_fbk_val != ptr->Fbk_Last_Pin_Value)
    609              	{
    610              		if (pin_fbk_val == TRUE)
    611              		{
    612              	    	if ( (ptr->Fbk_Counter >= SRDOORLOCKWAX_MIN_PERIOD_MS) &&
    613              					(ptr->Fbk_Counter <= SRDOORLOCKWAX_MAX_PERIOD_MS))
    614              			{
    615              	    		if (ptr->Debounce)
    616              	    		{
    617              	    			SRData__UpdateByte(&ptr->Debounce, &n_ptr->Debounce, ptr->Debounce-1);
    618              	    		}
    619              	    		else
    620              	    		{
    621              	    			sint8 tmp_offset = (2*ptr->Fbk_Last_Counter - ptr->Fbk_Counter)/4;
    622          						if (tmp_offset < 0)
    623          						{
    624          							tmp_offset += (ptr->Fbk_Period / 2);
    625          						}
    626          	    	    		SRData__UpdateByte((uint8 *) &ptr->Fbk_Offset,(uint8 *) &n_ptr->Fbk_Offset,(uint8) tmp_offset); //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    627              	    			SRData__UpdateByte(&ptr->Fbk_Period, &n_ptr->Fbk_Period, ptr->Fbk_Counter);
    628          
    629              	    		}
    630              			}
    631              	    	else
    632              	    	{
    633              	    		SRData__UpdateByte(&ptr->Debounce, &n_ptr->Debounce, SRDOORLOCKWAX_MAX_DEBOUNCE);
    634              	    	}
    635                  		SRData__UpdateShort(&ptr->Fbk_Timeout_Counter, &n_ptr->Fbk_Timeout_Counter, 0);
    636                  		SRData__UpdateByte(&ptr->Fbk_Counter, &n_ptr->Fbk_Counter, 0);
    637              		}
    638              		else
    639              		{
    640                  		SRData__UpdateByte(&ptr->Fbk_Last_Counter, &n_ptr->Fbk_Last_Counter, ptr->Fbk_Counter);
    641              		}
    642          
    643              		SRData__UpdateByte(&ptr->Fbk_Last_Pin_Value, &n_ptr->Fbk_Last_Pin_Value, pin_fbk_val);
    644              	}
    645              	else if (ptr->Fbk_Timeout_Counter > (param_ptr->Filter_Time*SRDOORLOCKWAX_TIMING_REF))
    646              	{
    647          			SRData__UpdateByte(&ptr->Debounce, &n_ptr->Debounce, SRDOORLOCKWAX_MAX_DEBOUNCE);
    648              		if (ptr->Fbk_Counter >= ptr->Fbk_Period)
    649          			{
    650                  		SRData__UpdateByte(&ptr->Fbk_Counter, &n_ptr->Fbk_Counter, 0);
    651          			}
    652              	}
    653              	else
    654              	{
    655              		SRData__UpdateShort(&ptr->Fbk_Timeout_Counter, &n_ptr->Fbk_Timeout_Counter, ptr->Fbk_Timeout_Counter+1);
    656              	}
    657          		SRData__UpdateByte(&ptr->Fbk_Counter, &n_ptr->Fbk_Counter, ptr->Fbk_Counter+1);
    658          
    659              	switch(ptr->Status)
    660              	{
    661              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKING:
    662              		pin_val = TRUE;
    663              		break;
    664          
    665              	case SRDOORLOCKWAX_STATUS_DOOR_LOCKED:
    666          			if ((param_ptr->Duty_On == 0) ||
    667          				(ptr->Counter >= (param_ptr->Duty_Off * 10)))
    668          			{
    669          				pin_val = TRUE;
    670          			}
    671              		break;
    672          
    673              	default:
    674              		break;
    675              	}
    676          
    677          		if (ptr->Wait_Trigger)
    678          		{
    679          			if ((ptr->Fbk_Counter == ptr->Fbk_Offset) ||
    680          				(ptr->Fbk_Counter == ptr->Fbk_Offset + (ptr->Fbk_Period / 2)))
    681          			{
    682          				SRData__UpdateByte(&ptr->Wait_Trigger, &n_ptr->Wait_Trigger, 0);
    683          			}
    684          			else
    685          			{
    686          				pin_val = FALSE;
    687          			}
    688          		}
    689          
    690              	if (ptr->TimingRef > 0)
    691              	{
    692              		SRData__UpdateByte(&ptr->TimingRef, &n_ptr->TimingRef, ptr->TimingRef-1);
    693              	}
    694              	else
    695              	{
    696              		SRData__UpdateByte(&ptr->TimingRef, &n_ptr->TimingRef, SRDOORLOCKWAX_TIMING_REF);
    697              		if (ptr->Counter > 0)
    698              		{
    699          				SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, ptr->Counter-1);
    700              		}
    701              	}
    702          
    703          		pin_val ^= (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    704          		pin_val &= TRUE;
    705                  virtual_pin = (*load->Pin_Ptr);
    706                  if((Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config, (BOOL_TYPE)ptr->Last_Pin_Out_Value))== TRUE)
    707                  {
    708          			pin_val ^= (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    709          			pin_val &= TRUE;
    710                  	Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    711                  	SRData__UpdateByte(&ptr->Last_Pin_Out_Value, &n_ptr->Last_Pin_Out_Value, pin_val);
    712                  }
    713                  else
    714                  {
    715                  	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_WAX_DOOR_LOCK, index);
    716                  }
    717          
    718          
    719              }
    720          
    721              return(retval);
    722          }
    723          
    724          //---------------------------------------------------------------------------------------------------------------------
    725          /**
    726           * @brief	Handler for DoorLockWaxPilot execution
    727           *
    728           * It checks SRDoorLockWaxPilot_Allocation integrity and all SRDoorLockWaxPilot_Data instances allocated
    729           * It sets SRTASKSEQUENCE_APPL_SRDOORLOCKWAXPILOT_CHECKS step in SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    730           *
    731           */
    732          void SRDoorLockWaxPilot__Handler(void)
    733          {
    734              if (SRData__CheckByte(&SRDoorLockWaxPilot_Allocation, &N_SRDoorLockWaxPilot_Allocation) != SRDATA_OK)
    735              {
    736              	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_WAX_DOOR_LOCK, 0xFF);
    737              }
    738              else
    739              {
    740              	uint8 index;
    741          
    742              	for(index = 0; index < HBL_PILOT_NUM_SRDOORLOCKWAX; index++)
    743                  {
    744                  	if (SRData__CheckArray(&SRDoorLockWaxPilot_Data[index], &N_SRDoorLockWaxPilot_Data[index], sizeof(SRDOORLOCKWAXPILOT_DATA_TYPE)) != SRDATA_OK)
    745                      {
    746                      	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_WAX_DOOR_LOCK, index);
    747                      	break;
    748                      }
    749                  }
    750              }
    751          
    752          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    753              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRDOORLOCKWAXPILOT_CHECKS);
    754          #endif
    755          
    756          }
    757          
    758          //=====================================================================================================================
    759          //-------------------------------------- Private Functions ------------------------------------------------------------
    760          //=====================================================================================================================
    761          
    762          BOOL_TYPE CheckItem(uint8 index)
    763          {
    764          	BOOL_TYPE retval = FALSE;
    765          
    766              if (SRData__CheckByte(&SRDoorLockWaxPilot_Allocation, &N_SRDoorLockWaxPilot_Allocation) != SRDATA_OK)
    767              {
    768              	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, 0xFF);
    769              }
    770              else
    771              {
    772              	if (index < SRDoorLockWaxPilot_Allocation)
    773                  {
    774                  	if (SRData__CheckArray(&SRDoorLockWaxPilot_Data[index], &N_SRDoorLockWaxPilot_Data[index], sizeof(SRDOORLOCKWAXPILOT_DATA_TYPE)) != SRDATA_OK)
    775                      {
    776                      	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, index);
    777                      }
    778                  	retval = TRUE;
    779                  }
    780              }
    781          
    782              return(retval);
    783          }
