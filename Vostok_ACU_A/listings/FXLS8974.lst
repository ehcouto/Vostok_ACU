      1          /**
      2           *  @file       
      3           *
      4           *  @brief      Low-level control to acquire XYZ acceleration data from an accelerometer.
      5           *
      6           *  @details    This module works with the FXL29874CF accelerometer from NXP.
      7           *
      8           *  @section    Applicable_Documents
      9           *                  FXLS8974CF Datasheet (Rev 1.3)
     10           *
     11              @startuml{FXLS8974_sm.png}
     12                  title FXLS8974 State-Machine
     13                  ' Suppress transition checks
     14          
     15                  [*] --> BootDelay
     16          
     17                  BootDelay : entry / AccelHwInit()
     18                  BootDelay : do / WaitForBootComplete()
     19                  BootDelay --> LowPowerMode : evBootComplete
     20          
     21                  LowPowerMode : entry / AccelDisable()
     22                  LowPowerMode : do / CheckForEnable()
     23                  LowPowerMode --> Restart : evEnable\n/ FXLS8974__FlushData()
     24          
     25                  Restart : entry / StartTimer()\n\t AccelHwInit()\n\t AccelEnable()
     26                  Restart : do / WaitForI2cReady()
     27                  Restart --> SelfTest : evI2cReady [SelfTestEnabled]
     28                  Restart --> Activate : evI2cReady
     29                  Restart --> LowPowerMode : evTimeout\n[IsDisableRequested()]
     30                  Restart --> Restart : evTimeout
     31          
     32                  SelfTest : entry / ConfigSelfTest()
     33                  SelfTest : do / WaitForI2cReady()
     34                  SelfTest --> Activate : evI2cReady
     35          
     36                  Activate : entry / StartTimer()\n\t AccelActivate()
     37                  Activate : do / WaitForI2cReady()
     38                  Activate --> HighResMode : evI2cReady
     39          
     40                  HighResMode : entry / StartTimer()
     41                  HighResMode : do / WaitForDataReady()
     42                  HighResMode --> ReadData : evDataReady
     43                  HighResMode -u-> LowPowerMode : evDisable
     44                  HighResMode -r-> Restart : evTimeout
     45          
     46                  ReadData : entry / AccelReadOneShot()
     47                  ReadData : do / WaitForData()
     48                  ReadData --> LowPowerMode : evDataReady\n[IsDisableRequested()]
     49                  ReadData --> ReadData : evDataReady\n/ StartTimer()
     50                  ReadData -u-> ReadTemp : evReadComplete \n[ReadTemp]
     51                  ReadData -u-> HighResMode : evReadComplete
     52                  ReadData --> AppBufferFull : evAppBufferFull
     53                  ReadData --> Restart : evTimeout
     54          
     55                  ReadTemp : entry / StartTimer()\n\t AccelReadTemp()
     56                  ReadTemp : do / WaitForTempData()
     57                  ReadTemp -u-> HighResMode : evReadComplete
     58                  ReadTemp --> Restart : evTimeout
     59          
     60                  AppBufferFull : entry / ReportTooMuchData()
     61                  AppBufferFull : do / CheckAppBuffer()
     62                  AppBufferFull -r-> HighResMode : evBufferHasSpace
     63                  AppBufferFull -u-> LowPowerMode : evDisable
     64              @enduml
     65          
