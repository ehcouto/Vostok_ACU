    528          /**
    529           * Function for loading parameters from setting file
    530           *
    531           */
    532          void Mci__ParameterLoading(void)
    533          {
    534              MCL_PARAMS_TYPE* mcl_params;
    535          #ifndef MCI_INTERNAL_PARAMETERS
    536              SETTINGFILE_LOADER_TYPE params;
    537          
    538              //Initializing default variables
    539              Mci_Params_Loaded = FALSE;
    540          
    541              //Load parameters
    542              if (SettingFile__BasicLoader(SF_PTR_MCU_CLASS_A_MCI, SF_DISPL_MOTOR_PARAMS_GLOBAL_WASH_SYSTEM, &params) == PASS)
    543              {
    544                  mcl_params = (MCL_PARAMS_TYPE*)(params.Data); //copying data into stack.
    545                  if(Mcl__SetParams(mcl_params) == TRUE)
    546                  {
    547                      //If parameters properly loaded into Motor Control Module...
    548                      Mci_Params_Loaded = TRUE;
    549                  }
    550              }
    551              else
    552              {
    553              	LOG_ADD_EXCEPTION(MCI_EXCEPTION_PARAMETERS_NOT_LOADED, (uint16)Mci_Params_Loaded);
    554              }
    555          
    556          #else
    557              //copying data into stack...
    558              mcl_params = (MCL_PARAMS_TYPE*)Mci_GWS_Params_SF; //lint !e927 Lint: 927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    559              if(Mcl__SetParams(mcl_params) == TRUE)
    560              {
    561                  //If parameters properly loaded into Motor Control Module...
    562                  Mci_Params_Loaded = TRUE;
    563              }
    564          #endif
    565          }

