    954          //=====================================================================================================================
    955          //-------------------------------------- Private Functions ------------------------------------------------------------
    956          //=====================================================================================================================
    957          
    958          //---------------------------------------------------------------------------------------------------------------------
    959          /**
    960           *  @brief      Performs pin check according to value and active_value (from SF).
    961           *
    962           *  @param      pin - pin index on VirtualPin Table.
    963           *  @param      value - ON/OFF value to be set
    964           *  @param      active_value - Real pin value to set if ON
    965           *  @return     Pin check result: PASS if check passed
    966           */
    967          PASS_FAIL_TYPE CheckPin(uint8 pin, uint8 value, uint8 active_value, uint8 debounce_counter)
    968          {
    969              PASS_FAIL_TYPE result = FAIL;
    970              VIRTUALPIN_TYPE *virtual_pin_ptr = (VIRTUALPIN_TYPE *) &VIRTUALPIN_TABLE[pin]; //lint !e929 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    971              BOOL_TYPE pin_value_read = Gpio__PinRead(virtual_pin_ptr->port, virtual_pin_ptr->pin);
    972              uint8 pin_value = value ^ ~active_value;
    973              pin_value &= 0x01;
    974          
    975              if( (pin_value == pin_value_read) ||
    976                  (debounce_counter >= SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT))
    977              {
    978                  if (TRUE == Gpio__CheckConfig(virtual_pin_ptr->port, virtual_pin_ptr->pin, virtual_pin_ptr->pin_config, (BOOL_TYPE) pin_value))
    979                  {
    980                      result = PASS;
    981                  }
    982              }
    983              return(result);
    984          }
    985          
    986          //---------------------------------------------------------------------------------------------------------------------
    987          /**
    988           *  @brief      Performs pin update according to value and active_value (from SF).
    989           *
    990           *  @param      pin - pin index on VirtualPin Table.
    991           *  @param      value - ON/OFF value to be set
    992           *  @param      active_value - Real pin value to set if ON
    993           */
    994          void UpdatePin(uint8 pin, uint8 value, uint8 active_value)
    995          {
    996              VIRTUALPIN_TYPE *virtual_pin_ptr = (VIRTUALPIN_TYPE *) &VIRTUALPIN_TABLE[pin]; //lint !e929 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    997              uint8 pin_value = value ^ ~active_value;
    998              pin_value &= 0x01;
    999              Gpio__PinWrite(virtual_pin_ptr->port, virtual_pin_ptr->pin, (BOOL_TYPE) pin_value);
   1000              Gpio__PinConfig(virtual_pin_ptr->port, virtual_pin_ptr->pin, virtual_pin_ptr->pin_config);
   1001          }
   1002          
   1003          //---------------------------------------------------------------------------------------------------------------------
   1004          /**
   1005           *  @brief      Returns if consistency value can be considered good
   1006           *              HBL_CONSISTENCY_TABLE_INVALID allows to bypass this check if no consistency table is set - for tests only!
   1007           *
   1008           *  @param      consistency - Consistency value to check
   1009           *  @return     TRUE/FALSE if Consistency is considered good or not
   1010           */
   1011          BOOL_TYPE IsConsistencyOK(HBL_CONSISTENCY_TYPE consistency)
   1012          {
   1013              BOOL_TYPE consistency_ok = (BOOL_TYPE) SRUMRELAYPILOT__ISCONSISTENCYOK_ADDITIONAL_CHECK();
   1014              consistency_ok &= (BOOL_TYPE) ((consistency.Consistency.Value == HBL_CONSISTENCY_OK) ||
   1015                  (consistency.Consistency.Table == HBL_CONSISTENCY_TABLE_INVALID));
   1016              return(consistency_ok);
   1017          }
   1018          
   1019          //---------------------------------------------------------------------------------------------------------------------
   1020          /**
   1021           *  @brief      Returns if a stop command has been detected
   1022           *              Stop command can be both Target_Speed and Acceleration 0 or both Cw and Ccw Relay at same status
   1023           *
   1024           *  @param      data_ptr - Pointer to instance data to check
   1025           *  @return     TRUE/FALSE if a stop command has been detected or not
   1026           */
   1027          BOOL_TYPE IsStopCommand(SRUMRELAYPILOT_DATA_TYPE *data_ptr)
   1028          {
   1029              BOOL_TYPE stop_check = (BOOL_TYPE) SRUMRELAYPILOT__ISSTOPCONDITION_ADDITIONAL_CHECK();
   1030          
   1031              stop_check |= (BOOL_TYPE) (((data_ptr->Processed.Target_Speed == 0) &&
   1032                              (data_ptr->Processed.Acceleration == 0)));
   1033              stop_check |= (BOOL_TYPE) (data_ptr->Status.Cw_Relay == data_ptr->Status.Ccw_Relay);
   1034          
   1035              return(stop_check);
   1036          }
   1037          
   1038          //---------------------------------------------------------------------------------------------------------------------
   1039          /**
   1040           *  @brief      Execute transition to Stop or Idle status
   1041           *
   1042           *  @param      data_ptr - Pointer to instance data to check
   1043           */
   1044          void StopMotor(SRUMRELAYPILOT_DATA_TYPE *data_ptr, SRUMRELAYPILOT_DATA_TYPE *n_data_ptr, SRUMRELAYPILOT_SF_PARAM_TYPE *param)
   1045          {
   1046              if (data_ptr->State == SRUMRELAYPILOT_START)
   1047              {
   1048                  SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_IDLE);
   1049              }
   1050              else if((data_ptr->State != SRUMRELAYPILOT_IDLE) &&
   1051                  (data_ptr->State != SRUMRELAYPILOT_STOP))
   1052              {
   1053                  HBL_LOAD_STATUS_TYPE load_status = data_ptr->Status.Load;
   1054                  load_status.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
   1055                  load_status.Load.Cur_Reg = OFF;
   1056                  SRData__UpdateByte((void *)&data_ptr->Status.Load.Byte, (void *)&n_data_ptr->Status.Load.Byte, load_status.Byte);
   1057                  SRData__UpdateByte((void *)&data_ptr->State, (void *)&n_data_ptr->State, SRUMRELAYPILOT_STOP);
   1058              }
   1059              SRData__UpdateShort((void *)&data_ptr->Time_Cnt, (void *)&n_data_ptr->Time_Cnt, param->Fbk_Debounce_Time);
   1060              SRData__UpdateByte((void *)&data_ptr->Enable_Triac, (void *)&n_data_ptr->Enable_Triac, OFF);
   1061          }
   1062          
   1063          
   1064          #endif


 

 


