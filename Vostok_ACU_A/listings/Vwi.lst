    756          /**
    757           * @brief	Function used in server configuration. In api221 interface to provide information about variables to client
    758           *
    759           * @param channel - number of channel used in API221
    760           * @return - Frame with pack of variables used in API221 module
    761           */
    762          sint32 Vwi__ServerRemoteData(uint8 channel)
    763          {
    764          	uint8 idx;
    765          	sint32 retval;
    766          
    767          	retval = 0;
    768          
    769          	for(idx=0; idx< (sizeof(Remote_Data)/sizeof(VWI_REMOTE_DATA_FRAME)); idx++)
    770          	{
    771          		if(Remote_Data[idx].Channel == channel)
    772          		{
    773          			uint16 *ptr = Remote_Data[idx].Variable_Pointer;
    774          
    775          			uint16 value = *ptr;
    776          			value &= ((1<<Remote_Data[idx].Size)-1);
    777          			retval |= (value<<(Remote_Data[idx].Bit_Shift));
    778          		}
    779          	}
    780          
    781          	return retval;
    782          }
    783          #endif //(VWI_SERVER_FEATURE == ENABLED)
