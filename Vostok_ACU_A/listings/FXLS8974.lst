   1132          
   1133          //---------------------------------------------------------------------------------------------------------------------
   1134          /**
   1135           * Wait for the read process to complete on the I2C bus.
   1136           */
   1137          static void WaitForData(void)
   1138          {
   1139              // Check if the accelerometer data has been received.
   1140          #if (SPI_ENABLED == 1)
   1141              if (Spi__GetStatus((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1142              {
   1143                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high now that transmission is complete
   1144          #else
   1145              if (I2c__GetStatus((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1146              {
   1147          #endif
   1148                  // Verify that there is space remaining in the application buffer for the new data.
   1149                  #if (ACCEL_COMM_TEST == ENABLED)
   1150                      if (Fxls8974.Number_Of_Points >= FXLS8974_MAX_POINTS)
   1151                      {
   1152                          Fxls8974.Number_Of_Points = 0;
   1153                      }
   1154                  #endif
   1155                  if (Fxls8974.Number_Of_Points < FXLS8974_MAX_POINTS)
   1156                  {
   1157                      // Read the data that was received from the I2C module.
   1158                      ACCEL_READ_REGISTERS_TYPE data;
   1159          #if (SPI_ENABLED == 1)
   1160                      (void)Spi__Read((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_READ_REGISTERS_TYPE));
   1161          #else
   1162                      if (I2c__Read((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_READ_REGISTERS_TYPE)) == TRUE)
   1163          #endif
   1164                      {
   1165                          //TODO: This content has to be modified to read the proper register from the NXP accelerometer
   1166          //                if (data.Overrun != 0)
   1167          //                {
   1168          //                    LOG_ADD_EXCEPTION(DETECTED_OVERRUN, COMBINE_NIBBLES(data.Overrun, data.Available));
   1169          //                    ACCELEROMETER_DATA_OVERWRITTEN();
   1170          //                }
   1171          
   1172                          // Move the write_index to the next point in the circular buffer.
   1173                          uint8 write_index = Fxls8974.Read + Fxls8974.Number_Of_Points;
   1174                          if (write_index >= FXLS8974_MAX_POINTS)
   1175                          {
   1176                              write_index -= FXLS8974_MAX_POINTS;
   1177                          }
   1178          
   1179                          // Copy the acceleration measurements for the application to use.
   1180                          Fxls8974.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_X)] = TRANSFORM_MULTIPLIER(MAP_AXIS_X) * data.Points[0] * Fxls8974.Scale_Factor;
   1181                          Fxls8974.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_Y)] = TRANSFORM_MULTIPLIER(MAP_AXIS_Y) * data.Points[1] * Fxls8974.Scale_Factor;
   1182                          Fxls8974.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_Z)] = TRANSFORM_MULTIPLIER(MAP_AXIS_Z) * data.Points[2] * Fxls8974.Scale_Factor;
   1183          
   1184                          Fxls8974.Number_Of_Points++;
   1185                          #if (ACCEL_COMM_TEST == ENABLED)
   1186                              Fxls8974.XYZ_Point_Counter++;
   1187                          #endif
   1188          
   1189                          Fxls8974.Failure_Counter = 0;     // Reset failure counter
   1190                      }
   1191          
   1192                      // Check if there is new data available from the accelerometer.
   1193                      if (FXLS8974_IS_DATA_READY())
   1194                      {
   1195                          EventDataReady();
   1196                          return;
   1197                      }
   1198                      else
   1199                      {
   1200                          EventReadComplete();
   1201                          return;
   1202                      }
   1203                  }
   1204                  else
   1205                  {
   1206                      // There is no space remaining in the application buffer.
   1207                      EventAppBufferFull();
   1208                      return;
   1209                  }
   1210              }
   1211          
   1212              if (Fxls8974.Timer > I2C_TIMEOUT_READY)
   1213              {
   1214                  #if (ACCEL_COMM_TEST == ENABLED)
   1215                      Fxls8974.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1216                      Fxls8974.Failure_Indicator_Counter++;
   1217                  #endif
   1218                  LOG_ADD_EXCEPTION(ACCEL_NOT_RESPONDING, 0);
   1219                  Fxls8974.Failure_Counter++;
   1220                  if (Fxls8974.Failure_Counter >= FXLS8974_MAX_FAILURES)
   1221                  {
   1222                      Fxls8974.Failure_Counter = 0;
   1223                      ACCELEROMETER_NOT_RESPONDING();
   1224                  }
   1225                  EventTimeout();
   1226              }
   1227          }
   1228          
   1229          
   1230          //---------------------------------------------------------------------------------------------------------------------
   1231          /**
   1232           * Wait for the accelerometer to indicate that at least one XYZ data point is ready.
   1233           */
   1234          static void WaitForDataReady(void)
   1235          {
   1236          #if (SPI_ENABLED == 1)
   1237              if (Spi__GetStatus((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1238          #else
   1239              if (I2c__GetStatus((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1240          #endif
   1241              {
   1242                  if (Fxls8974.Mode_Processed != Fxls8974.Mode_Requested)
   1243                  {
   1244                      EventDisable();
   1245                      return;
   1246                  }
   1247                  else if (FXLS8974_IS_DATA_READY())
   1248                  {
   1249                      EventDataReady();
   1250                      return;
   1251                  }
   1252              }
   1253          
   1254              if (Fxls8974.Timer > ACCEL_TIMEOUT_NO_DATA)
   1255              {
   1256                  if ((SelfTestEnabled() == FALSE) ||                     // If self test is not running, this is a failure
   1257                      (Fxls8974.Timer > ACCEL_TIMEOUT_SELF_TEST_NO_DATA)) // If self test is running, it must exceed time based on ODR from SELF_TEST_CONFIG_2
   1258                  {
   1259                      #if (ACCEL_COMM_TEST == ENABLED)
   1260                          Fxls8974.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1261                          Fxls8974.Failure_Indicator_Counter++;
   1262                      #endif
   1263                      LOG_ADD_EXCEPTION(NO_DATA_TIMEOUT, 0);
   1264                      Fxls8974.Failure_Counter++;
   1265                      if (Fxls8974.Failure_Counter >= FXLS8974_MAX_FAILURES)
   1266                      {
   1267                          Fxls8974.Failure_Counter = 0;
   1268                          ACCELEROMETER_OLD_DATA();
   1269                      }
   1270                      EventTimeout();
   1271                  }
   1272              }
   1273          }
   1274          
   1275          
   1276          //---------------------------------------------------------------------------------------------------------------------
   1277          /**
   1278           * Wait for the I2C bus to become idle.
   1279           */
   1280          static void WaitForI2cReady(void)
   1281          {
   1282          #if (SPI_ENABLED == 1)
   1283              if (Spi__GetStatus((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1284          #else
   1285              if (I2c__GetStatus((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1286          #endif
   1287              {
   1288                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);       // Pull chip select high after transmission
   1289                  EventI2cReady();
   1290              }
   1291              else if (Fxls8974.Timer > I2C_TIMEOUT_READY)
   1292              {
   1293                  #if (ACCEL_COMM_TEST == ENABLED)
   1294                      Fxls8974.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1295                      Fxls8974.Failure_Indicator_Counter++;
   1296                  #endif
   1297                  LOG_ADD_EXCEPTION(I2C_APPEARS_STUCK, Fxls8974_State);
   1298                  Fxls8974.Failure_Counter++;
   1299                  if (Fxls8974.Failure_Counter >= FXLS8974_MAX_FAILURES)
   1300                  {
   1301                      Fxls8974.Failure_Counter = 0;
   1302                      ACCELEROMETER_NOT_RESPONDING();
   1303                  }
   1304                  EventTimeout();
   1305              }
   1306          }
   1307          
   1308          
   1309          //---------------------------------------------------------------------------------------------------------------------
   1310          /**
   1311           *
   1312           */
   1313          static void WaitForTempData(void)
   1314          {
   1315              // Check if the temperature data has been received.
   1316          #if (SPI_ENABLED == 1)
   1317              if (Spi__GetStatus((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1318              {
   1319                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high now that transmission is complete
   1320          #else
   1321              if (I2c__GetStatus((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1322              {
   1323          #endif
   1324                  // Read the temperature data that was received from the I2C module.
   1325                  ACCEL_READ_TEMPERATURE_TYPE data;
   1326          #if (SPI_ENABLED == 1)
   1327                  (void)Spi__Read((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_CMD_READ_TEMPERATURE));
   1328          #else
   1329                  if (I2c__Read((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, (void*)&data, 1) == TRUE)
   1330          #endif
   1331                  {
   1332                      Fxls8974.Temperature_Delta = data.Value;
   1333          
   1334                      Fxls8974.Failure_Counter = 0;     // Reset failure counter
   1335          
   1336                      EventReadComplete();
   1337                  }
   1338              }
   1339          
   1340              if (Fxls8974.Timer > I2C_TIMEOUT_READY)
   1341              {
   1342                  #if (ACCEL_COMM_TEST == ENABLED)
   1343                      Fxls8974.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1344                      Fxls8974.Failure_Indicator_Counter++;
   1345                  #endif
   1346                  LOG_ADD_EXCEPTION(ACCEL_NOT_RESPONDING, 0);
   1347                  Fxls8974.Failure_Counter++;
   1348                  if (Fxls8974.Failure_Counter >= FXLS8974_MAX_FAILURES)
   1349                  {
   1350                      Fxls8974.Failure_Counter = 0;
   1351                      ACCELEROMETER_NOT_RESPONDING();
   1352                  }
   1353                  EventTimeout();
   1354              }
   1355          }
