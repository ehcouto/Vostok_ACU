    346          #if (TRIAC_V_DIAG_AC_LINE_FEATURE != ENABLED)
    347          void TriacVoltageMonitor__FastHandler1ms(void)
    348          {
    349              uint16 dc_voltage_sample;
    350          
    351              dc_voltage_sample = ((uint16)(Mci__GetAnalog(MOTOR0, MCI_AI_BUS_VOLTAGE_S16)>>16));
    352          
    353          	if (0 == TriacVoltage_Data.Dc_Voltage_Samples_Cnt)
    354              {
    355                  TriacVoltage_Data.Dc_Voltage_Current_Max = dc_voltage_sample;
    356              }
    357              else
    358              {
    359                  if (dc_voltage_sample > TriacVoltage_Data.Dc_Voltage_Current_Max)
    360                  {
    361                      TriacVoltage_Data.Dc_Voltage_Current_Max = dc_voltage_sample;
    362                  }
    363              }
    364              TriacVoltage_Data.Dc_Voltage_Samples_Cnt++;
    365          
    366              if(TriacVoltage_Data.Dc_Voltage_Samples_Cnt >= TRIACDIAGNOSTICS_SUPPLYVOLTAGE_NUMBER)
    367              {
    368              	TriacVoltage_Data.Dc_Voltage_Sampled = TriacVoltage_Data.Dc_Voltage_Current_Max;
    369              	TriacVoltage_Data.Dc_Voltage_Samples_Cnt = 0;
    370              }
    371          
    372          	if (TriacVoltage_Data.Dc_Voltage_Sampled < HVDC_Threshold)
    373          	{
    374          		Power_Loss_Occurring = TRUE;
    375          		//Set the stabilization timer
    376                  (void)SystemTimers__SetMs(TriacDiagnostic_Data.Triac_Stabilization_Timer, TRIACDIAGNOSTIC_POWER_LOSS_TIME);
    377          	}
    378          	else
    379          	{
    380          		Power_Loss_Occurring = FALSE;
    381              }
    382          }
    383          #endif // (TRIAC_V_DIAG_AC_LINE_FEATURE == DISABLED)
