    318          #pragma optimize = none

   \                                 In section .text, align 2, keep-with-next
    319          void BoardDebugging__25msHandler(void)
    320          {
    321          #if (BD_RESET == ENABLED)
    322              if (BD_Reset != 255)
    323              {
    324                  Micro__ForceReset((MICRO_RESET_MODE_TYPE)BD_Reset);
    325              }
    326          #endif
    327          
    328          #if (BD_PWM_ACCESS == ENABLED)
    329              if ((BD_Select_Method == SELECT_PWM) && (BD_Update_Cmd != 0))
    330              {
    331                  if (Pwm_Turn_On_Flag == 0)
    332                  {
    333                      Pwm_Turn_On_Flag = 1;
    334                      MotorSafetyMgr__Prepare2StartMotor();
    335                      // put MCI in debug state
    336                      Mci_Control_State = MCI_DEBUGGING;
    337                      Mcl__SetDigital(MCL_WRITE_INJECTION_DC_VOLTAGE);
    338                  }
    339              }
    340              if((BD_Select_Method == SELECT_STOP) && Pwm_Turn_On_Flag == 1)
    341              {
    342                  Pwm_Turn_On_Flag = 0;
    343                  MotorSafetyMgr__Prepare2StopMotor();
    344                  BD_Select_Method = SELECT_DISABLED;
    345                  Mci_Control_State = MCI_IDLE;
    346              }
    347          #endif
    348          
    349          #if (BD_MCI_CMD == ENABLED)
    350              if((BD_Select_Method == SELECT_SPEED) && (BD_Update_Cmd != 0))
    351              {
    352                  if(BD_Target_Speed != 0)
    353                  {
    354                      BD_Update_Cmd = BD_RUN(BD_Motor, BD_Target_Speed, BD_Target_Accel);
    355                  }
    356                  else
    357                  {
    358                      BD_Update_Cmd = BD_STOP(BD_Motor, BD_Target_Accel);
    359                  }
    360              }
    361              else if((BD_Select_Method == SELECT_MANUAL) && (BD_Update_Cmd != 0))
    362              {
    363                  BD_Update_Cmd = BD_MANUAL_INJ(BD_Motor, BD_Manual_Method, BD_Level_x32, BD_Level_Rate_x32, BD_Param_x32, BD_Param_Rate_x32);
    364              }
    365              else if(BD_Select_Method == SELECT_STOP)
    366              {
    367                  BD_STOP(BD_Motor, BD_Target_Stop);
    368                  BD_Select_Method = SELECT_DISABLED;
    369              }
    370              else if(BD_Select_Method == SELECT_DISABLED)
    371              {
    372                  BD_Update_Cmd = 0;
    373              }
    374          #ifdef BD_PLT_SPECIFIC
    375              else if ((BD_Select_Method == SELECT_PLTSPECIFIC) && (BD_Update_Cmd != 0))
    376              {
    377                  BD_Update_Cmd = 0;
    378                  BD_PLT_SPECIFIC(BD_Motor, BD_Plt_Specific_Buffer);
    379              }
    380          #endif
    381          
    382              if (BD_Update_Cmd > 0)
    383              {
    384                  BD_Update_Cmd = 0;
    385              }
    386          #endif
    387          
    388          
    389          #if (BD_ADC_NOISE_ASSESSMENT == ENABLED)
    390              Noise_Measure_Window_Cnt++;
    391              if(Noise_Measure_Window_Cnt == Noise_Measure_Window)
    392              {
    393                  Noise_Measure_Window_Cnt = 0;
    394                  Current_A.Noise_Cnt = 0;
    395                  Current_B.Noise_Cnt = 0;
    396                  Current_C.Noise_Cnt = 0;
    397                  DcBus.Noise_Cnt     = 0;
    398              }
    399          #endif
    400          
    401          #if (BD_LED == ENABLED)
    402              if(Is_Led_Blinking == FALSE)
    403              {
    404                  GPIO__PIN_SET(LED_PORT,LED_PIN);
    405                  Led_Counter--;
    406                  if(!Led_Counter)
    407                  {
    408                      Led_Counter = LED_TIMER;
    409                      Is_Led_Blinking = TRUE;
    410                  }
    411              }
    412              else
    413              {
    414                  Led_Counter--;
    415                  if(!Led_Counter)
    416                  {
    417                      GPIO__PIN_TOGGLE(LED_PORT,LED_PIN);
    418                      Led_Counter = LED_TIMER;
    419                      Is_Led_Blinking = TRUE;
    420                  }
    421              }
    422          #endif
    423          }
