   \                                 In section .text, align 2, keep-with-next
    985          static void CheckStatus(void)
    986          {
    987          	/*
    988          	API221_STS_ANY_ERROR_FOUND      = 0,             Any error found?
    989          	API221_STS_IS_MOTOR_STOPPED     = 1,             Is motor stopped?
    990          	API221_STS_REACHED_TARGET       = 2,             Target velocity == reference velocity
    991          	API221_STS_IS_IDLE              = 3,             Is the motor idle? If the speed is zero, no error found...
    992          	API221_STS_MOTOR_RUNNING        = 4
    993          	*/
    994          	#if (API221_CLIENT_FEATURE == ENABLED)
    995          	if ((Drain_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR) && ((uint8)Ask_Drain_Pump_Status == (uint8)TRUE))
    996          	{
    997          		if ((AC_PendingStatus[MOTOR_0]) && (AC_PendingStatus[MOTOR_1]))
    998          		{
    999          
   1000          			if (BIT_TEST(AC_Status[MOTOR_0],API221_STS_REACHED_TARGET) == 0U)
   1001          			{
   1002          				PumpControl__SetPreviousWashMotorSpeed(0);
   1003          			}
   1004          
   1005          			if (BIT_TEST(AC_Status[MOTOR_1],API221_STS_REACHED_TARGET) == 0U)
   1006          			{
   1007          				PumpControl__SetPreviousDrainMotorSpeed(0);
   1008          			}
   1009          
   1010          			if ((BIT_TEST(AC_Status[MOTOR_0],API221_STS_MOTOR_RUNNING) != 0U) && (BIT_TEST(AC_Status[MOTOR_0],API221_STS_REACHED_TARGET) == 0U))
   1011          			{
