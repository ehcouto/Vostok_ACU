    461              // FXLS8974_MODE_NEGATIVE_X
    462              {
    463                  0x36,   // SENS_CONFIG1:  ST X Axis, ST_POL Negative, SPI 4-wire, 16g Range, Standby mode (REGISTERS CAN ONLY BE MODIFIED IN STANDBY MODE)
    464                  0x50,   // SENS_CONFIG2:  High performance mode, little endian, Normal Read mode
    465                  0x55,   // SENS_CONFIG3   100Hz ODR (first sample will be valid)
    466                  0x01,   // SENS_CONFIG4:  INT_POL sets interrupt events as active high
    467                  0x00,   // SENS_CONFIG5:  Vector Magnitude calculation disabled, x/y/z axis auto-increment address enabled, hibernate disabled
    468                  0x00,   // WAKE_IDLE_LSB  (not used)
    469                  0x00,   // WAKE_IDLE_MSB  (not used)
    470                  0x00,   // SLEEP_IDLE_LSB (not used)
    471                  0x00,   // SLEEP_IDLE_MSB (not used)
    472                  0x00,   // ASLP_COUNT_LSB (not used)
    473                  0x00,   // ASLP_COUNT_MSB (not used)
    474                  0x82,   // INT_EN: Data-ready interrupt output enabled, Boot Interrupt Disabled
    475                  0x7F    // INT_PIN_SEL: DRDY_INT2 data-ready interrupt routing to INT1 pin
    476              },
    477              // FXLS8974_MODE_POSITIVE_Y
    478              {
    479                  0x46,   // SENS_CONFIG1:  ST Y Axis, ST_POL Positive, SPI 4-wire, 16g Range, Standby mode (REGISTERS CAN ONLY BE MODIFIED IN STANDBY MODE)
    480                  0x50,   // SENS_CONFIG2:  High performance mode, little endian, Normal Read mode
    481                  0x55,   // SENS_CONFIG3   100Hz ODR (first sample will be valid)
    482                  0x01,   // SENS_CONFIG4:  INT_POL sets interrupt events as active high
    483                  0x00,   // SENS_CONFIG5:  Vector Magnitude calculation disabled, x/y/z axis auto-increment address enabled, hibernate disabled
    484                  0x00,   // WAKE_IDLE_LSB  (not used)
    485                  0x00,   // WAKE_IDLE_MSB  (not used)
    486                  0x00,   // SLEEP_IDLE_LSB (not used)
    487                  0x00,   // SLEEP_IDLE_MSB (not used)
    488                  0x00,   // ASLP_COUNT_LSB (not used)
    489                  0x00,   // ASLP_COUNT_MSB (not used)
    490                  0x82,   // INT_EN: Data-ready interrupt output enabled, Boot Interrupt Disabled
    491                  0x7F    // INT_PIN_SEL: DRDY_INT2 data-ready interrupt routing to INT1 pin
    492              },
    493              // FXLS8974_MODE_NEGATIVE_Y
    494              {
    495                  0x56,   // SENS_CONFIG1:  ST Y Axis, ST_POL Negative, SPI 4-wire, 16g Range, Standby mode (REGISTERS CAN ONLY BE MODIFIED IN STANDBY MODE)
    496                  0x50,   // SENS_CONFIG2:  High performance mode, little endian, Normal Read mode
    497                  0x55,   // SENS_CONFIG3   100Hz ODR (first sample will be valid)
    498                  0x01,   // SENS_CONFIG4:  INT_POL sets interrupt events as active high
    499                  0x00,   // SENS_CONFIG5:  Vector Magnitude calculation disabled, x/y/z axis auto-increment address enabled, hibernate disabled
    500                  0x00,   // WAKE_IDLE_LSB  (not used)
    501                  0x00,   // WAKE_IDLE_MSB  (not used)
    502                  0x00,   // SLEEP_IDLE_LSB (not used)
    503                  0x00,   // SLEEP_IDLE_MSB (not used)
    504                  0x00,   // ASLP_COUNT_LSB (not used)
    505                  0x00,   // ASLP_COUNT_MSB (not used)
    506                  0x82,   // INT_EN: Data-ready interrupt output enabled, Boot Interrupt Disabled
    507                  0x7F    // INT_PIN_SEL: DRDY_INT2 data-ready interrupt routing to INT1 pin
    508              },
    509              // FXLS8974_MODE_POSITIVE_Z
    510              {
    511                  0x66,   // SENS_CONFIG1:  ST Z Axis, ST_POL Positive, SPI 4-wire, 16g Range, Standby mode (REGISTERS CAN ONLY BE MODIFIED IN STANDBY MODE)
    512                  0x50,   // SENS_CONFIG2:  High performance mode, little endian, Normal Read mode
    513                  0x55,   // SENS_CONFIG3   100Hz ODR (first sample will be valid)
    514                  0x01,   // SENS_CONFIG4:  INT_POL sets interrupt events as active high
    515                  0x00,   // SENS_CONFIG5:  Vector Magnitude calculation disabled, x/y/z axis auto-increment address enabled, hibernate disabled
    516                  0x00,   // WAKE_IDLE_LSB  (not used)
    517                  0x00,   // WAKE_IDLE_MSB  (not used)
    518                  0x00,   // SLEEP_IDLE_LSB (not used)
    519                  0x00,   // SLEEP_IDLE_MSB (not used)
    520                  0x00,   // ASLP_COUNT_LSB (not used)
    521                  0x00,   // ASLP_COUNT_MSB (not used)
    522                  0x82,   // INT_EN: Data-ready interrupt output enabled, Boot Interrupt Disabled
    523                  0x7F    // INT_PIN_SEL: DRDY_INT2 data-ready interrupt routing to INT1 pin
    524              },
    525              // FXLS8974_MODE_NEGATIVE_Z
    526              {
    527                  0x76,   // SENS_CONFIG1:  ST Z Axis, ST_POL Negative, SPI 4-wire, 16g Range, Standby mode (REGISTERS CAN ONLY BE MODIFIED IN STANDBY MODE)
    528                  0x50,   // SENS_CONFIG2:  High performance mode, little endian, Normal Read mode
    529                  0x55,   // SENS_CONFIG3   100Hz ODR (first sample will be valid)
    530                  0x01,   // SENS_CONFIG4:  INT_POL sets interrupt events as active high
    531                  0x00,   // SENS_CONFIG5:  Vector Magnitude calculation disabled, x/y/z axis auto-increment address enabled, hibernate disabled
    532                  0x00,   // WAKE_IDLE_LSB  (not used)
    533                  0x00,   // WAKE_IDLE_MSB  (not used)
    534                  0x00,   // SLEEP_IDLE_LSB (not used)
    535                  0x00,   // SLEEP_IDLE_MSB (not used)
    536                  0x00,   // ASLP_COUNT_LSB (not used)
    537                  0x00,   // ASLP_COUNT_MSB (not used)
    538                  0x82,   // INT_EN: Data-ready interrupt output enabled, Boot Interrupt Disabled
    539                  0x7F    // INT_PIN_SEL: DRDY_INT2 data-ready interrupt routing to INT1 pin
    540              }
    541          };
    542          #endif
    543          
    544          //! The command sent to the accelerometer to request x,y,z data
    545          #if (SPI_ENABLED == 1)
    546          // RW bit shall be 1 for a read command
    547          static const uint8 ACCEL_CMD_READ[] =
    548          {
    549              RW_READ | ACCEL_REG_OUT_X_L,
    550              0x00,   /* Dummy byte required after the register address */
    551              0x00,   /* Dummy byte for reading the X_Low  register */
    552              0x00,   /* Dummy byte for reading the X_High register */
    553              0x00,   /* Dummy byte for reading the Y_Low  register */
    554              0x00,   /* Dummy byte for reading the Y_High register */
    555              0x00,   /* Dummy byte for reading the Z_Low  register */
    556              0x00    /* Dummy byte for reading the Z_High register */
    557          };
    558          #else
    559          static const uint8 ACCEL_CMD_READ[] =
    560          {
    561              ACCEL_REG_OUT_X_L
    562          };
    563          #endif
    564          
    565          //! The command sent to the accelerometer to request the device temperature data (must read both temperature registers; only High register contains useful data)
    566          #if (SPI_ENABLED == 1)
    567          // RW bit shall be 1 for a read command; MS bit shall be 1 to auto-increment the register address
    568          static const uint8 ACCEL_CMD_READ_TEMPERATURE[] =
    569          {
    570              RW_READ | ACCEL_REG_OUT_TEMP,
    571              0x00,  /* Dummy byte required after the register address */
    572              0x00   /* Dummy byte for reading the TEMP register */
    573          };
    574          #else
    575          static const uint8 ACCEL_CMD_READ_TEMPERATURE[] =
    576          {
    577              ACCEL_REG_OUT_TEMP
    578          };
    579          #endif
    580          
    581          
    582          //! Table to conver the setting file output data rate to the value to set the ODR in the SENS_CONFIG3 register
    583          static const uint8 CONVERT_ODR[10] = {
    584                                                   15, /*0 = Standby Mode*/
    585                                                   11, /*1 = 1.5Hz*/
    586                                                   8,  /*2 = 12.5Hz*/
    587                                                   7,  /*3 = 25Hz*/
    588                                                   6,  /*4 = 50Hz*/
    589                                                   5,  /*5 = 100Hz*/
    590                                                   4,  /*6 = 200Hz*/
    591                                                   3,  /*7 = 400Hz*/
    592                                                   1,  /*8 = 1600Hz*/
    593                                                   0   /*9 = 3200Hz*/
    594                                               };
    595          
    596          // -- Private Variable Definitions --
    597          
    598          //! The variables used by this module.
    599          static FXLS8974_VARS_TYPE Fxls8974;
    600          
    601          static FXLS8974_SF_PARAM_TYPE ACCELEROMETERLLI_DEFAULT_SF_PARAM = {0, ACCELEROMETER_DEVICE_FXLS8974, 0, I2C0, 2, 0, 0x19, I2C_400KHZ, 2, 0, 0, 1, 1, 1, 1, 9, 0, 0, 1, 1, 1, 2, 1, 0};
