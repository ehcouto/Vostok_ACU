     85          //---------------------------------------------------------------------------------------------------------------------
     86          /**
     87           * @brief
     88           * @return
     89           */
     90          uint8 ZCTriacPilot__Allocate(void)
     91          {
     92              uint8 retval;
     93              retval = 0xFF;
     94              if (ZCTriacPilot_Allocation < HBL_PILOT_NUM_ZCTRIAC)
     95              {
     96                  retval = ZCTriacPilot_Allocation;
     97                  ZCTriacPilot_Allocation++;
     98              }
     99              return (retval);
    100          }
    101          
    102          //---------------------------------------------------------------------------------------------------------------------
    103          /**
    104           *
    105           * @param load
    106           */
    107          PASS_FAIL_TYPE ZCTriacPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    108          {
    109              PASS_FAIL_TYPE retval;
    110              retval = FAIL;
    111              uint8 virtual_pin = load->Pin_Ptr[0];
    112          
    113              if ((load->Pilot_Data_Index < ZCTriacPilot_Allocation) &&
    114              	(virtual_pin < VirtualPin__GetNumOf()))
    115              {
    116          		uint8 pin_val = ZCTriacPilot_Data[load->Pilot_Data_Index].Processed;
    117          		// Invert pin value according to Hi Low Activation Bitmap
    118          		pin_val ^= ~load->Hi_Low_Activation_Bitmap;
    119          		pin_val &= 0x01;
    120          
    121                  if (VIRTUALPIN_TABLE[virtual_pin].port != 0xFF)
    122                  {
    123                  	uint16 id = ZeroCross__RegisterGpioActivity(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin);
    124                  	if (id != ZEROCROSS_ID_INVALID)
    125                  	{
    126                  		ZCTriacPilot_Data[load->Pilot_Data_Index].Gpio_Id = id;
    127                      	Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) pin_val);
    128                          Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    129          
    130          
    131                          if (load->Parameter_Ptr.Length != 0)
    132                          {
    133                              ZCTriacPilot__Params[load->Pilot_Data_Index] = (ZCTRIACPILOT_PARAM_TYPE *)load->Parameter_Ptr.Data;
    134                          }
    135                          else //if there's no parameters defined, load the default.
    136                          {
    137                              ZCTriacPilot__Params[load->Pilot_Data_Index] = (ZCTRIACPILOT_PARAM_TYPE *)&ZCTRIACPILOT_DEFAULT_PARAMS;
    138                          }
    139          
    140                          retval = PASS;
    141                  	}
    142                  }
    143              }
    144          
    145              return (retval);
    146          }
    147          
    148          //---------------------------------------------------------------------------------------------------------------------
    149          /**
    150           * @brief
    151           * @param load
    152           * @param data
    153           * @return
    154           */
    155          PASS_FAIL_TYPE ZCTriacPilot__Request(HBL_LOAD_TYPE * load,void * data)
    156          {
    157              PASS_FAIL_TYPE retval = FAIL;
    158              uint8 max_value;
    159          
    160              if (load->Pilot_Data_Index < ZCTriacPilot_Allocation)
    161              {
    162              	uint8 new_value = *((uint8 *)data);
    163          
    164              	// Values accepted are from 0 to 100; other values are discarded
    165                  if (new_value <= 100)
    166                  {
    167                  	// Minimum percentage applied is set on setting file.
    168                  	// Except for 0 (OFF) it cannot be lower than Activation time plus a Minimum threshold time
    169                  	// that prevents pin activated during zero cross event
    170          
    171                      if(ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Activation_Percent == 0)
    172                      {
    173                          max_value = ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Deactivation_Percent+ZCTriacPilot__Params[load->Pilot_Data_Index]->Activation_Percent;
    174                      }
    175                      else
    176                      {
    177                          max_value = ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Deactivation_Percent+ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Activation_Percent;
    178                      }
    179          
    180          			if ((new_value > 0) &&
    181          				(new_value < max_value))
    182          			{
    183          				new_value = max_value;
    184          			}
    185          
    186                      ZCTriacPilot_Data[load->Pilot_Data_Index].Requested = new_value;
    187                      retval = PASS;
    188                  }
    189              }
    190              return(retval);
    191          }
    192          
    193          //---------------------------------------------------------------------------------------------------------------------
    194          /**
    195           *
    196           * @param load
    197           * @param data
    198           * @return
    199           */
    200          PASS_FAIL_TYPE ZCTriacPilot__Process(HBL_LOAD_TYPE * load)
    201          {
    202              PASS_FAIL_TYPE retval = FAIL;
    203              if (load->Pilot_Data_Index < ZCTriacPilot_Allocation)
    204              {
    205              	ZCTriacPilot_Data[load->Pilot_Data_Index].Processed = ZCTriacPilot_Data[load->Pilot_Data_Index].Requested;
    206                  retval = PASS;
    207              }
    208          
    209              return (retval);
    210          }
    211          
    212          //---------------------------------------------------------------------------------------------------------------------
    213          /**
    214           * @brief -
    215           * @param load
    216           * @return
    217           */
    218          PASS_FAIL_TYPE ZCTriacPilot__ZCProcess(HBL_LOAD_TYPE * load)
    219          {
    220              PASS_FAIL_TYPE retval;
    221              retval = FAIL;
    222          
    223              if (load->Pilot_Data_Index < ZCTriacPilot_Allocation)
    224              {
    225              	uint8 active_pin_value = load->Hi_Low_Activation_Bitmap & 0x01;
    226                  uint8 virtual_pin = load->Pin_Ptr[0];
    227                  ZEROCROSS_GPIO_REQUEST_TYPE activity_request;
    228              	// Replace with (ZCTRIACPILOT_PARAM_TYPE *) load->Load_Parameter_Ptr.Data;
    229          
    230                  activity_request.Gpio_Id = ZCTriacPilot_Data[load->Pilot_Data_Index].Gpio_Id;
    231                  activity_request.Active_value = (BOOL_TYPE) active_pin_value;
    232          
    233                  if (ZCTriacPilot_Data[load->Pilot_Data_Index].Processed > 0)
    234                  {
    235                  	uint16 degree = (100 - ZCTriacPilot_Data[load->Pilot_Data_Index].Processed) * ZEROCROSS_HALF_WAVE_ANGLE /100;
    236                  	activity_request.Active_Degree = degree;
    237          
    238                  	if (ZCTriacPilot_Data[load->Pilot_Data_Index].Processed <  ZCTriacPilot__Params[load->Pilot_Data_Index]->Activation_Percent + ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Deactivation_Percent)
    239                  	{
    240                  	    degree = (100 - ZCTriacPilot__Params[load->Pilot_Data_Index]->Min_Deactivation_Percent) * ZEROCROSS_HALF_WAVE_ANGLE /100;
    241                  	}
    242                  	else
    243                  	{
    244                  	    degree = (100 + ZCTriacPilot__Params[load->Pilot_Data_Index]->Activation_Percent - ZCTriacPilot_Data[load->Pilot_Data_Index].Processed) * ZEROCROSS_HALF_WAVE_ANGLE /100;
    245                  	}
    246          
    247                  	activity_request.Deactive_Degree = degree;
    248                  	retval = (ZeroCross__RequestGpioActivity(&activity_request) == TRUE) ? PASS : FAIL;
    249                  }
    250                  else
    251                  {
    252                  	// Force pin OFF
    253                  	active_pin_value ^= 0x01;
    254                     	Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) active_pin_value);
    255                     	retval = PASS;
    256                  }
    257          
    258              }
    259          
    260              return (retval);
    261          }
