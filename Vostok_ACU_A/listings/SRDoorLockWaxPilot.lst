    225          /**
    226           *  @brief      Set DoorLockWaxPilot instance request.
    227           *
    228           *  @param      HBL_LOAD_TYPE *load - Pointer to associated DoorLockWaxPilot instance.
    229           *
    230           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    231           *
    232           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot request.
    233           *  @retval     PASS - Instance request succeeded.
    234           *  @retval     FAIL - Instance request failed.
    235           */
    236          PASS_FAIL_TYPE SRDoorLockWaxPilot__Request(HBL_LOAD_TYPE * load,void * data)
    237          {
    238          	PASS_FAIL_TYPE retval = FAIL;
    239          	uint8 index = load->Pilot_Data_Index;
    240          
    241              if (CheckItem(index))
    242              {
    243              	SRData__UpdateByte(&SRDoorLockWaxPilot_Data[index].Requested, &N_SRDoorLockWaxPilot_Data[index].Requested, *((uint8 *) data));
    244              	retval = PASS;
    245              }
    246          
    247          	return(retval);
    248          }
