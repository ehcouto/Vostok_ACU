    939          /**
    940           * @brief   API returns the status of the NVData at the client side
    941           *
    942           * @details During boot up it takes time to read and verify the NVData from Server
    943           *          Application shall consider this timing
    944           *          Recommended to wait until the status becomes other then API007NVDATA_RESTORE_IN_PROGRESS
    945           *
    946           *
    947           * @return API007NVDATA_DATA_RESTORE_STATUS_TYPE
    948           */

   \                                 In section .text, align 2, keep-with-next
    949          API007NVDATA_DATA_RESTORE_STATUS_TYPE API007NVData__DataRestoreStatus(void)
    950          {
    951              API007NVDATA_DATA_RESTORE_STATUS_TYPE status = API007NVDATA_RESTORE_CORRUPTED;
    952          
    953              #if ((SYSTEM_ACU_HANDLING == ENABLED) && ((SYSTEM_HMI_HANDLING == ENABLED) || (SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)))  //P1 board or ACU+EXP HMI
    954                  if ((NVData__GetLastRestoreStatus()->Bit.Appliance_Data_Recovered == NVDATA_RESTORE_OKAY) && (NVData__GetLastRestoreStatus()->Bit.Statistics_Data_Recovered == NVDATA_RESTORE_OKAY))
    955                  {
    956                      status = API007NVDATA_RESTORE_OKAY;
    957                  }
    958              #else
    959                  #if (API007NVDATA_CLIENT_FEATURE == ENABLED)
    960                      status = API007NVData_Client_Data_Restore_Status;
    961                  #endif //(API007NVDATA_CLIENT_FEATURE == ENABLED)
    962              #endif
    963              return status;
   \                     API007NVData__DataRestoreStatus: (+1)
   \   00000000   0x2000             MOVS     R0,#+0
   \   00000002   0x4770             BX       LR               ;; return
    964          }
