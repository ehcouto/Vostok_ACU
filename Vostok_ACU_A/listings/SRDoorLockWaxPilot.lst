    106          /**
    107           *  @brief      It Initializes the module DoorLockWaxPilot and its variables
    108           *
    109           */
    110          void SRDoorLockWaxPilot__Initialize(void)
    111          {
    112          	SRData__UpdateByte(&SRDoorLockWaxPilot_Allocation, &N_SRDoorLockWaxPilot_Allocation, 0);
    113          	memset(&SRDoorLockWaxPilot_Data, 0, sizeof(SRDoorLockWaxPilot_Data));
    114          	memset(&N_SRDoorLockWaxPilot_Data, 0xFF, sizeof(N_SRDoorLockWaxPilot_Data));
    115          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    116              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRDOORLOCKWAXPILOT);
    117          #endif
    118          }
    119          
    120          //---------------------------------------------------------------------------------------------------------------------
    121          /**
    122           *  @brief      Allocate pilot instance for DoorlockWaxPilot.
    123           *
    124           *  @return     uint8 result - Allocation result.
    125           *  @retval     0-254 - Pilot allocation instance.
    126           *  @retval     0xFF - Allocation failed.
    127           */
    128          uint8 SRDoorLockWaxPilot__Allocate(void)
    129          {
    130              uint8 retval = 0xFF;
    131          
    132              if (SRData__CheckByte(&SRDoorLockWaxPilot_Allocation, &N_SRDoorLockWaxPilot_Allocation) == SRDATA_OK)
    133              {
    134                  if (SRDoorLockWaxPilot_Allocation < HBL_PILOT_NUM_SRDOORLOCKWAX)
    135                  {
    136                      retval = SRDoorLockWaxPilot_Allocation;
    137                  	SRData__UpdateByte(&SRDoorLockWaxPilot_Allocation, &N_SRDoorLockWaxPilot_Allocation, SRDoorLockWaxPilot_Allocation+1);
    138                  }
    139              }
    140              else
    141              {
    142              	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_WAX_DOOR_LOCK, 0xFF );
    143              }
    144              return(retval);
    145          }
    146          
    147          //---------------------------------------------------------------------------------------------------------------------
    148          /**
    149           *  @brief      Initialize DoorLockWaxPilot instance.
    150           *
    151           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
    152           *
    153           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot instance initialization.
    154           *  @retval     PASS - Instance initialization succeeded.
    155           *  @retval     FAIL - Instance initialization failed.
    156           */
    157          PASS_FAIL_TYPE SRDoorLockWaxPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    158          {
    159              PASS_FAIL_TYPE retval = FAIL;
    160              uint8 index = load->Pilot_Data_Index;
    161              SRDOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    162              SRDOORLOCKWAXPILOT_DATA_TYPE *ptr;
    163              SRDOORLOCKWAXPILOT_DATA_TYPE *n_ptr;
    164          	HBL_LOAD_STATUS_TYPE tmp_load;
    165              BOOL_TYPE pin_val;
    166              uint8 *ptr_pin_table;
    167              uint8 fbk_index;
    168              uint8 virtual_pin;
    169          
    170          
    171              if (CheckItem(index))
    172              {
    173              	ptr = (SRDOORLOCKWAXPILOT_DATA_TYPE *) &SRDoorLockWaxPilot_Data[index];  //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    174              	n_ptr = (SRDOORLOCKWAXPILOT_DATA_TYPE *) &N_SRDoorLockWaxPilot_Data[index];  //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    175              	param_ptr = (SRDOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    176          
    177              	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_INIT); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    178              	tmp_load.Load.Status = HBL_LOAD_STATUS_INITIALIZE;
    179              	tmp_load.Load.Cur_Reg = 0;
    180              	SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    181              	SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, param_ptr->Filter_Time);
    182              	SRData__UpdateShort(&ptr->Fbk_Timeout_Counter, &n_ptr->Fbk_Timeout_Counter, param_ptr->Filter_Time * SRDOORLOCKWAX_TIMING_REF);
    183              	SRData__UpdateByte(&ptr->Fbk_Period, &n_ptr->Fbk_Period, SRDOORLOCKWAX_INITIAL_PERIOD);
    184              	SRData__UpdateByte(&ptr->Debounce, &n_ptr->Debounce, SRDOORLOCKWAX_MAX_DEBOUNCE);
    185          
    186                  // Check if a SRFeedback LLI is configured for pin synchronization
    187                  fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_SRFEEDBACK);
    188                  if (fbk_index >= Hbl__GetNumLLI())
    189                  {
    190                      // Fallback for backward compatibility - Check that this LLI ID is handled by a class B module to use it!!
    191                      fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_FEEDBACK);
    192                  }
    193              	ptr_pin_table = Hbl__GetLLIPinTabPtr(fbk_index);
    194          
    195              	if (ptr_pin_table == NULL)
    196              	{
    197              		virtual_pin = VirtualPin__GetNumOf();
    198              	}
    199              	else
    200              	{
    201              		virtual_pin = ptr_pin_table[0];
    202              	}
    203              	SRData__UpdateByte(&ptr->Fbk_Pin, &n_ptr->Fbk_Pin, virtual_pin);
    204          
    205              	virtual_pin = load->Pin_Ptr[0];
    206          		if ((virtual_pin < VirtualPin__GetNumOf()) &&
    207          			(VIRTUALPIN_TABLE[virtual_pin].port != 0xFF))
    208          		{
    209          			pin_val = (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    210          			pin_val &= TRUE;
    211          			Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    212          			Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    213          	    	SRData__UpdateByte(&ptr->Last_Pin_Out_Value, &n_ptr->Last_Pin_Out_Value, pin_val);
    214          
    215          	    	if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config, pin_val)== TRUE)
    216          	    	{
    217          	    		retval = PASS;
    218          	    	}
    219          		}
    220              }
    221              return(retval);
    222          }
