     30          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     31          #define DOORLOCKWAX_INITIAL_PERIOD          20
     32          #define DOORLOCKWAX_TIMING_REF				10
     33          #define DOORLOCKWAX_MAX_DEBOUNCE			2
     34          
     35          #define ZC_ALLOWED_MIN_FREQUENCY            45
     36          #define ZC_ALLOWED_MAX_FREQUENCY            65
     37          
     38          // Minimum and maximum period from ZeroCross frequency boundaries set - Round to near
     39          #define DOORLOCKWAX_MIN_PERIOD_MS		((2000+ZC_ALLOWED_MAX_FREQUENCY)/(ZC_ALLOWED_MAX_FREQUENCY*2))
     40          #define DOORLOCKWAX_MAX_PERIOD_MS		((2000+ZC_ALLOWED_MIN_FREQUENCY)/(ZC_ALLOWED_MIN_FREQUENCY*2))
     41          
     42          
     43          typedef enum DOORLOCKWAX_STATUS_ENUM
     44          {
     45          	DOORLOCKWAX_STATUS_INIT,
     46          	DOORLOCKWAX_STATUS_DOOR_UNLOCKED,
     47          	DOORLOCKWAX_STATUS_DOOR_LOCKING,
     48          	DOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED,
     49          	DOORLOCKWAX_STATUS_DOOR_LOCKED,
     50          	DOORLOCKWAX_STATUS_DOOR_UNLOCKING,
     51          	DOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED
     52          } DOORLOCKWAX_STATUS_TYPE;
     53          
     54          PACKED typedef struct
     55          {
     56          	uint8 Requested;
     57          	uint8 Processed;
     58          	HBL_LOAD_STATUS_TYPE PilotStatus;
     59          	DOORLOCKWAX_STATUS_TYPE Status;
     60          	uint16 Counter;
     61          	uint16 Fbk_Timeout_Counter;
     62          	uint8 Fbk_Counter;
     63          	uint8 Fbk_Last_Counter;
     64          	uint8 Fbk_Period;
     65          	sint8 Fbk_Offset;
     66          	uint8 Fbk_Last_Pin_Value;
     67          	uint8 Wait_Trigger;
     68          	uint8 Debounce;
     69          	uint8 TimingRef;
     70          	uint8 Fbk_Pin;
     71          } DOORLOCKWAXPILOT_DATA_TYPE;
     72          
     73          typedef struct
     74          {
     75          	uint16 Unlock_Timeout;
     76          	uint16 Lock_Timeout;
     77          	uint8 Duty_On;
     78          	uint8 Duty_Off;
     79          	uint8 Filter_Time;
     80          	uint8 Unused;
     81          } DOORLOCKWAXPILOT_PARAM_TYPE;
     82          
     83          static uint8 DoorLockWaxPilot_Allocation;
     84          static DOORLOCKWAXPILOT_DATA_TYPE DoorLockWaxPilot_Data[HBL_PILOT_NUM_DOORLOCKWAX];
