    252          //! The variables used by this module.
    253          typedef struct FXLS8974_VARS_STRUCT
    254          {
    255              #if (ACCEL_COMM_TEST == ENABLED)
    256                  //! A count of the number of failures that have been detected since reset.
    257                  uint32 Failure_Indicator_Counter;
    258          
    259                  //! A count of the number of accelerometer points that have been successfully read since reset.
    260                  uint32 XYZ_Point_Counter;
    261          
    262                  //! A count that measures time in increments of 250 microseconds.
    263                  //! It can measure up to about 12.4 days then it will restart at 0.
    264                  //! It can be used to verify that the slot is running correctly.
    265                  uint32 Reference_Counter;
    266              #endif
    267          
    268              //! The array of points that have been read from the Accelerometer.
