    250          
    251          //---------------------------------------------------------------------------------------------------------------------
    252          /**
    253           *  @brief      Process DoorLockWaxPilot instance.
    254           *
    255           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    256           *
    257           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot instance process.
    258           *  @retval     PASS - Instance process succeeded.
    259           *  @retval     FAIL - Instance process failed.
    260           */
    261          PASS_FAIL_TYPE SRDoorLockWaxPilot__Process(HBL_LOAD_TYPE * load)
    262          {
    263              SRDOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    264          	SRDOORLOCKWAXPILOT_DATA_TYPE *ptr;
    265          	SRDOORLOCKWAXPILOT_DATA_TYPE *n_ptr;
    266          	HBL_LOAD_STATUS_TYPE tmp_load;
    267          	PASS_FAIL_TYPE retval = FAIL;
    268          	uint8 index = load->Pilot_Data_Index;
    269          
    270              if (CheckItem(index))
    271              {
    272              	ptr = &SRDoorLockWaxPilot_Data[index];
    273              	n_ptr = &N_SRDoorLockWaxPilot_Data[index];
    274          
    275              	if (ptr->Requested != ptr->Processed)
    276              	{
    277                  	param_ptr = (SRDOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    278          
    279              		if (ptr->Requested == 0)
    280              		{
    281              			switch (ptr->Status)
    282              			{
    283              			case SRDOORLOCKWAX_STATUS_DOOR_LOCKED:
    284              			case SRDOORLOCKWAX_STATUS_DOOR_LOCKING:
    285              	    		tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    286              	    		tmp_load.Load.Cur_Reg = ptr->Processed;
    287              	    		SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    288              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    289              				SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, ENDIANS16_STON(param_ptr->Unlock_Timeout));
    290              		    	SRData__UpdateByte(&ptr->Wait_Trigger, &n_ptr->Wait_Trigger, 1);
    291              				break;
    292          
    293              			default:
    294              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_INIT); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    295              				SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, param_ptr->Filter_Time);
    296              				break;
    297              			}
    298              		}
    299              		else
    300          			{
    301          				switch (SRDoorLockWaxPilot_Data[index].Status)
    302          				{
    303          				case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    304          				case SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING:
    305              	    		tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    306              	    		tmp_load.Load.Cur_Reg = ptr->Processed;
    307              	    		SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    308              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_DOOR_LOCKING); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    309              				SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, ENDIANS16_STON(param_ptr->Unlock_Timeout));
    310              		    	SRData__UpdateByte(&ptr->Wait_Trigger, &n_ptr->Wait_Trigger, 1);
    311          					break;
    312          
    313          				default:
    314              		    	SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8)SRDOORLOCKWAX_STATUS_INIT); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    315              				SRData__UpdateShort(&ptr->Counter, &n_ptr->Counter, param_ptr->Filter_Time);
    316          					break;
    317          				}
    318          			}
    319              	}
    320          
    321              	SRData__UpdateByte(&ptr->Processed, &n_ptr->Processed, ptr->Requested);
    322              }
    323          
    324          	return(retval);
    325          }
