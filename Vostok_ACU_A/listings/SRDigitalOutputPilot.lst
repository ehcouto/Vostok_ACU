    295          //=====================================================================================================================
    296          //  --- Private Functions ---------------------------------------------------------------------------------------------
    297          //=====================================================================================================================
    298          
    299          
    300          //---------------------------------------------------------------------------------------------------------------------
    301          /**
    302           * Update the output pin based on the requested value.
    303           * Before updating, the function checks that related RAM is consistent.
    304           * Before updating, the function checks that no other function changed the output pin.
    305           * @param load = Data structure for the Pilot.
    306           * @param requested = The requested output value.
    307           * @return PASS if there were no problems updating the output pin; otherwise FAIL.
    308           */
    309          static void DoPinUpdate(HBL_LOAD_TYPE* load, GPIO_PORT_TYPE port, uint8 pin)
    310          {
    311              // Verify RAM integrity.
    312              uint8 pilot_index = load->Pilot_Data_Index;
    313              SR_CHECK_BYTE(Digital_Output.Data[pilot_index].Processed);
    314          
    315              // Set the new value for the pin.
    316              uint8 new_pin_value = Digital_Output.Data[pilot_index].Processed;
    317              new_pin_value ^= ~load->Hi_Low_Activation_Bitmap;
    318              new_pin_value &= 1;
    319          
    320              Gpio__PinWrite(port, pin, (BOOL_TYPE)new_pin_value);
    321              SR_SET_BYTE(Digital_Output.Data[pilot_index].Last_Pin_Value, new_pin_value);
    322          }
    323          
