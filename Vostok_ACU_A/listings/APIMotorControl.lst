    633          #ifndef API220_FVT_ONLY
    634          //---------------------------------------------------------------------------------------------------------------------
    635          /*
    636           * @brief       Set a new target speed and invoke the Mci run command.
    637           * @param       buffer - a pointer to the received Reveal buffer.
    638           * @return      Returns whether Mci has accepted or not the command; TRUE = accepted; FALSE = denied
    639           */
    640          uint8 Run_Motor(REVEAL_MSG_TYPE *buffer)
    641          {
    642          #ifdef API220_ENABLE_MCI_CALLS
    643          
    644              uint8 ret_val;
    645              MOTOR_ENUM_TYPE motor_index;
    646              sint16 target_speed;
    647              sint16 target_accel;
    648              #ifndef ENABLE_API220_CALLBACKS
    649                  MCI_CMD_RESPONSE_TYPE feedback;
    650                  REVEAL_COMMAND_TYPE *command;
    651              #endif
    652          
    653              ret_val = FALSE;                                // Default answer is FALSE
    654          
    655              if(buffer->sdu_length == 7)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
    656              {
    657                  // custom code
    658                  API220_MCI_RUN_CALLBACK();
    659          
    660                  // Build up the data from the Reveal buffer
    661                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
    662                  target_speed = ((sint16)(buffer->payload[1])<<8) + buffer->payload[2];
    663                  target_accel = ((sint16)(buffer->payload[3])<<8) + buffer->payload[4];
    664          
    665                  #ifdef ENABLE_API220_CALLBACKS
    666          
    667                      // Invoke Mci
    668                      Mci__Run(motor_index, target_speed, target_accel);
    669          
    670                      ret_val = TRUE;
    671          
    672                  #else
    673          
    674                      // Invoke Mci run and read its feedback
    675                      feedback = Mci__Run(motor_index, target_speed, target_accel);
    676          
    677                      command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_RUN, REVEAL_BROADCAST_NODE, 6);
    678                      if(command != NULL)
    679                      {
    680                          // Build and enqueue the Reveal buffer with the required feedback
    681                          Reveal__AddDataU8(command, motor_index);
    682                          Reveal__AddDataU16(command, target_speed);
    683                          Reveal__AddDataU16(command, target_accel);
    684                          Reveal__AddDataU8(command, (uint8)feedback);
    685          
    686                          ret_val = Reveal__QueueCommand(command);
    687                      }
    688          
    689                  #endif
    690          
    691                  // Set the last commands to internal variables.
    692                  Last_Speed_Target[motor_index] = target_speed;
    693                  Last_Ramp_Target[motor_index] = target_accel;
    694              }
    695          
    696              return(ret_val);
    697          
    698          #else
    699          
    700              return(FALSE);
    701          
    702          #endif
    703          }
