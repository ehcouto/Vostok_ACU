    291          /**
    292           * This method parses API013 commands sent to a broadcast or exclusively to this node.
    293           * @param cmd = Pointer to the received command or feedback message.
    294           * @return REVEAL_RECIPE_STATUS_TYPE that expresses the result of the parsing.
    295           */

   \                                 In section .text, align 2, keep-with-next
    296          REVEAL_RECIPE_STATUS_TYPE API013RemoteFunction__CommandParser(REVEAL_MSG_TYPE* cmd)
    297          {
    298              #if (API013_SERVER_FEATURE == ENABLED)
    299                  // React to the command message by OpCode.
    300                  REVEAL_RECIPE_STATUS_TYPE reveal_response = NVO_RS_UNSUP_INVALID_PARAM;
    301          
    302                  switch ((API013_OPCODE_TYPE)cmd->op_code)
    303                  {
    304                      case API013_CMD_SEND_FUNCTION_CONTROL:
    305                          // Expected Payload:
    306                          //  Byte 0 = Server-side remote function id
    307                          //  Byte 1 = Control command code (0 = Disable, 1 = Enable, 2+ = function-specific command)
    308                          //  Byte 2+ = Command-specific parameters
    309                          if (cmd->size >= 2U)
    310                          {
    311                              REMOTE_FUNCTION_CONTROL_RESPONSE_TYPE control_response = RemoteFunctionDoControl(cmd->payload[0], cmd->payload[1], &(cmd->payload[2]), (cmd->size - 2U));
    312                              if ((control_response == REMOTE_FUNCTION_CONTROL_RESPONSE_INACTIVE) ||
    313                                  (control_response == REMOTE_FUNCTION_CONTROL_RESPONSE_ACTIVE))
    314                              {
    315                                  Api013.Data_Receiver_Node = cmd->node_id;
    316                                  reveal_response = NVO_RS_READY;
    317                              }
    318                          }
    319                          break;
    320          
    321                      case API013_CMD_REQUEST_FUNCTION_STATUS:
    322                          // Expected Payload:
    323                          //  Byte 0 = Server-side remote function id
    324                          if (cmd->size >= 1U)
    325                          {
    326                              uint8 server_function_id = cmd->payload[0];
    327                              uint8* status;
    328                              uint8 status_size;
    329                              if (RemoteFunctionGetStatus(server_function_id, &status, &status_size) != FALSE)
    330                              {
    331                                  if (PublishRemoteFunctionStatus(cmd->node_id, server_function_id, status, status_size) != FALSE)
    332                                  {
    333                                      Api013.Data_Receiver_Node = cmd->node_id;
    334                                      reveal_response = NVO_RS_READY;
    335                                  }
    336                              }
    337                          }
    338                          break;
    339          
    340                      case API013_CMD_SET_PUBLICATION_PERIOD:
    341                          // Expected Payload:
    342                          //  Byte 0-1 = Big-endian millisecond period
    343                          if (cmd->size >= 2U)
    344                          {
    345                              uint16 milliseconds = Utilities__ConvertArrayTo16bits(cmd->payload);
    346                              if (SetPublicationPeriod(milliseconds) != FALSE)
    347                              {
    348                                  Api013.Data_Receiver_Node = cmd->node_id;
    349                                  reveal_response = NVO_RS_READY;
    350                              }
    351                          }
    352                          break;
    353          
    354                      default:
    355                          reveal_response = NVO_RS_UNSUP_OP_CODE;
    356                          break;
    357                  }
    358          
    359                  return reveal_response;
    360              #else       // #if (API013_SERVER_FEATURE == ENABLED)
    361                  return NVO_RS_UNSUP_OP_CODE;
   \                     API013RemoteFunction__CommandParser: (+1)
   \   00000000   0x2005             MOVS     R0,#+5
   \   00000002   0x4770             BX       LR               ;; return
    362              #endif      // #if (API013_SERVER_FEATURE == ENABLED)
    363          }
