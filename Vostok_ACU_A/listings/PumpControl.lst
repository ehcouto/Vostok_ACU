    136          //! The maximum number of times that the PumpControl process can be used in the same step.
    137          #ifndef PUMP_CONTROL_MAX_INSTANCES
    138              //! Set this value to the maximum number of instances of the PumpControl process that can be
    139              //! executed in a single step of a cycle.
    140              //! For example, "2" means that the same step can use two instances of the PumpControl process.
    141              //! One instance could control a load with hysteresis while the other turned loads on.
    142              #define PUMP_CONTROL_MAX_INSTANCES 2
    143          #endif
