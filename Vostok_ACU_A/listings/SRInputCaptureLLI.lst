    108          /**
    109           * @brief      It Initializes the module DigitalLowLevel and its variables
    110           */
    111          void SRInputCaptureLLI__Initialize(void)
    112          {
    113              SRData__Fill(SRInputCaptureLLI_Data, N_SRInputCaptureLLI_Data, 0, sizeof(SRInputCaptureLLI_Data));
    114              SRData__UpdateByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation, 0);
    115          
    116          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    117              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRINPUTCAPTURE_LLI);
    118          #endif
    119          }
