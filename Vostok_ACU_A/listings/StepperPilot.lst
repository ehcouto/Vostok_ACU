    221          
    222              requested = NULL;
    223          
    224              if (load->Load_Data_Index < Stepper_Pilot_Allocation)
    225              {
    226                  requested = &(Stepper_Pilot_Data[load->Pilot_Data_Index].Requested);
    227              }
    228          
    229              return (requested);
    230          }
