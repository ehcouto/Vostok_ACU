   1012          //---------------------------------------------------------------------------------------------------------------------
   1013          /**
   1014           * Determine if the application buffer is full.
   1015           */
   1016          static void CheckAppBuffer(void)
   1017          {
   1018              if (Fxls8974.Mode_Processed != Fxls8974.Mode_Requested)
   1019              {
   1020                  EventDisable();
   1021              }
   1022              else if (Fxls8974.Number_Of_Points < FXLS8974_MAX_POINTS)
   1023              {
   1024                  EventBufferHasSpace();
   1025              }
   1026          }
