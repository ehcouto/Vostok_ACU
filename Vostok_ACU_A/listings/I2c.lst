   1381          
   1382                          if (I2c1_RxPointer > I2C1_BUFFER_IN_SIZE)
   1383                          {
   1384                              I2C_1.CR2 |= I2C_CR2_NACK;
   1385                          }
   1386                      }
   1387          
   1388          
   1389                      if ((I2C_1.ISR & I2C_ISR_TXIS) != FALSE)
   1390                      {
   1391                          I2C_1.TXDR = I2c1_Buffer_Out[I2c1_TxPointer];
