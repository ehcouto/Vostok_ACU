    980          /**
    981           * Send a command to the accelerometer to read a single XYZ data point.
    982           */
    983          static void AccelReadOneShot(void)
    984          {
    985          #if (SPI_ENABLED == 1)
    986              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
    987              (void)Spi__Write((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, (void*)ACCEL_CMD_READ, sizeof(ACCEL_CMD_READ));
    988          #else
    989              I2c__WriteThenRead((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port,
    990                                 (void*)ACCEL_CMD_READ, sizeof(ACCEL_CMD_READ),
    991                                 sizeof(ACCEL_READ_REGISTERS_TYPE));
    992          #endif
    993          }
