     40          // -- Compile Options --
     41          
     42          #ifndef EQUATION_MAX_MAP_DIMENSIONS
     43              //! The maximum number of dimensions supported in look-up tables.
     44              //! Set this value to 0 to disable ELEMENT_MAP in equations.
     45              //!     0 = Look-up tables (ELEMENT_MAP) not supported
     46              //!     2 = Support 1-D and 2-D look-up tables
     47              //!     5 = Support 1-D, 2-D, 3-D, 4-D, and 5-D look-up tables
     48              //! Example: A 3-D look-up table solves Y = f(x1, x2, x3)
     49              #define EQUATION_MAX_MAP_DIMENSIONS 2
     50          #endif
     51          CT_ASSERT((0 <= EQUATION_MAX_MAP_DIMENSIONS) && (EQUATION_MAX_MAP_DIMENSIONS <= 10));
     52          
     53          #ifndef EQUATION_STACK_SIZE
     54              //! The number of values that can be pushed onto the stack.
     55              //! Memory allocated = 4 * EQUATION_STACK_SIZE
     56              #define EQUATION_STACK_SIZE 6
     57          #endif
     58          
     59          
     60          // -- Private Constant Declarations --
     61          
     62          //! Reuse the invalid data type as a equation displacement data type
     63          #define DATATYPE_DISPLACEMENT DATATYPE_INVALID
     64          
     65          // The List_Displacements[] array in the SF_LOOK_UP_TABLE_TYPE structure includes:
     66          //      A 2-byte displacement for each dimension
     67          //      A 2-byte displacement for the output
     68          //      A 4-bit method for each dimension
     69          #define DISPLACEMENTS_ARRAY_SIZE (EQUATION_MAX_MAP_DIMENSIONS + 1 + (EQUATION_MAX_MAP_DIMENSIONS + 3) / 4)
     70          
     71          //! Interpolation index precision (1 / INDEX_SCALE)
     72          #define INDEX_SCALE 256
     73          
     74          //! The maximum number of input elements allowed in an Xn Values List
     75          #define MAX_INPUT_LIST_ELEMENTS 255u
     76          
     77          //! The maximum number of output elements allowed in the Y Values List
     78          #define MAX_OUTPUT_LIST_ELEMENTS 4095u
     79          
     80          //! The maximum size of the data for the output list values (in bytes)
     81          #define MAX_OUTPUT_LIST_SIZE (sizeof(sint32) * MAX_OUTPUT_LIST_ELEMENTS)
     82          
     83          //! The name of this module for use by the Log module.
     84          #define MODULE_NAME MODULE_EQUATION
     85          
