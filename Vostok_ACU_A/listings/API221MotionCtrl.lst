    405          //---------------------------------------------------------------------------------------------------------------------
    406          /**
    407           * Initialize the API221MotionCtrl module variables.
    408           */
    409          void API221MotionCtrl__Initialize(void)
    410          {
    411              if (Micro__GetResetMode() == MICRO_RESET_MODE_COLD)
    412              {
    413                  memset(&Api221, 0, sizeof(Api221));
    414          
    415                  #if (API221_CLIENT_FEATURE == ENABLED)
    416                      Callback__Initialize(&Api221_Callback);
    417                      memset(&Api221.Data, UCHAR_MAX, sizeof(Api221.Data));
    418                  #endif
    419              }
    420          }
    421          
    422          //---------------------------------------------------------------------------------------------------------------------
    423          /**
    424           * Periodically publish analog inputs that were requested.
    425           */
    426          void API221MotionCtrl__Background(void)
    427          {
    428              #if ((API221_CLIENT_FEATURE == ENABLED) && (KEEP_RUNNING_TIMER > 0))
    429                  SendKeepRunningMessages();
    430              #endif
    431          
    432              #if (API221_SERVER_FEATURE == ENABLED)
    433                  // Iterate through the server motors
    434                  for (uint8 server_motor = 0; server_motor < API221_SERVER_MOTOR_COUNT; server_motor++)
    435                  {
    436                      #if (TIMEOUT_TO_STOP > 0)
    437                          AutoStopCheck(server_motor);
    438                      #endif
    439                      #ifdef API221_READ_FAILURE_FLAGS
    440                          CheckForRemovedFailureFlags(server_motor);
    441                      #endif
    442          
    443                      CheckForMotorStatusChangeEvents(server_motor);
    444                  }
    445          
    446                  #ifdef API221_READ_ANALOG_DATA
    447                      CheckIfTimeToPublishPeriodicData();
    448                  #endif
    449              #endif      // #if (API221_SERVER_FEATURE == ENABLED)
    450          }
    451          
    452          //---------------------------------------------------------------------------------------------------------------------
    453          /**
    454           * This method parses API221 commands sent to a broadcast or exclusively to this node.
    455           * @param cmd = Pointer to the received command message.
    456           * @return REVEAL_RECIPE_STATUS_TYPE that expresses the result of the parsing.
    457           */
    458          REVEAL_RECIPE_STATUS_TYPE API221MotionCtrl__CommandParser(REVEAL_MSG_TYPE* cmd)
    459          {
    460              // Assume that the message will be incorrectly formatted.
    461              REVEAL_RECIPE_STATUS_TYPE reveal_response = NVO_RS_UNSUP_INVALID_PARAM;
    462          
    463              #if (API221_SERVER_FEATURE == ENABLED)
    464                  // Assume that the first byte of the payload identifies the motor and evaluate it once for all
    465                  // OpCodes that use it.
    466                  uint8 server_motor = cmd->payload[0];
    467              #endif
    468          
    469              // Parse the command based on the OpCode.
    470              switch (cmd->op_code)
    471              {
    472          #if (API221_SERVER_FEATURE == ENABLED)
    473              #ifdef API221_READ_FAILURE_FLAGS
    474                  case API221_CMD_REQUEST_FAILURE_FLAGS:
    475                      // Expected Payload:
    476                      //      One byte for the server motor index
    477                      if ((cmd->size >= 1) && (server_motor < API221_SERVER_MOTOR_COUNT))
    478                      {
    479                          reveal_response = PublishFailureFlags(cmd->node_id, server_motor);
    480                      }
    481                      break;
    482              #endif      // #ifdef API221_READ_FAILURE_FLAGS
    483          
    484              #ifdef API221_CLEAR_FAILURES
    485                  case API221_CMD_CLEAR_FAILURE_FLAGS:
    486                      // Expected Payload:
    487                      //      One byte for the server motor index
    488                      if ((cmd->size >= 1) && (server_motor < API221_SERVER_MOTOR_COUNT))
    489                      {
    490                          API221_CLEAR_FAILURES(server_motor);
    491                          reveal_response = NVO_RS_READY;
    492                      }
    493                      break;
    494              #endif      // #ifdef API221_CLEAR_FAILURES
    495          
    496                  case API221_CMD_KEEP_RUNNING:
    497                      // Expected Payload:
    498                      //      One byte for the server motor index
    499                      if ((cmd->size >= 1) && (server_motor < API221_SERVER_MOTOR_COUNT))
    500                      {
    501                          if (BIT_TEST(Api221.Status_Flags[server_motor], API221_STS_IS_MOTOR_STOPPED))
    502                          {
    503                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    504                          }
    505                          else
    506                          {
    507                              // Restart the timeout to stop the motor.
    508                              #if (TIMEOUT_TO_STOP > 0)
    509                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    510                              #endif
    511                              reveal_response = NVO_RS_READY;
    512                          }
    513                      }
    514                      break;
    515          
    516                  case API221_CMD_STOP:
    517                      // Expected Payload:
    518                      //      One byte for the server motor index
    519                      //      Two big-endian bytes for the deceleration rate
    520                      if ((cmd->size >= 3) && (server_motor < API221_SERVER_MOTOR_COUNT))
    521                      {
    522                          uint16 deceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[1]);
    523                          if (API221_DEVICE_STOP(server_motor, deceleration) == TRUE)
    524                          {
    525                              // Disable the timeout-based stopping since a stop command was accepted.
    526                              #if (TIMEOUT_TO_STOP > 0)
    527                                  Api221.Stop_Timeout[server_motor] = 0;
    528                              #endif
    529                              reveal_response = NVO_RS_READY;
    530                          }
    531                          else
    532                          {
    533                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    534                          }
    535                      }
    536                      break;
    537          
    538                  case API221_CMD_RUN:
    539                      // Expected Payload:
    540                      //      One byte for the server motor index
    541                      //      Two big-endian bytes for the velocity
    542                      //      Two big-endian bytes for the acceleration
    543                      if ((cmd->size >= 5) && (server_motor < API221_SERVER_MOTOR_COUNT))
    544                      {
    545                          sint16 velocity = (sint16)Utilities__ConvertArrayTo16bits(&cmd->payload[1]);
    546                          uint16 acceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[3]);
    547                          if (API221_DEVICE_RUN(server_motor, velocity, acceleration) == TRUE)
    548                          {
    549                              // Enable the timeout-based stopping since a command was accepted.
    550                              #if (TIMEOUT_TO_STOP > 0)
    551                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    552                              #endif
    553                              reveal_response = NVO_RS_READY;
    554                          }
    555                          else
    556                          {
    557                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    558                          }
    559                      }
    560                      break;
    561          
    562              #ifdef API221_DEVICE_MOTION
    563                  case API221_CMD_SET_MOTION_BEHAVIOR:
    564                      // Expected Payload:
    565                      //      One byte for the server motor index
    566                      //      One or more parameter bytes to describe the requested motion behavior.
    567                      if ((cmd->size >= 2) && (server_motor < API221_SERVER_MOTOR_COUNT))
    568                      {
    569                          if (API221_DEVICE_MOTION(server_motor, &cmd->payload[1], cmd->size - 1) == TRUE)
    570                          {
    571                              // Enable the timeout-based stopping since a command was accepted.
    572                              #if (TIMEOUT_TO_STOP > 0)
    573                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    574                              #endif
    575                              reveal_response = NVO_RS_READY;
    576                          }
    577                          else
    578                          {
    579                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    580                          }
    581                      }
    582                      break;
    583              #endif      // #ifdef API221_DEVICE_MOTION
    584          
    585                  case API221_CMD_REQUEST_MOTOR_STATUS:
    586                      // Expected Payload:
    587                      //      One byte for the server motor index
    588                      if ((cmd->size >= 1) && (server_motor < API221_SERVER_MOTOR_COUNT))
    589                      {
    590                          if (PublishMotorStatus(cmd->node_id, server_motor) == TRUE)
    591                          {
    592                              reveal_response = NVO_RS_READY;
    593                          }
    594                          else
    595                          {
    596                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    597                          }
    598                      }
    599                      break;
    600          
    601              #ifdef API221_READ_ANALOG_DATA
    602                  case API221_CMD_REQUEST_ANALOG_DATA:
    603                      // Expected Payload:
    604                      //      One byte for the server motor index
    605                      //      One byte for the analog channel
    606                      if ((cmd->size >= 2) &&
    607                          (server_motor < API221_SERVER_MOTOR_COUNT) &&
    608                          (cmd->payload[1] < 32))
    609                      {
    610                          uint8 channel = cmd->payload[1];
    611                          if (PublishAnalogData(cmd->node_id, server_motor, channel) == TRUE)
    612                          {
    613                              reveal_response = NVO_RS_READY;
    614                          }
    615                          else
    616                          {
    617                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    618                          }
    619                      }
    620                      break;
    621          
    622                  case API221_CMD_SET_DATA_PUBLICATION_PERIOD:
    623                      // Expected Payload:
    624                      //      Two big-endian bytes with the publication period.
    625                      if (cmd->size >= 2)
    626                      {
    627                          if (SetPublicationPeriod(cmd->node_id, Utilities__ConvertArrayTo16bits(&cmd->payload[0])) == TRUE)
    628                          {
    629                              reveal_response = NVO_RS_READY;
    630                          }
    631                      }
    632                      break;
    633          
    634                  case API221_CMD_ADD_PERIODIC_DATA_CHANNELS:
    635                  case API221_CMD_REMOVE_PERIODIC_DATA_CHANNELS:
    636                      // Expected Payload:
    637                      //      One byte for the server motor index
    638                      //      Four big-endian bytes of bits for a combination of up to 32 analog channels.
    639                      if ((cmd->size >= 5) && (server_motor < API221_SERVER_MOTOR_COUNT))
    640                      {
    641                          BOOL_TYPE add = (BOOL_TYPE)(cmd->op_code == API221_CMD_ADD_PERIODIC_DATA_CHANNELS);
    642                          uint32 channels_bitmap = Utilities__ConvertArrayTo32bits(&cmd->payload[1]);
    643                          UpdatePeriodicDataChannels(add, server_motor, channels_bitmap);
    644                          reveal_response = NVO_RS_READY;
    645                      }
    646                      break;
    647          
    648                  case API221_CMD_REQUEST_PERIODIC_DATA_STATUS:
    649                      // Expected No Payload
    650                      if (PublishPeriodicDataStatus(cmd->node_id) == TRUE)
    651                      {
    652                          reveal_response = NVO_RS_READY;
    653                      }
    654                      else
    655                      {
    656                          reveal_response = NVO_RS_REJECTED;
    657                      }
    658                      break;
    659              #endif      // #ifdef API221_READ_ANALOG_DATA
    660          
    661              #ifdef API221_DEVICE_WASH
    662                  case API221_CMD_WASH:
    663                      // Expected Payload:
    664                      //      One byte for the server motor index
    665                      //      Two big-endian bytes for the on time
    666                      //      Two big-endian bytes for the off time
    667                      //      Two big-endian bytes for the velocity
    668                      //      Two big-endian bytes for the acceleration
    669                      //      Two big-endian bytes for the deceleration
    670                      if ((cmd->size >= 11) && (server_motor < API221_SERVER_MOTOR_COUNT))
    671                      {
    672                          EMP_WASH_PARAM_TYPE wash;
    673                          wash.On_Time = Utilities__ConvertArrayTo16bits(&cmd->payload[1]);
    674                          wash.Off_Time = Utilities__ConvertArrayTo16bits(&cmd->payload[3]);
    675                          wash.Velocity = (sint16)Utilities__ConvertArrayTo16bits(&cmd->payload[5]);
    676                          wash.Acceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[7]);
    677                          wash.Deceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[9]);
    678                          if (API221_DEVICE_WASH(server_motor, &wash) == TRUE)
    679                          {
    680                              // Enable the timeout-based stopping since a command was accepted.
    681                              #if (TIMEOUT_TO_STOP > 0)
    682                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    683                              #endif
    684                              reveal_response = NVO_RS_READY;
    685                          }
    686                          else
    687                          {
    688                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    689                          }
    690                      }
    691                      break;
    692              #endif      // #ifdef API221_DEVICE_WASH
    693          
    694              #ifdef API221_DEVICE_ROTATE
    695                  case API221_CMD_ROTATE_X_DEGREES:
    696                      // Expected Payload:
    697                      //      One byte for the server motor index
    698                      //      Two big-endian bytes for the angular distance to rotate (in degrees)
    699                      //      Two big-endian bytes for the velocity
    700                      //      Two big-endian bytes for the acceleration
    701                      if ((cmd->size >= 7) && (server_motor < API221_SERVER_MOTOR_COUNT))
    702                      {
    703                          EMP_ROTATE_PARAM_TYPE rotate;
    704                          rotate.Degrees = (sint16)Utilities__ConvertArrayTo16bits(&cmd->payload[1]);
    705                          rotate.Velocity = (sint16)Utilities__ConvertArrayTo16bits(&cmd->payload[3]);
    706                          rotate.Acceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[5]);
    707                          if (API221_DEVICE_ROTATE(server_motor, &rotate) == TRUE)
    708                          {
    709                              // Enable the timeout-based stopping since a command was accepted.
    710                              #if (TIMEOUT_TO_STOP > 0)
    711                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    712                              #endif
    713                              reveal_response = NVO_RS_READY;
    714                          }
    715                          else
    716                          {
    717                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    718                          }
    719                      }
    720                      break;
    721              #endif      // #ifdef API221_DEVICE_ROTATE
    722          
    723              #ifdef API221_DEVICE_PULSE
    724                  case API221_CMD_PULSE_IMMEDIATE:
    725                  case API221_CMD_PULSE_MODIFY:
    726                  case API221_CMD_PULSE_QUEUE:
    727                      // Expected Payload:
    728                      //      One byte for the server motor index
    729                      //      Two big-endian bytes for the on time
    730                      //      Two big-endian bytes for the off time
    731                      //      Two big-endian bytes for the velocity
    732                      //      Two big-endian bytes for the acceleration
    733                      //      Two big-endian bytes for the deceleration
    734                      if ((cmd->size >= 11) && (server_motor < API221_SERVER_MOTOR_COUNT))
    735                      {
    736                          uint8 command = (EXTERNAL_MOTOR_PULSE_IMMEDIATE + cmd->op_code - API221_CMD_PULSE_IMMEDIATE);
    737                          EMP_PULSE_PARAM_TYPE pulse;
    738                          pulse.On_Time = Utilities__ConvertArrayTo16bits(&cmd->payload[1]);
    739                          pulse.Off_Time = Utilities__ConvertArrayTo16bits(&cmd->payload[3]);
    740                          pulse.Velocity = (sint16)Utilities__ConvertArrayTo16bits(&cmd->payload[5]);
    741                          pulse.Acceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[7]);
    742                          pulse.Deceleration = Utilities__ConvertArrayTo16bits(&cmd->payload[9]);
    743                          if (API221_DEVICE_PULSE(server_motor, (EXTERNAL_MOTOR_SIMPLE_COMMAND_TYPE)command, &pulse) == TRUE)
    744                          {
    745                              // Enable the timeout-based stopping since a command was accepted.
    746                              #if (TIMEOUT_TO_STOP > 0)
    747                                  Api221.Stop_Timeout[server_motor] = TIMEOUT_TO_STOP;
    748                              #endif
    749                              reveal_response = NVO_RS_READY;
    750                          }
    751                          else
    752                          {
    753                              reveal_response = NVO_RS_UNSUP_UNAVAILABLE;
    754                          }
    755                      }
    756                      break;
    757              #endif      // #ifdef API221_DEVICE_PULSE
    758          
    759          #endif      // #if (API221_SERVER_FEATURE == ENABLED)
    760                  default:
    761                      reveal_response = NVO_RS_UNSUP_OP_CODE;
    762                      break;
    763              }
    764          
    765              return reveal_response;
    766          }
    767          
    768          //---------------------------------------------------------------------------------------------------------------------
    769          /**
    770           * This method parses API221 feedbacks sent to a broadcast or exclusively to this node.
    771           * @param fbk = Pointer to the received feedback message.
    772           */
    773          void API221MotionCtrl__FeedbackParser(REVEAL_MSG_TYPE* fbk)
    774          {
    775              // Parse the command based on the OpCode.
    776              switch (fbk->op_code)
    777              {
    778          #if (API221_CLIENT_FEATURE == ENABLED)
    779                  case API221_FBK_PUBLISH_EVENT:
    780                      // Expected Payload:
    781                      //      One byte for the server motor index (0-3)
    782                      //      One byte for event code (0-63)
    783                      if (fbk->size >= 2)
    784                      {
    785                          PostEvent(fbk->node_id, fbk->payload[0], (API221_MOTOR_EVENT_TYPE)fbk->payload[1]);
    786                      }
    787                      break;
    788          
    789              #if (API221_STORED_ANALOG_INPUTS > 0)
    790                  case API221_FBK_PUBLISH_ANALOG_DATA:
    791                  case API221_FBK_PUBLISH_PERIODIC_DATA:
    792                      // Expected Payload:
    793                      //      6 Bytes for each analog value:
    794                      //          One byte for the server motor index
    795                      //          One byte for analog data channel
    796                      //          Four little-endian bytes for signed data
    797                      if (fbk->size >= SIZE_OF_ANALOG_DATA_PAYLOAD)
    798                      {
    799                          uint8* payload = fbk->payload;
    800                          for (uint8 index = 0; index < fbk->size; index += SIZE_OF_ANALOG_DATA_PAYLOAD)
    801                          {
    802                              API221_CLIENT_MOTOR_INDEX_TYPE client_motor = ConvertServerMotorIndexToClientMotorIndex(fbk->node_id, payload[index]);
    803                              uint8 channel = payload[index + 1];
    804                              if ((client_motor < API221_SYSTEM_MOTOR_COUNT) && (channel < MAX_CHANNELS_PER_MOTOR))
    805                              {
    806                                  sint32 value = *((PACKED sint32*)(void*)&payload[index + 2]);
    807                                  StoreAnalogInput(client_motor, channel, value);
    808                              }
    809                          }
    810                      }
    811                      break;
    812              #endif      // #if (API221_STORED_ANALOG_INPUTS > 0)
    813          
    814                  case API221_FBK_PUBLISH_FAILURE_FLAGS:
    815                      // Expected Payload:
    816                      //      One byte for the server motor index
    817                      //      Four big-endian bytes for bitmap of failure flags
    818                      if (fbk->size >= 5)
    819                      {
    820                          API221_CLIENT_MOTOR_INDEX_TYPE client_motor = ConvertServerMotorIndexToClientMotorIndex(fbk->node_id, fbk->payload[0]);
    821                          if (client_motor < API221_SYSTEM_MOTOR_COUNT)
    822                          {
    823                              uint32 failure_flags = Utilities__ConvertArrayTo32bits(&fbk->payload[1]);
    824                              API221_FAILURES_HANDLER_TYPE* handlers = Api221.Failures_Handler[client_motor];
    825                              for (uint8 handler_index = 0; handler_index < API221_MAX_FAILURE_EVENT_HANDLERS; handler_index++)
    826                              {
    827                                  if (handlers[handler_index] == NULL)
    828                                  {
    829                                      // There are no more handlers for the failure flags.
    830                                      break;                  // Break out of the for() loop.
    831                                  }
    832                                  handlers[handler_index](client_motor, failure_flags);
    833                                  handlers[handler_index] = NULL;
    834                              }
    835                          }
    836                      }
    837                      break;
    838          
    839                  case API221_FBK_PUBLISH_MOTOR_STATUS:
    840                      // Expected Payload:
    841                      //      One byte for the server motor index
    842                      //      One byte for the motor status
    843                      if (fbk->size >= 2)
    844                      {
    845                          API221_CLIENT_MOTOR_INDEX_TYPE client_motor = ConvertServerMotorIndexToClientMotorIndex(fbk->node_id, fbk->payload[0]);
    846                          if (client_motor < API221_SYSTEM_MOTOR_COUNT)
    847                          {
    848                              uint8 status_flags = fbk->payload[1];
    849                              API221_MOTOR_STATUS_HANDLER_TYPE* handlers = Api221.Motor_Status_Handler[client_motor];
    850                              for (uint8 handler_index = 0; handler_index < API221_MAX_STATUS_EVENT_HANDLERS; handler_index++)
    851                              {
    852                                  if (handlers[handler_index] == NULL)
    853                                  {
    854                                      // There are no more handlers for the motor status.
    855                                      break;                  // Break out of the for() loop.
    856                                  }
    857                                  handlers[handler_index](client_motor, status_flags);
    858                                  handlers[handler_index] = NULL;
    859                              }
    860                          }
    861                      }
    862                      break;
    863          
    864                  case API221_FBK_PUBLISH_PERIODIC_DATA_STATUS:
    865                      // Expected Payload:
    866                      //      Two big-endian bytes for publication period in milliseconds
    867                      //      Four big-endian bytes for each motor's channel bitmap
    868                      if ((fbk->size >= 6) && (Api221.Periodic_Data_Status_Handler != NULL))
    869                      {
    870                          uint16 millisecond_period = Utilities__ConvertArrayTo16bits(fbk->payload);
    871                          uint8 num_of_motors = (fbk->size - sizeof(millisecond_period)) / sizeof(uint32);
    872                          uint32* channels_bitmaps = (uint32*)(void*)&fbk->payload[sizeof(millisecond_period)];
    873                          for (uint8 m = 0; m < num_of_motors; m++)
    874                          {
    875                              channels_bitmaps[m] = Utilities__ConvertArrayTo32bits((uint8*)(void*)&channels_bitmaps[m]);
    876                          }
    877                          Api221.Periodic_Data_Status_Handler(millisecond_period, channels_bitmaps, num_of_motors);
    878                          Api221.Periodic_Data_Status_Handler = NULL;
    879                      }
    880                      break;
    881          #endif      // #if (API221_CLIENT_FEATURE == ENABLED)
    882          
    883                  default:
    884                      LOG_ADD_EXCEPTION(FEEDBACK_OPCODE_NOT_SUPPORTED, fbk->op_code);
    885                      break;
    886              }
    887          }
    888          
    889          
    890          //=====================================================================================================================
    891          //  --- Public Functions (Client Only) --------------------------------------------------------------------------------
    892          //=====================================================================================================================
    893          
    894          
    895          #if (API221_CLIENT_FEATURE == ENABLED)
    896          //---------------------------------------------------------------------------------------------------------------------
    897          /**
    898           * Add analog data channels from the periodically published data.
    899           * @param client_motor = The value used to uniquely identify the system device on the client.
    900           * @param channels_bitmap = The analog input channels to add to the request for periodic data.
    901           *                          Each bit represents an analog data channel.
    902           * @return TRUE if the request was sent. Otherwise, FALSE.
    903           */
    904          BOOL_TYPE API221MotionCtrl__AddPeriodicDataChannels(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint32 channels_bitmap)
    905          {
    906              if (client_motor >= API221_SYSTEM_MOTOR_COUNT)
    907              {
    908                  LOG_ADD_EXCEPTION(ADD_CHANS_INVALID_PARAMS, COMBINE_BYTES(client_motor, 0));
    909              }
    910              else
    911              {
    912                  return RequestPeriodicDataChannels(TRUE, client_motor, channels_bitmap);
    913              }
    914              return FALSE;
    915          }
    916          
    917          //---------------------------------------------------------------------------------------------------------------------
    918          /**
    919           * Request that all failure flags be cleared for the specified motor.
    920           * @param client_motor = The value used to uniquely identify the system motor on the client.
    921           * @return TRUE if the request was sent. Otherwise, FALSE.
    922           */
    923          BOOL_TYPE API221MotionCtrl__ClearFailureFlags(API221_CLIENT_MOTOR_INDEX_TYPE client_motor)
    924          {
    925              BOOL_TYPE result = FALSE;
    926              if (client_motor >= API221_SYSTEM_MOTOR_COUNT)
    927              {
    928                  LOG_ADD_EXCEPTION(CLEAR_FAILURES_INVALID_PARAMS, COMBINE_BYTES(client_motor, 0));
    929              }
    930              else
    931              {
    932                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
    933                  uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
    934                  #if (API221_SERVER_FEATURE == ENABLED)
    935                      if (motor_node == WIN_NODE)
    936                      {
    937                          #ifdef API221_CLEAR_FAILURES
    938                              if (server_motor < API221_SERVER_MOTOR_COUNT)
    939                              {
    940                                  API221_CLEAR_FAILURES(server_motor);
    941                                  result = TRUE;
    942                              }
    943                          #endif
    944                      }
    945                      else
    946                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
    947                  {
    948                      result = Reveal__QueueMessageU8(API221MOTIONCTRL_NUM, API221_CMD_CLEAR_FAILURE_FLAGS, motor_node, TRUE, FALSE, server_motor);
    949                  }
    950              }
    951              return result;
    952          }
    953          
    954          //---------------------------------------------------------------------------------------------------------------------
    955          /**
    956           * Send a command to run the specified motor or motor-controlled device using a platform-specific behavior.
    957           * @param client_motor = The value used to uniquely identify the system device on the client.
    958           * @param buffer = Pointer to an array of platform-specific parameters.
    959           * @param size = Size of the 'buffer' array.
    960           * @return TRUE if the request was sent. Otherwise, FALSE.
    961           */
    962          BOOL_TYPE API221MotionCtrl__DeviceMotion(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8* buffer, uint8 size)
    963          {
    964              BOOL_TYPE result = FALSE;
    965              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
    966                  (buffer == NULL) ||
    967                  (size <= 0) || (EXTERNAL_MOTOR_MAX_COMMAND_SIZE - 1 < size))
    968              {
    969                  LOG_ADD_EXCEPTION(MOTION_INVALID_PARAMS, COMBINE_BYTES(((buffer == NULL) ? 0x80 : 0x00) + client_motor, size));
    970              }
    971              else
    972              {
    973                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
    974                  uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
    975                #if (API221_SERVER_FEATURE == ENABLED)
    976                  if (motor_node == WIN_NODE)
    977                  {
    978                      #ifdef API221_DEVICE_MOTION
    979                          if (server_motor < API221_SERVER_MOTOR_COUNT)
    980                          {
    981                              result = API221_DEVICE_MOTION(server_motor, buffer, size);
    982                          }
    983                      #endif
    984                  }
    985                  else
    986                #endif      // #if (API221_SERVER_FEATURE == ENABLED)
    987                  {
    988                      REVEAL_COMMAND_TYPE* cmd = Reveal__NewCommand(API221MOTIONCTRL_NUM, API221_CMD_SET_MOTION_BEHAVIOR, motor_node, size + 1);
    989                      result = (BOOL_TYPE)((Reveal__AddDataU8(cmd, server_motor) == PASS) &&
    990                                           (Reveal__AddDataU8Buffer(cmd, buffer, size) == PASS) &&
    991                                           (Reveal__QueueCommand(cmd) == TRUE));
    992                      #if (KEEP_RUNNING_TIMER > 0)
    993                          if (result == TRUE)
    994                          {
    995                              Api221.Keep_Running_Timer[client_motor] = KEEP_RUNNING_TIMER;
    996                          }
    997                      #endif
    998                  }
    999              }
   1000              return result;
   1001          }
   1002          
   1003          //---------------------------------------------------------------------------------------------------------------------
   1004          /**
   1005           * Send a command to run the specified motor or motor-controlled device with the specified pulse pattern.
   1006           * @param client_motor = The value used to uniquely identify the system device on the client.
   1007           * @param command = The type of pulse command.
   1008           * @param pulse = A pointer to the pulse parameters.
   1009           * @return TRUE if the request was sent. Otherwise, FALSE.
   1010           */
   1011          BOOL_TYPE API221MotionCtrl__DevicePulse(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, EXTERNAL_MOTOR_SIMPLE_COMMAND_TYPE command, EMP_PULSE_PARAM_TYPE* pulse)
   1012          {
   1013              BOOL_TYPE result = FALSE;
   1014              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1015                  (pulse == NULL))
   1016              {
   1017                  LOG_ADD_EXCEPTION(PULSE_INVALID_PARAMS, COMBINE_BYTES(client_motor, (pulse == NULL)));
   1018              }
   1019              else
   1020              {
   1021                  #if (API221_SERVER_FEATURE == ENABLED)
   1022                      uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1023                      if (motor_node == WIN_NODE)
   1024                      {
   1025                          #ifdef API221_DEVICE_PULSE
   1026                              uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1027                              if (server_motor < API221_SERVER_MOTOR_COUNT)
   1028                              {
   1029                                  result = API221_DEVICE_PULSE(server_motor, command, pulse);
   1030                              }
   1031                          #endif
   1032                      }
   1033                      else
   1034                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1035                  {
   1036                      API221MOTIONCTRL_OPCODE_TYPE op_code = API221_NO_OPCODE;
   1037                      switch (command)
   1038                      {
   1039                          case EXTERNAL_MOTOR_PULSE_IMMEDIATE:
   1040                              op_code = API221_CMD_PULSE_IMMEDIATE;
   1041                              break;
   1042          
   1043                          case EXTERNAL_MOTOR_PULSE_MODIFY:
   1044                              op_code = API221_CMD_PULSE_MODIFY;
   1045                              break;
   1046          
   1047                          case EXTERNAL_MOTOR_PULSE_QUEUE:
   1048                              op_code = API221_CMD_PULSE_QUEUE;
   1049                              break;
   1050          
   1051                          default:
   1052                              LOG_ADD_EXCEPTION(PULSE_INVALID_COMMAND, COMBINE_BYTES(client_motor, command));
   1053                              break;
   1054                      }
   1055                      if (op_code > 0)
   1056                      {
   1057                          result = SendStandardCommand(client_motor, op_code, (uint16*)(void*)pulse, sizeof(EMP_PULSE_PARAM_TYPE) / sizeof(uint16));
   1058                      }
   1059                  }
   1060              }
   1061              return result;
   1062          }
