    183          /**
    184           * @brief    Handler for SRFeedbackLLI execution; this call (and sequence) checks both SRFeedbackLLI and SRAcLLI
    185           */
    186          void SRFeedbackLLI__Handler(void)
    187          {
    188              (void) SRData__CheckByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation);
    189              (void) SRData__CheckByte(&SRZeroCross_Index, &N_SRZeroCross_Index);
    190              (void) SRData__CheckArrayNonBlocking(SRFeedbackLLI_Data, N_SRFeedbackLLI_Data, sizeof(SRFeedbackLLI_Data));
    191          
    192          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    193              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRFEEDBACK_CHECKS);
    194          #endif
    195          
    196          }
