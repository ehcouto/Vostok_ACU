     20              #error: I2CMGR_FEATURE must be defined in SystemConfig_prm.h as ENABLED or DISABLED
     21          #endif
     22          
     23          #if (I2CMGR_FEATURE == ENABLED)
     24          //-------------------------------------- Include Files ----------------------------------------------------------------
     25          #include "I2cMgr.h"
     26          #include "I2cMgr_prv.h"
     27          #include "Millis.h"
     28          #include <string.h>
