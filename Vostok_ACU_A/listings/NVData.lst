      7           @startuml{"NVData_SM.png" }
      8              title NVDATA STATE MACHINE
      9              [*] --> NVDATA_IDLE
     10              NVDATA_IDLE --> NVDATA_STORING : EV_BROWNOUT
     11              NVDATA_STORING --> NVDATA_STORED : EV_STORE_SUCCESS
     12              NVDATA_STORING --> NVDATA_ERROR : EV_STORE_FAIL
     13              NVDATA_ERROR --> NVDATA_STORING : EV_RECOVERED
     14          
     15          
     16              NVDATA_IDLE:do / check for brownout
     17              NVDATA_STORING: do / store segments
     18              NVDATA_STORED: do / check for power
     19              NVDATA_ERROR: entry / recover
     20          
     21          
     22           @enduml
