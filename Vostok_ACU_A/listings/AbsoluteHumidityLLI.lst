    304          //---------------------------------------------------------------------------------------------------------------------
    305          /**
    306           * @brief   Get function to provide Data of an AbsoluteHumidityLLI instance
    307           *
    308           * @param   input   pointer to HBL_LLI_TYPE structure instance
    309           *
    310           * @return	pointer to a ABSOLUTE_HUMIDITY_LLI_DATA_TYPE which contains the specified input state and pwm count
    311           * @return  NULL is the input parameter is invalid
    312           */
    313          void * AbsoluteHumidityLLI__Get(HBL_LLI_TYPE * input)
    314          {
    315              if(input->Data_Index < Absolute_Humidity_LLI_Allocation)
    316              {
    317                  LLI_Index = input->Data_Index;
    318          
    319                  if(Absolute_Humidity_LLI_Data[LLI_Index].Enable == TRUE)
    320                  {
    321                      if(Absolute_Humidity_LLI_Data[LLI_Index].Error_Status == TRUE)
    322                      {
    323                          Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_ERROR;
    324                      }
    325                      else
    326                      {
    327                          switch(Absolute_Humidity_LLI_Data[LLI_Index].State)
    328                          {
    329                              case STATE_ABSOLUTE_HUMIDITY_LLI_HEATING:
    330                                  Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_HEATING;
    331                                  break;
    332          
    333                              case STATE_ABSOLUTE_HUMIDITY_LLI_BALANCING:
    334                                  Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_BALANCING;
    335                                  break;
    336          
    337                              case STATE_ABSOLUTE_HUMIDITY_LLI_REGULATING:
    338                                  Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_REGULATING;
    339                                  break;
    340          
    341                              case STATE_ABSOLUTE_HUMIDITY_LLI_BALANCED:
    342                                  Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_BALANCED;
    343                                  break;
    344          
    345                              default:
    346                                  Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.State = ABSOLUTE_HUMIDITY_LLI_STATE_OFF;
    347                                  break;
    348                          }
    349                      }
    350          
    351                      //! Disable the OS scheduler
    352                      OS_EnterRegion();
    353          
    354                      Absolute_Humidity_LLI_Data[LLI_Index].Get_Data.Value = Absolute_Humidity_LLI_Data[LLI_Index].Filtered_PWM;
    355          
    356                      //! Enabled the OS scheduler
    357                      OS_LeaveRegion();
    358          
    359                      return (&Absolute_Humidity_LLI_Data[LLI_Index].Get_Data);
    360                  }
    361                  else
    362                  {
    363                      return (NULL);
    364                  }
    365              }
    366              else
    367              {
    368                  return (NULL);
    369              }
    370          }
    371          
    372          //---------------------------------------------------------------------------------------------------------------------
    373          /**
    374           * @brief	AsynchProcess called at every 5ms to generate Absolute humidity 100ms handler
    375           * @param   input   pointer to HBL_LLI_TYPE structure instance
    376           * @param   status
    377           * @return	PASS if a new sample is ready, FAIL otherwise
    378           */
    379          BOOL_TYPE AbsoluteHumidityLLI__AsynchProcess(HBL_LLI_TYPE * input)
    380          {
    381              BOOL_TYPE retval = FALSE;
    382          
    383              if(input->Data_Index < Absolute_Humidity_LLI_Allocation)
    384              {
    385                  LLI_Index = input->Data_Index;
    386          
    387                  if(Absolute_Humidity_LLI_Data[LLI_Index].Enable == TRUE)
    388                  {
    389                      Absolute_Humidity_LLI_Data[LLI_Index].Asynch_Process_Counter++;
    390                      if(Absolute_Humidity_LLI_Data[LLI_Index].Asynch_Process_Counter >= 20)
    391                      {
    392                          Absolute_Humidity_LLI_Data[LLI_Index].Asynch_Process_Counter = 0;
    393          
    394                          AbsoluteHumidityLLIExecute();
    395          
    396                          //! Disable the OS scheduler
    397                          OS_EnterRegion();
    398          
    399                          Absolute_Humidity_LLI_Data[LLI_Index].Filtered_PWM = AbsoluteHumidityFilter(AbsoluteHumidityPWMGetDuty());
    400          
    401                          //! Enabled the OS scheduler
    402                          OS_LeaveRegion();
    403          
    404                          retval = TRUE;
    405                      }
    406                  }
    407              }
    408          
    409              return (retval);
    410          }
    411          
    412          //---------------------------------------------------------------------------------------------------------------------
    413          /**
    414           * @brief   Process function to read on ZC Peak angle (90, 270)
    415           * @param   input   pointer to HBL_LLI_TYPE structure instance
    416           * @param   status
    417           * @param   peak_polarity   TRUE for 90, FALSE for 270
    418           * @return  TRUE if a new sample is ready, FALSE otherwise
    419           */
    420          BOOL_TYPE AbsoluteHumidityLLI__PeakProcess(HBL_LLI_TYPE * input, BOOL_TYPE peak_polarity)
    421          {
    422              BOOL_TYPE retval = FALSE;
    423          
    424              if(input->Data_Index < Absolute_Humidity_LLI_Allocation)
    425              {
    426                  //! Sample the feedback at ZC peak angle 270 only
    427                  if(peak_polarity == FALSE)
    428                  {
    429                      //! Save LLI_Index before changing it in peak process
    430                      uint8 LLI_Index_Bak = LLI_Index;
    431          
    432                      LLI_Index = input->Data_Index;
    433          
    434                      if(Absolute_Humidity_LLI_Data[LLI_Index].Enable == TRUE)
    435                      {
    436                          if(AbsoluteHumidityGetFeedback() == TRUE)
    437                          {
    438                              if(Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status >= ABSOLUTE_HUMIDITY_FB_HIGH_THRESHOLD)
    439                              {
    440                                  Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status = ABSOLUTE_HUMIDITY_FB_HIGH_THRESHOLD;
    441                              }
    442                              else
    443                              {
    444                                  Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status++;
    445                              }
    446                          }
    447                          else
    448                          {
    449                              if(Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status <= ABSOLUTE_HUMIDITY_FB_LOW_THRESHOLD)
    450                              {
    451                                  Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status = ABSOLUTE_HUMIDITY_FB_LOW_THRESHOLD;
    452                              }
    453                              else
    454                              {
    455                                  Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status--;
    456                              }
    457                          }
    458          
    459                          retval = TRUE;
    460                      }
    461          
    462                      //! Restore LLI_Index to previous value before exiting peak process
    463                      LLI_Index = LLI_Index_Bak;
    464                  }
    465              }
    466          
    467              return (retval);
    468          }
