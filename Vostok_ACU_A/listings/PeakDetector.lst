    242          
    243                          SRData__UpdateShort(&(peak_detector->Period_Counter_Rough), &(n_peak_detector->Period_Counter_Rough), peak_detector->Period_Counter_Reload);
    244                      }
    245                      else
    246                      {
    247                          SRData__UpdateShort(&(peak_detector->Period_Counter_Rough), &(n_peak_detector->Period_Counter_Rough), (peak_detector->Period_Counter_Rough) - 1);
