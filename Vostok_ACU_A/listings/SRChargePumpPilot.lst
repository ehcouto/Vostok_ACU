     74          //---------------------------------------------------------------------------------------------------------------------
     75          /**
     76           * Initialize all instances of this Pilot type.
     77           *  - Initialize static RAM used by the module.
     78           *  - Initialize any corrupted NVData used by the module.
     79           */
     80          void SRChargePumpPilot__Initialize(void)
     81          {
     82              SR_FILL(SRChargePumpPilot_Data, 0, sizeof(SRChargePumpPilot_Data));
     83          
     84              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     85                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRCHARGEPUMP_PILOT);
     86              #endif
     87          }
     88          
     89          //---------------------------------------------------------------------------------------------------------------------
     90          /**
     91           * Reserve memory for this pilot instance.
     92           * @return The index of the allocated Pilot.
     93           *         Return 0xFF if there is no space allocated for another Pilot of this type.
     94           */
     95          uint8 SRChargePumpPilot__Allocate(void)
     96          {
     97              uint8 pilot_index = 0xFF;
     98          
     99              SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    100          
    101              if (SRChargePumpPilot_Data.Allocation < HBL_PILOT_NUM_SRCHARGEPUMP)
    102              {
    103                  pilot_index = SRChargePumpPilot_Data.Allocation;
    104                  SR_SET_BYTE(SRChargePumpPilot_Data.Allocation, SRChargePumpPilot_Data.Allocation + 1);
    105              }
    106              return (pilot_index);
    107          }
    108          
    109          //---------------------------------------------------------------------------------------------------------------------
    110          /**
    111           * Initialize this pilot instance.
    112           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    113           * @return PASS if the Pilot instance is successfully initialized; otherwise FAIL.
    114           */
    115          PASS_FAIL_TYPE SRChargePumpPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    116          {
    117              PASS_FAIL_TYPE result = FAIL;
    118          
    119              if (load != NULL)
    120              {
    121                  uint8 virtual_pin = (*load->Pin_Ptr);;
    122          
    123                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    124          
    125                  if ((load->Pilot_Data_Index < SRChargePumpPilot_Data.Allocation) &&
    126                      (virtual_pin < VirtualPin__GetNumOf()) &&
    127                      (VIRTUALPIN_TABLE[virtual_pin].port != PORT_NULL))
    128                  {
    129                      const VIRTUALPIN_TYPE* vp = &VIRTUALPIN_TABLE[virtual_pin];
    130                      GPIO_PORT_TYPE port = vp->port;
    131                      uint8 pin = vp->pin;
    132                      if ((Gpio__Validate(port, pin) == PASS) &&
    133                          (vp->pin_config == OUTPUT_PUSHPULL))
    134                      {
    135                          SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State,
    136                              (uint8 *)&N_SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State);
    137                          SRData__UpdateByte((uint8 *)&SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State,
    138                              (uint8 *)&N_SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State,
    139                              (~load->Hi_Low_Activation_Bitmap) & 0x01);
    140                          Gpio__PinWrite(port, pin, (BOOL_TYPE) SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State);
    141                          Gpio__PinConfig(port, pin, vp->pin_config);
    142                          result = PASS;
    143                      }
    144                  }
    145              }
    146          
    147              return (result);
    148          }
    149          
    150          //---------------------------------------------------------------------------------------------------------------------
    151          /**
    152           * Update the requested state of the output controlled by this pilot instance.
    153           * This function must not set the output.
    154           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    155           * @param data = A pointer to memory that contains the new requested pilot state.
    156           * @return PASS if the requested pilot state is successfully saved; otherwise FAIL.
    157           */
    158          PASS_FAIL_TYPE SRChargePumpPilot__Request(HBL_LOAD_TYPE * load,void * data)
    159          {
    160              PASS_FAIL_TYPE result = FAIL;
    161          
    162              if (load != NULL)
    163              {
    164                  uint8 pilot_index = load->Pilot_Data_Index;
    165          
    166                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    167          
    168                  if (load->Pilot_Data_Index < SRChargePumpPilot_Data.Allocation)
    169                  {
    170                      BOOL_TYPE drive_request = (BOOL_TYPE)OFF;
    171                      if (*((uint8 *)data) > 0)
    172                      {
    173                          drive_request = (BOOL_TYPE)ON;
    174                      }
    175          
    176                      SRData__UpdateByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Requested, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Requested, drive_request);
    177                      result = PASS;
    178                  }
    179              }
    180          
    181              return result;
    182          }
    183          
    184          //---------------------------------------------------------------------------------------------------------------------
    185          /**
    186           * Update the output controlled by this pilot instance based on previous requests.
    187           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    188           * @return PASS if the controlled output is successfully updated; otherwise FAIL.
    189           */
    190          PASS_FAIL_TYPE SRChargePumpPilot__Process(HBL_LOAD_TYPE * load)
    191          {
    192              PASS_FAIL_TYPE result = FAIL;
    193              if (load != NULL)
    194              {
    195                  uint8 pilot_index = load->Pilot_Data_Index;
    196                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    197                  if (pilot_index < SRChargePumpPilot_Data.Allocation)
    198                  {
    199                      SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Requested, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Requested);
    200                      SRData__UpdateByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Processed, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Processed, SRChargePumpPilot_Data.Data[pilot_index].Requested);
    201          
    202                      result = PASS;
    203                  }
    204              }
    205          
    206              return result;
    207          }
    208          
    209          //---------------------------------------------------------------------------------------------------------------------
    210          /**
    211           * Get the requested state of the output controlled by this pilot instance.
    212           * This function does not necessarily return the current state of the output.
    213           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    214           * @return A pointer to data that describes the requested state of the output.
    215           */
    216          void * SRChargePumpPilot__GetRequested(HBL_LOAD_TYPE * load)
    217          {
    218              void* requested = NULL;
    219              if (load != NULL)
    220              {
    221                  uint8 pilot_index = load->Pilot_Data_Index;
    222                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    223                  if (pilot_index < SRChargePumpPilot_Data.Allocation)
    224                  {
    225                      SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Requested, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Requested);
    226          
    227                      requested = &SRChargePumpPilot_Data.Data[pilot_index].Requested;
    228                  }
    229              }
    230              return requested;
    231          }
    232          
    233          //---------------------------------------------------------------------------------------------------------------------
    234          /**
    235           * Get the state of the output controlled by this pilot instance.
    236           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    237           * @return A pointer to data that describes the state of the output.
    238           */
    239          void * SRChargePumpPilot__GetProcessed(HBL_LOAD_TYPE * load)
    240          {
    241              void* processed = NULL;
    242              if (load != NULL)
    243              {
    244                  uint8 pilot_index = load->Pilot_Data_Index;
    245                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    246                  if (pilot_index < SRChargePumpPilot_Data.Allocation)
    247                  {
    248                      SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Processed, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Processed);
    249                      processed = &SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Processed;
    250                  }
    251              }
    252              return processed;
    253          }
    254          
    255          //---------------------------------------------------------------------------------------------------------------------
    256          /**
    257           * @brief - This API been called every 1ms periodically by the HBL
    258           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    259           * @return PASS if the Pilot is called successfully or else fail
    260           */
    261          PASS_FAIL_TYPE SRChargePumpPilot__Handler1ms(HBL_LOAD_TYPE * load)
    262          {
    263              PASS_FAIL_TYPE result = FAIL;
    264              if (load != NULL)
    265              {
    266                  uint8 pilot_index = load->Pilot_Data_Index;
    267                  uint8 virtual_pin = load->Pin_Ptr[0];
    268          
    269                  SR_CHECK_BYTE(SRChargePumpPilot_Data.Allocation);
    270          
    271                  if ((pilot_index < SRChargePumpPilot_Data.Allocation) &&
    272                      (virtual_pin < VirtualPin__GetNumOf()) &&
    273                      (VIRTUALPIN_TABLE[virtual_pin].port != PORT_NULL))
    274                  {
    275                      // Determine the port/pin information.
    276                      const VIRTUALPIN_TYPE* vp = &VIRTUALPIN_TABLE[virtual_pin];
    277                      GPIO_PORT_TYPE port = vp->port;
    278                      uint8 pin = vp->pin;
    279          
    280                      SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Processed, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Processed);
    281                      SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Pin_State, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Pin_State);
    282          
    283                      BOOL_TYPE previous_pin_state = SRChargePumpPilot_Data.Data[pilot_index].Pin_State;
    284          
    285                      if (SRChargePumpPilot_Data.Data[pilot_index].Processed == ON)
    286                      {
    287                          SRData__UpdateByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Pin_State, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Pin_State, ((SRChargePumpPilot_Data.Data[pilot_index].Pin_State ^ 1) & 0x01));
    288                      }
    289                      else
    290                      {
    291                          SRData__UpdateByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Pin_State, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Pin_State, (~load->Hi_Low_Activation_Bitmap) & 0x01);
    292                      }
    293          
    294          
    295                      if (Gpio__CheckConfig(port, pin, vp->pin_config, previous_pin_state) == TRUE)
    296                      {
    297                          SRData__CheckByte((uint8 *)&SRChargePumpPilot_Data.Data[pilot_index].Pin_State, (uint8 *)&N_SRChargePumpPilot_Data.Data[pilot_index].Pin_State);
    298                          Gpio__PinWrite(port, pin, SRChargePumpPilot_Data.Data[load->Pilot_Data_Index].Pin_State);
    299                          result = PASS;
    300                      }
    301                      else
    302                      {
    303                          SRException__Queue(SREXCEPTION_GPIO_CONFIGURATION_CORRUPTION, load->Load_Id, vp->pin_config);
    304                      }
    305                  }
    306              }
    307          
    308              return result;
    309          }
