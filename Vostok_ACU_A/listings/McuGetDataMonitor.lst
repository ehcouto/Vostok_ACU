     61           */

   \                                 In section .text, align 2, keep-with-next
     62          void McuGetDataMonitor__Execution(void)
     63          {
     64          #if ((API221_CLIENT_FEATURE == ENABLED) && (API221_SERVER_FEATURE == DISABLED))
     65          	sint32 temp_data;
     66          	uint16 reveal_node_status = Reveal__GetNodestatus();
     67          	uint8 *mcu_enable_state_ptr;
     68          
     69          	mcu_enable_state_ptr = (uint8 *)Hbl__GetProcessedLoad(Hbl__GetLoadIndexByLoadID(HBL_LOAD_MCU_ENABLE));
     70          
     71          	if (((mcu_enable_state_ptr != NULL) && (*mcu_enable_state_ptr == (uint8)OFF)) ||
     72          		(BIT_TEST(reveal_node_status, WIN_MCU_ADDRESS) == (uint16)0))
     73          	{
     74          		// MCU is off or is not communicating, assume both speeds are 0
     75          		if (MGD_Wash_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
     76          		{
     77          			MGD_Wash_Pump_Speed = 0;
     78          		}
     79          
     80          		if (MGD_Drain_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
     81          		{
     82          			MGD_Drain_Pump_Speed = 0;
     83          		}
     84          
     85          		MGD_Reveal_Node_Status_Old = 0;
     86          	}
     87          	else
     88          	{
     89          		if (BIT_TEST(MGD_Reveal_Node_Status_Old, WIN_MCU_ADDRESS) == (uint16)0)
     90          		{
     91          			ActivateActualSpeedChannels();
     92          		}
     93          		MGD_Reveal_Node_Status_Old = reveal_node_status;
     94          
     95          		if (MGD_Wash_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
     96          		{
     97          			if(API221MotionCtrl__GetData(MOTOR_0,MCI_AI_ACTUAL_SPEED_S16, &temp_data))
     98          			{
     99          				MGD_Wash_Pump_Speed = temp_data >> 16;
    100          			}
    101          		}
    102          		if (MGD_Drain_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
    103          		{
    104          			if(API221MotionCtrl__GetData(MOTOR_1,MCI_AI_ACTUAL_SPEED_S16, &temp_data))
    105          			{
    106          				MGD_Drain_Pump_Speed = temp_data >> 16;
    107          			}
    108          		}
    109          	}
    110          
    111          
    112          	// ENABLE or DISABLE Communication failure with MCU
    113          	if (mcu_enable_state_ptr != NULL)
    114          	{
    115          		if (*mcu_enable_state_ptr != MGD_Mcu_Enable_State_Old)
    116          		{
    117          			if (*mcu_enable_state_ptr == (uint8)OFF)
    118          			{
    119          				CommunicationMonitor__Disable(WIN_MCU_ADDRESS);
    120          			}
    121          			else
    122          			{
    123          				CommunicationMonitor__Enable(WIN_MCU_ADDRESS);
    124          			}
    125          		}
    126          
    127          		MGD_Mcu_Enable_State_Old = *mcu_enable_state_ptr;
    128          	}
    129          #elif ((API221_CLIENT_FEATURE == ENABLED) && (API221_SERVER_FEATURE == ENABLED))
    130          	if (MGD_Wash_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
    131          	{
    132          		MGD_Wash_Pump_Speed = MciSensorsDw__GetAnalog(SRMOTORSWITCH_LOAD_L0, (MCISENSORSDW_AI_TYPE) MCI_AI_ACTUAL_SPEED_S16) >> 16;
    133          	}
    134          	if (MGD_Drain_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
    135          	{
    136          		MGD_Drain_Pump_Speed = MciSensorsDw__GetAnalog(SRMOTORSWITCH_LOAD_L1, (MCISENSORSDW_AI_TYPE) MCI_AI_ACTUAL_SPEED_S16) >> 16;
    137          	}
    138          #endif
    139          }
