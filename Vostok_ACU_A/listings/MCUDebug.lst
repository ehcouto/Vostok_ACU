    275          #ifdef ENABLE_PILOT_MCI
    276          void PilotRelay(void)
    277          {
    278              if (Pilot_Relay_Request)
    279              {
    280              	GPIO__PIN_SET(PILOT_DRIVE_PORT,PILOT_DRIVE_PIN); //Enable Pilot
    281                  Pilot_Relay_Timer++;
    282          
    283                  //Pilot Relay ON
    284                  if (Pilot_Relay_Drive_Status == DISABLED)
    285                  {
    286                      // time to switch ON?
    287                      if (Pilot_Relay_Timer >= PILOT_RELAY_DISABLED_TIME)
    288                      {
    289                          GPIO__PIN_SET(PILOT_RELAY_PORT, PILOT_RELAY_PIN);
    290                          Pilot_Relay_Drive_Status = ENABLED;
    291                          Pilot_Relay_Timer = 0;
    292                      }
    293                  }
    294                  else
    295                  {
    296                      // time to switch OFF?
    297                      if (Pilot_Relay_Timer >= PILOT_RELAY_ENABLED_TIME)
    298                      {
    299                          GPIO__PIN_CLR(PILOT_RELAY_PORT, PILOT_RELAY_PIN);
    300                          Pilot_Relay_Drive_Status = DISABLED;
    301                          Pilot_Relay_Timer = 0;
    302                      }
    303                  }
    304              }
    305              else
    306              {
    307              	if(Pilot_Relay_Drive_Status == ENABLED)
    308              	{
    309              		Pilot_Relay_Timer = 0;
    310              		GPIO__PIN_CLR(PILOT_RELAY_PORT, PILOT_RELAY_PIN);
    311              		GPIO__PIN_CLR(PILOT_DRIVE_PORT,PILOT_DRIVE_PIN);
    312              		Pilot_Relay_Drive_Status = DISABLED;
    313              	}
    314              }
    315          }
    316          #endif
