     72          //---------------------------------------------------------------------------------------------------------------------
     73          /**
     74           *  @brief      It Initializes the module I2cMgr and its variables
     75           *
     76           */
     77          void I2cMgr__Initialize(void)
     78          {
     79              uint8 index;
     80          
     81              memset(I2cMgr_DeviceHandle, I2CMGR_CHANNEL_INVALID, sizeof(I2cMgr_DeviceHandle));
     82              memset(I2cMgr_TimeoutHandle, 0, sizeof(I2cMgr_TimeoutHandle));
     83          
     84          #if(I2CMGR_NUM_DEVICES > 1)
     85              memset(I2cMgr_RequestQueue, 0, sizeof(I2cMgr_RequestQueue));
     86          #endif
     87          
     88              for(index= 0; index < I2CMGR_NUM_CHANNELS; index++)
     89              {
     90                  Millis__Reset(&I2cMgr_TimeoutHandle[index]);
     91          
     92          #if(I2CMGR_NUM_DEVICES > 1)
     93                  memset(I2cMgr_RequestQueue[index].I2cMgr_TokenQueue, I2CMGR_HANDLE_INVALID, sizeof(I2cMgr_RequestQueue[index].I2cMgr_TokenQueue));
     94          #endif
     95              }
     96          }
     97          
     98          //---------------------------------------------------------------------------------------------------------------------
     99          /**
    100           * @brief This method obtains a handle from the array for the requesting device
    101           * @details This method is necessary to prepare a device to be used with I2C correctly. It lets the manager know which\n
    102           * channel the device needs to operate on as well.
    103           *
    104           * @param i2c_channel - define the i2c channel the calling device is operating on
    105           * @retval uint8 device_id - define the index into the handle array for devices
    106           */
    107          uint8 I2cMgr__GetDeviceHandle(I2C_ENUM_TYPE i2c_channel)
    108          {
    109              uint8 device_id = I2CMGR_HANDLE_INVALID;
    110              uint8 index;
    111          
    112              if(i2c_channel < I2CMGR_NUM_CHANNELS)
    113              {
    114                  for(index = 0; index < I2CMGR_NUM_DEVICES; index++)
    115                  {
    116                      if(I2cMgr_DeviceHandle[index].i2c_channel == (I2C_ENUM_TYPE) I2CMGR_CHANNEL_INVALID)
    117                      {
    118                          I2cMgr_DeviceHandle[index].i2c_channel = i2c_channel;
    119                          device_id = index;
    120                          break; // Break when a free handle is found
    121                      }
    122                  }
    123              }
    124          
    125              return device_id;
    126          }
    127          
    128          //---------------------------------------------------------------------------------------------------------------------
    129          /**
    130           * @brief This method releases a handle from the array for the requesting device
    131           * @details This method releases a device from the handle array and creates room for a new device.
    132           *
    133           * @param uint8 device_id - define the index into the handle array for devices
    134           */
    135          void I2cMgr__ReleaseDeviceHandle(uint8 device_id)
    136          {
    137              if(device_id < I2CMGR_NUM_DEVICES)
    138              {
    139                  I2cMgr_DeviceHandle[device_id].i2c_channel = (I2C_ENUM_TYPE) I2CMGR_CHANNEL_INVALID;
    140              }
    141          }
    142          
    143          //---------------------------------------------------------------------------------------------------------------------
    144          /**
    145           * @brief This method gives a calling device access to an I2c channel.
    146           * @details The method is used to grant access to a specific i2c channel's bus. The method returns true to allow\n
    147           * the calling device to operate over i2c. It will return false if the i2c bus is not free
    148           *
    149           * @param uint8 device_id - define the index into the handle array for devices
    150           *
    151           * @retval FALSE which means the the requested i2c write operation cannot be performed since i2c bus is busy
    152           * @retval TRUE which means the requested i2c write operation is completed
    153           */
    154          BOOL_TYPE I2cMgr__RequestBus(uint8 device_id)
    155          {
    156              BOOL_TYPE response = FALSE;
    157              BOOL_TYPE exists = FALSE;
    158              uint8 index;
    159          
    160              if(device_id < I2CMGR_NUM_DEVICES)
    161              {
    162                  if(I2cMgr_DeviceHandle[device_id].i2c_channel != (I2C_ENUM_TYPE) I2CMGR_CHANNEL_INVALID)
    163                  {
    164          #if(I2CMGR_NUM_DEVICES > 1)
    165                      // See if the device is already in the queue
    166                      for(index = 0; index < I2CMGR_QUEUE_SIZE; index++)
    167                      {
    168                          if(I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[index] == device_id)
    169                          {
    170                              exists = TRUE;
    171                              break;
    172                          }
    173                      }
    174          
    175                      // Add the device to the queue if it isnt already in
    176                      if((I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_WriteIndex] == I2CMGR_HANDLE_INVALID) &&
    177                         (exists == FALSE))
    178                      {
    179                          AddItemToQueue(device_id);
    180                      }
    181          
    182                      // Process the next item in the queue for request
    183                      // The device gets access if it is the current device at the read index of the queue
    184                      if(I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_ReadIndex] == device_id)
    185                      {
    186                          // Prepare timeout timer for countdown
    187                          Millis__Start(&I2cMgr_TimeoutHandle[I2cMgr_DeviceHandle[device_id].i2c_channel]);
    188                          response = TRUE;
    189                      }
    190          #else       // Return true is only 1 device exists since there is no possible interference
    191                      // Prepare timeout timer for countdown
    192                      Millis__Start(&I2cMgr_TimeoutHandle[I2cMgr_DeviceHandle[device_id].i2c_channel]);
    193          
    194                      response = TRUE;
    195          #endif
    196                  }
    197              }
    198          
    199              return response;
    200          }
    201          
    202          //---------------------------------------------------------------------------------------------------------------------
    203          /**
    204           * @brief This method releases the i2c bus if it is being used by the calling device.
    205           * @details The method will only release the bus if the calling device currently owns the bus operation
    206           *
    207           * @param uint8 device_id - define the index into the handle array for devices
    208           *
    209           *  @retval TRUE which means the i2c bus was released successfully
    210           *  @retval FALSE which means the i2c bus was not released
    211           */
    212          BOOL_TYPE I2cMgr__ReleaseBus(uint8 device_id)
    213          {
    214              BOOL_TYPE response = FALSE;
    215          
    216              if(device_id < I2CMGR_NUM_DEVICES)
    217              {
    218                  if(I2cMgr_DeviceHandle[device_id].i2c_channel != (I2C_ENUM_TYPE) I2CMGR_CHANNEL_INVALID)
    219                  {
    220          #if(I2CMGR_NUM_DEVICES > 1)
    221                      // The device can only release the bus if it currently has control
    222                      if(I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_ReadIndex] == device_id)
    223                      {
    224                          RemoveItemFromQueue(device_id);
    225          
    226                          // Invalidate timeout for the channel
    227                          Millis__Reset(&I2cMgr_TimeoutHandle[I2cMgr_DeviceHandle[device_id].i2c_channel]);
    228          
    229                          response = TRUE;
    230                      }
    231          #else       // Return true is only 1 device exists since there is no possible interference
    232                      // Invalidate timeout for the channel
    233                      Millis__Reset(&I2cMgr_TimeoutHandle[I2cMgr_DeviceHandle[device_id].i2c_channel]);
    234          
    235                      response = TRUE;
    236          #endif
    237                  }
    238              }
    239          
    240              return response;
    241          }
    242          
    243          //---------------------------------------------------------------------------------------------------------------------
    244          /**
    245           * @brief This handler is called constantly by the OS to calculate timeouts
    246           * @details This method will call the timeout action when a timeout occurs. The method will also keep track of the\n
    247           * timeout for each i2c channel.
    248           */
    249          void I2cMgr__Handler(void)
    250          {
    251              uint8 index;
    252          
    253              // Process each timeout variable to see if time has expired for the channel
    254              for(index = 0; index < I2CMGR_NUM_CHANNELS; index++)
    255              {
    256          
    257          #if(I2CMGR_NUM_DEVICES > 1)
    258                  if((Millis__IsTimerPaused(&I2cMgr_TimeoutHandle[index]) != FALSE) &&
    259                     ((I2cMgr_RequestQueue[index].I2cMgr_TokenQueue[I2cMgr_RequestQueue[index].I2cMgr_ReadIndex]) != I2CMGR_HANDLE_INVALID))
    260                  {
    261                       Millis__Start(&I2cMgr_TimeoutHandle[index]);
    262                  }
    263          #endif
    264          
    265                  if(Millis__ReachedTarget(&I2cMgr_TimeoutHandle[index], I2CMGR_TIMEOUT_VALUE))
    266                  {
    267                      TimeoutAction((I2C_ENUM_TYPE) index);
    268                  }
    269              }
    270          }
    271          //=====================================================================================================================
    272          //-------------------------------------- Private Functions ------------------------------------------------------------
    273          //=====================================================================================================================
    274          //---------------------------------------------------------------------------------------------------------------------
    275          /**
    276           * @brief This method is used to process a timeout for an i2c channel
    277           * @details This method will either reset the i2c bus if it is locked or it will remove the token from the device\n
    278           * currently holding it.
    279           *
    280           * @param i2c_channel - define the i2c channel the calling device is operating on
    281           */
    282          static void TimeoutAction(I2C_ENUM_TYPE i2c_channel)
    283          {
    284              // Only reset the I2c bus if it is locked up
    285              if(I2c__GetStatus(i2c_channel, I2C_STATUS_ERROR) == I2C_ERROR_BUS_LOCKED)
    286              {
    287                  I2c__ResetBus(i2c_channel);
    288              }
    289          
    290              // Invalidate the timeout variable
    291              Millis__Reset(&I2cMgr_TimeoutHandle[i2c_channel]);
    292          
    293          #if(I2CMGR_NUM_DEVICES > 1)
    294              // Remove the current item at the read index for the channel that has timed out
    295              RemoveItemFromQueue(I2cMgr_RequestQueue[i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[i2c_channel].I2cMgr_ReadIndex]);
    296          #endif
    297          }
    298          
    299          //---------------------------------------------------------------------------------------------------------------------
    300          /**
    301           * @brief This method is used to add a device to the i2c channel request queue
    302           * @details This method will add the current device id passed to the position in the token queue pointed to by the\n
    303           * write index.
    304           *
    305          * @param uint8 device_id - define the index into the handle array for devices
    306           */
    307          #if(I2CMGR_NUM_DEVICES > 1)
    308          static void AddItemToQueue(uint8 device_id)
    309          {
    310              // Add device to the current queue
    311              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_WriteIndex] = device_id;
    312          
    313              // Move the token queue pointer to the next write spot
    314              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_WriteIndex++;
    315              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_WriteIndex %= I2CMGR_QUEUE_SIZE;
    316          }
    317          
    318          //---------------------------------------------------------------------------------------------------------------------
    319          /**
    320           * @brief This method is used to remove a device from the i2c channel request queue
    321           * @details This method will remove the current device id passed from the position in the token queue pointed to by the\n
    322           * read index.
    323           *
    324          * @param uint8 device_id - define the index into the handle array for devices
    325           */
    326          static void RemoveItemFromQueue(uint8 device_id)
    327          {
    328              // Remove device to the current queue
    329              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_TokenQueue[I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_ReadIndex] = I2CMGR_HANDLE_INVALID;
    330          
    331              // Move the token queue pointer to read next device
    332              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_ReadIndex++;
    333              I2cMgr_RequestQueue[I2cMgr_DeviceHandle[device_id].i2c_channel].I2cMgr_ReadIndex %= I2CMGR_QUEUE_SIZE;
    334          }
    335          #endif  //I2CMGR_NUM_DEVICES > 1
    336          #endif  //I2CMGR_FEATURE == ENABLED


 

 


