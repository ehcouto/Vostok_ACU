     97          /**
     98           *
     99           * @param generic_input
    100           * @param lli_data
    101           * @return
    102           */
    103          BOOL_TYPE ProbeLpsGI__AsynchProcess(HBL_GI_TYPE * generic_input,void * lli_data, uint8 lli_sequence)
    104          {
    105          	BOOL_TYPE retval;
    106          
    107          	retval = FALSE;
    108          
    109          	if(generic_input->Data_Index < ProbeLpsGI_Allocation)
    110          	{
    111          		if (ProbeLpsGI_LLI_Sequence[generic_input->Data_Index] != lli_sequence)
    112          		{
    113          			ProbeLpsGI_LLI_Sequence[generic_input->Data_Index] = lli_sequence;
    114          			retval = TRUE;
    115          		}
    116          	}
    117              return(retval);
    118          
    119          }
