   1029          //---------------------------------------------------------------------------------------------------------------------
   1030          /**
   1031           * Enable the accelerometer if requested by the application.
   1032           */
   1033          static void CheckForEnable(void)
   1034          {
   1035              if (Fxls8974.Mode_Requested != FXLS8974_MODE_DISABLED)
   1036              {
   1037                  EventEnable();
   1038              }
   1039          }
