     82          // -- Private Constant Declarations --
     83          
     84          //! The number of bytes that each API020 payload consumes as overhead when transferring safety data.
     85          #define API020_PACKET_OVERHEAD (sizeof(API020_SAFETY_PACKET_TYPE) - MAX_CLASSB_DATA_SIZE)
     86          
     87          //! The maximum size of Class B Safety Data on a single Transmit Channel or Receive Channel.
     88          #define MAX_CLASSB_DATA_SIZE 11
     89          
     90          //! The first Sequence Number used on a Transmit Channel after a reset.
     91          #define SEQUENCE_RESET 0
     92          
     93          //! The Sequence Number that sequentially follows the SEQUENCE_LAST Sequence Number.
     94          //! This is also the first Sequence Number that represents a potentially valid sequence.
     95          #define SEQUENCE_FIRST 1
     96          
     97          //! The last Sequence Number before having to restart counting at a lower value.
     98          #define SEQUENCE_LAST 253
     99          
    100          //! A Sequence Number that represents that the Transmit Channel did not satisfy the timing requirements.
    101          #define SEQUENCE_LOST 254
    102          
    103          //! A Sequence Number used internally to represent an invalid Sequence Number.
    104          //! This Sequence Number is not expected in the API020 messages.
    105          #define SEQUENCE_INVALID 255
    106          
    107          
    108          // -- Private Structure Type Declarations --
    109          
    110          //! The format of a data packet.
    111          typedef struct API020_SAFETY_PACKET_STRUCT
    112          {
    113              uint8 Sequence;
    114              uint8 Src_Addr;
    115              uint8 Dst_Addr;
    116              uint8 Data[MAX_CLASSB_DATA_SIZE + sizeof(uint8) /* sizeof(Crc8) */];
    117          } API020_SAFETY_PACKET_TYPE;
    118          
    119          //! A structure that declares all the variables used by this module.
    120          typedef struct API020_DATA_STRUCT
    121          {
    122              #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    123                  // The time of the last received message for each Receive Channel.
    124                  uint32 Rx_Time[API020_NUMBER_OF_RX_CHANNELS];
    125          
    126                  // The expected sequence number for the next received message on each Receive Channel.
    127                  uint8 Rx_Expected_Sequence[API020_NUMBER_OF_RX_CHANNELS];
    128          
    129                  // A flag that indicates that the Receive Channel has satisfied all sequence requirements.
    130                  uint8 Rx_Sequence_Valid[API020_NUMBER_OF_RX_CHANNELS];
    131              #endif
    132              #if (API020_NUMBER_OF_TX_CHANNELS > 0)
    133                  // The time of the last transmitted message for each Transmit Channel.
    134                  uint32 Tx_Time[API020_NUMBER_OF_TX_CHANNELS];
    135          
    136                  // The expected sequence number for the next transmitted message on each Transmit Channel.
    137                  uint8 Tx_Next_Sequence[API020_NUMBER_OF_TX_CHANNELS];
    138              #endif
    139          } API020_DATA_TYPE;
