      1          /**
      2           * @file
      3           * @brief       Low-level control to acquire XYZ acceleration data from an accelerometer.
      4           *
      5           * @details     This module will work for both the LIS2DH and LIS3DH accelerometer from ST.
      6           *              There are some features of the LIS3DH that are not supported
      7           *              (Ex. ADC output registers)
      8           *
      9              @startuml{LISXDH_sm.png}
     10                  title LISXDH State-Machine
     11                  ' Suppress transition checks
     12          
     13                  [*] --> BootDelay
     14          
     15                  BootDelay : entry / AccelHwInit()
     16                  BootDelay : do / WaitForBootComplete()
     17                  BootDelay --> LowPowerMode : evBootComplete
     18          
     19                  LowPowerMode : entry / AccelDisable()
     20                  LowPowerMode : do / CheckForEnable()
     21                  LowPowerMode --> Restart : evEnable\n/ LISxDH__FlushData()
     22          
     23                  Restart : entry / StartTimer()\n\t AccelHwInit()\n\t AccelEnable()
     24                  Restart : do / WaitForI2cReady()
     25                  Restart --> HighResMode : evI2cReady
     26                  Restart --> LowPowerMode : evTimeout\n[IsDisableRequested()]
     27                  Restart --> Restart : evTimeout
     28          
     29                  HighResMode : entry / StartTimer()
     30                  HighResMode : do / WaitForDataReady()
     31                  HighResMode --> ReadData : evDataReady
     32                  HighResMode -u-> LowPowerMode : evDisable
     33                  HighResMode -r-> Restart : evTimeout
     34          
     35                  ReadData : entry / AccelReadOneShot()
     36                  ReadData : do / WaitForData()
     37                  ReadData --> LowPowerMode : evDataReady\n[IsDisableRequested()]
     38                  ReadData --> ReadData : evDataReady\n/ StartTimer()
     39                  ReadData -u-> ReadTemp : evReadComplete \n[ReadTemp]
     40                  ReadData -u-> HighResMode : evReadComplete
     41                  ReadData --> AppBufferFull : evAppBufferFull
     42                  ReadData --> Restart : evTimeout
     43          
     44                  ReadTemp : entry / StartTimer()\n\t AccelReadTemp()
     45                  ReadTemp : do / WaitForTempData()
     46                  ReadTemp -u-> HighResMode : evReadComplete
     47                  ReadTemp --> Restart : evTimeout
     48          
     49                  AppBufferFull : entry / ReportTooMuchData()
     50                  AppBufferFull : do / CheckAppBuffer()
     51                  AppBufferFull -r-> HighResMode : evBufferHasSpace
     52                  AppBufferFull -u-> LowPowerMode : evDisable
     53              @enduml
     54           *
     55           * @copyright   Copyright 2017 Whirlpool Corporation.  All rights reserved - CONFIDENTIAL.
     56           */
