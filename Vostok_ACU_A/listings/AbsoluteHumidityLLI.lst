    478           * @brief   Initialize the error status before a new measurement.
    479           */
    480          static void ErrorStatusInitialize(void)
    481          {
    482              Absolute_Humidity_LLI_Data[LLI_Index].Error_Status = FALSE;
    483              Absolute_Humidity_LLI_Data[LLI_Index].Error_Counter = 0;
    484          }
