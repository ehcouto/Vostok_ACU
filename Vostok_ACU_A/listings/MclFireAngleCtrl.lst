    748          /**
    749           * Update pi output with proper saturation
    750           *
    751           */
    752          static void UpdatePiOutput(MCL_FIREANGLE_CTRL_IO_TYPE *io, sint8 percent_of_semicycle)
    753          {
    754              sint16 output_change;
    755              sint16 output;
    756          
    757              output_change = 0;
    758              output = Pi__GetOutput(io->Pi_Bemf_Shift);
    759          
    760              if(output > *io->Triac_Start_Time)
    761              {
    762                  output_change = -CONVERT_TO_PI_FORMAT(MCISLFAC_PERCENT_OF_SEMI_PERIOD_60HZ(-percent_of_semicycle));
    763          
    764                  output = output + output_change;
    765                  if(output > *io->Triac_Start_Time)
    766                  {
    767                      Pi__SetOutput(io->Pi_Bemf_Shift, output);
    768                  }
    769                  else
    770                  {
    771                      Pi__SetOutput(io->Pi_Bemf_Shift, *io->Triac_Start_Time);
    772                  }
    773              }
    774          }
    775          
