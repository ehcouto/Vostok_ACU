    954          /**
    955           * @brief   Builds the reveal message for HMI GI data
    956           * @details
    957           *   Payload[0] = GI READ_TYPE and GI POSITION
    958           *   Payload[1] = GI DATA SIZE (n)
    959           *   Payload[2] = GI DATA[0]
    960           *   Payload[3] = GI DATA[n-1]
    961           * @param item_index
    962           * @param data_size
    963           * @param ptr
    964           */
    965          static void BuildHmiGIDataMessage(uint8 item_index, uint8 data_size, REVEAL_COMMAND_TYPE * ptr)
    966          {
    967              uint8 gi_id;
    968              gi_id = HblHmi__GetGIPositionByIndex(item_index);
    969              gi_id = gi_id | (HblHmi__GetGIReadTypeByIndex(item_index)<< 6);
    970          
    971              // Form the message
    972              Reveal__AddDataU8(ptr,gi_id);
    973              Reveal__AddDataU8(ptr, data_size);
    974              Reveal__AddDataU8Buffer(ptr, HblHmi__GetGIByIndex(item_index), data_size);
    975          }
    976          
    977          //----------------------------------------------------------------------------------------------------------
    978          /**
    979           * @brief
    980           * @details
    981           *   Payload[0] = LLI TYPEx
    982           *   Payload[1] = LLI POSITIONx
    983           *   Payload[2] = LLI DATA SIZE (n)
    984           *   Payload[3] = LLI DATA[0]
    985           *   Payload[4] = LLI DATA[n-1]
    986           * @param item_index
    987           * @param data_size
    988           * @param ptr
    989           */
    990          static void BuildHmiLLIDataMessage(uint8 item_index, uint8 data_size, REVEAL_COMMAND_TYPE * ptr)
    991          {
