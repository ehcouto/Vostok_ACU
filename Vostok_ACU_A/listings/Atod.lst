    145          #define MAX_ADC_EXTERN_CHANNEL              16
    146          #define MAX_ADC_INTERNAL_CHANNEL            3
    147          #define MAX_ADC_CHANNEL                     (MAX_ADC_EXTERN_CHANNEL + MAX_ADC_INTERNAL_CHANNEL)
    148          
    149          /* Fixed timeout value for ADC calibration.                                   */
    150          /* Values defined to be higher than worst cases: maximum ratio between ADC    */
    151          /* and CPU clock frequencies.                                                 */
    152          /* Example of profile low frequency : ADC frequency at 31.25kHz (ADC clock    */
    153          /* source PLL 8MHz, ADC clock prescaler 256), CPU frequency 52MHz.            */
    154          /* Calibration time max = 116 / fADC (refer to datasheet)                     */
    155          /*                      = 193 024 CPU cycles                                  */
    156          #define ADC_CALIBRATION_TIMEOUT             (193024UL)   /*!< ADC calibration time-out value (unit: CPU cycles) */
    157          
    158          #define CLEAR_IER_REG                       ((uint32)0x00000000)
    159          
    160          #define CLEAR_ADC_CR_REG                    ((uint32)0x00000000)
