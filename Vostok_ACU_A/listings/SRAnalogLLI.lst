    310          /**
    311           * @brief		Get function to provide value of an SRAnalogLLI instance
    312           * @param input		pointer to HBL_LLI_TYPE structure instance
    313           * @return	pointer to Value
    314           */
    315          void * SRAnalogLLI__Get(HBL_LLI_TYPE * input)
    316          {
