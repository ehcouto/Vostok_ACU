    909                                              (Win_Header.sap.bits.msg_count == 0))
    910                                          {
    911                                              // set the message to be parsed.
    912                                              if (Win_Rx_Buffer.sdu_length > 0)
    913                                              {
    914                                                  Win_Rx_Message_Time = WIN_MAX_RX_PARSER_TIMEOUT;    // load the max time for the application to get the message
    915                                                  Win_Rx_Message_State = WIN_MESSAGE_READY;
    916                                              }
    917                                          }
    918                                          Prev_Rx_Msg_Count[Win_Header.address.bits.source] = Win_Header.sap.bits.msg_count;
    919          
    920          
    921                                          // if this is a direct message targeted to this node replay with ACK.
    922                                          if (Win_Header.address.bits.destination == Win_Node)
    923                                          {
    924                                              // send ACK back
    925                                              Uart__WriteByte(WIN_COM,WIN_DLE);
    926                                              Uart__WriteByte(WIN_COM,WIN_ACK);
    927                                          }
    928                                      }
    929                                      else
    930                                      {
    931                                          // if the crc doesn't match
    932                                          WIN_BAD_CRC_INCOMING_MESSAGE(Win_Rx_Buffer.header,Uart_Data,Win_Rx_Crc);
    933                                          #if (WIN_DEBUG == ENABLED)
    934                                              Win_Error_Crc_Counter++;
    935                                          #endif
    936                                      }
    937                                      Win_Rx_State = WIN_RX_STATE_IDLE;
    938                                      break;
    939                                  case WIN_RX_STATE_WAIT_FOR_IDLE:
    940                                      // waiting for the end of the transmission
    941                                      break;
    942                                  default:
    943                                      Win_Rx_State = WIN_RX_STATE_IDLE;
    944                                      break;
    945                              }
    946                          }
    947                          else
    948                          {
    949                              #if (WIN_DEBUG == ENABLED)
    950                                  Win_Error_Uart_Incoming_Counter++;
    951                              #endif
    952                              Win_Rx_State = WIN_RX_STATE_IDLE;
    953                          }
    954                      }
    955                  }
    956              }
    957          }
