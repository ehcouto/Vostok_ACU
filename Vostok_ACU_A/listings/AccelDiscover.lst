    162          //---------------------------------------------------------------------------------------------------------------------
    163          /**
    164           *  @brief      Initializes the module variables
    165           */
    166          void AccelDiscover__Initialize(uint8 port, uint8 address)
    167          {
    168              AccelDiscover.Address = address;
    169              AccelDiscover.Port = port;
    170          
    171              // Chip Select pin
    172              Gpio__PinConfig(SPI_CS_PORT, SPI_CS_PIN, OUTPUT_PUSHPULL);
    173          #if (SPI_ENABLED == 1)
    174              // Set Chip Select pin low for SPI communication
    175              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);
    176          #else
    177              // Set Chip Select pin high for I2C communication
    178              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);
    179          #endif
    180          
    181              AccelDiscoverInitialize();
    182          }
    183          
    184          //---------------------------------------------------------------------------------------------------------------------
    185          /**
    186           *  @brief
    187           */
    188          void AccelDiscover__Execute(void)
    189          {
    190              // Update the local time keeping variable.
    191              AccelDiscover.Timer++;
    192          
    193              // Run the state machine.
    194              AccelDiscoverExecute();
    195          }
    196          
    197          //---------------------------------------------------------------------------------------------------------------------
    198          /**
    199           *  @brief  Returns the unique accelerometer device ID
    200           *  @retval 0x33(51d) : ST LISxDH
    201           *  @retval 0x86(134d): NXP FXLS8974
    202           */
    203          uint8 AccelDiscover__GetId(void)
    204          {
    205              return (AccelDiscover.Id);
    206          }
    207          
    208          //---------------------------------------------------------------------------------------------------------------------
    209          /**
    210           *  @brief  Returns the completion of the auto discovery
    211           *  @return TRUE if a known accelerometer has been discovered, else FALSE
    212           */
    213          BOOL_TYPE AccelDiscover__IsComplete(void)
    214          {
    215              return((Accel_Discover_State == STATE_ACCEL_DISCOVER_COMPLETE) ? TRUE : FALSE);
    216          }
