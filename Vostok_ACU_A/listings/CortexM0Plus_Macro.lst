  210                           ; Function Name  : StartupRegisterTest
  211                           ; Description    : Full Cortex-M0 CPU test at
                                 start-up
  212                           ;                  Note: when possible, BRANCH
                                 are 16-bit only (depending on
  213                           ;                  relative offset to final BL
                                 instruction)
  214                           ; Input          : None.
  215                           ; Output         : Branch directly to a Fail
                                 Safe routine in case of failure
  216                           ; Return         : TRUE (=1)
  217                           ;*********************************************
                                **********************************/
  218                           __StartupRegisterTest:
  219                                   ;save the register value to be
                                 tested
  220    00000050 12B5                  PUSH     {R1, R4, LR}
  221                                   
  222    00000052 0020              MOVS R0, #0x00000000                ; Set
                                          Z(ero) Flag
  223    00000054 0FD1              BNE srt_fail                        ; Fails
                                          if Z clear
  224    00000056 0138              SUBS R0,#1                          ; Set
                                          N(egative) Flag
  225    00000058 0DD5              BPL srt_fail                        ; Fails
                                          if N clear
  226    0000005A 0230              ADDS R0,#2                          ; Set
                                          C(arry) Flag and do not set
                                          Z
  227    0000005C 0BD3              BCC srt_fail                        ; Fails
                                          if C clear
  228    0000005E 4148              LDR R0, = 0x80000000                       
                                         ; Prepares Overflow test
  229    00000060 0018              ADDS R0, R0, R0                     ; Set
                                          V(overflow) Flag
  230    00000062 08D7              BVC srt_fail                               
                                          ; Fails if V clear
  231    00000064 EFF30080          MRS R0, APSR                        ; Get
                                         Status register
  232    00000068 3F49              LDR R1, = 0x70000000                       
                                         ; Prepares Overflow test
  233    0000006A 8842              CMP R0, R1                                 
                                                 ; Verifies that Z=C=V=1
  234    0000006C 03D1              BNE srt_fail                               
                                          ; Fails if Q+N+C=V clear
  235                               
  236                               srt_pass:
  237    0000006E 00F005F8          BL __RunRegisterTest
  238                               ;restore the register value
  239    00000072 12BD                  POP      {R1, R4, PC}
  240    00000074 7047              BX LR               ; return to the
                                                         caller
  241                           
  242                               srt_fail:
  243                               ;restore the register value
  244    00000076 12BD                  POP      {R1, R4, PC}
  245                                   
  246    00000078 0020                  MOVS R0, #0x0
  247    0000007A 7047                  BX LR               ; return to the
                                                             caller
  248                                   
  249                           ;*********************************************
                                **********************************
  250                           ; Function Name  : RunRegisterTest
  251                           ; Description    : Full Cortex-M0 CPU test
                                 during run-time
  252                           ;                  Note: when possible, BRANCH
                                 are 16-bit only (depending on
  253                           ;                  relative offset to final BL
                                 instruction)
  254                           ; Input          : None.
  255                           ; Output         : Branch directly to a Fail
                                 Safe routine in case of failure
  256                           ; Return         : TRUE (=1) if test is
                                 ok
  257                           ;*********************************************
                                **********************************/
  258                           __RunRegisterTest:
  259                           
  260    0000007C FEB4              PUSH     {R1, R2, R3, R4, R5, R6,
                                              R7}
  261                               ; Register R0 (holds value returned by the
                                 function)
  262                               
  263                               ; Register R0 and R1
  264    0000007E 3B48              LDR R0,=0xAAAAAAAA
  265    00000080 3A49              LDR R1,=0xAAAAAAAA
  266    00000082 8842              CMP R0, R1
  267    00000084 6AD1              BNE rrt_fail
  268    00000086 3A48              LDR R0,=0x55555555
  269    00000088 3949              LDR R1,=0x55555555
  270    0000008A 8842              CMP R0, R1
  271    0000008C 66D1              BNE rrt_fail
  272    0000008E 0121              MOVS R1, #0x01            ; For ramp
                                                               test
  273                           
  274                               ; Link register (Register R14)
  275                               ;LDR R0,=0xAAAAAAAA
  276                               ;LDR R14,=0xAAAAAAAA
  277                               ;CMP R0, R14
  278                               ;BNE rrt_fail
  279                               ;LDR R0,=0x55555555
  280                               ;LDR R14,=0x55555555
  281                               ;CMP R0, R14
  282                               ;BNE rrt_fail
  283                           
  284                               ; Register R2
  285    00000090 3648              LDR R0,=0xAAAAAAAA
  286    00000092 364A              LDR R2,=0xAAAAAAAA
  287    00000094 9042              CMP R0, R2
  288    00000096 61D1              BNE rrt_fail
  289    00000098 3548              LDR R0,=0x55555555
  290    0000009A 354A              LDR R2,=0x55555555
  291    0000009C 9042              CMP R0, R2
  292    0000009E 5DD1              BNE rrt_fail
  293    000000A0 0222              MOVS R2, #0x02            ; For ramp
                                                               test
  294                           
  295                               ; Register R3
  296    000000A2 3248              LDR R0,=0xAAAAAAAA
  297    000000A4 314B              LDR R3,=0xAAAAAAAA
  298    000000A6 9842              CMP R0, R3
  299    000000A8 58D1              BNE rrt_fail
  300    000000AA 3148              LDR R0,=0x55555555
  301    000000AC 304B              LDR R3,=0x55555555
  302    000000AE 9842              CMP R0, R3
  303    000000B0 54D1              BNE rrt_fail
  304    000000B2 0323              MOVS R3, #0x03            ; For ramp
                                                               test
  305                           
  306                               ; Register R4
  307    000000B4 2D48              LDR R0,=0xAAAAAAAA
  308    000000B6 2D4C              LDR R4,=0xAAAAAAAA
  309    000000B8 A042              CMP R0, R4
  310    000000BA 4FD1              BNE rrt_fail
  311    000000BC 2C48              LDR R0,=0x55555555
  312    000000BE 2C4C              LDR R4,=0x55555555
  313    000000C0 A042              CMP R0, R4
  314    000000C2 4BD1              BNE rrt_fail
  315    000000C4 0424              MOVS R4, #0x04            ; For ramp
                                                               test
  316                           
  317                               ; Register R5
  318    000000C6 2948              LDR R0,=0xAAAAAAAA
  319    000000C8 284D              LDR R5,=0xAAAAAAAA
  320    000000CA A842              CMP R0, R5
  321    000000CC 46D1              BNE rrt_fail
  322    000000CE 2848              LDR R0,=0x55555555
  323    000000D0 274D              LDR R5,=0x55555555
  324    000000D2 A842              CMP R0, R5
  325    000000D4 42D1              BNE rrt_fail
  326    000000D6 0525              MOVS R5, #0x05            ; For ramp
                                                               test
  327                           
  328                               ; Register R6
  329    000000D8 2448              LDR R0,=0xAAAAAAAA
  330    000000DA 244E              LDR R6,=0xAAAAAAAA
  331    000000DC B042              CMP R0, R6
  332    000000DE 3DD1              BNE rrt_fail
  333    000000E0 2348              LDR R0,=0x55555555
  334    000000E2 234E              LDR R6,=0x55555555
  335    000000E4 B042              CMP R0, R6
  336    000000E6 39D1              BNE rrt_fail
  337    000000E8 0626              MOVS R6, #0x06            ; For ramp
                                                               test
  338                           
  339                               ; Register R7
  340    000000EA 2048              LDR R0,=0xAAAAAAAA
  341    000000EC 1F4F              LDR R7,=0xAAAAAAAA
  342    000000EE B842              CMP R0, R7
  343    000000F0 34D1              BNE rrt_fail
  344    000000F2 1F48              LDR R0,=0x55555555
  345    000000F4 1E4F              LDR R7,=0x55555555
  346    000000F6 B842              CMP R0, R7
  347    000000F8 30D1              BNE rrt_fail
  348    000000FA 0727              MOVS R7, #0x07            ; For ramp
                                                               test
  349                           
  350    000000FC 0020              MOVS R0, #0x00            ; For ramp
                                                               test
  351                           
  352                               ; Ramp pattern verification
  353    000000FE 0028              CMP R0, #0x00
  354    00000100 2CD1              BNE rrt_fail
  355    00000102 0129              CMP R1, #0x01
  356    00000104 2AD1              BNE rrt_fail
  357    00000106 022A              CMP R2, #0x02
  358    00000108 28D1              BNE rrt_fail
  359    0000010A 032B              CMP R3, #0x03
  360    0000010C 26D1              BNE rrt_fail
  361    0000010E 042C              CMP R4, #0x04
  362    00000110 24D1              BNE rrt_fail
  363    00000112 052D              CMP R5, #0x05
  364    00000114 22D1              BNE rrt_fail
  365    00000116 062E              CMP R6, #0x06
  366    00000118 20D1              BNE rrt_fail
  367    0000011A 072F              CMP R7, #0x07
  368    0000011C 1ED1              BNE rrt_fail
  369                           
  370                               ; Process Stack pointer (banked Register
                                 R13)
  371    0000011E EFF30980          MRS R0, PSP         ; Save process stack
                                                         value
  372    00000122 1449              LDR R1, =0xAAAAAAA8     ; Test is different
                                                             (PSP is word
                                                             aligned)
  373    00000124 81F30988          MSR PSP, R1         ; load process stack
                                                         value
  374    00000128 EFF30982          MRS R2, PSP         ; Get back process
                                                         stack value
  375    0000012C 8A42              CMP R2, R1          ; Verify value
  376    0000012E 15D1              BNE rrt_fail
  377    00000130 1149              LDR R1, =0x55555554     ; Test is different
                                                             (PSP is word
                                                             aligned)
  378    00000132 81F30988          MSR PSP, R1         ; load process stack
                                                         value
  379    00000136 EFF30982          MRS R2, PSP         ; Get back process
                                                         stack value
  380    0000013A 8A42              CMP R2, R1          ; Verify value
  381    0000013C 0ED1              BNE rrt_fail
  382    0000013E 80F30988          MSR PSP, R0         ; Restore process stack
                                                         value
  383                           
  384                               ; Stack pointer (Register R13)
  385    00000142 EC46              MOV R12, R13            ; Contains the
                                                             return address and
                                                             must be saved
  386    00000144 0B49              LDR R1, =0xAAAAAAA8     ; It must be loaded
                                                             half-word by
                                                             half-word
  387    00000146 8D46              MOV R13, R1             ; Contains the
                                                             return address and
                                                             must be saved
  388    00000148 8D45              CMP R13, R1             ; and compared with
                                                             another register
  389    0000014A 07D1              BNE rrt_fail
  390    0000014C 0A49              LDR R1, =0x55555554     ; It must be loaded
                                                             half-word by
                                                             half-word
  391    0000014E 8D46              MOV R13, R1             ; Contains the
                                                             return address and
                                                             must be saved
  392    00000150 8D45              CMP R13, R1             ; and compared with
                                                             another register
  393    00000152 03D1              BNE rrt_fail
  394    00000154 E546              MOV R13, R12
  395                           
  396                               rrt_pass:   
  397                               ;restore the register value
  398    00000156 FEBC              POP      {R1, R2, R3, R4, R5, R6,
                                              R7}
  399                           
  400    00000158 0120              MOVS R0, #0x1
  401    0000015A 7047              BX LR               ; return to the
                                                         caller
  402                           
  403                               rrt_fail:
  404                               ;restore the register value
  405    0000015C FEBC              POP      {R1, R2, R3, R4, R5, R6,
                                              R7}
  406                           
  407    0000015E 0020              MOVS R0, #0x0
  408    00000160 7047              BX LR               ; return to the
                                                         caller
