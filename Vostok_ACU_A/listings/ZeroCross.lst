   1211                  }
   1212          
   1213                  for (uint8 gpio_req_index = 0U; gpio_req_index < ((uint8) ZEROCROSS_GPIO_REQUEST_NUMBER); gpio_req_index++)
   1214                  {
   1215                      ZEROCROSS_GPIO_CONFIG_TYPE *cfg_ptr = &ZeroCross_Gpio_Pin_Configuration[gpio_req_index];
   1216                      if(cfg_ptr->Gpio_Id != ZEROCROSS_ID_INVALID)
   1217                      {
   1218                          ZEROCROSS_GPIO_REQUEST_TYPE *processing_ptr = &ZeroCross_Gpio_Processing[gpio_req_index];
   1219          
   1220                          if (processing_ptr->Gpio_Id == cfg_ptr->Gpio_Id)
   1221                          {
   1222                              BOOL_TYPE gpio_value = processing_ptr->Active_value;
   1223          
