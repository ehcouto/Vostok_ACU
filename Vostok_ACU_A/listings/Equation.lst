    185          // -- Private Structure Type Declarations --
    186          
    187          //! Structure that holds variables for evaluating an equation.
    188          //! Variables include the stack.
    189          typedef struct EQ_STRUCT
    190          {
    191              //! Holds 32-bit values pushed onto the stack as part of the equation evaluation.
    192              sint32 Data[EQUATION_STACK_SIZE];
    193          
    194              //! Pointer where the setting file data for this equation is located.
    195              SETTINGFILE_OFFSET_TYPE Pointer;
    196          
    197              //! Index to the element on the top of the stack's Data[] array.
    198              sint8 Index;
    199          
    200              //! Error associated with the equation evaluation.
    201              MODULE_EQUATION_LOG_MESSAGE_ID_TYPE Error;
    202          
    203              //! TRUE if the operation is part of a prediction; otherwise FALSE.
    204              //! Will use pre-determined predicted values for predictions.
    205              BOOL_TYPE Predict;
    206          } EQ_TYPE;
    207          
    208          //! The parameter sent to all operator functions.
    209          typedef struct OPERATOR_PARAM_STRUCT
    210          {
    211              uint8* Element_Params;
    212              sint32* Values;
    213              EQ_TYPE* Equation;
    214              sint8 Extra_Param;
    215          } EQ_OPERATOR_PARAMS_TYPE;
    216          
    217          //! A function type used by all operator functions.
    218          typedef void (*FUNC_OPERATOR) (EQ_OPERATOR_PARAMS_TYPE params);
    219          
    220          //! A structure that describes one of the input dimensions
    221          typedef struct MAPPED_INPUT_STRUCT
    222          {
    223              uint16 Index;                                   //!< A fixed-point index using INDEX_SCALE
    224              uint8 Size;                                     //!< The number of elements in the input dimension
    225          } MAPPED_INPUT_TYPE;
    226          
    227          //! The result of a binary search
    228          typedef struct NEAR_VALUES_STRUCT
    229          {
    230              sint32 Value_Lo;                                //!< The value from the list at Index_Lo
    231              sint32 Value_Hi;                                //!< The value from the list at Index_Hi
    232              uint8 Index_Lo;                                 //!< The highest index whose value is <= the input
    233              uint8 Index_Hi;                                 //!< The lowest index whose value is >= the input
    234          } NEAR_VALUES_TYPE;
    235          
    236          //! A structure used to describe operator elements that can be used in equations.
    237          typedef struct OPERATOR_STRUCT
    238          {
    239              FUNC_OPERATOR Function;
    240              ELEMENT_TYPE Element;
    241              uint8 Num_Of_Element_Params;
    242              sint8 Num_Of_Stack_Inputs;
    243              sint8 Extra_Param;
    244          } OPERATOR_TYPE;
    245          
    246          //! Setting file displacement data for an equation.
    247          typedef struct EQUATION_STRUCT
    248          {
    249              uint8 Size      : 6;
    250              uint8 Version   : 2;
    251              uint8 Data[63];
    252          } SF_EQUATION_TYPE;
    253          
    254          //! The setting file data structure for a list of values
    255          typedef struct SF_LOOK_UP_LIST_STRUCT
    256          {
    257              uint16 Num_Of_Values            : 12;
    258              uint16 Data_Type                : 4;            //!< Value is of type DATATYPE_TYPE from C_Extensions.h
    259              sint16 Values[MAX_OUTPUT_LIST_SIZE / sizeof(sint16)];
    260          } SF_LOOK_UP_LIST_TYPE;
    261          
    262          //! Setting file displacement data for a look-up table.
    263          typedef struct LOOK_UP_TABLE_STRUCT
    264          {
    265              uint8 Number_Of_Dimensions      : 4;
    266              uint8 Version                   : 4;
    267              LOOK_UP_METHOD_TYPE Method;
    268              uint16 List_Displacements[DISPLACEMENTS_ARRAY_SIZE];
    269          } SF_LOOK_UP_TABLE_TYPE;
    270          
    271          //! Part of the setting file for a multi-dimensional table that holds input search methods
    272          typedef struct SF_METHOD_PAIR_STRUCT
    273          {
    274              LOOK_UP_METHOD_TYPE Method2     : 4;
    275              LOOK_UP_METHOD_TYPE Method1     : 4;
    276          } SF_METHOD_PAIR_TYPE;
    277          
