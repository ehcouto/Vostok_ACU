     54           * @brief
     55           * @return
     56           */
     57          uint8 DoorSwitchGI__Allocate(void)
     58          {
     59              uint8 retval;
     60              retval = 0xFF;
     61              if (DoorSwitchGI_Allocation < HBL_GI_NUM_DOORSWITCH)
     62              {
     63                  retval = DoorSwitchGI_Allocation;
     64                  DoorSwitchGI_Allocation++;
     65          
     66              }
     67              return (retval);
     68          }
