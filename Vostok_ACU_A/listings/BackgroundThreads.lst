    108          void BackgroundThreads__Initialize(void)
    109          {
    110              #if (BACKGROUNDTHREADS_FEATURE == ENABLED)
    111                  BACKGROUNDTHREADS_DATA_TYPE *data_ptr;
    112                  uint16 stack_offset;
    113                  uint8 index;
    114          
    115                  memset(BackgroundThreads_Data, 0, sizeof(BackgroundThreads_Data));
    116                  memset(BackgroundThreads_Tcb, 0, sizeof(BackgroundThreads_Tcb));
    117                  BackgroundThreads_Stack_Allocated = 1;
    118                  // Check if reserved stack area fits the thread configuration
    119                  for(index = 0; index < NUM_BG_THREADS; index++)
    120                  {
    121                      BackgroundThreads_Stack_Allocated += BACKGROUNDTHREADS_THREADS_STACKS[index]/sizeof(uint32)+1;
    122                  }
    123                  // Allow Background thread if stack fits the space requested and
    124                  // OS supports Round Robin feature or there is only one thread defined
    125                  if(((OS_RR_SUPPORTED != 0) || (NUM_BG_THREADS == 1)) &&
    126                      (BackgroundThreads_Stack_Allocated <= ELEMENTS_IN_ARRAY(BackgroundThreads_Stack_Area)))
    127                  {
    128                      stack_offset = 0;
    129                      for(index = 0; index < NUM_BG_THREADS; index++)
    130                      {
    131                          data_ptr = &BackgroundThreads_Data[index];
    132                          BackgroundThreads_Stack_Area[stack_offset] = BACKGROUNDTHREADS_STACK_KEYWORD;
    133                          stack_offset++;
    134                          OS_CreateTaskEx(&BackgroundThreads_Tcb[index], BACKGROUNDTHREADS_NAME BACKGROUNDTHREADS_THREADS_PRIO,
    135                              BackgroundThreadsExec, &BackgroundThreads_Stack_Area[stack_offset],
    136                              BACKGROUNDTHREADS_THREADS_STACKS[index], BACKGROUNDTHREADS_TIME_SLICE, (void *) data_ptr);
    137                          stack_offset += BACKGROUNDTHREADS_THREADS_STACKS[index]/sizeof(uint32);
    138                      }
    139                      BackgroundThreads_Stack_Area[ELEMENTS_IN_ARRAY(BackgroundThreads_Stack_Area)-1] = BACKGROUNDTHREADS_STACK_KEYWORD;
    140                  }
    141              #endif
    142          }
