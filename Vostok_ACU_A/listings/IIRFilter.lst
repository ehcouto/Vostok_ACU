     78          /**
     79           *  @brief      Determine a filtered value based on an input value.
     80           *
     81           *  @param      iir_value = A value that stores the current filtered value with additional precision.
     82           *                      The additional precision required depends on the alpha_bits.
     83           *  @param      new_value = An input to the filter system with normal precision.
     84           *  @param      alpha_bits = Exponent of alpha.  alpha = 2 ^ (-alpha_bits).
     85           *
     86           *              Sum of new_value resolution and alpha_bits must not be higher than 32 bits
     87           *
     88           *  @return     Returns the updated filtered value after rounding.
     89           */

   \                                 In section .text, align 2, keep-with-next
     90          ADDR_SIZE_IIRFILTER uint16 IIRFilterLong(uint32 *iir_value, uint16 new_value, uint8 alpha_bits)
     91          {
     92              *iir_value += new_value - (((*iir_value >> (alpha_bits - 1)) + 1) >> 1);
