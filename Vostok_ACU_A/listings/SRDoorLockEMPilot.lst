    100          //---------------------------------------------------------------------------------------------------------------------
    101          /**
    102           *  @brief      It Initializes the module DoorLockEMPilot and its variables
    103           *
    104           */
    105          void SRDoorLockEMPilot__Initialize(void )
    106          {
    107              SRData__UpdateByte(&SRDoorLockEMPilot_Allocation, &N_SRDoorLockEMPilot_Allocation, 0);
    108              SRData__Fill(SRDoorLockEMPilot_Data, N_SRDoorLockEMPilot_Data, 0, sizeof(SRDoorLockEMPilot_Data));
    109          
    110          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    111              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRDOORLOCKEMPILOT);
    112          #endif
    113          
    114          }
    115          
    116          //---------------------------------------------------------------------------------------------------------------------
    117          /**
    118           *  @brief      Allocate pilot instance for DoorlockEMPilot.
    119           *
    120           *  @return     uint8 result - Allocation result.
    121           *  @retval     0-254 - Pilot allocation instance.
    122           *  @retval     0xFF - Allocation failed.
    123           */
    124          uint8 SRDoorLockEMPilot__Allocate(void )
    125          {
    126              uint8 retval = 0xFF;
    127          
    128              if (SRData__CheckByte(&SRDoorLockEMPilot_Allocation, &N_SRDoorLockEMPilot_Allocation) == SRDATA_OK)
    129              {
    130                  if (SRDoorLockEMPilot_Allocation < HBL_PILOT_NUM_SRDOORLOCKEM)
    131                  {
    132                      retval = SRDoorLockEMPilot_Allocation;
    133                      SRData__UpdateByte(&SRDoorLockEMPilot_Allocation, &N_SRDoorLockEMPilot_Allocation,
    134                      SRDoorLockEMPilot_Allocation + 1);
    135                  }
    136              }
    137              else
    138              {
    139                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_IMPULSES_DOOR_LOCK, 0xFF);
    140              }
    141              return (retval);
    142          }
    143          
    144          //---------------------------------------------------------------------------------------------------------------------
    145          /**
    146           *  @brief      Initialize DoorLockEMPilot instance.
    147           *
    148           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
    149           *
    150           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot instance initialization.
    151           *  @retval     PASS - Instance initialization succeeded.
    152           *  @retval     FAIL - Instance initialization failed.
    153           */
    154          PASS_FAIL_TYPE SRDoorLockEMPilot__InitializeInstance(HBL_LOAD_TYPE * load )
    155          {
    156              PASS_FAIL_TYPE retval = FAIL;
    157              uint8 index = load->Pilot_Data_Index;
    158              SRDOORLOCKEMPILOT_PARAM_TYPE *param_ptr = (SRDOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    159              SRDOORLOCKEMPILOT_DATA_TYPE *ptr;
    160              SRDOORLOCKEMPILOT_DATA_TYPE *n_ptr;
    161              HBL_LOAD_STATUS_TYPE tmp_load;
    162              BOOL_TYPE pin_val;
    163              uint8 *ptr_pin_table;
    164              uint8 fbk_index;
    165              uint8 virtual_pin;
    166          
    167              if ((CheckItem(index)) && (param_ptr != NULL ))
    168              {
    169                  ptr = &SRDoorLockEMPilot_Data[index];
    170                  n_ptr = &N_SRDoorLockEMPilot_Data[index];
    171          
    172                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, (uint8) SRDOORLOCKEM_STATUS_INIT); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    173                  SRData__UpdateByte(&ptr->Period, &n_ptr->Period, (uint8) SRDOORLOCKEM_INITIAL_PERIOD);
    174                  tmp_load.Load.Status = HBL_LOAD_STATUS_INITIALIZE;
    175                  tmp_load.Load.Cur_Reg = 0;
    176                  SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    177                  SRData__UpdateShort(&ptr->Retries_Counter, &n_ptr->Retries_Counter, 0);
    178          
    179                  // Check if a SRFeedback LLI is configured for pin synchronization
    180                  fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_SRFEEDBACK);
    181                  if (fbk_index >= Hbl__GetNumLLI())
    182                  {
    183                      // Fallback for backward compatibility - Check that this LLI ID is handled by a class B module to use it!!
    184                      fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_FEEDBACK);
    185                  }
    186                  ptr_pin_table = Hbl__GetLLIPinTabPtr(fbk_index);
    187          
    188                  if (ptr_pin_table == NULL)
    189                  {
    190                      virtual_pin = VirtualPin__GetNumOf();
    191                  }
    192                  else
    193                  {
    194                      virtual_pin = ptr_pin_table[0];
    195                  }
    196                  SRData__UpdateByte(&ptr->Fbk_Pin, &n_ptr->Fbk_Pin, virtual_pin);
    197          
    198                  virtual_pin = load->Pin_Ptr[0];
    199                  if ((virtual_pin < VirtualPin__GetNumOf()) && (VIRTUALPIN_TABLE[virtual_pin].port != 0xFF))
    200                  {
    201                      pin_val = (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    202                      pin_val &= TRUE;
    203                      Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    204                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin,
    205                      VIRTUALPIN_TABLE[virtual_pin].pin_config);
    206                      SRData__UpdateByte(&ptr->Last_Pin_Out_Value, &n_ptr->Last_Pin_Out_Value, pin_val);
    207          
    208                      if (Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin,
    209                      VIRTUALPIN_TABLE[virtual_pin].pin_config, pin_val) == TRUE)
    210                      {
    211                          retval = PASS;
    212                      }
    213                  }
    214          
    215              }
    216          
    217              return (retval);
    218          }
    219          
    220          //---------------------------------------------------------------------------------------------------------------------
    221          /**
    222           *  @brief      Set DoorLockEMPilot instance request.
    223           *
    224           *  @param      HBL_LOAD_TYPE *load - Pointer to associated DoorLockEMPilot instance.
    225           *
    226           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    227           *
    228           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot request.
    229           *  @retval     PASS - Instance request succeeded.
    230           *  @retval     FAIL - Instance request failed.
    231           */
    232          PASS_FAIL_TYPE SRDoorLockEMPilot__Request(HBL_LOAD_TYPE * load ,void * data )
    233          {
    234              PASS_FAIL_TYPE retval = FAIL;
    235              uint8 index = load->Pilot_Data_Index;
    236          
    237              if (CheckItem(index))
    238              {
    239                  uint8 new_target = (*(uint8 *)data);
    240                  uint8 new_triac_on = (new_target & SRDOORLOCKEM_PROCESSED_KEEP_PIN_MASK) ? TRUE : FALSE;
    241                  new_target &= ~SRDOORLOCKEM_PROCESSED_KEEP_PIN_MASK;
    242          
    243                  SRData__UpdateByte(&SRDoorLockEMPilot_Data[index].Requested, &N_SRDoorLockEMPilot_Data[index].Requested,
    244                      new_target);
    245                  SRData__UpdateByte(&SRDoorLockEMPilot_Data[index].Request_Triac_On, &N_SRDoorLockEMPilot_Data[index].Request_Triac_On,
    246                      new_triac_on);
    247                  retval = PASS;
    248              }
    249          
    250              return (retval);
    251          }
    252          
    253          //---------------------------------------------------------------------------------------------------------------------
    254          /**
    255           *  @brief      Process DoorLockEMPilot instance.
    256           *
    257           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    258           *
    259           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot instance process.
    260           *  @retval     PASS - Instance process succeeded.
    261           *  @retval     FAIL - Instance process failed.
    262           */
    263          PASS_FAIL_TYPE SRDoorLockEMPilot__Process(HBL_LOAD_TYPE * load )
    264          {
    265              PASS_FAIL_TYPE retval = FAIL;
    266              uint8 index = load->Pilot_Data_Index;
    267          
    268              if (CheckItem(index))
    269              {
    270                  SRDOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    271                  SRDOORLOCKEMPILOT_DATA_TYPE *ptr;
    272                  SRDOORLOCKEMPILOT_DATA_TYPE *n_ptr;
    273          
    274                  param_ptr = (SRDOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    275                  ptr = &SRDoorLockEMPilot_Data[index];
    276                  n_ptr = &N_SRDoorLockEMPilot_Data[index];
    277          
    278          		// Prevent any state update if Time_Spacing time has not been elapsed
    279                  if ((ptr->Retries_Counter >= (param_ptr->Time_Spacing * SRDOORLOCKEM_TIME_SPACING_UNIT_MS))
    280                      && (ptr->Requested != ptr->Processed))
    281                  {
    282                      SRDOORLOCKEM_STATUS_TYPE new_status;
    283                      HBL_LOAD_STATUS_TYPE tmp_load;
    284                      HBL_CONSISTENCY_TYPE requested_consistency;
    285          
    286                      tmp_load.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    287                      tmp_load.Load.Cur_Reg = ptr->Requested;
    288                      requested_consistency.Byte = Hbl__GetOwnLoadConsistency(load, tmp_load.Byte);
    289          
    290                      if (ptr->Requested == (uint8) OFF)
    291                      {
    292                          switch (ptr->Status)
    293                          {
    294                              case SRDOORLOCKEM_STATUS_DOOR_LOCKED:
    295                                  if (requested_consistency.Consistency.Value != HBL_CONSISTENCY_OK)
    296                                  {
    297                                      tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    298                                      tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    299                                      new_status = SRDOORLOCKEM_STATUS_DOOR_UNLOCKING;
    300                                      SRData__UpdateByte(&ptr->Retries, &n_ptr->Retries, param_ptr->Max_Retries);
    301                                  }
    302                                  else
    303                                  {
    304                                      // If current consistency related to Requested value already match, go directly to
    305                                      // new status - this prevents to change door lock status
    306                                      new_status = SRDOORLOCKEM_STATUS_DOOR_UNLOCKED;
    307                                  }
    308                                  SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    309                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    310                                  (uint8) new_status);
    311                                  retval = PASS;
    312                                  break;
    313          
    314                              case SRDOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    315                                  tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    316                                  tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    317                                  SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    318                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    319                                      (uint8) SRDOORLOCKEM_STATUS_INIT);
    320                                  retval = PASS;
    321                                  break;
    322          
    323                              default:
    324                                  break;
    325                          }
    326                      }
    327                      // Everything else is considered Door Locked target
    328                      else
    329                      {
    330                          switch (ptr->Status)
    331                          {
    332                              case SRDOORLOCKEM_STATUS_DOOR_UNLOCKED:
    333                                  if (requested_consistency.Consistency.Value != HBL_CONSISTENCY_OK)
    334                                  {
    335                                      tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    336                                      tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    337                                      new_status = SRDOORLOCKEM_STATUS_DOOR_LOCKING;
    338                                      SRData__UpdateByte(&ptr->Retries, &n_ptr->Retries, param_ptr->Max_Retries);
    339                                  }
    340                                  else
    341                                  {
    342                                      // If current consistency related to Requested value already match, go directly to
    343                                      // new status - this prevents to change door lock status
    344                                      new_status = SRDOORLOCKEM_STATUS_DOOR_LOCKED;
    345                                  }
    346                                  SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    347                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    348                                  (uint8) new_status);
    349                                  retval = PASS;
    350                                  break;
    351          
    352                              case SRDOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    353                                  tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    354                                  tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    355                                  SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    356                                  SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    357                                      (uint8) SRDOORLOCKEM_STATUS_INIT);
    358                                  retval = PASS;
    359                                  break;
    360          
    361                              default:
    362                                  break;
    363                          }
    364                      }
    365                  }
    366                  else if ((ptr->Status == SRDOORLOCKEM_STATUS_INIT) ||
    367                      (ptr->Requested  == ptr->Processed))
    368                  {
    369                      retval = PASS;
    370                  }
    371          
    372                  // Update Processed data only when status has been updated
    373                  if (retval == PASS)
    374                  {
    375                      SRData__UpdateByte(&ptr->Processed, &n_ptr->Processed, ptr->Requested);
    376                  }
    377          
    378                  // Check Request_Triac_On and Process_Triac_On changes
    379                  if (ptr->Request_Triac_On != ptr->Process_Triac_On)
    380                  {
    381                      /* If Process_Triac_On was set, pin has been forced ON and this could alter Door lock device status regardless of
    382                       * Status instance field value; in order to align it properly and initialize will be performed.
    383                       */
    384                      if(ptr->Process_Triac_On)
    385                      {
    386                          HBL_LOAD_STATUS_TYPE tmp_load;
    387          
    388                          tmp_load.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    389                          tmp_load.Load.Cur_Reg = ptr->PilotStatus.Load.Cur_Reg;
    390                          SRData__UpdateByte(&ptr->PilotStatus.Byte, &n_ptr->PilotStatus.Byte, tmp_load.Byte);
    391                          SRData__UpdateByte((uint8 *) &ptr->Status, (uint8 *) &n_ptr->Status, //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    392                              (uint8) SRDOORLOCKEM_STATUS_INIT);
    393                      }
    394                      SRData__UpdateByte(&ptr->Process_Triac_On, &n_ptr->Process_Triac_On,
    395                          ptr->Request_Triac_On);
    396                      retval = PASS;
    397                  }
    398          
    399              }
    400          
    401          
    402              return (retval);
    403          }
