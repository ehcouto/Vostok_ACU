    816          /**
    817           * @brief - This function manages the Crossloads of type Reverse Switch Load
    818           *
    819           * @param CROSSLOAD_DATA_TYPE * , CROSSLOAD_PARAMETERS_TYPE *
    820           */
    821          static void ReverseLoadRelayHandler(HBL_CROSS_LOAD_TYPE *cfg_ptr, CROSSLOAD_DATA_TYPE * data_ptr, uint8 *hbl_prio_ptr)
    822          {
    823              CROSSLOAD_PARAMETERS_TYPE *param_ptr = cfg_ptr->Parameter_Ptr;
    824              uint8 my_prio = GetLoadPriority(cfg_ptr->Crossload_Position, hbl_prio_ptr);
    825              uint8 position_index;
    826              uint8 load_check_index; // Load index to check if switch has to be executed
    827              uint8 load_keep_index;  // Load index to check if swict position should be kept
    828              uint8 load_check_prio;
    829              uint8 load_keep_prio;
    830              uint8 *load_request_ptr;
    831              uint8 load_request_len;
    832              BOOL_TYPE do_switch = FALSE;
    833              BOOL_TYPE keep_status = FALSE;
    834          
    835              for(position_index = 0 ; position_index < cfg_ptr->Number_Of_Couples ; position_index++)
    836              {
    837                  // Place check and keep positions according to Reverse Switch status
    838                  if (data_ptr->Processed == OFF)
    839                  {
    840                      load_check_index = param_ptr->Load_Position[position_index].On;
    841                      load_keep_index = param_ptr->Load_Position[position_index].Off;
    842                  }
    843                  else
    844                  {
    845                      load_check_index = param_ptr->Load_Position[position_index].Off;
    846                      load_keep_index = param_ptr->Load_Position[position_index].On;
    847                  }
    848          
    849                  load_keep_prio = GetLoadPriority(load_keep_index, hbl_prio_ptr);
    850                  load_check_prio = GetLoadPriority(load_check_index, hbl_prio_ptr);
    851          
    852                  if (load_keep_prio >= my_prio)
    853                  {
    854                      // If keep position is ON: keep actual status
    855                      load_request_ptr = Hbl__GetRequestedLoad(load_keep_index);
    856                      if (load_request_ptr != NULL)
    857                      {
    858                          load_request_len = Hbl__GetLoadDataSize(load_keep_index);
    859          
    860                          // Perform clear only if Switch load priorty is lower than load to keep
    861                          // otherwise load status is kept as is
    862                          if (memcmp(load_request_ptr, Hbl__GetFlushBuffer(), load_request_len) != 0)
    863                          {
    864                              keep_status = TRUE;
    865                              do_switch = FALSE;
    866                              if(PASS == Hbl__SetLoadRequestByIndex(load_check_index,
    867                                  (HBL_PRIORITY_TYPE)load_check_prio, (uint8 *)Hbl__GetFlushBuffer()))   //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    868                              {
    869                                  ResetCrossLoadTransition(load_check_index);
    870                              }
    871                          }
    872                      }
    873                  }
    874          
    875                  if ((keep_status == FALSE) &&
    876                      (load_check_prio >= my_prio))
    877                  {
    878                      load_request_ptr = Hbl__GetRequestedLoad(load_check_index);
    879                      if (load_request_ptr != NULL)
    880                      {
    881                          load_request_len = Hbl__GetLoadDataSize(load_check_index);
    882          
    883                          // Perform Reverse Switch load transition only if priorty is higher than maximum of other loads *
    884                          if(memcmp(load_request_ptr, (uint8 *)Hbl__GetFlushBuffer(), load_request_len) != 0)
    885                          {
    886                              do_switch = TRUE;
    887                          }
    888                      }
    889                  }
    890              }
    891          
    892              switch (data_ptr->Generic_State)
    893              {
    894                  case CROSSLOAD_STEADY_STATE:
    895                  case CROSSLOAD_FORCED_STATE:
    896                  {
    897          
    898                      if (keep_status == FALSE)
    899                      {
    900                          // No keep status required: check if Switch Load request changed by
    901                          // direct request or via other load
    902                          if (do_switch == FALSE)
    903                          {
    904                              if (data_ptr->Processed != OFF)
    905                              {
    906                                  if ((data_ptr->Requested != OFF) && (my_prio > SRHBL_PRIORITY_MINIMUM))
    907                                  {
    908                                      data_ptr->Generic_State = CROSSLOAD_FORCED_STATE;
    909                                  }
    910                                  else if (data_ptr->Generic_State == CROSSLOAD_FORCED_STATE)
    911                                  {
    912                                      data_ptr->Generic_State = CROSSLOAD_STEADY_STATE;
    913                                      data_ptr->Processed = OFF;
    914                                  }
    915                                  else
    916                                  {
    917                                      do_switch = TRUE;
    918                                  }
    919                              }
    920                              else if (data_ptr->Requested != OFF)
    921                              {
    922                                  data_ptr->Generic_State = CROSSLOAD_STEADY_STATE;
    923                                  data_ptr->Processed = ON;
    924                              }
    925                          }
    926          
    927                          if (do_switch != FALSE)
    928                          {
    929                              if (data_ptr->Processed == OFF)
    930                              {
    931                                  data_ptr->Timer = param_ptr->On_Delay;
    932                                  data_ptr->Generic_State = CROSSLOAD_ON_TRANSITION;
    933                                  if(param_ptr->On_Delay == 0)
    934                                  {
    935                                      data_ptr->Processed = ON;
    936                                  }
    937                              }
    938                              else
    939                              {
    940                                  data_ptr->Processed = OFF;
    941                                  data_ptr->Timer = param_ptr->Off_Delay;
    942                                  if(param_ptr->Off_Delay > 0)
    943                                  {
    944                                      data_ptr->Generic_State = CROSSLOAD_OFF_TRANSITION;
    945                                      for(position_index = 0 ; position_index < cfg_ptr->Number_Of_Couples ; position_index++)
    946                                      {
    947                                          load_check_index = param_ptr->Load_Position[position_index].On;
    948                                          load_check_prio = GetLoadPriority(load_check_index, hbl_prio_ptr);
    949                                          load_request_ptr = Hbl__GetProcessedLoad(load_check_index);
    950                                          if (load_request_ptr != NULL)
    951                                          {
