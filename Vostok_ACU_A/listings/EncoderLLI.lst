     19          //-------------------------------------- Include Files ----------------------------------------------------------------
     20          #include "SystemConfig.h"
     21          #include "EncoderLLI.h"
     22          
     23          #if (HBL_LLI_NUM_ENCODER > 0)
     24          #include "Gpio.h"
     25          #include <string.h>
