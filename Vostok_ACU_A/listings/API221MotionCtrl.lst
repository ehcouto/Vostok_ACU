     83          // -- Compile-Time Assertions --
     84          
     85          // The number of milliseconds per call to background must be greater than 0.
     86          // This is required to avoid divide-by-zero pre-compiler errors.
     87          CT_ASSERT(API221_MS_PER_CALL_TO_BACKGROUND > 0);
     88          
     89          // Verify that API221 event values will fit in 6 bits.
     90          // This is required by the events that use only six bits to represent the event.
     91          CT_ASSERT(API221_EVENT_COUNT <= 0x40);
