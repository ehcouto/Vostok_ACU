    211          //---------------------------------------------------------------------------------------------------------------------
    212          /**
    213           *  Measure the Negative X axis self test value and calculate the self test output change (STOC)
    214           *      STOC = (Positive Output - Negative Output) / 2
    215           *  If the STOC is within the range per the specification, continue to the Y Axis test, else fail the self test.
    216           */
    217          static void MeasureNegativeXAxis(void)
    218          {
    219              sint16 axis_data[3];
    220              if (FXLS8974__Read((sint16 *)(&axis_data)) == TRUE)
    221              {
    222                  // Set the Negative X Axis value
    223                  SelfTestFXLS8974.Negative_Measurements[0] = axis_data[0];
    224          
    225                  // Calculate Self Test Output Change (STOC): (Positive Output - Negative Output) / 2
    226                  sint16 self_test_output_change = ((SelfTestFXLS8974.Positive_Measurements[0] - SelfTestFXLS8974.Negative_Measurements[0]) >> 1);
    227          
    228                  // Compare STOC to data sheet specification for the given axis and 16g range (Defined in FXLS8974 module)
    229                  if ((self_test_output_change < -52) ||
    230                      (self_test_output_change > -19))
    231                  {
    232                      EventFailed();
    233                  }
    234                  else
    235                  {
    236                      EventPassed();
    237                  }
    238              }
    239          }
    240          
    241          
    242          //---------------------------------------------------------------------------------------------------------------------
    243          /**
    244           *  Measure the Negative Y axis self test value and calculate the self test output change (STOC)
    245           *      STOC = (Positive Output - Negative Output) / 2
    246           *  If the STOC is within the range per the specification, continue to the X Axis test, else fail the self test.
    247           */
    248          static void MeasureNegativeYAxis(void)
    249          {
    250              sint16 axis_data[3];
    251              if (FXLS8974__Read((sint16 *)(&axis_data)) == TRUE)
    252              {
    253                  // Set the Negative Y Axis value
    254                  SelfTestFXLS8974.Negative_Measurements[1] = axis_data[1];
    255          
    256                  // Calculate Self Test Output Change (STOC): (Positive Output - Negative Output) / 2
    257                  sint16 self_test_output_change = ((SelfTestFXLS8974.Positive_Measurements[1] - SelfTestFXLS8974.Negative_Measurements[1]) >> 1);
    258          
    259                  // Compare STOC to data sheet specification for the given axis and 16g range (Defined in FXLS8974 module)
    260                  if ((self_test_output_change < 19) ||
    261                      (self_test_output_change > 52))
    262                  {
    263                      EventFailed();
    264                  }
    265                  else
    266                  {
    267                      EventPassed();
    268                  }
    269              }
    270          }
