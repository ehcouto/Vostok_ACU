    130          /**
    131           * @brief   - This method converts the Digital to analog value on the specified channel
    132           * @details - Continuous Conversion -
    133           *                  DTOA_CONTINUOUS_CONVERSION_FEATURE shall be enabled
    134           *
    135           *            Single Conversion -
    136           *                  If the application is going to use only the sngle conversion then DTOA_CONTINUOUS_CONVERSION_FEATURE shall be disabled
    137           *                  for optimization
    138           *
    139           * @param channel - DTOA_CHANNEL_DEF
    140           * @param resolution - DTOA_CHANNEL_RESOLUTION_DEF
    141           * @param sampling_hz - sampling rate
    142           * @param source_address
    143           * @param size
    144           * @return
    145           *  @retval PASS - If the conversion requested is processed
    146           *  @retval FAIL - If the conversion requested is failed to process
    147           */

   \                                 In section .text, align 2, keep-with-next
    148          PASS_FAIL_TYPE Dtoa__Convert(DTOA_CHANNEL_DEF channel, DTOA_CHANNEL_RESOLUTION_DEF resolution, uint16 sampling_hz, uint32 source_address, uint32 size)
    149          {
    150              #if ((DTOA_CH1_FEATURE == ENABLED) || (DTOA_CH2_FEATURE == ENABLED))
    151          
    152                  PASS_FAIL_TYPE response;
    153                  uint32 volatile *dac_dhr_ptr;
    154          
    155                  response = FAIL;
    156          
    157                  if (source_address != 0)
    158                  {
    159                      #if (DTOA_CH2_FEATURE == ENABLED)
    160                          #if (DTOA_CH1_FEATURE == ENABLED)
    161                          if (channel == DTOA_CH2)
    162                          #endif
    163                          {
    164                              //Configure the Dtoa Channel in Analog mode
    165                              Gpio__PinConfig(DTOA_CHANNEL_2_PORT, DTOA_CHANNEL_2_PORTBIT, INPUT_ANALOG);
    166          
    167                              //clear the DMA under run
    168                              DAC.SR |= DAC_SR_DMAUDR2;
    169          
    170                              #if (DTOA_CHANNEL_RESOLUTION_HARDCODED == 0)
    171                                  if (resolution == DTOA_RESOLUTION_12BITS)
    172                                  {
    173                                      dac_dhr_ptr = &DAC.DHR12R2;
    174          
    175                                  }
    176                                  else
    177                                  {
    178                                      dac_dhr_ptr = &DAC.DHR8R2;
    179          
    180                                  }
    181                              #else
    182                                  #if (DTOA_CHANNEL_RESOLUTION_HARDCODED == 12)
    183                                      dac_dhr_ptr = &DAC.DHR12R2;
    184                                  #else
    185                                      dac_dhr_ptr = &DAC.DHR8R2;
    186                                  #endif
    187                              #endif
    188          
    189                              if (size == 1)
    190                              {
    191                                  //000: DAC channel2 is connected to external pin with Buffer enabled
    192                                  //Enable the Output buffer which is used to reduce the output impedance
    193                                  DAC.MCR &= ~DAC_MCR_MODE2;
    194          
    195                                  (*(uint32 *)dac_dhr_ptr) = (*(uint32 *)source_address);
    196          
    197                                  //Enable the Dtoa Channel
    198                                  DAC.CR |= DAC_CR_EN2;
    199          
    200                                  response = PASS;
    201                              }
    202                          }
    203                      #endif
    204          
    205                      #if (DTOA_CH1_FEATURE == ENABLED) && (DTOA_CH2_FEATURE == ENABLED)
    206                          else
    207                      #endif
    208                      #if (DTOA_CH1_FEATURE == ENABLED)
    209                      {
    210                          {
    211                              //Configure the Dtoa Channel in Analog mode
    212                              Gpio__PinConfig(DTOA_CHANNEL_1_PORT, DTOA_CHANNEL_1_PORTBIT, INPUT_ANALOG);
    213          
    214                              //clear the DMA under run
    215                              DAC.SR |= DAC_SR_DMAUDR1;
    216          
    217                              #if (DTOA_CHANNEL_RESOLUTION_HARDCODED == 0)
    218                                  if (resolution == DTOA_RESOLUTION_12BITS)
    219                                  {
    220                                      dac_dhr_ptr = &DAC.DHR12R1;
    221                                  }
    222                                  else
    223                                  {
    224                                      dac_dhr_ptr = &DAC.DHR8R1;
    225                                  }
    226                              #else
    227                                  #if (DTOA_CHANNEL_RESOLUTION_HARDCODED == 12)
    228                                      dac_dhr_ptr = &DAC.DHR12R1;
    229                                  #else
    230                                      dac_dhr_ptr = &DAC.DHR8R1;
    231                                  #endif
    232                              #endif
    233          
    234                              if (size == 1)
    235                              {
    236                                  //000: DAC channel1 is connected to external pin with Buffer enabled
    237                                  //Enable the Output buffer which is used to reduce the output impedance
    238                                  DAC.MCR &= ~DAC_MCR_MODE1;
    239          
    240                                  (*(uint32 *)dac_dhr_ptr) = (*(uint32 *)source_address);
    241          
    242                                  //Enable the Dtoa Channel and Enable the Output buffer which is used to reduce the output impedance
    243                                  DAC.CR |= DAC_CR_EN1;
    244          
    245                                  response = PASS;
    246                              }
    247                          }
    248                      }
    249                      #endif
    250                  }
    251                  return (response);
    252              #else
    253                  return (FAIL);
   \                     Dtoa__Convert: (+1)
   \   00000000   0x2000             MOVS     R0,#+0
   \   00000002   0x4770             BX       LR               ;; return
    254              #endif
    255          }
