    152          //---------------------------------------------------------------------------------------------------------------------
    153          /**
    154           *
    155           * @param input
    156           * @return
    157           */
    158          BOOL_TYPE ConductivityLLI__ICProcess(HBL_LLI_TYPE * input)
    159          {
    160              CONDUCTIVITY_DATA_TYPE *data;
    161              BOOL_TYPE retval;
    162              uint8 virtual_pin;
    163              uint8 n_read_cfg;
    164              uint32 frequency;
    165              uint16 duty;
    166          
    167              retval = FALSE;
    168          
    169              if (input->Data_Index < HBL_LLI_NUM_CONDUCTIVITY)
    170              {
    171                  virtual_pin = input->Pin_Ptr[0];
    172          
    173                  //TODO: the below number shall come from the editor tool
    174                  n_read_cfg = CONDUCTIVITYLLI_N_READ;
    175                  //n_read_cfg          = 1 << (input->Parameter_Ptr.Data[1] & CONDUCTIVITYLLI_CFG1_N_READ_MASK);
    176          
    177                  data = &ConductivityLLI_Data[input->Data_Index];
    178          
    179                  //if its the new sampling
    180                  if(data->Private_Current_Count >= n_read_cfg)
    181                  {
    182                      //Copy previous sampling data
    183                      data->Average_Duty              = (uint16)data->Private_Duty.Filtered_Value;
    184                      data->Maximum_Duty              = data->Private_Maximum_Duty;
    185                      data->Valid_Sample_Count        = data->Private_Valid_Sample_Count;
    186                      data->InValid_Sample_Count      = data->Private_Invalid_Sample_Count;
    187                      data->Threshold_Sample_Count    = data->Private_Threshold_Sample_Count;
    188          
    189                      //new readings available
    190                      data->Reading_Sync_Count++;
    191          
    192                      //Prepare for reading new sampling
    193                      InitConductivityData(data);
    194          
    195                      //Data ready after the filter
    196                      retval = TRUE;
    197                  }
    198          
    199                  data->Private_Current_Count++;
    200          
    201                  frequency = Timer__GetCaptureFrequcncy(&ConductivityLLI_Timer_Parameter[input->Data_Index]);
    202          
    203                  //validate the frequency
    204                  if ((frequency >= CONDUCTIVITY_VALID_MINIMUM_FREQUENCY) &&
    205                      (frequency <= CONDUCTIVITY_VALID_MAXIMUM_FREQUENCY))
    206                  {
    207                      duty = Timer__GetCaptureDuty(&ConductivityLLI_Timer_Parameter[input->Data_Index]);
    208          
    209                      //validate the duty
    210                      if ((duty >= CONDUCTIVITY_VALID_MINIMUM_DUTY) &&
    211                          (duty <= CONDUCTIVITY_VALID_MAXIMUM_DUTY))
    212                      {
    213                          data->Private_Valid_Sample_Count++;
    214                          Filter__Update(&data->Private_Duty, (FILTER_DATA_TYPE)duty, FILTER_IIR);
    215          
    216                          if (duty > CONDUCTIVITY_THRESHOLD_DUTY)
    217                          {
    218                              data->Private_Threshold_Sample_Count++;
    219                          }
    220          
    221                          if (duty > data->Private_Maximum_Duty)
    222                          {
    223                              data->Private_Maximum_Duty = duty;
    224                          }
    225                      }
    226                      else
    227                      {
    228                          data->Private_Invalid_Sample_Count++;
    229                      }
    230                  }
    231                  else
    232                  {
    233                      data->Private_Invalid_Sample_Count++;
    234                  }
    235          
    236              }
    237          
    238          
    239          
    240              return (retval);
    241          }
    242          
    243          
    244          //=====================================================================================================================
    245          //-------------------------------------- Private Functions ------------------------------------------------------------
    246          //=====================================================================================================================
    247          
    248          static void InitConductivityData(CONDUCTIVITY_DATA_TYPE *data)
    249          {
    250              data->Private_Duty.Inverted_Alpha                   = 2;
    251              Filter__Initialize(&data->Private_Duty, CONDUCTIVITY_VALID_MINIMUM_DUTY, FILTER_IIR);
    252              data->Private_Maximum_Duty                          = 0;
    253              data->Private_Valid_Sample_Count                    = 0;
    254              data->Private_Invalid_Sample_Count                  = 0;
    255              data->Private_Threshold_Sample_Count                = 0;
    256              data->Private_Current_Count                         = 0;
    257          }
    258          
    259          
    260          #endif


 

 


