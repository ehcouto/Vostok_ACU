    272              //! Possible states of Client state machine.
    273              typedef enum
    274              {
    275              	REQUEST_NVDATA_INFO,
    276          		CHECK_RECEIVED_NVDATA_INFO,
    277          
    278                  REQUEST_READ_DATA,
    279                  WAIT_FOR_DATA_RECEPTION,
    280          
    281                  REQUEST_WRITE_DATA,
    282                  WAITING_FOR_SERVER_COMPLETED_WRITING,
    283          
    284          
    285          		ERROR_IRRICOVERABLE_STATE,
    286                  NUM_OF_CLIENT_STATE_MACHINE_STATES
    287              }API007NVDATA_CLIENT_STATE;
    288          
