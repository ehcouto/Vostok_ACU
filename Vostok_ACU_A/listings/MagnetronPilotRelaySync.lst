    176          /**
    177           *  @brief      It Initializes the module MagnetronPilotRelaySync and its variables
    178           */
    179          void MagnetronPilotRelaySync__Initialize(void)
    180          {
    181              Pilot_Index = 0;
    182              memset(Relay_Sync_Data, 0, sizeof(Relay_Sync_Data));
    183          }
    184          
    185          //---------------------------------------------------------------------------------------------------------------------
    186          /**
    187           *  @brief      Initialize magnetron pilot Relay Sync instance.
    188           *
    189           *  @param      uint8 Parent_Pilot_Index - Index to associated magnetron Pilot instance.
    190           *              uint8 MW_Feedback_Pin - Index into virtual pin table to find the MW feedback signal.
    191           *              uint8 MW_FB_Active_High - Flag to indicate MW feedback signal active high or low: True: Active High / False: Active Low
    192           *              uint8 MW_Relay_Pin - Index into virtual pin table to find the MW relay signal.
    193           *              uint8 Turbo_Enable - Flag to indicate Turbo enable or disable: True: Enable / False: Disable
    194           *              uint8 Turbo_Relay_Pin - Index into virtual pin table to find the Turbo relay signal.
    195           *              uint8 Turbo_On_Off_Delay - Delay time between switching microwave and turbo relays.
    196           *
    197           *  @return     void
    198           */
    199          void MagnetronPilotRelaySync__InitializeInstance(uint8 Parent_Pilot_Index, uint8 MW_Feedback_Pin, uint8 MW_FB_Active_High, uint8 MW_Relay_Pin, uint8 Turbo_Enable, uint8 Turbo_Relay_Pin, uint8 Turbo_On_Off_Delay, uint8 Door_GI_Index)
    200          {
    201              uint8 table_index;
    202          
    203              Pilot_Index = Parent_Pilot_Index;
    204          
    205              Relay_Sync_Data[Pilot_Index].MW_Feedback_Pin = MW_Feedback_Pin;
    206              Relay_Sync_Data[Pilot_Index].MW_FB_Active_High = MW_FB_Active_High;
    207              Relay_Sync_Data[Pilot_Index].MW_Relay_Pin = MW_Relay_Pin;
    208              Relay_Sync_Data[Pilot_Index].Turbo_Enable = Turbo_Enable;
    209              Relay_Sync_Data[Pilot_Index].Turbo_Relay_Pin = Turbo_Relay_Pin;
    210              Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Delay = Turbo_On_Off_Delay;
    211              Relay_Sync_Data[Pilot_Index].Door_GI_Index = Door_GI_Index;
    212          
    213              //! Initialize MW feedback pin
    214              table_index = Relay_Sync_Data[Pilot_Index].MW_Feedback_Pin;
    215              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    216              {
    217                  Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    218              }
    219          
    220              //! Initialize MW relay pin
    221              table_index = Relay_Sync_Data[Pilot_Index].MW_Relay_Pin;
    222              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    223              {
    224                  Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    225              }
    226          
    227              //! Initialize MW relay parameter
    228              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = COLD_START_ON_DELAY;
    229              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay = COLD_START_OFF_DELAY;
    230              Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point = COUNTER_TWO_PERIODS;
    231              Relay_Sync_Data[Pilot_Index].Zero_Cross_Start_Found = FALSE;
    232              Relay_Sync_Data[Pilot_Index].Peak_Start_Found = FALSE;
    233              Relay_Sync_Data[Pilot_Index].Previous_Feedback_State = 0;
    234              Relay_Sync_Data[Pilot_Index].Majority_Feedback_State = 0;
    235              Relay_Sync_Data[Pilot_Index].Door_Open_Detected = FALSE;
    236              Relay_Sync_Data[Pilot_Index].One_MS_Handler_Counter = 0;
    237              MwRelayInitialize();
    238              Fault__ConditionRemoved(XCATEGORY_MAGNETRON_RELAY_FAILURE);
    239              Fault__ConditionRemoved(XCATEGORY_MAGNETRON_RELAY_SYNCHRONIZATION_FAILURE);
    240          
    241              if(Relay_Sync_Data[Pilot_Index].Turbo_Enable == TRUE)
    242              {
    243                  //! Initialize turbo relay pin
    244                  table_index = Relay_Sync_Data[Pilot_Index].Turbo_Relay_Pin;
    245                  if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    246                  {
    247                      Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    248                  }
    249          
    250                  //! Initialize turbo relay parameter
    251                  Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter = 0;
    252                  TurboRelayOff();
    253              }
    254          
    255              //! Initialize Magnetron Pilot Relay Sync state machine
    256              MagnetronPilotRelaySyncInitialize();
    257          }
    258          
    259          //----------------------------------------------------------------------------------------------
    260          /**
    261          *    @brief    Execute function called at the same rate as main sampler.
    262          *              Shall be called regularly at the same execution rate as mains sampler.
    263          *              Main state machine for relay on and relay off handling. Waits for
    264          *              a mains frequency peak and zero-cross to occur and executes the sample and
    265          *              calculate functions when the time is deemed to be within the allowed window.
    266          */
    267          void MagnetronPilotRelaySync__200usHandler(uint8 Parent_Pilot_Index)
    268          {
    269              //! Save Pilot_Index before entering interrupt handler
    270              uint8 Pilot_Index_Bak = Pilot_Index;
    271          
    272              Pilot_Index = Parent_Pilot_Index;
    273          
    274              MagnetronPilotRelaySyncExecute();
    275          
    276              //! Restore Pilot_Index before exiting interrupt handler
    277              Pilot_Index = Pilot_Index_Bak;
    278          }
    279          
    280          //---------------------------------------------------------------------------------------------------------------------
    281          /**
    282           * @brief      Handler called at every 5ms.
    283           * @param      Parent_Pilot_Index, Pilot_Request
    284           * @return
    285           */
    286          //---------------------------------------------------------------------------------------------------------------------
    287          void MagnetronPilotRelaySync__AsynchHandler(uint8 Parent_Pilot_Index, MAGNETRON_PILOT_REQUEST_TYPE Pilot_Request)
    288          {
    289              Pilot_Index = Parent_Pilot_Index;
    290          
    291              //! Turbo_On_Off_Counter count down every 5ms
    292              if(Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter > 0)
    293              {
    294                  Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter--;
    295              }
    296          
    297              //! Turn on/off relay every 25ms
    298              Relay_Sync_Data[Pilot_Index].One_MS_Handler_Counter++;
    299              if((Relay_Sync_Data[Pilot_Index].One_MS_Handler_Counter >= 5) ||
    300                 ((Pilot_Request == MAGNETRON_PILOT_REQUEST_OFF) && (MagnetronPilotMainsSampler__GetMainsFrequencyStatus(Pilot_Index) == MAINS_FREQ_ERROR)))
    301              {
    302                  Relay_Sync_Data[Pilot_Index].One_MS_Handler_Counter = 0;
    303          
    304                  if(Relay_Sync_Data[Pilot_Index].Turbo_Enable == TRUE)
    305                  {
    306                      switch(Pilot_Request)
    307                      {
    308                          case MAGNETRON_PILOT_REQUEST_OFF:
    309                              MwRelayOffSyncStart();
    310                              if(IsTurboRelayOn())
    311                              {
    312                                  if(Relay_Sync_Data[Pilot_Index].MW_Relay_State == STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF && !IsMWRelayOn())
    313                                  {
    314                                      TurboRelayOff();
    315                                  }
    316                              }
    317          
    318                              Fault__ConditionRemoved(XCATEGORY_MAGNETRON_RELAY_SYNCHRONIZATION_FAILURE);
    319                              break;
    320          
    321                          case MAGNETRON_PILOT_REQUEST_ON:
    322                              if(IsTurboRelayOn())
    323                              {
    324                                  MwRelayOffSyncStart();
    325                                  if(Relay_Sync_Data[Pilot_Index].MW_Relay_State == STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF && !IsMWRelayOn())
    326                                  {
    327                                      TurboRelayOff();
    328                                      Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter = (Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Delay) / 5;
    329                                  }
    330                              }
    331                              else
    332                              {
    333                                  if(Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter == 0)
    334                                  {
    335                                      MwRelayOnSyncStart();
    336                                  }
    337                              }
    338                              break;
    339          
    340                          case MAGNETRON_PILOT_REQUEST_TURBO:
    341                              if(!IsTurboRelayOn())
    342                              {
    343                                  TurboRelayOn();
    344                                  Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter = (Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Delay) / 5;
    345                              }
    346                              else
    347                              {
    348                                  if(Relay_Sync_Data[Pilot_Index].Turbo_On_Off_Counter == 0)
    349                                  {
    350                                      MwRelayOnSyncStart();
    351                                  }
    352                              }
    353                              break;
    354                      }
    355                  }
    356                  else
    357                  {
    358                      if(Pilot_Request == MAGNETRON_PILOT_REQUEST_ON)
    359                      {
    360                          MwRelayOnSyncStart();
    361                      }
    362                      else
    363                      {
    364                          MwRelayOffSyncStart();
    365          
    366                          Fault__ConditionRemoved(XCATEGORY_MAGNETRON_RELAY_SYNCHRONIZATION_FAILURE);
    367                      }
    368                  }
    369              }
    370          
    371              //! Read the new state of the door from door GI every 5ms.
    372              Relay_Sync_Data[Pilot_Index].Door_Open_Detected = (uint8)(Hbl__GetGIDataConvertedByIndex(Relay_Sync_Data[Pilot_Index].Door_GI_Index) == 0);
    373          
    374              //! Check if there is relay error msg needed to be published
    375              if (Relay_Sync_Data[Pilot_Index].Error_Present == TRUE)
    376              {
    377                  Fault__ConditionDetected(XCATEGORY_MAGNETRON_RELAY_FAILURE);
    378                  if (Relay_Sync_Data[Pilot_Index].Error_Changed == TRUE)
    379                  {
    380                      LOG_ADD_EXCEPTION(MW_RELAY_ERROR_PRESENT, Pilot_Index);
    381                  }
    382              }
    383              else
    384              {
    385                  Fault__ConditionRemoved(XCATEGORY_MAGNETRON_RELAY_FAILURE);
    386                  if (Relay_Sync_Data[Pilot_Index].Error_Changed == TRUE)
    387                  {
    388                      LOG_ADD_EXCEPTION(MW_RELAY_ERROR_CANCEL, Pilot_Index);
    389                  }
    390              }
    391              Relay_Sync_Data[Pilot_Index].Error_Changed = FALSE;
    392          }
    393          
    394          //---------------------------------------------------------------------------------------------------------------------
    395          /**
    396           * @brief      Handler to sync the mains period
    397           * @param      Parent_Pilot_Index, Period
    398           * @return
    399           */
    400          //---------------------------------------------------------------------------------------------------------------------
    401          void MagnetronPilotRelaySync__MainsPeriodSync(uint8 Parent_Pilot_Index, uint8 Period)
    402          {
    403              if ((Relay_Sync_Data[Parent_Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_ON_PENDING) && (Relay_Sync_Data[Parent_Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF_PENDING))
    404              {
    405                  Relay_Sync_Data[Parent_Pilot_Index].Intend_Relay_Switch_Point = (Period * 2);
    406              }
    407          }
    408          
    409          //---------------------------------------------------------------------------------------------------------------------
    410          /**
    411           * @brief      Handler to handle the mains angle 0,90,180,270 event
    412           * @param      Parent_Pilot_Index, Event_Type
    413           * @return
    414           */
    415          //---------------------------------------------------------------------------------------------------------------------
    416          void MagnetronPilotRelaySync__MainsEventHandler(uint8 Parent_Pilot_Index, MAINS_EVENT_TYPE Event_Type)
    417          {
    418              //! Save Pilot_Index before entering interrupt handler
    419              uint8 Pilot_Index_Bak = Pilot_Index;
    420          
    421              Pilot_Index = Parent_Pilot_Index;
    422          
    423              switch(Event_Type)
    424              {
    425                  case MAINS_ANGLE_0_EVENT:
    426                      if (Relay_Sync_Data[Pilot_Index].MW_Relay_State == STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF_PENDING)
    427                          Relay_Sync_Data[Pilot_Index].Zero_Cross_Start_Found = TRUE;
    428                      else
    429                          Relay_Sync_Data[Pilot_Index].Zero_Cross_Start_Found = FALSE;
    430                      break;
    431          
    432                  case MAINS_ANGLE_90_EVENT:
    433                      if (Relay_Sync_Data[Pilot_Index].MW_Relay_State == STATE_MAGNETRON_PILOT_RELAY_SYNC_ON_PENDING)
    434                          Relay_Sync_Data[Pilot_Index].Peak_Start_Found = TRUE;
    435                      else
    436                          Relay_Sync_Data[Pilot_Index].Peak_Start_Found = FALSE;
    437          
    438                      //! Relay error detection
    439                      if (Relay_Sync_Data[Pilot_Index].Relay_Stable_Delay > 0)
    440                      {
    441                          Relay_Sync_Data[Pilot_Index].Relay_Stable_Delay--;
    442                      }
    443                      else
    444                      {
    445                          if (Relay_Sync_Data[Pilot_Index].Door_Open_Detected == FALSE && !IsMWRelayOn())
    446                          {
    447                              if(MwRelayReadFeedbackSignal())
    448                              {
    449                                  if (Relay_Sync_Data[Pilot_Index].Error_Present == FALSE)
    450                                  {
    451                                      Relay_Sync_Data[Pilot_Index].Error_Counter++;
    452                                      if(Relay_Sync_Data[Pilot_Index].Error_Counter > 16)
    453                                      {
    454                                          Relay_Sync_Data[Pilot_Index].Error_Counter = 16;
    455                                          Relay_Sync_Data[Pilot_Index].Error_Present = TRUE;
    456                                          Relay_Sync_Data[Pilot_Index].Error_Changed = TRUE;
    457                                          EventOff();
    458                                      }
    459                                  }
    460                              }
    461                              else
    462                              {
    463                                  if (Relay_Sync_Data[Pilot_Index].Error_Present == TRUE)
    464                                  {
    465                                      Relay_Sync_Data[Pilot_Index].Error_Counter--;
    466                                      if (Relay_Sync_Data[Pilot_Index].Error_Counter == 0)
    467                                      {
    468                                          Relay_Sync_Data[Pilot_Index].Error_Present = FALSE;
    469                                          Relay_Sync_Data[Pilot_Index].Error_Changed = TRUE;
    470                                      }
    471                                  }
    472                              }
    473                          }
    474                          else
    475                          {
    476                              if (Relay_Sync_Data[Pilot_Index].Error_Present == TRUE)
    477                              {
    478                                  Relay_Sync_Data[Pilot_Index].Error_Present = FALSE;
    479                                  Relay_Sync_Data[Pilot_Index].Error_Changed = TRUE;
    480                              }
    481                              Relay_Sync_Data[Pilot_Index].Error_Counter = 0;
    482                          }
    483                      }
    484                      break;
    485          
    486                  case MAINS_ANGLE_180_EVENT:
    487                      break;
    488          
    489                  case MAINS_ANGLE_270_EVENT:
    490                      break;
    491          
    492                  case MAINS_NO_EVENT:
    493                      break;
    494              }
    495          
    496              //! Restore Pilot_Index before exiting interrupt handler
    497              Pilot_Index = Pilot_Index_Bak;
    498          }
