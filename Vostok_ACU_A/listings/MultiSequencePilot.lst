    516           * @return
    517           */
    518          PASS_FAIL_TYPE MultiSequencePilot__OCProcess(HBL_LOAD_TYPE * load)
    519          {
    520              #if (HBL_PILOT_NUM_TRIAC > 0)
    521                  PASS_FAIL_TYPE retval;
    522                  uint8 index;
    523                  uint8 handler_index;
    524          
    525                  retval     = FAIL;
    526          
    527                  #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    528                      if (load->Pilot_Data_Index < MultiSequencePilot_Allocation)
    529                      {
    530                          for (index = 0; index < MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot; index++)
    531                          {
    532                              handler_index = MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Handler_Index;
    533          
    534                              if (handler_index != HBL_INDEX_INVALID)
    535                              {
    536                                  if (MULTIDRIVER__PILOT_HANDLERS[handler_index].OCProcess != NULL)
    537                                  {
    538                                      retval  = MULTIDRIVER__PILOT_HANDLERS[handler_index].OCProcess(&MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index]);
    539                                  }
    540                              }
    541                          }
    542                      }
    543          
    544                  #endif
    545          
    546              return (retval);
    547              #else
    548                  return(FAIL);
    549              #endif
    550          }
