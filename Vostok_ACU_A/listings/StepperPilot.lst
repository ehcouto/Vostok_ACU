     57          //-------------------------------------- Public Functions -------------------------------------------------------------
     58          //=====================================================================================================================
     59          //---------------------------------------------------------------------------------------------------------------------
     60          /**
     61           *  @brief      It Initializes the module StepperPilot and its variables
     62           */
     63          void StepperPilot__Initialize(void)
     64          {
     65              Stepper_Pilot_Allocation = 0;
     66              memset(Stepper_Pilot_Data, 0, sizeof(Stepper_Pilot_Data));
     67          }
     68          
     69          //---------------------------------------------------------------------------------------------------------------------
     70          /**
     71           *  @brief      Allocate pilot instance for stepper.
     72           *
     73           *  @return     uint8 result - Allocation result.
     74           *  @retval     0-254 - Pilot allocation instance.
     75           *  @retval     0xFF - Allocation failed.
     76           */
     77          uint8 StepperPilot__Allocate(void)
     78          {
     79              uint8 result;
     80          
     81              result = 0xFF;
     82          
     83              if (Stepper_Pilot_Allocation < HBL_PILOT_NUM_STEPPER)
     84              {
     85                  result = Stepper_Pilot_Allocation;
     86                  Stepper_Pilot_Allocation++;
     87              }
     88          
     89              return (result);
     90          }
     91          
     92          //---------------------------------------------------------------------------------------------------------------------
     93          /**
     94           *  @brief      Initialize stepper pilot instance.
     95           *
     96           *  @param      HBL_LOAD_TYPE *load - Pointer to associated stepper load instance.
     97           *
     98           *  @return     PASS_FAIL_TYPE result - Result of stepper pilot instance initialization.
     99           *  @retval     PASS - Instance initialization succeeded.
    100           *  @retval     FAIL - Instance initialization failed.
    101           */
    102          PASS_FAIL_TYPE StepperPilot__InitializeInstance(HBL_LOAD_TYPE *load)
    103          {
    104              PASS_FAIL_TYPE result;
    105              STEPPER_PILOT_DATA_TYPE *data;
    106              uint8 loop_index;
    107              uint8 table_index;
    108          
    109              result = FAIL;
    110          
    111              if (load->Pilot_Data_Index < Stepper_Pilot_Allocation)
    112              {
    113                  data = &Stepper_Pilot_Data[load->Pilot_Data_Index];
    114                  StepperPilotReadParameters(load);
    115          
    116                  data->Step = 0;
    117                  data->Pulse_Width = 1;
    118                  data->Stepper_Array_Index = data->Parameters.Number_Of_Sequences;
    119          
    120                  for (loop_index = 0; loop_index < 4; loop_index++)
    121                  {
    122                      table_index = load->Pin_Ptr[loop_index];
    123          
    124                      if (VIRTUALPIN_TABLE[table_index].port != 0xFF)
    125                      {
    126                          Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    127                      }
    128                  }
    129          
    130                  result = PASS;
    131              }
    132          
    133              return (result);
    134          }
    135          
    136          //---------------------------------------------------------------------------------------------------------------------
    137          /**
    138           *  @brief      Set stepper pilot instance request.
    139           *
    140           *  @param      HBL_LOAD_TYPE *load - Pointer to associated stepper load instance.
    141           *
    142           *  @param      void *data - Pointer to request data. Pass argument as STEPPER_PILOT_REQUEST_TYPE *.
    143           *
    144           *  @return     PASS_FAIL_TYPE result - Result of stepper pilot request.
    145           *  @retval     PASS - Instance request succeeded.
    146           *  @retval     FAIL - Instance request failed.
    147           */
    148          PASS_FAIL_TYPE StepperPilot__Request(HBL_LOAD_TYPE *load, void *data)
    149          {
    150              PASS_FAIL_TYPE result;
    151          
    152              result = FAIL;
    153          
    154              if (load->Pilot_Data_Index < Stepper_Pilot_Allocation)
    155              {
    156                  Stepper_Pilot_Data[load->Pilot_Data_Index].Requested = *((STEPPER_PILOT_REQUEST_TYPE *)data);
    157                  Stepper_Pilot_Data[load->Pilot_Data_Index].Request_Updated = TRUE;
    158          
    159                  result = PASS;
    160              }
    161          
    162              return (result);
    163          }
    164          
    165          //---------------------------------------------------------------------------------------------------------------------
    166          /**
    167           *  @brief      Process stepper pilot instance.
    168           *
    169           *  @param      HBL_LOAD_TYPE *load - Pointer to ice dispenser door load instance.
    170           *
    171           *  @return     PASS_FAIL_TYPE result - Result of stepper pilot instance process.
    172           *  @retval     PASS - Instance process succeeded.
    173           *  @retval     FAIL - Instance process failed.
    174           */
    175          PASS_FAIL_TYPE StepperPilot__Process(HBL_LOAD_TYPE *load)
    176          {
    177              PASS_FAIL_TYPE result;
    178              STEPPER_PILOT_DATA_TYPE *data;
    179          
    180              result = FAIL;
    181          
    182              if (load->Pilot_Data_Index < Stepper_Pilot_Allocation)
    183              {
    184                  data = &Stepper_Pilot_Data[load->Pilot_Data_Index];
    185          
    186                  if (data->Request_Updated == TRUE)
    187                  {
    188                      MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    189                      data->Request_Updated = FALSE;
    190                      data->Processed = data->Requested;
    191                      data->Pulse_Width = data->Requested.Pulse_Width;
    192          
    193                      // The following variables are also written in StepperPilot__Handler1ms() which is an interrupt routine.
    194                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    195                      data->Step = data->Requested.Number_Of_Steps / data->Parameters.Number_Of_Sequences;
    196                      data->Pulse_Counter = 1;
    197                      data->Stepper_Array_Index = 0;
    198                      data->Status = INCOMPLETE;
    199                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    200                  }
    201          
    202                  result = PASS;
    203              }
    204          
    205              return (result);
    206          }
    207          
