    271          
    272              #if (ACCEL_COMM_TEST == ENABLED)
    273                  //! A timer used to measure the time that the comm failure indicator is set.
    274                  uint16 Failure_Indicator_Timer;
    275              #endif
    276          
    277              //! A timer used to measure time and create timeout events.
    278              uint16 Timer;
    279          
    280              //! The temperature sensor can be used to measure temperature variations. The output value represents a difference with respect to an unspecified reference value.
    281              //! Calibration is required to determine the reference temperature.
    282              sint8  Temperature_Delta;
    283          
    284              //! The current requested mode of the module.
    285              FXLS8974_MODE_TYPE Mode_Requested;
    286          
    287              //! The currently active mode of the module.
    288              FXLS8974_MODE_TYPE Mode_Processed;
    289          
    290              //! An index into the Points[] array for the next point that will be read by the application.
    291              uint8 Read;
    292          
    293              //! The number of points in the Points[] array that the application has not yet read.
    294              uint8 Number_Of_Points;
    295          
    296              //! Counter used to read the temperature sensor only every 1 second
    297              uint8 Temperature_Read_Delay_Count;
    298          
    299              //! Amount to de-scale the resulting acceleration values to keep the values in units of 1mg/digit
