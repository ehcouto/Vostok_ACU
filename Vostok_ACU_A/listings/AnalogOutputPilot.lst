    272           *  @return     void *requested - Requested instance data.
    273           *  @retval     Address of requested instance data. Cast it using *((uint8 *)ptr) to get values.
    274           *  @retval     NULL - Invalid load index.
    275           */
    276          void * AnalogOutputPilot__GetRequested(HBL_LOAD_TYPE * load)
    277          {
    278              void * requested = NULL;
    279          
    280              if (load->Pilot_Data_Index < AnalogOutputPilot_Allocation)
    281              {
    282                  requested =  &(AnalogOutputPilot_Data[load->Pilot_Data_Index].Requested);
    283              }
    284          
    285              return (requested);
    286          }
