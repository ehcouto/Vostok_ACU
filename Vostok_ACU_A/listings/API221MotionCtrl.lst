   1214          //---------------------------------------------------------------------------------------------------------------------
   1215          /**
   1216           * Get the specified analog input channel.
   1217           * Returns the same value if called again and no new value has been received.
   1218           * @param client_motor = The value used to uniquely identify the system motor on the client.
   1219           * @param channel = The analog input channel whose value is requested.
   1220           * @param data = A pointer to where the value should be stored if it is available.
   1221           * @return TRUE if the analog input value was available and copied into *data; otherwise FALSE.
   1222           */
   1223          BOOL_TYPE API221MotionCtrl__GetData(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8 channel, sint32* data)
   1224          {
   1225              BOOL_TYPE result = FALSE;
   1226              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1227                  (channel >= MAX_CHANNELS_PER_MOTOR) ||
   1228                  (data == NULL))
   1229              {
   1230                  LOG_ADD_EXCEPTION(GET_DATA_INVALID_PARAMS, COMBINE_BYTES(((data == NULL) ? 0x80 : 0x00) + client_motor, channel));
   1231              }
   1232              else
   1233              {
   1234                  #if (API221_SERVER_FEATURE == ENABLED)
   1235                      uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1236                      if (motor_node == WIN_NODE)
   1237                      {
   1238                          #ifdef API221_READ_ANALOG_DATA
   1239                              uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1240                              *data = API221_READ_ANALOG_DATA(server_motor, channel);
   1241                              result = TRUE;
   1242                          #endif
   1243                      }
   1244                      else
   1245                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1246                  {
   1247                      #if (API221_STORED_ANALOG_INPUTS > 0)
   1248                          for (uint8 i = 0; i < API221_STORED_ANALOG_INPUTS; i++)
   1249                          {
   1250                              API221_STORED_DATA_TYPE* stored = &Api221.Data[i];
   1251                              if ((channel == stored->Channel) &&
   1252                                  (client_motor == stored->Motor) &&
   1253                                  (stored->Sequence != 0xFF))
   1254                              {
   1255                                  *data = stored->Value;
   1256                                  result = TRUE;
   1257                                  break;
   1258                              }
   1259                          }
   1260                      #endif      // #if (API221_STORED_ANALOG_INPUTS > 0)
   1261                  }
   1262              }
   1263              return result;
   1264          }
   1265          
   1266          //---------------------------------------------------------------------------------------------------------------------
   1267          /**
   1268           * Get the specified analog input only if it is a new value that was not previously read.
   1269           * @param client_motor = The value used to uniquely identify the system motor on the client.
   1270           * @param channel = The analog input channel whose value is requested.
   1271           * @param sync = The synchronization byte used to detect new values that were not previously read.
   1272           * @param data = A pointer to where the value should be stored if it is available.
   1273           * @return TRUE if the analog input value was available, new, and copied into *data; otherwise FALSE.
   1274           */
   1275          BOOL_TYPE API221MotionCtrl__GetSynchronizedData(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8 channel, uint8* sync, sint32* data)
   1276          {
   1277              BOOL_TYPE result = FALSE;
   1278              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1279                  (channel >= MAX_CHANNELS_PER_MOTOR) ||
   1280                  (sync == NULL) ||
   1281                  (data == NULL))
   1282              {
   1283                  LOG_ADD_EXCEPTION(GET_SYNC_DATA_INVALID_PARAMS, COMBINE_BYTES(((data == NULL) ? 0x80 : 0x00) + ((sync == NULL) ? 0x40 : 0x00) + client_motor, channel));
   1284              }
   1285              else
   1286              {
   1287                  #if (API221_STORED_ANALOG_INPUTS > 0)
   1288                      for (uint8 i = 0; i < API221_STORED_ANALOG_INPUTS; i++)
   1289                      {
   1290                          API221_STORED_DATA_TYPE* stored = &Api221.Data[i];
   1291                          if ((channel == stored->Channel) &&
   1292                              (client_motor == stored->Motor) &&
   1293                              (*sync != stored->Sequence) &&
   1294                              (stored->Sequence != UCHAR_MAX))
   1295                          {
   1296                              *data = stored->Value;
   1297                              *sync = stored->Sequence;
   1298                              result = TRUE;
   1299                              break;                      // Break out of the for() loop.
   1300                          }
   1301                      }
   1302                  #endif      // #if (API221_STORED_ANALOG_INPUTS > 0)
   1303              }
   1304              return result;
   1305          }
   1306          
   1307          //---------------------------------------------------------------------------------------------------------------------
   1308          /**
   1309           * Determine whether the specified motor is present on the communications bus.
   1310           * @param client_motor = The value used to uniquely identify the system device on the client.
   1311           * @return TRUE if the specified motor is present on the communications bus; otherwise, FALSE.
   1312           */
   1313          BOOL_TYPE API221MotionCtrl__IsMotorPresentOnBus(API221_CLIENT_MOTOR_INDEX_TYPE client_motor)
   1314          {
   1315              BOOL_TYPE result = FALSE;
   1316              if (client_motor >= API221_SYSTEM_MOTOR_COUNT)
   1317              {
   1318                  LOG_ADD_EXCEPTION(IS_MOTOR_PRESENT_INVALID_PARAMS, COMBINE_BYTES(client_motor, 0));
   1319              }
   1320              else
   1321              {
   1322                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1323                  #if (API221_SERVER_FEATURE == ENABLED)
   1324                      if (motor_node == WIN_NODE)
   1325                      {
   1326                          result = TRUE;
   1327                      }
   1328                      else
   1329                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1330                  {
   1331                      result = (BOOL_TYPE)(BIT_TEST(Reveal__GetNodestatus(), motor_node));
   1332                  }
   1333              }
   1334              return result;
   1335          }
