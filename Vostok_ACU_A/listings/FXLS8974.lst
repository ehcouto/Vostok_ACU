   1067          /**
   1068           * Determine if a request has been made to disable the module.
   1069           * @return TRUE if a request has been made to disable the module; otherwise FALSE.
   1070           */
   1071          static BOOL_TYPE IsDisableRequested(void)
   1072          {
   1073              return (BOOL_TYPE)(Fxls8974.Mode_Requested == FXLS8974_MODE_DISABLED);
   1074          }
