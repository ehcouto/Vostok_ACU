     62          typedef struct HEAT_MONITOR_DATA_STRUCT
     63          {
     64          	//! Down counter for the activation delay
     65          	uint16 Activation_Delay_Counter;
     66          	//! Down counter for WS_WATER state
     67          	uint16 Stable_Water_Ctr;
