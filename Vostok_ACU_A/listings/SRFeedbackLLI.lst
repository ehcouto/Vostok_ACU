     32          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     33          
     34          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     35          #define DEFAULT_NUM_SAMPLES                 16
     36          #define MIN_NUM_SAMPLES                     8
     37          #define LAST_FREQUENCY_EVENT_TIMEOUT        30
     38          #define SAMPLES_NOISE_THRESHOLD             2
     39          
     40          typedef struct
     41          {
     42              uint8 N_Read:3;
     43              uint8 Unused_0:5;
     44              uint8 Unused_1:5;
     45              uint8 Pull_Up:1;
     46              uint8 Unused_2:1;
     47              uint8 Inverted:1;
     48          } SRFEEDBACKLLI_PARAM_TYPE;
     49          
     50          typedef struct
     51          {
     52              // Buffer of Gpio samples collected
     53              uint16 Pin_Buffer;
     54              // Sampling Sequence counter - updated on each 1ms sample
     55              uint8 Sampling_Counter;
     56              // last Sampling Sequence counter reference of the last Asynch iteration
     57              uint8 Async_Sampling_Reference;
     58              // Frequency detection in progress
     59              BOOL_TYPE Is_Detecting_Frequency;
     60              // Sampling Sequence counter reference of the last frequency event detected
     61              uint8 Last_Frequency_Event_Reference;
     62              // Time (in ms) between last two frequency events detected
     63              uint8 Time_Between_Frequency_Events;
     64              // Counter of High / Low pin level event detected: it increments on a new High value event, decrements on a new Low value event
     65              sint8 Level_Counter;
     66              // Counter of valid Frequency event detected: it increments when valid Frequency events have been detected
     67              uint8 Frequency_Counter;
     68              // Counter of Frequency an in phase with ZeroCross (phase shift around +/- 90 degrees) event detected
     69              uint8 Phase_Counter;
     70              // Current Feedback LLI value (0, 1, 2, 3)
     71              SRFEEDBACKLLI_VALUE_ENUM_TYPE Value;
     72              // Current AC LLI value (0, 1)
     73              uint8 Ac_Is_Present;
     74              // Last phase shift (in ms) between Frequency signal and ZeroCross - 0 if channel or ZeroCross signals are not valid frequency ones
     75              uint8 Phase_Shift;
     76          } SRFEEDBACKLLI_DATA_TYPE;
     77          
     78          // FeedbackLLI data structure
     79          static SRFEEDBACKLLI_DATA_TYPE SRFeedbackLLI_Data[HBL_LLI_NUM_SRFEEDBACK];
     80          // ZeroCross / SRZeroCross instance index - if present
     81          static uint8 SRZeroCross_Index;
     82          // Number of FeedbackLLI instances allocated
     83          static uint8 SRFeedbackLLI_Allocation;
     84          
     85          // Complement Class B variables
     86          static SRFEEDBACKLLI_DATA_TYPE N_SRFeedbackLLI_Data[HBL_LLI_NUM_SRFEEDBACK];
     87          static uint8 N_SRZeroCross_Index;
     88          static uint8 N_SRFeedbackLLI_Allocation;
     89          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     90          static void UpdateLastFrequencyTimingEvents(SRFEEDBACKLLI_DATA_TYPE *data_ptr, SRFEEDBACKLLI_DATA_TYPE *n_data_ptr, uint8 new_frequency_reference);
     91          //=====================================================================================================================
     92          //-------------------------------------- Public Functions -------------------------------------------------------------
     93          //=====================================================================================================================
