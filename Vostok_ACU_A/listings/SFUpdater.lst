    400                                  }
    401                                  break;
    402          
    403                              case SFUPDATER_DISPLACEMENT_STATE_WAIT_SFDISPLACEMENT_INFO:
    404                                  // Wait for reply from ACU with message size; See SFUpdater__RxSFDisplacementInfo()
    405                                  if (displacement_timeout_counter >= SFUPDATER_ONE_SECOND_IN_FIVE_MS_UNIT)
    406                                  {
    407                                      //Restart the process if  ACU did not replied
    408                                      SYSTEM_RESET();
    409                                  }
    410                                  break;
    411          
    412                              case SFUPDATER_DISPLACEMENT_STATE_PROGRAMMING_DATA:
    413                                  // shall not stuck in the programming
    414                                  if (displacement_timeout_counter >= SFUPDATER_TEN_SECOND_IN_FIVE_MS_UNIT)
    415                                  {
    416                                      //Restart the process if  ACU did not replied
    417                                      SYSTEM_RESET();
    418                                  }
    419                                  break;
    420          
    421                              case SFUPDATER_DISPLACEMENT_STATE_PROGRAMMING_END:
    422                                  SFUpdater_Displacement_State = SFUPDATER_DISPLACEMENT_STATE_REQUEST_SFDISPLACEMENT_INFO;
    423                                  break;
    424          
    425                              default:
    426                                  break;
    427                          }
    428                      }
    429                  }
    430              #endif
