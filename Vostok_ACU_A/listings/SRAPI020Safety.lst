    167          /**
    168           * Initialize the module's variables.
    169           */
    170          void SRAPI020Safety__Initialize(void)
    171          {
    172              memset(&Api020, 0, sizeof(Api020));
    173              memset(&N_Api020, ~0, sizeof(N_Api020));
    174              #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    175                  memset(&Api020.Rx_Expected_Sequence, ~0, sizeof(Api020.Rx_Expected_Sequence));
    176                  memset(&N_Api020.Rx_Expected_Sequence, 0, sizeof(N_Api020.Rx_Expected_Sequence));
    177              #endif      // #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    178          
    179              API020_INIT_TASK_SEQUENCE();
    180          }
