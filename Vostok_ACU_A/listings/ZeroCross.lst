   1193                      {
   1194                          ZEROCROSS_GPIO_REQUEST_TYPE *processing_ptr = &ZeroCross_Gpio_Processing[gpio_req_index];
   1195                          ZEROCROSS_GPIO_REQUEST_TYPE *req_ptr = &ZeroCross_Gpio_Requests[gpio_req_index];
   1196                          if (req_ptr->Gpio_Id == ZEROCROSS_ID_INVALID)
