    278          //---------------------------------------------------------------------------------------------------------------------
    279          /**
    280           *  @brief  Get TIMxx Frequency
    281           *
    282           *  @param  input_number    : Defines the specific Time capture channel
    283           *
    284           *  @retval Basic timer tick frequency in MHz unit
    285           */
    286          uint32 GetTIMFreq(void)
    287          {
    288              uint32 bus_freq;
    289          
    290              bus_freq = Micro__GetClock()->PCLK1_Frequency;
    291          
    292              // 1. If the APB prescaler is set to 1, TIMPCLK frequency is equal to PCLK frequency.
    293              // 2. Otherwise, the TIMPCLK frequency is set to twice the PCLK frequency.
    294              if ((RCC.CFGR & RCC_CFGR_PPRE) != 0)
    295              {
    296                  bus_freq = bus_freq * 2;
    297              }
    298          
    299              return bus_freq;
    300          }
