      1          /**
      2           *  @file
      3           *
      4           *  @brief      Implements the Nonfunctional pilot module.
      5           *
      6           *  @details    Pilot for Virtual Loads. Satisfies HBL API. Does not control any physical outputs.
      7           *              Allows API 012 to send a load command that does not drive a physical output.
      8           *              The status of the load can be used on an expansion board to enable/disable complex loads (e.g. I2C).
      9           *
     10           *  @copyright  Copyright 2018 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     11           */
     12          
     13          //-------------------------------------- Include Files ----------------------------------------------------------------
     14          
     15          //lint -e766 Suppress Info: header not used in module 'VirtualGI.c'
     16          #include "SystemConfig.h"
     17          
     18          #if (HBL_PILOT_NUM_NONFUNCTIONAL > 0)
     19          #include "NonfunctionalPilot.h"
     20          #include <string.h>
     21          
     22          //  --- Private Declarations ------------------------------------------------------------------------------------------
     23          //! The structure that holds all the variables used by this module.
     24          typedef struct NONFUNCTIONAL_PILOT_DATA_STRUCT
     25          {
     26              uint8 Requested[HBL_PILOT_NUM_NONFUNCTIONAL];
     27              uint8 Processed[HBL_PILOT_NUM_NONFUNCTIONAL];
     28          
     29              //! Tracks the number of Virtual GI instances.
     30              uint8 Allocation;
     31          } NONFUNCTIONAL_PILOT_DATA_TYPE;
     32          
     33          // -- Private Variable Definitions ------------------------------------------------------------------------------------
     34          //! Define storage for module data.
     35          static NONFUNCTIONAL_PILOT_DATA_TYPE Nonfunctional_Data;
     36          
     37          //=====================================================================================================================
     38          //-------------------------------------- Public Functions -------------------------------------------------------------
     39          //=====================================================================================================================
     40          //---------------------------------------------------------------------------------------------------------------------
     41          /**
     42           *  @brief      It Initializes the module NonfunctionalPilot and its variables
     43           */
     44          void NonfunctionalPilot__Initialize(void)
     45          {
     46              memset(&Nonfunctional_Data, 0, sizeof(Nonfunctional_Data));
     47          }
     48          
     49          //---------------------------------------------------------------------------------------------------------------------
     50          /**
     51           *  @brief      Allocate Nonfunctional pilot instance.
     52           *
     53           *  @return     uint8 result - Allocation result.
     54           *  @retval     0-254 - Pilot allocation instance.
     55           *  @retval     0xFF - Allocation failed.
     56           */
     57          uint8 NonfunctionalPilot__Allocate(void)
     58          {
     59              uint8 result;
     60          
     61              result = HBL_INDEX_INVALID ;
     62          
     63              if (Nonfunctional_Data.Allocation < HBL_PILOT_NUM_NONFUNCTIONAL)
     64              {
     65                  result = Nonfunctional_Data.Allocation;
     66                  Nonfunctional_Data.Allocation++;
     67              }
     68          
     69              return (result);
     70          }
     71          
     72          //---------------------------------------------------------------------------------------------------------------------
     73          /**
     74           *  @brief      Initialize Nonfunctional pilot instance.
     75           *
     76           *  @param      HBL_LOAD_TYPE *load - Pointer to associated virtual load instance.
     77           *
     78           *  @return     PASS_FAIL_TYPE result - Result of Nonfunctional pilot instance initialization.
     79           *  @retval     PASS - Instance initialization succeeded.
     80           *  @retval     FAIL - Instance initialization failed.
     81           */
     82          PASS_FAIL_TYPE NonfunctionalPilot__InitializeInstance(HBL_LOAD_TYPE *load)
     83          {
     84              if (load->Pilot_Data_Index < Nonfunctional_Data.Allocation)
     85              {
     86                  return (PASS);
     87              }
     88              return (FAIL);
     89          }
     90          
     91          //---------------------------------------------------------------------------------------------------------------------
     92          /**
     93           *  @brief      Set Nonfunctional pilot instance request.
     94           *
     95           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Virtual load instance.
     96           *
     97           *  @param      void *data - Pointer to request data. Not used.
     98           *
     99           *  @return     PASS_FAIL_TYPE result - Result of Nonfunctional pilot request.
    100           *  @retval     PASS - Request instance is allocated.
    101           *  @retval     FAIL - Request instance is not allocated.
    102           */
    103          PASS_FAIL_TYPE NonfunctionalPilot__Request(HBL_LOAD_TYPE *load, void *data)
    104          {
    105              PASS_FAIL_TYPE result = FAIL;
    106          
    107              if (load->Pilot_Data_Index < Nonfunctional_Data.Allocation)
    108              {
    109                  Nonfunctional_Data.Requested[load->Pilot_Data_Index] = *(uint8 *)data;
    110                  result = PASS;
    111              }
    112          
    113              return (result);
    114          }
    115          
    116          //---------------------------------------------------------------------------------------------------------------------
    117          /**
    118           *  @brief      Process Nonfunctional pilot instance.
    119           *
    120           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Virtual load instance.
    121           *
    122           *  @return     PASS_FAIL_TYPE result - Result of Nonfunctional pilot instance process.
    123           *  @retval     PASS - Request instance is allocated.
    124           *  @retval     FAIL - Request instance is not allocated.
    125           */
    126          PASS_FAIL_TYPE NonfunctionalPilot__Process(HBL_LOAD_TYPE *load)
    127          {
    128              PASS_FAIL_TYPE result = FAIL;
    129          
    130              if (load->Pilot_Data_Index < Nonfunctional_Data.Allocation)
    131              {
    132                  Nonfunctional_Data.Processed[load->Pilot_Data_Index] = Nonfunctional_Data.Requested[load->Pilot_Data_Index];
    133                  result = PASS;
    134              }
    135          
    136              return (result);
    137          }
    138          
    139          //---------------------------------------------------------------------------------------------------------------------
    140          /**
    141           *  @brief      Get the number of Nonfunctional pilot instances.
    142           *
    143           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Virtual load instance.
    144           *
    145           *  @return     void * requested - Returns the number of allocated instances.
    146           *  @retval     Address of allocation tracking value. Cast it using *((uint8 *)ptr) to get value.
    147           *  @retval     NULL - Invalid load index.
    148           */
    149          void * NonfunctionalPilot__GetRequested(HBL_LOAD_TYPE *load)
    150          {
    151              void *requested = NULL;
    152          
    153              if (load->Load_Data_Index < Nonfunctional_Data.Allocation)
    154              {
    155                  requested = &(Nonfunctional_Data.Requested[load->Pilot_Data_Index]);
    156              }
    157          
    158              return (requested);
    159          }
    160          
    161          //---------------------------------------------------------------------------------------------------------------------
    162          /**
    163           *  @brief      Get the number of Nonfunctional pilot instances.
    164           *
    165           *  @param      HBL_LOAD_TYPE *load - Pointer to associated Virtual load instance.
    166           *
    167           *  @return     void * processed - Returns the number of allocated instances.
    168           *  @retval     Address of allocation tracking value. Cast it using *((uint8 *)ptr) to get value.
    169           *  @retval     NULL - Invalid load index.
    170           */
    171          void * NonfunctionalPilot__GetProcessed(HBL_LOAD_TYPE *load)
    172          {
    173              void *processed = NULL;
    174          
    175              if (load->Pilot_Data_Index < Nonfunctional_Data.Allocation)
    176              {
    177                  processed = &(Nonfunctional_Data.Processed[load->Pilot_Data_Index]);
    178              }
    179          
    180              return (processed);
    181          }
    182          
    183          #endif // (HBL_PILOT_NUM_NONFUNCTIONAL > 0)


 

 


