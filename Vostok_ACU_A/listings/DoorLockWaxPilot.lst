     93          /**
     94           *  @brief      It Initializes the module DoorLockWaxPilot and its variables
     95           *
     96           */
     97          void DoorLockWaxPilot__Initialize(void)
     98          {
     99          	DoorLockWaxPilot_Allocation = 0;
    100          	memset(&DoorLockWaxPilot_Data, 0, sizeof(DoorLockWaxPilot_Data));
    101          }
