    102          //---------------------------------------------------------------------------------------------------------------------
    103          /**
    104           *  @brief      Initialize SRDigitalOutputMultiPilot instance.
    105           *
    106           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
    107           *
    108           *  @return     PASS_FAIL_TYPE result - Result of SRDigitalOutputMultiPilot instance initialization.
    109           *  @retval     PASS - Instance initialization succeeded.
    110           *  @retval     FAIL - Instance initialization failed.
    111           */
    112          PASS_FAIL_TYPE SRDigitalOutputMultiPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    113           {
    114              PASS_FAIL_TYPE retval;
    115              uint8 virtual_pin;
    116              uint8 virtual_pin2;
    117              BOOL_TYPE pin1_val;
    118              BOOL_TYPE pin2_val;
    119              retval = FAIL;
    120          
    121              if (CheckItem(load->Pilot_Data_Index))
    122              {
    123                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *ptr = &SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    124                  virtual_pin = load->Pin_Ptr[0];
    125                  virtual_pin2 = load->Pin_Ptr[1];
    126                  if ((VIRTUALPIN_TABLE[virtual_pin].port != 0xFF) && (VIRTUALPIN_TABLE[virtual_pin2].port != 0xFF))
    127                  {
    128                      // Shortcut to set pin output values according to load status at initialization
    129                      DoPinsUpdate(load);
    130                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,	VIRTUALPIN_TABLE[virtual_pin].pin, VIRTUALPIN_TABLE[virtual_pin].pin_config);
    131                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin, VIRTUALPIN_TABLE[virtual_pin2].pin_config);
    132                  }
    133          
    134                  pin1_val = (BOOL_TYPE)ptr->Last_Pin_1_Value;
    135                  pin2_val = (BOOL_TYPE)ptr->Last_Pin_2_Value;
    136          
    137                  if ((Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, VIRTUALPIN_TABLE[virtual_pin].pin_config, pin1_val) == TRUE) &&
    138                      (Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin, VIRTUALPIN_TABLE[virtual_pin2].pin_config, pin2_val) == TRUE))
    139                  {
    140                      retval = PASS;
    141                  }
    142          
    143              }
    144              else
    145              {
    146                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, load->Pilot_Data_Index);
    147              }
    148          
    149              return (retval);
    150          }
