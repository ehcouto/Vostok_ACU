    132          /**
    133           * @brief Function read VWI Data period value from SettingFile and set
    134           *
    135           */
    136          static void ReadSfData()
    137          {
    138          	SETTINGFILE_LOADER_TYPE loader;
    139          	uint16 Data_Period;
    140          
    141          	if (SettingFile__BasicLoader(VWI_SETTING_FILE_PTR, VWI_SETTING_FILE_DISPL_DEFAULT, &loader) == PASS)
    142          	{
    143          		uint8 sf_data;
    144          		sf_data = ((VWI_PARAMETER_TYPE*)(loader.Data))->VWI_Data_Channel_Period; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    145          
    146          		//Multiply SettingFile parameter x100
    147          		Data_Period = (sf_data*100);
    148          	}
    149          	else
    150          	{
    151          		Data_Period = 1000;
    152          		LOG_ADD_EXCEPTION(ERROR_LOADING_VWI_PARAMETERS, 0);
    153          	}
    154          	
    155          	Vwi__RemoteChannelPeriod(0xFF, Data_Period);
    156          }
    157          
    158          
    159          /**
    160           * Handle events published through API221.
    161           * This function is called by the communication thread.
    162           * @param event = The event that was published through API221.
    163           */
    164          static void API221HandleMotorEvent(API221_EVENT_TYPE event)
    165          {
    166          	switch (event.Event)
    167          	{
    168          		case API221_EVENT_ERROR:
    169          		case API221_EVENT_STOPPED:
    170          			Vwi__RemoteChannelEnable(event.Motor, MCISENSORSDW_AI_VWI_CHANNEL_0, FALSE);
    171          			Vwi__RemoteChannelEnable(event.Motor, MCISENSORSDW_AI_VWI_CHANNEL_1, FALSE);
    172          			break;
    173          
    174          		case API221_EVENT_RAMP_STARTED:
    175          		case API221_EVENT_REACHED_TARGET:
    176          			Vwi__RemoteChannelEnable(event.Motor, MCISENSORSDW_AI_VWI_CHANNEL_0, TRUE);
    177          			Vwi__RemoteChannelEnable(event.Motor, MCISENSORSDW_AI_VWI_CHANNEL_1, TRUE);
    178          			break;
    179          
    180          		default:
    181          			// Ignore all other events
    182          			break;
    183          	}
    184          }
    185          
    186          #endif // (VWI_CLIENT_FEATURE == ENABLED)

