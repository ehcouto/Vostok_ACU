   1019          /**
   1020           *    @brief    This method performs non-volatile memory (FLASH) test periodically.
   1021           *    @details  This method is responsible for checking the FLASH memory consistency.
   1022           *              Run time Flash Test which calculates CRC couple bytes each time and keeps on continuing until it
   1023           *              reaches the FLASH memory end and compare the calculated CRC against a CRC value stored
   1024           *              in FLASH memory.
   1025           *
   1026           *              INBUILT_FLASH_CRC_CALCULATOR macro defines the CRC calculation engine either Inbuilt or External.
   1027           *
   1028           *              MICRO_NUM_WORD_FOR_FLASH_CONTINUOUS_TEST configuration macro defined in the SRMicro_prv.h file
   1029           *              Defines how many words will be processed each interaction of the Continuous Flash Test.
   1030           *
   1031           *              The time taken for complete FLASH test is calculated below-
   1032           *              For the inbuilt CRC tool(IELF) -
   1033           *              FULL FLASH TEST (in ms) =
   1034           *                 (((FLASH Size in words)-4)/ MICRO_NUM_WORD_FOR_FLASH_CONTINUOUS_TEST) * Call rate(of Micro__FlashTest())
   1035           *
   1036           *              If the external CRC tool(IELF) is used-
   1037           *              FULL FLASH TEST (in ms) =
   1038           *                  (((FLASH Size in bytes)-4)/ MICRO_NUM_WORD_FOR_FLASH_CONTINUOUS_TEST) * Call rate(of Micro__FlashTest())
   1039           *
   1040           *              In the calculation FLASH Size-4 because the last 4- bytes of the flash memory is used to
   1041           *              hold the calculated CRC value on which the Flash test is not performed.
   1042           *
   1043           *
   1044           *              For example
   1045           *              Flash size is 32768 in words,  number of bytes processed in each call are 4 and the call rate is 5ms
   1046           *              then time taken by the inbuilt CRC calculator is-
   1047           *              FULL FLASH TEST (in ms) =  ((32768-4) /4)  * 5 ms
   1048           *                                      = 2047.75ms
   1049           *
   1050           *              Along with this it provides the flow control log and exception control for each tests.
   1051           *              Note- Should be called at every 5ms or 25ms slot.
   1052           */
   1053          #pragma optimize=none

   \                                 In section .text, align 2, keep-with-next
   1054          void Micro__SRFlashTest(void)
   1055          {
   \                     Micro__SRFlashTest: (+1)
   \   00000000   0xB510             PUSH     {R4,LR}
   1056              #if (MICRO_SR_FEATURE_TEST == ENABLED)
   1057                  uint16 count;
   1058          
   1059                  #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
   1060                      SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_MICRO_SRFLASHTEST_ENTER);
   \   00000002   0x2111             MOVS     R1,#+17
   \   00000004   0x2004             MOVS     R0,#+4
   \   00000006   0x.... 0x....      BL       SRTaskSequence__SetSequenceStep
   1061                  #endif
   1062          
   1063                  for (count=0; count< MICRO_NUM_WORD_FOR_FLASH_CONTINUOUS_TEST;count++)
   \   0000000A   0x2000             MOVS     R0,#+0
   \   0000000C   0x0004             MOVS     R4,R0
   \                     ??Micro__SRFlashTest_0: (+1)
   \   0000000E   0xB2A4             UXTH     R4,R4
   \   00000010   0x2C08             CMP      R4,#+8
   \   00000012   0xDA27             BGE      ??Micro__SRFlashTest_1
   1064                  {
   1065                      //Calculate the CRC16 CCIT
   1066                      Micro_Flash_Crc = Crc16__ConstRangeProcess((uint8 *)Micro_Flash_Crc_Pt,Micro_Flash_Crc,4);
   \   00000014   0x2204             MOVS     R2,#+4
   \   00000016   0x....             LDR      R0,??DataTable16
