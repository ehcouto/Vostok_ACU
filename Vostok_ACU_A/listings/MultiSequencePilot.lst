    165          /**
    166           *  @brief      It Initializes the module MULTISEQUENCEPILOT and its variables
    167           *
    168           */
    169          void MultiSequencePilot__Initialize(void)
    170          {
    171              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    172                  MultiSequencePilot_Allocation = 0;
    173                  memset(&MultiSequencePilot_Data,0,sizeof(MultiSequencePilot_Data));
    174              #endif
    175          }
    176          
    177          //---------------------------------------------------------------------------------------------------------------------
    178          /**
    179           * @brief
    180           * @return
    181           */
    182          uint8 MultiSequencePilot__Allocate(void)
    183          {
    184              uint8 retval;
    185              retval = 0xFF;
    186          
    187              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    188                  if (MultiSequencePilot_Allocation < HBL_PILOT_NUM_MULTISEQUENCE)
    189                  {
    190                      retval = MultiSequencePilot_Allocation;
    191                      MultiSequencePilot_Allocation++;
    192                  }
    193              #endif
    194          
    195              return (retval);
    196          }
    197          
    198          //---------------------------------------------------------------------------------------------------------------------
    199          /**
    200           * @brief
    201           * @param load
    202           */
    203          PASS_FAIL_TYPE MultiSequencePilot__InitializeInstance(HBL_LOAD_TYPE * load)
    204          {
    205              PASS_FAIL_TYPE retval;
    206              uint8 index;
    207              uint8 handler_index;
    208              MULTISEQUENCEPILOT_PARAMETERS_TYPE *parameters;
    209          
    210              retval = FAIL;
    211          
    212              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    213                  if (load->Pilot_Data_Index < MultiSequencePilot_Allocation)
    214                  {
    215                      parameters = (void*)load->Parameter_Ptr.Data;
    216          
    217                      //HBL_PILOT_MULTISEQUENCE_1
    218                      MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot             = 1;
    219          
    220                      if (load->Pilot_Type == HBL_PILOT_MULTISEQUENCE_2)
    221                      {
    222                          MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot = 2;
    223                      }
    224                      else if (load->Pilot_Type == HBL_PILOT_MULTISEQUENCE_3)
    225                      {
    226                          MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot = 3;
    227                      }
    228                      else if (load->Pilot_Type == HBL_PILOT_MULTISEQUENCE_4)
    229                      {
    230                          MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot = 4;
    231                      }
    232          
    233                      //Load the Pilot parameters
    234                      for (index = 0; index < MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot; index++)
    235                      {
    236                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Load_Id                  = load->Load_Id;
    237                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type               = parameters[index].Pilot_Type;
    238                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset = parameters[index].Pilot_Type_Params_Offset;
    239                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pin_Ptr                  = &(load->Pin_Ptr[index]);
    240          
    241                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Hi_Low_Activation_Bitmap =  (load->Hi_Low_Activation_Bitmap >> index) & 0x01;
    242          
    243                          if (MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset != NO_PARAMETER_OFFSET)
    244                          {
    245                              SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset, &MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr);
    246                          }
    247                          else
    248                          {
    249                              MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr.Data = NULL;
    250                              MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr.Length = 0;
    251                          }
    252          
    253                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Data_Index = 0xFF;
    254                          MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Handler_Index= HBL_INDEX_INVALID;
    255          
    256                          for (handler_index = 0; handler_index < MULTISEQUENCE_NUM_REGISTERED_PILOT; handler_index++)
    257                          {
    258                              if (MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type == MULTIDRIVER__PILOT_HANDLERS[handler_index].Pilot)
    259                              {
    260                                  MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Handler_Index  = handler_index;
    261                                  MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Data_Index  = MULTIDRIVER__PILOT_HANDLERS[handler_index].Allocate();
    262                                  retval  = MULTIDRIVER__PILOT_HANDLERS[handler_index].InitializeInstance(&MultiSequencePilot_Data[load->Pilot_Data_Index].Load[index]);
    263                                  break;
    264                              }
    265                          }
    266                      }
    267          
    268                      //Multi Sequence part
    269                      MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Sequence              = load->Parameter_Ptr.Data[sizeof(MULTISEQUENCEPILOT_PARAMETERS_TYPE) * MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot];
    270                      MultiSequencePilot_Data[load->Pilot_Data_Index].Sequence_Displacement_Ptr = &(load->Parameter_Ptr.Data[(sizeof(MULTISEQUENCEPILOT_PARAMETERS_TYPE) * MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot) + 1]);
    271          
    272                      MultiSequencePilot_Data[load->Pilot_Data_Index].TimeOut = 0;
    273                      Millis__Reset(&MultiSequencePilot_Data[load->Pilot_Data_Index].Millis_Timer);
    274          
    275                      MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State           = 0;
    276                      MultiSequencePilot_Data[load->Pilot_Data_Index].Processed_State           = 0;
    277                      MultiSequencePilot_Data[load->Pilot_Data_Index].Status.Load.Status        = HBL_LOAD_STATUS_TARGET_COMPLETED;
    278                      MultiSequencePilot_Data[load->Pilot_Data_Index].Status.Load.Cur_Reg       = 0;
    279          
    280                      //Turn off all the pilots
    281                      memset(MultiSequencePilot_Data[load->Pilot_Data_Index].Pilot_OutPut_State, 0, MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Pilot);
    282                  }
    283          
    284              #endif
    285          
    286              return (retval);
    287          }
    288          
    289          //---------------------------------------------------------------------------------------------------------------------
    290          /**
    291           * @brief
    292           * @param load
    293           * @param data
    294           * @return
    295           */
    296          PASS_FAIL_TYPE MultiSequencePilot__Request(HBL_LOAD_TYPE * load, void * data)
    297          {
    298              PASS_FAIL_TYPE retval;
    299          
    300              retval = FAIL;
    301          
    302              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    303                  if (load->Pilot_Data_Index < MultiSequencePilot_Allocation)
    304                  {
    305                      if (MultiSequencePilot_Data[load->Pilot_Data_Index].Max_Sequence > *((uint8 *)data))
    306                      {
    307                          MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State = *((uint8 *)data);
    308          
    309                          retval = PASS;
    310                      }
    311                  }
    312          
    313              #endif
    314          
    315              return (retval);
    316          }
    317          
    318          //---------------------------------------------------------------------------------------------------------------------
    319          /**
    320           * @brief
    321           * @param load
    322           * @return
    323           */
    324          PASS_FAIL_TYPE MultiSequencePilot__Process(HBL_LOAD_TYPE * load)
    325          {
    326              PASS_FAIL_TYPE retval;
    327              SETTINGFILE_LOADER_TYPE sequence_state_loader;
    328          
    329              retval     = FAIL;
    330          
    331              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    332                  if (load->Pilot_Data_Index < MultiSequencePilot_Allocation)
    333                  {
    334                      //Sequence 0 is to turn off all the loads has the highest priority
    335                      // Other sequence requested are accepted only when the previous sequence is reached to SEQUENCE_END
    336                      // If Requested_State and Processed_State are the same, it continues on that sequence.
    337                      if (((MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State == 0) ||
    338                              (MultiSequencePilot_Data[load->Pilot_Data_Index].Status.Load.Status == HBL_LOAD_STATUS_TARGET_COMPLETED)) &&
    339                          (MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State != MultiSequencePilot_Data[load->Pilot_Data_Index].Processed_State))
    340                      {
    341                          MultiSequencePilot_Data[load->Pilot_Data_Index].Sequence_State_Ptr       = NULL;
    342                          SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, MultiSequencePilot_Data[load->Pilot_Data_Index].Sequence_Displacement_Ptr[MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State], &sequence_state_loader);
    343                          MultiSequencePilot_Data[load->Pilot_Data_Index].Processed_State          = MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State;
    344                          MultiSequencePilot_Data[load->Pilot_Data_Index].Current_Sequence_State   = 0;
    345                          MultiSequencePilot_Data[load->Pilot_Data_Index].Status.Load.Status       = HBL_LOAD_STATUS_WAITING_TARGET;
    346                          MultiSequencePilot_Data[load->Pilot_Data_Index].Status.Load.Cur_Reg      = MultiSequencePilot_Data[load->Pilot_Data_Index].Requested_State;
    347          
    348                          //expire the timeout
    349                          MultiSequencePilot_Data[load->Pilot_Data_Index].TimeOut = 0;
    350                          Millis__Reset(&MultiSequencePilot_Data[load->Pilot_Data_Index].Millis_Timer);
    351          
    352                          MultiSequencePilot_Data[load->Pilot_Data_Index].Sequence_State_Ptr = (void*)sequence_state_loader.Data;
    353          
    354                          retval = PASS;
    355                      }
    356                  }
    357          
    358              #endif
    359          
    360              return (retval);
    361          }
    362          
    363          //---------------------------------------------------------------------------------------------------------------------
    364          /**
    365           * @brief
    366           * @param load
    367           * @param data
    368           * @return
    369           */
    370          PASS_FAIL_TYPE MultiSequencePilot__AsynchProcess(HBL_LOAD_TYPE * load)
    371          {
    372              PASS_FAIL_TYPE retval = FAIL;
    373              #if (MULTISEQUENCE_NUM_REGISTERED_PILOT > 0)
    374              if (load->Pilot_Data_Index < MultiSequencePilot_Allocation)
    375              {
    376                  MULTISEQUENCEPILOT_DATA_TYPE * data = &MultiSequencePilot_Data[load->Pilot_Data_Index];
    377          
    378                  // Manage the Sequence State
    379                  if ( (Millis__ReachedTarget(&data->Millis_Timer , data->TimeOut * 5) == TRUE) &&
    380                       (data->Sequence_State_Ptr != NULL) )
    381                  {
    382                      if ( data->Current_Sequence_State < data->Sequence_State_Ptr->Number_Sequence)
    383                      {
    384                          MULTISEQUENCEPILOT_SEQUENCE_STATE_TYPE * sequence_state_parameter = (MULTISEQUENCEPILOT_SEQUENCE_STATE_TYPE *)((uint8 *)data->Sequence_State_Ptr +
    385                                                                                                                                         MULTISEQUENCEPILOT_SEQUENCE_STATE_HEADER_SIZE +
    386                                                                                                                                         data->Current_Sequence_State * (data->Max_Pilot + 1));
    387          
    388                          memcpy(data->Pilot_OutPut_State, sequence_state_parameter->Pilot_State, data->Max_Pilot);
    389          
    390                          // Handle the Request function for pilots
    391                          for ( uint8 index = 0; index < data->Max_Pilot; index++ )
    392                          {
    393                              uint8 handler_index = data->Load[index].Pilot_Handler_Index;
    394                              if (( handler_index != HBL_INDEX_INVALID ) &&
    395                                  ( MULTIDRIVER__PILOT_HANDLERS[handler_index].Request != NULL ))
    396                              {
    397                                  retval = MULTIDRIVER__PILOT_HANDLERS[handler_index].Request(&(data->Load[index]), &(data->Pilot_OutPut_State[index]) );
    398                                  if (( retval == PASS ) &&
    399                                      ( MULTIDRIVER__PILOT_HANDLERS[handler_index].Process != NULL ))
    400                                  {
    401                                      retval &= MULTIDRIVER__PILOT_HANDLERS[handler_index].Process(&(data->Load[index]));
    402                                  }
    403                              }
    404                          }
    405          
    406                          // set the timer
    407                          data->TimeOut = sequence_state_parameter->Duration;
    408                          Millis__Start(&data->Millis_Timer);
    409          
    410                          data->Current_Sequence_State++;
    411          
    412                      }
    413                      else
    414                      {
    415                          data->Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    416                          data->Sequence_State_Ptr = NULL;
    417                      }
    418                  }
    419          
    420                  // Handle the Asynchronous function for pilots
    421                  for ( uint8 index = 0; index < data->Max_Pilot; index++ )
    422                  {
    423                      uint8 handler_index = data->Load[index].Pilot_Handler_Index;
    424                      if (( handler_index != HBL_INDEX_INVALID ) &&
    425                          ( MULTIDRIVER__PILOT_HANDLERS[handler_index].AsynchProcess != NULL ))
    426                      {
    427                          retval = MULTIDRIVER__PILOT_HANDLERS[handler_index].AsynchProcess(&(data->Load[index]));
    428                      }
    429                  }
    430              }
    431              #endif
    432              return ( retval );
    433          }
    434          
