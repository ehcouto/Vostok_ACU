    688          //---------------------------------------------------------------------------------------------------------------------
    689          /**
    690           * Failure handler
    691           *
    692           */
    693          static void FailureHandler(void)
    694          {
    695              Total_Restart_Cnt++;
    696              Restart_Cnt++;
    697              if(Restart_Cnt >= 2)
    698              {
    699              	Mcl_Cs.Failure_State = FAILURE_DETECTED;
    700              }
    701              else
    702              {
    703              	Mcl_Cs.Failure_State = FAILURE_RECOVERY;
    704              }
    705              GoToStopCheck();
    706          }
    707          
    708          
    709          //---------------------------------------------------------------------------------------------------------------------
    710          /**
    711           * Failure handler with recovery only
    712           *
    713           */
    714          static void FailureHandlerRecover(MCI_ERROR_TYPE last_failure)
    715          {
    716          #ifdef RECOVERY_AT_STARTUP
    717             if((Mcl_Cs.Control_Mode != MCISLFAC_IDLE) &&
    718                (Mcl_Cs.Control_Mode != MCISLFAC_STOP_CHECK) &&
    719                (Mcl_Cs.Control_Mode != MCISLFAC_STARTUP) &&
    720                (Mcl_Cs.Control_Mode != MCISLFAC_STARTUP_PULSE_MEAS) &&
    721                (Mcl_Cs.Control_Mode != MCISLFAC_STARTUP_WAIT))
    722          #else
    723              if(Mcl_Cs.Control_Mode > MCISLFAC_IDLE)
    724          #endif
    725              {
    726                  Total_Restart_Cnt++;
    727                  Mcl_Cs.Failure_State = FAILURE_RECOVERY;
    728                  GoToStopCheck();
    729              }
    730          }
