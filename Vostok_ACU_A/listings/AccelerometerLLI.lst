    258          /**
    259           *
    260           */
    261          void AccelerometerLLI__Enable(void)
    262          {
    263              AccelerometerLLI.Enabled = TRUE;
    264              if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    265              {
    266                  LISxDH__Enable(LISXDH_MODE_NORMAL);
    267              }
    268              else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    269              {
    270                  FXLS8974__Enable(FXLS8974_MODE_NORMAL);
    271              }
    272          }
    273          
    274          //---------------------------------------------------------------------------------------------------------------------
    275          /**
    276           *
    277           */
    278          void AccelerometerLLI__Disable(void)
    279          {
    280              AccelerometerLLI.Enabled = FALSE;
    281              if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    282              {
    283                  LISxDH__Disable();
    284              }
    285              else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    286              {
    287                  FXLS8974__Disable();
    288              }
    289              memset(&(AccelerometerLLI_Public.Raw), 0, sizeof(AccelerometerLLI_Public.Raw));  // Clear all accelerometer data
    290          }
