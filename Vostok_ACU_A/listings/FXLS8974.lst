   1077          //---------------------------------------------------------------------------------------------------------------------
   1078          /**
   1079           *
   1080           * @return
   1081           */
   1082          static BOOL_TYPE ReadTemp(void)
   1083          {
   1084              Fxls8974.Temperature_Read_Delay_Count++;
   1085          
   1086              if (Fxls8974.Temperature_Read_Delay_Count >= 5U)
   1087              {
   1088                  Fxls8974.Temperature_Read_Delay_Count = 0;
   1089                  return(TRUE);
   1090              }
   1091              else
   1092              {
   1093                  return(FALSE);
   1094              }
   1095          }
