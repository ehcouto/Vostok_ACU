     94          /**
     95           * @brief      This method disables the Dtoa Channel
     96           * @param      channel - Dtoa Channel
     97           */

   \                                 In section .text, align 2, keep-with-next
     98          void Dtoa__Disable(DTOA_CHANNEL_DEF channel)
     99          {
    100              #if ((DTOA_CH1_FEATURE == ENABLED) || (DTOA_CH2_FEATURE == ENABLED))
    101          
    102                  #if (DTOA_CH2_FEATURE == ENABLED)
    103                      #if (DTOA_CH1_FEATURE == ENABLED)
    104                      if (channel == DTOA_CH2)
    105                      #endif
    106                      {
    107                          DAC.SR |= DAC_SR_DMAUDR2;
    108          
    109                          //Disable the Dtoa Channel
    110                          DAC.CR &= DMA_CR_CHNL2_CLEAR;
    111                      }
    112                  #endif
    113          
    114                  #if (DTOA_CH1_FEATURE == ENABLED) && (DTOA_CH2_FEATURE == ENABLED)
    115                      else
    116                  #endif
    117                  #if (DTOA_CH1_FEATURE == ENABLED)
    118                      {
    119                          DAC.SR |= DAC_SR_DMAUDR1;
    120          
    121                          //Enable the Dtoa Channel and Enable the Output buffer which is used to reduce the output impedance
    122                          DAC.CR &= DMA_CR_CHNL1_CLEAR;
    123                      }
    124          
    125                  #endif
    126              #endif
    127          }
   \                     Dtoa__Disable: (+1)
   \   00000000   0x4770             BX       LR               ;; return
