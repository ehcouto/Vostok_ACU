     69          //---------------------------------------------------------------------------------------------------------------------
     70          /**
     71           * Check if the calibration data stored in non-volatile memory is properly sized.
     72           */
     73          void Calibration__Initialize(void)
     74          {
     75              // Check for valid configuration of the module.
     76              uint16 required = 0;
     77              for (uint8 i = 0; i < ELEMENTS_IN_ARRAY(CALIBRATION_CONFIG); i++)
     78              {
     79                  required += CALIBRATION_CONFIG[i].Data_Size;
     80              }
     81              if (required != CALIBRATION_DATA_BUFFER_LENGTH)
     82              {
     83                  LOG_ADD_EXCEPTION(IMPROPER_BUFFER_SIZE, COMBINE_BYTES(CALIBRATION_DATA_BUFFER_LENGTH, required));
     84              }
     85          }
     86          
     87          
     88          //---------------------------------------------------------------------------------------------------------------------
     89          /**
     90           * Get the calibrated value of the specified HBL_GENERIC_INPUT_ENUM_TYPE.
     91           * @param gi = The generic input (GI) associated with the Calibration Item.
     92           * @param input = The raw measured value before any calibration.
     93           * @return The calibration value of the specified HBL_GENERIC_INPUT_ENUM_TYPE.
     94           *         Returns the same value if Calibration Item is not configured.
     95           */
     96          sint32 Calibration__ApplyByGI(HBL_GENERIC_INPUT_ENUM_TYPE gi, sint32 input)
     97          {
     98              uint16 offset = 0;
     99              for (uint8 i = 0; i < ELEMENTS_IN_ARRAY(CALIBRATION_CONFIG); i++)
    100              {
    101                  if (CALIBRATION_CONFIG[i].Gi == gi)
    102                  {
    103                      CALIBRATION_FUNCTION_TYPE calibration_function = CALIBRATION_CONFIG[i].Function;
    104                      if ((calibration_function != NULL) &&
    105                          (offset < CALIBRATION_DATA_BUFFER_LENGTH))
    106                      {
    107                          void* data = &Calibration_Data[offset];
    108                          return calibration_function(input, data);
    109                      }
    110                  }
    111                  else
    112                  {
    113                      offset += CALIBRATION_CONFIG[i].Data_Size;
    114                  }
    115              }
    116              return input;
    117          }
    118          
    119          
    120          //---------------------------------------------------------------------------------------------------------------------
    121          /**
    122           * Get the calibrated value of the specified CALIBRATION_ITEM_ID_TYPE.
    123           * @param id = The ID of the requested Calibration Item.
    124           * @param input = The raw measured value before any calibration.
    125           * @return The calibration value of the specified CALIBRATION_ITEM_ID_TYPE.
    126           *         Returns the same value if Calibration Item is not configured.
    127           */
    128          sint32 Calibration__ApplyByItemID(CALIBRATION_ITEM_ID_TYPE id, sint32 input)
    129          {
    130              uint16 offset = 0;
    131              for (uint8 i = 0; i < ELEMENTS_IN_ARRAY(CALIBRATION_CONFIG); i++)
    132              {
    133                  if (CALIBRATION_CONFIG[i].Item == id)
    134                  {
    135                      CALIBRATION_FUNCTION_TYPE calibration_function = CALIBRATION_CONFIG[i].Function;
    136                      if ((calibration_function != NULL) &&
    137                          (offset < CALIBRATION_DATA_BUFFER_LENGTH))
    138                      {
    139                          void* data = &Calibration_Data[offset];
    140                          return calibration_function(input, data);
    141                      }
    142                  }
    143                  else
    144                  {
    145                      offset += CALIBRATION_CONFIG[i].Data_Size;
    146                  }
    147              }
    148              return 0;
    149          }
    150          
    151          
    152          //---------------------------------------------------------------------------------------------------------------------
    153          /**
    154           * Get the size of the calibration data used by the Calibration Item.
    155           * @param id = The Calibration Item.
    156           * @return The size of the calibration data used by the Calibration Item.
    157           */
    158          uint8 Calibration__GetDataSize(CALIBRATION_ITEM_ID_TYPE id)
    159          {
    160              for (uint8 i = 0; i < ELEMENTS_IN_ARRAY(CALIBRATION_CONFIG); i++)
    161              {
    162                  if (CALIBRATION_CONFIG[i].Item == id)
    163                  {
    164                      return CALIBRATION_CONFIG[i].Data_Size;
    165                  }
    166              }
    167              return 0;
    168          }
    169          
    170          
    171          //---------------------------------------------------------------------------------------------------------------------
    172          /**
    173           * Get a pointer to the calibration data for the specified CALIBRATION_ITEM_ID_TYPE.
    174           * @param id = The requested CALIBRATION_ITEM_ID_TYPE.
    175           * @return A pointer to the calibration data for the specified CALIBRATION_ITEM_ID_TYPE.
    176           */
    177          void* Calibration__GetDataPointer(CALIBRATION_ITEM_ID_TYPE id)
    178          {
    179              uint16 offset = 0;
    180              for (uint8 i = 0; i < ELEMENTS_IN_ARRAY(CALIBRATION_CONFIG); i++)
    181              {
    182                  if (CALIBRATION_CONFIG[i].Item == id)
    183                  {
    184                      return &Calibration_Data[offset];
    185                  }
    186                  else
    187                  {
    188                      offset += CALIBRATION_CONFIG[i].Data_Size;
    189                  }
    190              }
    191              return NULL;
    192          }
