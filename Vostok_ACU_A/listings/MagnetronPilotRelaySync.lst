    807          /**
    808           *  @brief      It Turn on actual MW Relay
    809           */
    810          static void MWRelayOn(void)
    811          {
    812              Relay_Sync_Data[Pilot_Index].MW_Relay_Pin_State = ON;
    813          
    814              uint8 table_index = Relay_Sync_Data[Pilot_Index].MW_Relay_Pin;
    815              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    816              {
    817                  Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, TRUE);
    818              }
    819          }
    820          
