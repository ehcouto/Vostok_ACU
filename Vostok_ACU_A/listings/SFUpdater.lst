    319                      timer_parameter.Timer     = TIMER1;
    320                      timer_parameter.Channel   = TIMER_CHANNEL1;
    321                      timer_parameter.Mode      = TIMER_MODE_INPUT_CAPTURE;
    322                      timer_parameter.Port      = PORT_NULL;
    323                      timer_parameter.Pin       = 0;
    324                      timer_parameter.Pin_ReMap = 0;
    325                      timer_parameter.Polarity  = TIMER_POLARITY_ACTIVE_HIGH;
    326          
    327                      Timer__Config(&timer_parameter);
    328          
    329                      communication_1ms_timer         = Timer__StartCount(&timer_parameter);
    330                      communication_5ms_counter       = 0;
    331                      displacement_timeout_counter    = 0;
    332                      displacement_index              = 0;
    333          
    334                      while (1)
    335                      {
    336                          if (Timer__GetCount(communication_1ms_timer) > SFUPDATER_ONE_MILLISECOND_IN_MICROSECOND_UNIT)
    337                          {
    338                              Timer__ReStartCount(communication_1ms_timer);
    339                              Win__Handle1ms();
    340                              Reveal__Handler1ms();
    341                              communication_5ms_counter++;
    342                          }
    343          
    344                          if (communication_5ms_counter >= SFUPDATER_FIVE_MILLISECOND_IN_MS_UNIT)
    345                          {
    346                              communication_5ms_counter = 0;
    347                              Reveal__Handler();
    348                              displacement_timeout_counter++;
    349                              SERVICE_WATCHDOG();
    350                          }
    351          
    352                          //manage updating the displacement data
    353                          switch (SFUpdater_Displacement_State)
    354                          {
    355                              case SFUPDATER_DISPLACEMENT_STATE_INITIALIZE:
    356                                  SFUpdater_Displacement_State = SFUPDATER_DISPLACEMENT_STATE_WAIT_ACU_ALIVE;
    357                                  break;
    358          
    359                              case SFUPDATER_DISPLACEMENT_STATE_WAIT_ACU_ALIVE:
    360                                  if ((Reveal__GetNodestatus() & ((uint16) 1U << (uint8) WIN_ACU_ADDRESS)) != 0U)
    361                                  {
    362                                      // ACU is alive
    363                                      SFUpdater_Displacement_State = SFUPDATER_DISPLACEMENT_STATE_WAIT_MSG_SIZE;
    364                                      (void) Reveal__QueueMessageNoData(1,17,WIN_ACU_ADDRESS,TRUE,FALSE);
    365                                      displacement_timeout_counter = 0;
    366                                  }
    367                                  break;
    368          
    369                              case SFUPDATER_DISPLACEMENT_STATE_WAIT_MSG_SIZE:
    370                                  // Wait for reply from ACU with message size; See SFUpdater__RxMaxPackage()
    371                                  if (displacement_timeout_counter >= SFUPDATER_ONE_SECOND_IN_FIVE_MS_UNIT)
    372                                  {
    373                                      //Restart the process if  ACU did not replied
    374                                      SYSTEM_RESET();
    375                                  }
    376                                  break;
    377          
    378                              case SFUPDATER_DISPLACEMENT_STATE_REQUEST_SFDISPLACEMENT_INFO:
    379                                  if (displacement_index < SFUPDATER_NUM_DISPLACEMENT)
    380                                  {
    381                                      (void) API007Data__RequestSettingFileDisplacementInfo(WIN_ACU_ADDRESS, SFUPDATER_DISPLACEMENT_LIST[displacement_index].SF_Pointer_ID,
    382                                          SFUPDATER_DISPLACEMENT_LIST[displacement_index].SF_Displacement);
    383          
    384                                      displacement_index++;
    385                                      SFUpdater_Displacement_State = SFUPDATER_DISPLACEMENT_STATE_WAIT_SFDISPLACEMENT_INFO;
    386                                      displacement_timeout_counter = 0;
    387                                  }
    388                                  else
    389                                  {
