    964          /**
    965          *
    966          * @brief    Handling SINGLEREQ command.
    967          *
    968          * @param    pMessageIO - original command (in) and response buffer (out)
    969          *
    970          * @return   As all command handlers, the return value should be the buffer
    971          *           pointer where the response output finished (except checksum)
    972          *
    973          */
    974          MC_BPTR MC_SingleReq(MC_BPTR pMessageIO)
    975          {
    976              MC_BPTR pResponse = pMessageIO;
    977              MC_ADDR nAddr = (MC_ADDR) Receive;
    978              MC_ADDR pAddr = (MC_ADDR) Transmit;
    979              unsigned char index = 0;
    980          
    981              /* Skips command byte and Len byte */
    982              pMessageIO = MC_SkipInBuffer(pMessageIO, 2U);
    983          
    984              /* Retrieve the index byte */
    985              pMessageIO = MC_ValueFromBuffer8(&index, pMessageIO);
    986          
    987              /* Retrieve the values */
    988              pMessageIO = MC_CopyFromBuffer(nAddr, pMessageIO, SIM_INPUT_LEN_ARRAY[index]);
    989          
    990              // Copy to the mapped variables
    991              COPY_TO_VAR(index, Receive);
    992          
    993              // Call back
    994              SINGLEREQ_CALLBACK(index);
    995          
    996              // Read operation
    997              // check the response will safely fit into comm buffer
    998              if(SIM_INPUT_LEN_ARRAY[index] > (MC_U8)MC_COMM_BUFFER_SIZE)
    999              {
   1000                  return MC_ConstToBuffer8(pResponse, MC_STC_RSPBUFFOVF);
   1001              }
   1002          
   1003              // Success
   1004              pResponse = MC_ConstToBuffer8(pResponse, MC_STS_OK);
   1005              // Copy from variables to buffer payload
   1006              COPY_FROM_VAR(index, Transmit);
   1007          
   1008              // Copy from buffer payload to send buffer
   1009              pResponse = MC_CopyToBuffer(pResponse, pAddr, SIM_OUTPUT_LEN_ARRAY[index]);
   1010          
   1011              return pResponse;
   1012          }
