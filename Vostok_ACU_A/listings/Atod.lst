    124          /**
    125           *    @brief  - Maximum de-bounce counter value for invalid reference voltage detection.
    126           *    @details- When the ADC get stuck then the de-bounce counter starts incrementing and
    127           *              whenever the counter reaches to the above macro value it throws an SRATOD_STUCK_EXCEPTION.
    128           *
    129           *              If the Atod__EngineClassBCheck() function is called from Applience thread which runs at 100ms then
    130           *              module will throw an SRATOD_STUCK_EXCEPTION exception after 100 * MAX_INTERNAL_REF_DEBOUNCE time if the Atod engine got stuck
    131           *
    132           *    @param  - 1/2/3/4
    133           *
    134           *    @note -   "#define MAX_INTERNAL_REF_DEBOUNCE          5"
    135           *              "#define MAX_INTERNAL_REF_DEBOUNCE          10"
    136           */
    137          //=====================================================================================================================
    138          #ifndef MAX_INTERNAL_REF_DEBOUNCE
    139              #define MAX_INTERNAL_REF_DEBOUNCE                       5
    140          #endif
    141          
