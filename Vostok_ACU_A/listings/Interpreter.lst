     90          {
     91              // Cross category Op Codes 0 - 5. Common and required for all projects.
     92              NULL_PROCESS,                                   //!< OpCode:  0 SetState (handled by interpreter)
     93              SetVariable__Process,                           //!< OpCode:  1 SetVariable
     94              Maintain__Process,                              //!< OpCode:  2 Implements timing in the cycle step.
