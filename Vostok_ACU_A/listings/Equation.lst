    279          // -- Private Macro Declarations --
    280          
    281          //! Macro that returns the number of values that are on the equation stack.
    282          #define STACK_USED(eq)              ((eq)->Index + 1)
    283          
    284          //! Macro that returns TRUE if the equation stack is full.
    285          #define STACK_IS_FULL(eq)           ((eq)->Index >= EQUATION_STACK_SIZE - 1)
