     65          //---------------------------------------------------------------------------------------------------------------------
     66          /**
     67           *    @brief  - Time the Master node executes the wake up sequence defined for each node in the SRPOWERMGR_WAKEUP_LIST[] list
     68           *              which could be either by sending WIN Break Signal, Asserting GPIO pin to wake up the other node or
     69           *              applying project specific method
     70           *
     71           *              Modifies this time only if your board requires longer time of assertion
     72           *    @details- Resolution 10, value can not be 0
     73           */
     74          #ifndef SRPOWERMGR_EXECUTE_WAKEUP_SEQUENCE_IN_MS
     75              #define SRPOWERMGR_EXECUTE_WAKEUP_SEQUENCE_IN_MS                150
     76          #elif (SRPOWERMGR_EXECUTE_WAKEUP_SEQUENCE_IN_MS == 0)
     77              #error: "SRPOWERMGR_EXECUTE_WAKEUP_SEQUENCE_IN_MS shall be non zero value with resolution of 10"
     78          #endif
     79          
     80          
     81          //---------------------------------------------------------------------------------------------------------------------
     82          /**
     83           *    @brief  - Node response/communication/activation time after performing the wake up sequence(WIN Break Signal,
     84           *              GPIO Pin assertion or project specific  function call) to communicate over the network
     85           *
     86           *              This depends on the boot up time of the individual node.
     87           *
     88           *              If one of the node failed to response then the module try the wake up sequence for 3 times
     89           *    @details- Resolution 10, value can not be 0
     90           */
     91          #ifndef SRPOWERMGR_NODE_RESPONSE_TIMEOUT_AFTER_WAKEUP_SEQUENCE_IN_MS
     92              #define SRPOWERMGR_NODE_RESPONSE_TIMEOUT_AFTER_WAKEUP_SEQUENCE_IN_MS                1000
     93          #elif (SRPOWERMGR_NODE_RESPONSE_TIMEOUT_AFTER_WAKEUP_SEQUENCE_IN_MS == 0)
     94              #error: "SRPOWERMGR_NODE_RESPONSE_TIMEOUT_AFTER_WAKEUP_SEQUENCE_IN_MS shall be non zero value with resolution of 10"
     95          #endif
     96          
     97          
     98          //---------------------------------------------------------------------------------------------------------------------
     99          /**
    100           *    @brief  - After coming from low power to the normal power mode the communication line shall be idle within
    101           *              SRPOWERMGR_COM_CHECK_TIMEOUT_IN_MS time to determine the
    102           *    @details- Resolution 10, value can not be 0
    103           */
    104          #ifndef SRPOWERMGR_COM_CHECK_TIMEOUT_IN_MS
    105              #define SRPOWERMGR_COM_CHECK_TIMEOUT_IN_MS                2000
    106          #elif (SRPOWERMGR_COM_CHECK_TIMEOUT_IN_MS == 0)
    107              #error: "SRPOWERMGR_COM_CHECK_TIMEOUT_IN_MS shall be non zero value with resolution of 10"
    108          #endif
    109          
    110          
    111          //---------------------------------------------------------------------------------------------------------------------
    112          /**
    113           *    @brief  - Node to send the feedback for the Command message within SRPOWERMGR_FEEDBACK_MESSAGE_TIMEOUT_IN_MS timeout
    114           *    @details- Resolution 10, value can not be 0
    115           */
    116          #ifndef SRPOWERMGR_FEEDBACK_MESSAGE_TIMEOUT_IN_MS
    117              #define SRPOWERMGR_FEEDBACK_MESSAGE_TIMEOUT_IN_MS                2000
    118          #elif (SRPOWERMGR_FEEDBACK_MESSAGE_TIMEOUT_IN_MS == 0)
    119              #error: "SRPOWERMGR_FEEDBACK_MESSAGE_TIMEOUT_IN_MS shall be non zero value with resolution of 10"
    120          #endif
