    209          //---------------------------------------------------------------------------------------------------------------------
    210          /**
    211           * Initialize all the instances of this pilot type.
    212           *  - Initialize static RAM used by the module.
    213           *  - Initialize any corrupted NVData used by the module.
    214           */
    215          void ExternalMotorPilot__Initialize(void)
    216          {
    217              memset(Emp, 0, sizeof(Emp));
    218              Emp_Allocation = 0;
    219              Emp_Sf = NULL;
    220              Emp_This = NULL;
    221          }
    222          
    223          
    224          //---------------------------------------------------------------------------------------------------------------------
    225          /**
    226           * Reserve memory for this pilot instance.
    227           * @return The index of the allocated pilot.
    228           *         Return UCHAR_MAX if there is no space allocated for another pilot of this type.
    229           */
    230          uint8 ExternalMotorPilot__Allocate(void)
    231          {
    232              uint8 pilot_index = UCHAR_MAX;
    233              if (Emp_Allocation < HBL_PILOT_NUM_EXTERNAL_MOTOR)
    234              {
    235                  pilot_index = Emp_Allocation;
    236                  Emp_Allocation++;
    237              }
    238              return pilot_index;
    239          }
    240          
    241          
    242          //---------------------------------------------------------------------------------------------------------------------
    243          /**
    244           * Initialize this pilot instance.
    245           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    246           * @return Always returns PASS.
    247           *         The return value is ignored by HBL.
    248           */
    249          PASS_FAIL_TYPE ExternalMotorPilot__InitializeInstance(HBL_LOAD_TYPE* load)
    250          {
    251              if (load != NULL)
    252              {
    253                  uint8 pilot_index = load->Pilot_Data_Index;
    254                  if (pilot_index < Emp_Allocation)
    255                  {
    256                      // Start the state machine for the pilot.
    257                      Emp_This = &Emp[pilot_index];
    258                      Emp_This->Requested.Standard.Command = EXTERNAL_MOTOR_NO_CHANGE;
    259                      Emp_This->Processed.Standard.Command = EXTERNAL_MOTOR_NO_CHANGE;
    260                      ExternalMotorPilotInitialize();
    261                      return PASS;
    262                  }
    263              }
    264              return FAIL;
    265          }
    266          
    267          
    268          //---------------------------------------------------------------------------------------------------------------------
    269          /**
    270           * Update the requested state of the output controlled by this pilot instance.
    271           * If 'load' correctly identifies a pilot and if 'data' represents an invalid command, then this
    272           * function will generate a EXTERNAL_MOTOR_NO_COMMAND command.
    273           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    274           * @param data = A pointer to memory that contains the new requested pilot state.
    275           * @return Always returns PASS.
    276           *         The return value is ignored by HBL.
    277           */
    278          PASS_FAIL_TYPE ExternalMotorPilot__Request(HBL_LOAD_TYPE* load, void* data)
    279          {
    280              if ((load != NULL) && (data != NULL))
    281              {
    282                  // Determine if the pilot index is in range.
    283                  uint8 pilot_index = load->Pilot_Data_Index;
    284                  if (pilot_index < Emp_Allocation)
    285                  {
    286                      // Determine the size of the data.
    287                      EXTERNAL_MOTOR_COMMAND_TYPE* cmd = (EXTERNAL_MOTOR_COMMAND_TYPE*)data;
    288                      uint8 size = GetCommandSize(cmd->Common.Command);
    289          
    290                      // Determine if command size is in range.
    291                      if ((1 <= size) && (size <= EXTERNAL_MOTOR_MAX_COMMAND_SIZE))
    292                      {
    293                          // Save the external motor command for later processing.
    294                          memcpy(&Emp[pilot_index].Requested, cmd, size);
    295                          return PASS;
    296                      }
    297                      else
    298                      {
    299                          // Invalid command -- stop the motor.
    300                          LOG_ADD_EXCEPTION(INVALID_MOTOR_REQUEST, COMBINE_BYTES(load->Load_Id, cmd->Standard.Command));
    301                          Emp[pilot_index].Requested.Standard.Command = EXTERNAL_MOTOR_NO_COMMAND;
    302                      }
    303                  }
    304              }
    305              return FAIL;
    306          }
    307          
    308          
    309          //---------------------------------------------------------------------------------------------------------------------
    310          /**
    311           * Update the output(s) controlled by this pilot instance based on previous requests.
    312           *  - If the command is a custom command, then it should always be sent. The same custom
    313           *      platform-specific commands may need to be sent sequentially more than once.
    314           *  - If the command is an EXTERNAL_MOTOR_NO_CHANGE command, then there is nothing to do.
    315           *      The previously processed command should be preserved.
    316           *  - If the command is a standard command, and it is different from the previously processed
    317           *      command, then send the new standard command.
    318           *  - If the command is a standard command, and it is the same as the previously processed
    319           *      command, then there is nothing to do. Let the Keep Running mechanism preserve the original
    320           *      standard command.
    321           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    322           * @return Always returns PASS.
    323           *         The return value is ignored by HBL.
    324           */
    325          PASS_FAIL_TYPE ExternalMotorPilot__Process(HBL_LOAD_TYPE* load)
    326          {
    327              if (load != NULL)
    328              {
    329                  uint8 pilot_index = load->Pilot_Data_Index;
    330                  if (pilot_index < Emp_Allocation)
    331                  {
    332                      // Setup the RAM and SettingFile access variables.
    333                      Emp_This = &Emp[pilot_index];
    334                      Emp_Sf = (EXTERNAL_MOTOR_PILOT_SF_CONFIG_TYPE*)(void*)load->Parameter_Ptr.Data;
    335          
    336                      // Check if the command needs to be processed.
    337                      EXTERNAL_MOTOR_COMMAND_TYPE* processed = &Emp_This->Processed;
    338                      EXTERNAL_MOTOR_COMMAND_TYPE* cmd = &Emp_This->Requested;
    339                      uint8 size = GetCommandSize(cmd->Common.Command);
    340                      BOOL_TYPE changed = (BOOL_TYPE)((cmd->Standard.Command != EXTERNAL_MOTOR_NO_CHANGE) &&
    341                                                      (memcmp(processed, cmd, size) != 0));
    342                      if ((changed == TRUE) || (cmd->Custom.Is_Custom_Command == TRUE))
    343                      {
    344                          // Process the command.
    345                          memcpy(processed, cmd, size);
    346                          if (Emp_This->State == STATE_EXTERNAL_MOTOR_PILOT_CONNECTED)
    347                          {
    348                              SendProcessed();
    349                          }
    350                      }
    351          
    352                      // Run the pilot state machine.
    353                      if ((Emp_This != NULL) && (Emp_Sf != NULL))
    354                      {
    355                          ExternalMotorPilotExecute();
    356                      }
    357                  }
    358              }
    359              return PASS;
    360          }
    361          
    362          
    363          //---------------------------------------------------------------------------------------------------------------------
    364          /**
    365           * Get the requested state of the output controlled by this pilot instance.
    366           * This function does not necessarily return the current state of the output.
    367           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    368           * @return A pointer to data that describes the requested state of the output.
    369           */
    370          void* ExternalMotorPilot__GetRequested(HBL_LOAD_TYPE* load)
    371          {
    372              if (load != NULL)
    373              {
    374                  uint8 pilot_index = load->Pilot_Data_Index;
    375                  if (pilot_index < Emp_Allocation)
    376                  {
    377                      EXTERNAL_MOTOR_PILOT_DATA_TYPE* pilot = &Emp[pilot_index];
    378                      if (pilot->Requested.Standard.Command == EXTERNAL_MOTOR_NO_CHANGE)
    379                      {
    380                          // Since the request is to not change anything, return the processed.
    381                          return (&pilot->Processed);
    382                      }
    383                      else if (GetCommandSize(pilot->Requested.Common.Command) > 0)
    384                      {
    385                          // Return the latest request.
    386                          return (&pilot->Requested);
    387                      }
    388                  }
    389              }
    390              return NULL;
    391          }
    392          
    393          
    394          //---------------------------------------------------------------------------------------------------------------------
    395          /**
    396           * Get the state of the output controlled by this pilot instance.
    397           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    398           * @return A pointer to data that describes the state of the output.
    399           */
    400          void* ExternalMotorPilot__GetProcessed(HBL_LOAD_TYPE* load)
    401          {
    402              if (load != NULL)
    403              {
    404                  uint8 pilot_index = load->Pilot_Data_Index;
    405                  if (pilot_index < Emp_Allocation)
    406                  {
    407                      return (&Emp[pilot_index].Processed);
    408                  }
    409              }
    410              return NULL;
    411          }
    412          
    413          
    414          //---------------------------------------------------------------------------------------------------------------------
    415          /**
    416           * Get the status of this pilot instance.
    417           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    418           * @return A pointer to #BOOL_TYPE value that indicates whether the motor is connected.
    419           *         FALSE = Disconnected. TRUE = Connected.
    420           */
    421          void* ExternalMotorPilot__GetStatus(HBL_LOAD_TYPE* load)
    422          {
    423              if (load != NULL)
    424              {
    425                  Emp_Sf = (EXTERNAL_MOTOR_PILOT_SF_CONFIG_TYPE*)(void*)load->Parameter_Ptr.Data;
    426                  Emp_Status.Motor_Index = (uint8)EMP_MOTOR_INDEX();
    427                  Emp_Status.Is_Connected = API221MotionCtrl__IsMotorPresentOnBus((API221_CLIENT_MOTOR_INDEX_TYPE)Emp_Status.Motor_Index);
    428                  return &Emp_Status;
    429              }
    430              return NULL;
    431          }
