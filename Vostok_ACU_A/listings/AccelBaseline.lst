    393          /**
    394           * Request that the module measure the baseline acceleration of the machine.
    395           * @return TRUE if the baseline measurement has been scheduled; otherwise, FALSE.
    396           */
    397          BOOL_TYPE AccelBaseline__MeasureBaseline(void)
    398          {
    399              BOOL_TYPE is_measurement_started = FALSE;
    400          
    401              if ((Accel_Baseline_State == STATE_ACCEL_BASELINE_IDLE) &&
    402                  (LISxDH__GetStatus() == ACCELEROMETER_DISABLED))
    403              {
    404                  EventBaseline();
    405                  is_measurement_started = TRUE;
    406              }
    407              else
    408              {
    409                  LOG_ADD_EXCEPTION(BASELINE_MEASUREMENT_NOT_AVAILABLE, Accel_Baseline_State);
    410                  is_measurement_started = FALSE;
    411              }
    412          
    413              return(is_measurement_started);
    414          }
    415          
