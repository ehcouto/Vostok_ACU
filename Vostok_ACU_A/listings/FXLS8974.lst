   1119          
   1120          //---------------------------------------------------------------------------------------------------------------------
   1121          /**
   1122           * Wait the necessary boot up time for the accelerometer hardware.
   1123           */
   1124          static void WaitForBootComplete(void)
   1125          {
   1126              if (Fxls8974.Timer > ACCEL_TIME_BOOT_UP)
   1127              {
   1128                  EventBootComplete();
   1129              }
   1130          }
