    289          //---------------------------------------------------------------------------------------------------------------------
    290          /**
    291           *  @brief      Get the motor load index for the external load.
    292           *
    293           *  @param      HBL_LOAD_TYPE *load - Pointer to ice dispenser door load instance.
    294           *
    295           *  @return     uint8 motor_load_index - value from setting file for load position in motor ACU loads buffer.
    296           */
    297          static uint8 GetMotorLoadIndex(HBL_LOAD_TYPE *load)
    298          {
    299              PASS_FAIL_TYPE load_success;
    300              uint8 motor_load_index;
    301              SETTINGFILE_LOADER_TYPE sf_loader_data;
    302          
    303              motor_load_index = 0;
    304              load_success = SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE,
    305                                                      load->Pilot_Type_Params_Offset,
    306                                                      &sf_loader_data);
    307              if (load_success == PASS)
    308              {
    309                  if (sf_loader_data.Length > 0)
    310                  {
    311                      motor_load_index = sf_loader_data.Data[0];
    312                  }
    313              }
    314          
    315              return (motor_load_index);
    316          }
    317          #endif /* (MOTO_PILOT_AUX_FUNC == TRUE) */
