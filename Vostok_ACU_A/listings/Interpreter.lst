     44          
     45          //! Structure type to hold interpreter running data
     46          PACKED typedef struct INTERPRETER_DATA_STRUCT
     47          {
     48              uint8               Setting_File_Index;         //!< '0' primary SF. Non 0 new cycle data added in customers home.
     49              CYCLE_PHASE_STATEMENT_TYPE  Cps;                //!< Current cycle, phase and statement.
     50              CYCLE_STATE_TYPE    Cycle_State;                //!< The state cycle that the interpreter shall run.
     51              uint8               Step_Time_Counter;          //!< 100 millisecond counter used to count seconds for elapsed step time.
     52              BOOL_TYPE           Step_Initializing   : 1;    //!< TRUE = This is the first call to this process on this step.
     53              BOOL_TYPE           Resume_From_Pause   : 1;    //!< TRUE = Step is resuming after a cycle pause or sub-cycle.
     54              BOOL_TYPE           Resume_From_Reset   : 1;    //!< TRUE = Step is resuming after a power reset.
     55              BOOL_TYPE           SF_Error            : 1;    //!< TRUE = Error loading settings file data (Interpreter will not run).
     56              uint16              Lo_Statement_Index;         //!< Index (displacement) to process data table.
     57          } INTERPRETER_DATA_TYPE;
