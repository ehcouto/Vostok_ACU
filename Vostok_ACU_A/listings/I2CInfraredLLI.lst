    776          static void RequestEepromRead(void)
    777          {
    778              uint8 address = I2C_READ_INSTRUCTIONS[I2c_Infrared_Lli.Transfer_Step].Read_Address;
    779              uint8 size = I2C_READ_INSTRUCTIONS[I2c_Infrared_Lli.Transfer_Step].Read_Size;
    780              if (I2c__WriteThenRead(I2c_Infrared_Lli.Sf->I2c_Channel, &address, sizeof(address), size) == FALSE)
    781              {
    782                  EventFail();
    783              }
    784          }
