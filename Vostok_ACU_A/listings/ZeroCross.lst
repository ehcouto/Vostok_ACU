    794                  if(ZeroCross_Gpio_Port != PORT_NULL)
    795                  {
    796                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    797                      switch(ZeroCross_Event)
    798                      {
    799                          case ZEROCROSS_ANGLE_0_EVENT:
    800                              event = ZEROCROSS_ANGLE_90_EVENT;
    801                              ZeroCross_Lobe = ZEROCROSS_POS_LOBE;
    802                              break;
    803                          case ZEROCROSS_ANGLE_90_EVENT:
    804                              event = ZEROCROSS_ANGLE_180_EVENT;
    805                              ZeroCross_Lobe = ZEROCROSS_NEG_LOBE;
    806                              break;
    807                          case ZEROCROSS_ANGLE_180_EVENT:
    808                              event = ZEROCROSS_ANGLE_270_EVENT;
    809                              ZeroCross_Lobe = ZEROCROSS_NEG_LOBE;
    810                              break;
    811                          case ZEROCROSS_ANGLE_270_EVENT:
    812                          default:
    813                              event = ZEROCROSS_ANGLE_0_EVENT;
    814                              if(ZeroCross_Debounce_Counter < (uint8) ZC_DEBOUNCE_CYCLE)
    815                              {
    816                                  sint32 new_cycle_sync = 0;
    817                                  uint32 delta_time = Millis__GetElapsed(&ZeroCross_Blackout);
    818                                  sint32 new_angle_event_time = (sint32) Timer__GetCount(ZeroCross_Timer_Count_Id);
    819                                  new_angle_event_time += (sint32) Zero_Angle_Reference;
    820          
    821                                  // Set the current Angle event time - used as timing reference
    822                                  if(new_angle_event_time < ((sint32) ZeroCross_Cycle / 4))
    823                                  {
    824                                      new_angle_event_time += (sint32) ZeroCross_Cycle;
    825                                  }
    826                                  ZeroCross_Angle_Event_Time = (uint16) new_angle_event_time;
    827          
    828                                  // ZeroCross Cycle Sync - determine the distance between current Angle 0 event and
    829                                  // the detected one from Signal events, then calculate the compensation value to
    830                                  // synchronize Angle events.
    831                                  // Performed only if last event detect happened within the maximum cycle time allowed.
    832                                  if((ZeroCross_Debounce_Counter > 0U) &&
    833                                      (delta_time < MAX_CYCLE_TIME_MS))
    834                                  {
    835                                      ZeroCross_Debounce_Counter--;
    836                                      if(ZeroCross_Angle_Event_Time >= (ZeroCross_Cycle / 4U))
    837                                      {
    838                                          new_cycle_sync = (sint32) ZeroCross_Angle_Event_Time;
    839                                          if(ZeroCross_Angle_Event_Time >= (ZeroCross_Cycle / 2U))
    840                                          {
    841                                              new_cycle_sync -= (sint32) ZeroCross_Cycle;
    842                                          }
    843                                          new_cycle_sync -= ZC_ADVANCE_PULSE_DELAY;
    844                                          #if(ZC_INVERT_PIN_VALUE == ENABLED)
    845                                              new_cycle_sync -= (sint32) Duty_Cycle_Offset;
    846                                          #else
    847                                              new_cycle_sync += (sint32) Duty_Cycle_Offset;
    848                                          #endif
    849                                          new_cycle_sync /= 4;
    850                                      }
    851                                  }
    852          
    853          
    854                                  // Debounce completed - update state, ZeroCross valid range and nominal frequency
    855                                  if(ZeroCross_Debounce_Counter == 0U)
    856                                  {
    857                                      UpdateNominalFrequency();
    858                                      UpdateValidRange();
    859                                      if(ZeroCross_State != ZEROCROSS_DETECTED_SIGNAL)
    860                                      {
    861                                          ZeroCross_State = ZEROCROSS_DETECTED_SIGNAL;
    862                                      }
    863                                  }
    864          
    865                                  ZeroCross_Cycle_Sync = (sint16) new_cycle_sync;
    866                                  Zero_Events_Sequence++;
    867                              }
    868                              ZeroCross_Lobe = ZEROCROSS_POS_LOBE;
    869                              break;
    870                      }
    871          
    872                      // Cycle offset evaluated from Asynch handler and needs to be applied
    873                      // It will be limited to the maximum distance allowed by the valid range
    874                      // and offset decremented to be applied on the next angle event
    875                      if(ZeroCross_Cycle_Offset != 0)
    876                      {
    877                          offset = ZeroCross_Cycle_Offset;
    878                          if(ZeroCross_Cycle_Offset < 0)
    879                          {
    880                              offset = -offset;
    881                          }
    882                          offset_threshold = (sint16) ZeroCross_Max_Cycle;
    883                          offset_threshold -= (sint16) ZeroCross_Min_Cycle;
    884                          offset_threshold /= 2;
    885                          if(offset > offset_threshold)
    886                          {
    887                              offset = offset_threshold;
    888                          }
    889                          if(ZeroCross_Cycle_Offset < 0)
    890                          {
    891                              offset = -offset;
    892                          }
    893                          ZeroCross_Cycle_Offset -= offset;
    894                      }
    895          
    896                      ZeroCross_Event = event;
    897                      offset_threshold = (sint16) ZeroCross_Cycle / 4;
    898                      offset = offset_threshold - offset;
    899                      offset -= ZeroCross_Cycle_Sync;
    900                      (void) Timer__OutputCompareStartFromLast(&ZeroCross_Pin_Timer, TIMER_ONCOMPARE_INTERRUPT, (uint32) ((sint32) offset));
    901                      ZC_ANGLE_EVENT(event);
