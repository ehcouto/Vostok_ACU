   1316          /**
   1317           * @brief       Function that Updates Nominal Frequency from current Cycle time
   1318           *
   1319           * @details     If no Nominal frequency was detected, it uses ZC_NOMINAL_FREQ_THRESHOLD (55 Hz) as separator between 50 and 60 Hz
   1320           *              Transition between 50 and 60 Hz will happen if current frequency goes above 56 Hz
   1321           *              Transition between 60 and 50 Hz will happen if current frequency goes below 54 Hz
   1322           *
   1323           */
   1324          static void UpdateNominalFrequency(void)
   1325          {
   1326              // Update ZeroCross nominal frequency with an hysteresis if already determined
   1327              if(Nominal_Frequency != 0U)
   1328              {
   1329                  if(ZeroCross_Cycle > ZC_CYCLE_USEC(ZC_NOMINAL_FREQ_THRESHOLD-1))
   1330                  {
   1331                      Nominal_Frequency = 50U;
   1332                  }
   1333                  else if(ZeroCross_Cycle < ZC_CYCLE_USEC(ZC_NOMINAL_FREQ_THRESHOLD+1))
   1334                  {
   1335                      Nominal_Frequency = 60U;
   1336                  }
   1337              }
   1338              // Use ZC_NOMINAL_FREQ_THRESHOLD reference on the first run
   1339              else if(ZeroCross_Cycle < ZC_CYCLE_USEC(ZC_NOMINAL_FREQ_THRESHOLD))
   1340              {
   1341                  Nominal_Frequency = 60U;
   1342              }
   1343              else
   1344              {
   1345                  Nominal_Frequency = 50U;
   1346              }
   1347          }
   1348          
   1349          /**
   1350           * @brief       Reset valid range to the full Min-Max range (e.g. 45-65 Hz) if ZC_THRESHOLD_PERCENTAGE is not 0
   1351           *
   1352           */
   1353          static void ResetValidRange(void)
   1354          {
   1355              #if(ZC_THRESHOLD_PERCENTAGE > 0)
   1356                  ZeroCross_Max_Cycle = (uint16) ZC_CYCLE_USEC(ZC_ALLOWED_MIN_FREQUENCY);
   1357                  ZeroCross_Min_Cycle = (uint16) ZC_CYCLE_USEC(ZC_ALLOWED_MAX_FREQUENCY);
   1358              #endif
   1359          }
   1360          
   1361          /**
   1362           * @brief       Update valid range (Min-Max) applying ZC_THRESHOLD_PERCENTAGE to the determined Cycle time,
   1363           *                  if ZC_THRESHOLD_PERCENTAGE is not 0
   1364           *
   1365           */
   1366          static void UpdateValidRange(void)
   1367          {
   1368          #if(ZC_THRESHOLD_PERCENTAGE > 0)
   1369              ZeroCross_Max_Cycle = (uint16) (((uint32) ZeroCross_Cycle * (100U + (uint8) ZC_THRESHOLD_PERCENTAGE)) / 100U);
   1370              ZeroCross_Min_Cycle = (uint16) (((uint32) ZeroCross_Cycle * (100U - (uint8) ZC_THRESHOLD_PERCENTAGE)) / 100U);
   1371          #endif
   1372          }
