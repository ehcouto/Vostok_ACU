   1052              API12_Expansion_ACU_GI_Buffer[0] = number_of_gis;
   1053          
   1054              uint8 data_index = 1;
   1055          
   1056              uint32 gi_converted_data;
   1057              for (uint8 gi_index = 0; gi_index < number_of_gis; gi_index++)
   1058              {
   1059                  //DATA[1]-->GI DATA SIZE
   1060                  API12_Expansion_ACU_GI_Buffer[data_index]     = Hbl__GetGISequenceIDByIndex(gi_index);
   1061          
   1062                  //DATA[2 - 5]--> GI_DATA
   1063                  gi_converted_data = Hbl__GetGIDataConvertedByIndex(gi_index);
   1064          
   1065                  API12_Expansion_ACU_GI_Buffer[data_index + 1] = (gi_converted_data >> 24);
   1066                  API12_Expansion_ACU_GI_Buffer[data_index + 2] = (gi_converted_data >> 16);
   1067                  API12_Expansion_ACU_GI_Buffer[data_index + 3] = (gi_converted_data >> 8);
   1068                  API12_Expansion_ACU_GI_Buffer[data_index + 4] = gi_converted_data;
   1069                  data_index += API012_GI_PAYLOAD_SIZE+1;
   1070              }
   1071          
   1072              if (memcmp(compare_buffer, API12_Expansion_ACU_GI_Buffer, AP12_ACU_GI_Data_Size) != 0)
   1073              {
   1074                  return TRUE;
   1075              }
   1076              else
   1077              {
   1078                  return FALSE;
   1079              }
   1080          }
   1081          
   1082          //---------------------------------------------------------------------------------------------------------------------
   1083          /**
   1084           * @brief Update ACU Load Status buffer.
   1085           *
   1086           *  @return     BOOL_TYPE changed - Indicates if the status of any GI has changed.
   1087           *  @retval     TRUE - Load Status has changed.
   1088           *  @retval     FALSE - Load Status has no changed
   1089           */
   1090          static BOOL_TYPE UpdateAcuLoadStatus(void)
   1091          {
   1092              BOOL_TYPE changed;
   1093              uint8 compare_buffer[API12_ACU_MAX_LOADS];
   1094              uint8 *data_ptr;
   1095              uint8 load_index;
   1096              uint8 num_loads;
   1097          
   1098              changed = FALSE;
   1099              memcpy(compare_buffer, API12_ACU_Loads_Status_Buffer, sizeof(compare_buffer));
   1100          
   1101              num_loads = Hbl__GetNumLoads();
   1102              for (load_index = 0; load_index < num_loads; load_index++)
   1103              {
   1104                  data_ptr = Hbl__GetLoadStatusByIndex(load_index);
   1105                  if (data_ptr != NULL)
   1106                  {
   1107                      API12_ACU_Loads_Status_Buffer[load_index] = *data_ptr;
   1108                  }
   1109                  else
   1110                  {
   1111                      API12_ACU_Loads_Status_Buffer[load_index] = 0xFF;
   1112                  }
   1113          
   1114              }
   1115          
   1116              if (memcmp(compare_buffer, API12_ACU_Loads_Status_Buffer, sizeof(API12_ACU_Loads_Status_Buffer)) != 0)
   1117              {
   1118                  changed = TRUE;
   1119              }
   1120          
   1121              return (changed);
   1122          }
   1123          #endif // (SYSTEM_ACU_EXPANSION_HANDLING == ENABLED)
   1124          
   1125          #if (SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)
   1126              #if (API012EXP_HMI_EVENT_BASED == DISABLED)
   1127              //----------------------------------------------------------------------------------------------------------
   1128              /**
   1129               *
   1130               * @param address
   1131               */
   1132              static void PublishHMIGIs(uint8 address)
   1133              {
   1134                  uint8 index;
   1135                  uint8 size;
   1136                  uint8 * pt_data;
   1137                  REVEAL_COMMAND_TYPE * ptr;
   1138          
   1139                  size = BIT_STORAGE_SIZE(AP12_Hmi_Num_GI_Digital) + 1;
   1140                  size += (AP12_Hmi_Num_GI_Analog >> 1) + 1;
   1141                  size += AP12_Hmi_Num_GI_Encoder + 1;
   1142          
   1143                  ptr = API012REVEAL__NEWFEEDBACK(API012EXP_NUM, API012EXP_REQ_HMI_PUB_GIS, WIN_UI_ADDRESS,size);
   1144          
   1145                  if (ptr != (REVEAL_COMMAND_TYPE *) NULL)
   1146                  {
   1147                      Reveal__AddDataU8(ptr, AP12_Hmi_Num_GI_Digital);
   1148                      if (AP12_Hmi_Num_GI_Digital > 0)
   1149                      {
   1150                          Reveal__AddDataU8Buffer(ptr, API12_Buffer_Digital,BIT_STORAGE_SIZE(AP12_Hmi_Num_GI_Digital));
   1151                      }
   1152          
   1153                      Reveal__AddDataU8(ptr, AP12_Hmi_Num_GI_Analog);
   1154                      if (AP12_Hmi_Num_GI_Analog > 0)
   1155                      {
   1156                          // HMI Analog Data processing
   1157                          for (index = 0; index < AP12_Hmi_Num_GI_Analog; index++)
   1158                          {
   1159                              pt_data = HblHmi__GetGIData(HBLHMI_GI_READ_ANALOG,index);
   1160                              if (pt_data != NULL)
   1161                              {
   1162                                  Reveal__AddDataU16(ptr,*((uint16 *)pt_data));
   1163                              }
   1164                              else
   1165                              {
   1166                                  Reveal__AddDataU16(ptr,0xFFFF);
   1167                              }
   1168                          }
   1169                      }
   1170          
   1171                      Reveal__AddDataU8(ptr, AP12_Hmi_Num_GI_Encoder);
   1172                      if (AP12_Hmi_Num_GI_Encoder > 0)
   1173                      {
   1174                          for (index = 0; index < AP12_Hmi_Num_GI_Encoder; index++)
   1175                          {
   1176                              pt_data = HblHmi__GetGIData(HBLHMI_GI_READ_ENCODER,index);
   1177                              if (pt_data != NULL)
   1178                              {
   1179                                  Reveal__AddDataU8(ptr,*pt_data);
   1180                              }
   1181                              else
   1182                              {
   1183                                  Reveal__AddDataU8(ptr,0xFF);
   1184                              }
   1185                          }
   1186                      }
   1187                      Reveal__QueueCommand(ptr);
   1188                  }
   1189              }
   1190              #else // API012EXP_HMI_EVENT_BASED is ENABLED
   1191              //---------------------------------------------------------------------------------------------------------------------
   1192              /**
   1193               * @brief Parse the API012EXP_HMI_LED_EVENT OpCode
   1194               * @details payload[0] = 0 the command is directed to a single LED or a group of LEDs
   1195               *          payload[0] = 1 the command is directed to ALL Leds listed in the SettingFile
   1196               * @param buffer as received from Reveal
   1197               * @retval NVO_RS_READY command successfully parsed
   1198               * @retval NVO_RS_UNSUP_INVALID_PARAM payload[0] contains an unsupported value
   1199               * @retval NVO_RS_REJECTED unable to parse the received NULL buffer
   1200               */
   1201              REVEAL_RECIPE_STATUS_TYPE LedCommandParser(REVEAL_MSG_TYPE * buffer)
   1202              {
   1203                  REVEAL_RECIPE_STATUS_TYPE retval = NVO_RS_READY;
   1204                  uint8 instance_field = 0;
   1205                  ON_OFF_TYPE led_state = OFF;
   1206                  uint8 led_intensity = 0;
   1207          
   1208                  if((NULL != buffer ) && (NULL != buffer->payload))
   1209                  {
   1210                      // Reveal Payload: Instance |LED State | LED Intensity.
   1211                      // If Instance is 255, then it is using Opcode zero to drive a group of LEDs.
   1212                      if(buffer->payload[0] == LED_CMD_SET_STATE)
   1213                      {
   1214                          instance_field = buffer->payload[1];
   1215                          led_state = (ON_OFF_TYPE)buffer->payload[2];
   1216                          led_intensity = buffer->payload[3];
   1217          
   1218                          if(instance_field < INVALID_LED_INDEX)
   1219                          {
   1220                              if(led_state == OFF)
   1221                              {
   1222                                  HblHmi__SetObject(VISUAL_OBJECT_LED, instance_field, PATTERN_ALL, LED_INTENSITY_OFF, HBLHMI_LED_PRIORITY_EMBEDDED);
   1223                              }
   1224                              if(led_state == ON)
   1225                              {
   1226                                  HblHmi__SetObjectWithPWM(VISUAL_OBJECT_LED, instance_field, PATTERN_ALL, led_intensity, VIEWMGR_PWM_0, HBLHMI_LED_PRIORITY_EMBEDDED);
   1227                              }
   1228                          }
   1229                          else
   1230                          {
   1231                              //Here we need the number of instances and we need to point to them.
   1232                              // Reveal Payload: Set LED | Instance | LED State | LED Intensity | Number of Instances | Instance #1 | Instance #2 | ... | Instance n.
   1233                              uint8 number_of_instances = buffer->payload[4];
   1234                              uint8 *instances = &(buffer->payload[5]);
   1235                              for(uint8 led=0; led< number_of_instances; led++)
   1236                              {
   1237                                  if(led_state == OFF)
   1238                                  {
   1239                                      HblHmi__SetObject(VISUAL_OBJECT_LED, instances[led], PATTERN_ALL, LED_INTENSITY_OFF, HBLHMI_LED_PRIORITY_EMBEDDED);
   1240                                  }
   1241                                  if(led_state == ON)
   1242                                  {
   1243                                      HblHmi__SetObjectWithPWM(VISUAL_OBJECT_LED, instances[led], PATTERN_ALL, led_intensity, VIEWMGR_PWM_0, HBLHMI_LED_PRIORITY_EMBEDDED);
   1244                                  }
   1245                              }
   1246                          }
   1247                      }
   1248                      else if(buffer->payload[0] == LED_CMD_SET_ALL)
   1249                      {
   1250                          led_state = (ON_OFF_TYPE)(buffer->payload[1]&0x01);
   1251                          led_intensity = buffer->payload[2];
   1252                          LedMgr__SetAllLeds(led_intensity*led_state,0);
   1253                      }
   1254                      else
   1255                      {
   1256                          retval = NVO_RS_UNSUP_INVALID_PARAM;
   1257                      }
   1258                  }
   1259                  else
   1260                  {
   1261                      retval = NVO_RS_REJECTED;
   1262                  }
   1263          
   1264                  return retval;
   1265              }
   1266          
   1267              //---------------------------------------------------------------------------------------------------------------------
   1268              /**
   1269               * @brief HblHmi callback from HblHmi for GI events
   1270               * @details Publishes GI events to SoC
   1271               * @param event received from HblHmi
   1272               */
   1273              static void HmiGIEventHandler(HBLHMI_GI_EVENT_TYPE event)
   1274              {
   1275                  HmiGIGetAndPublish(event.GI_Read_Type, event.GI_Position);
   1276                  Last_GI_Event.GI_Position = event.GI_Position;
   1277                  Last_GI_Event.GI_Read_Type = event.GI_Read_Type;
   1278              }
   1279          
   1280              //---------------------------------------------------------------------------------------------------------------------
   1281              /**
   1282               * @brief Parse the API012EXP_HMI_GI_EVENT OpCode
   1283               * @param buffer as received from Reveal
   1284               * @retval NVO_RS_READY command successfully parsed
   1285               * @retval NVO_RS_REJECTED unable to parse the received NULL buffer
   1286               */
   1287              REVEAL_RECIPE_STATUS_TYPE GiCommandParser(REVEAL_MSG_TYPE * buffer)
   1288              {
   1289                  REVEAL_RECIPE_STATUS_TYPE retval = NVO_RS_READY;
   1290                  uint8 gi_index;
   1291                  uint8 num_of_gis = HblHmi__GetNumGIReadType(buffer->payload[0]);     //total number of GIs of specific read type as payload[0] is read type
   1292          
   1293                  if(NULL != buffer)
   1294                  {
   1295                      if(buffer->payload[1] == 0xFF)                                   //payload[1] is used for GI index, special payload 0xFF is used to publish all the GIs of same read type
   1296                      {
   1297                          for(gi_index = 0; gi_index < num_of_gis; gi_index++)
   1298                          {
   1299                              HmiGIGetAndPublish(buffer->payload[0], gi_index);        //publish all GIs of same read type
   1300                          }
   1301                      }
   1302                      else
   1303                      {
   1304                          HmiGIGetAndPublish(buffer->payload[0], buffer->payload[1]);
   1305                      }
   1306                  }
   1307                  else
   1308                  {
   1309                      retval = NVO_RS_REJECTED;
   1310                  }
   1311          
   1312                  return retval;
   1313              }
   1314          
   1315          //---------------------------------------------------------------------------------------------------------------------
   1316              /**
   1317               * @brief publish event on request because of which system wake up
   1318               * @details Publish last GI event data on API012, opcode 18 (API012EXP_HMI_GI_EVENT)
   1319               * API 012, Opcode 20 publish last event publish on API 012 opcode 18
   1320               * Last_Event_Data[] holds data of latest event and used to publish upon request
   1321               */
   1322          
   1323              static void PublishLastGiEvent(void)
   1324              {
   1325                  REVEAL_COMMAND_TYPE *cmd;
   1326                  cmd = Reveal__NewFeedback(API012EXP_NUM, API012EXP_HMI_LAST_STORED_GI_EVENT, REVEAL_BROADCAST_NODE, API012_OP20_MAX_DATA_SIZE);
   1327          
   1328                  if(cmd != NULL)
   1329                  {
   1330                      Reveal__AddDataU8(cmd, Last_GI_Event.GI_Read_Type);
   1331                      Reveal__AddDataU8(cmd, Last_GI_Event.GI_Position);
   1332                      if(!Reveal__QueueCommand(cmd))
   1333                      {
   1334                          LOG_ADD_EXCEPTION(QUEUEING_ON_REVEAL, Reveal__GetFreeQueueSpace());
   1335                      }
   1336                  }
   1337          
   1338              }
   1339          
   1340          
   1341          //---------------------------------------------------------------------------------------------------------------------
   1342              /**
   1343               * @brief clears last GI event variable when reset
   1344               * @details sets invalid GI read type (=3 not defined) and GI position to =63 when system reset
   1345               */
   1346              static void ClearLastGiEventInfo (void)
   1347              {
   1348                  memset((void *)&Last_GI_Event, 0xFF, sizeof(Last_GI_Event));
   1349              }
   1350          
   1351              //---------------------------------------------------------------------------------------------------------------------
   1352              /**
   1353               * @brief Get the data of specified GI and publish it
   1354               * @details Publish GI data on API012, opcode 18 (API012EXP_HMI_GI_EVENT)
   1355               *          Payload composition:
   1356               *          |      Payload[0]      | Payload[1] | Payload[2] | Payload[3] | Payload[4] |  Payload[5]  |
   1357               *          |       GI TYPE        |GI position | Data size  |            |
   1358               *          ------------------------------------------EXAMPLES-----------------------------------------
   1359               *          |HBLHMI_GI_READ_DIGITAL|      n     |     1      |  b0000ppcc*|
   1360               *          |HBLHMI_GI_READ_ANALOG |      n     |     2      |  current   |  previous  |
   1361               *          |HBLHMI_GI_READ_ENCODER|      n     |     3      |  current   |  previous  | direction     |
   1362               *
   1363               *          *pp - previous state,cc - current state {00 - released, 01 - pressed, 11 - unknown}
   1364               *
   1365               * @param read_type Type of the GI to publish
   1366               * @param gi_position Position of the GI to publish
   1367               */
   1368              static void HmiGIGetAndPublish(HBLHMI_GI_READ_TYPE read_type, uint8 gi_position)
   1369              {
   1370                  void* gi_data;
   1371                  uint8 gi_index;
   1372                  uint8 gi_data_size;
   1373                  REVEAL_COMMAND_TYPE *cmd;
   1374          
   1375                  gi_data      = HblHmi__GetGIData(read_type, gi_position);
   1376                  gi_index     = HblHmi__GetGIConfigIndexByType(read_type, gi_position);
   1377                  gi_data_size = HblHmi__GetGIDataSizeByIndex(gi_index);
   1378                  cmd = Reveal__NewFeedback(API012EXP_NUM, API012EXP_HMI_GI_EVENT, REVEAL_BROADCAST_NODE, HMI_GI_EVENT_HEADER_LENGHT + gi_data_size);
   1379          
   1380                  if(cmd != NULL)
   1381                  {
   1382                      Reveal__AddDataU8(cmd, read_type);
   1383                      Reveal__AddDataU8(cmd, gi_position);
   1384                      Reveal__AddDataU8(cmd, gi_data_size);
   1385                      Reveal__AddDataU8Buffer(cmd, (uint8*)gi_data, gi_data_size);
   1386                      if(!Reveal__QueueCommand(cmd))
   1387                      {
   1388                          LOG_ADD_EXCEPTION(QUEUEING_ON_REVEAL, Reveal__GetFreeQueueSpace());
   1389                      }
   1390                  }
   1391              }
