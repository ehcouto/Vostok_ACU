    112          //---------------------------------------------------------------------------------------------------------------------
    113          /**
    114           * @brief   Checks if there is free space and reserve a new instance
    115           * @return  index of AnalogLLI instance, 0xFF if all HBL_LLI_NUM_SRFEEDBACK are already allocated
    116           */
    117          uint8 SRFeedbackLLI__Allocate(void)
    118          {
    119              uint8 retval = HBL_ALLOCATION_INVALID;
    120          
    121              (void) SRData__CheckByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation);
    122              if(SRFeedbackLLI_Allocation < (uint8) HBL_LLI_NUM_SRFEEDBACK)
    123              {
    124                  retval = SRFeedbackLLI_Allocation;
    125                  SRData__UpdateByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation, SRFeedbackLLI_Allocation + 1U);
    126              }
    127              return (retval);
    128          }
    129          
    130          //---------------------------------------------------------------------------------------------------------------------
    131          /**
    132           * @brief       It initialises an instance in the module SRFeedbackLLI and its variables
    133           * @param       input - Hbl LLI Data structure of the instance to process
    134           * @return      PASS if initialization succeeded
    135           *
    136           */
    137          
    138          PASS_FAIL_TYPE SRFeedbackLLI__InitializeInstance(HBL_LLI_TYPE * input)
    139          {
    140              PASS_FAIL_TYPE retval = FAIL;
    141          
    142              (void) SRData__CheckByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation);
    143          
    144              if(input->Data_Index < SRFeedbackLLI_Allocation)
    145              {
    146                  SRFEEDBACKLLI_DATA_TYPE *data = &SRFeedbackLLI_Data[input->Data_Index];
    147                  SRFEEDBACKLLI_DATA_TYPE *n_data = &N_SRFeedbackLLI_Data[input->Data_Index];
    148                  SRFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *)input->Parameter_Ptr.Data;
    149                  GPIO_PIN_MODE_TYPE type = INPUT_FLOAT;
    150                  uint8 virtual_pin = input->Pin_Ptr[0];
    151          
    152                  (void) SRData__CheckArray(data, n_data, sizeof(SRFEEDBACKLLI_DATA_TYPE));
    153          
    154                  if((feedback_param != NULL) &&
    155                      ((uint8) feedback_param->Pull_Up != 0U))
    156                  {
    157                      type = INPUT_PULLUP;
    158                  }
    159          
    160                  if(virtual_pin < VirtualPin__GetNumOf())
    161                  {
    162                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, type);
    163                      SRData__UpdateByte((void *) &data->Value,(void *) &n_data->Value, SRFEEDBACKLLI_INVALID);
    164          
    165                      // Save SRZeroCrossLLI instance reference to check FeedbackLLI in/opposite phase
    166                      if(input->LLI_ID == HBL_LLI_SRZEROCROSS)
    167                      {
    168                          (void) SRData__CheckByte(&SRZeroCross_Index, &N_SRZeroCross_Index);
    169                          SRData__UpdateByte(&SRZeroCross_Index, &N_SRZeroCross_Index, input->Data_Index);
    170                      }
    171          
    172                      if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, type, FALSE))
    173                      {
    174                          retval = PASS;
    175                      }
    176                  }
    177              }
    178          
    179              return (retval);
    180          }
