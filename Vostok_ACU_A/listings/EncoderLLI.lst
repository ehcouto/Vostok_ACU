     28          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     29          
     30          typedef enum
     31          {
     32          	ENCODER_MACHINE_RESET = 0,
     33          	ENCODER_MACHINE_WAIT,
     34          	ENCODER_MACHINE_DONE
     35          } ENCODER_MACHINE_TYPE;
     36          
     37          typedef struct
     38          {
     39          	uint8 Pin_CH1_Old;
     40          	uint8 Pin_CH2_Old;
     41          	uint8 Latch_CHx   				:1;
     42          	uint8 Rotation_Type    			:2;  // Store temporary ClockWise versus.
     43          	uint8 Machine_Enc_Filter_Steps  :5;
     44          } ARRAY_PINS_TRANSITION_TYPE;
     45          
     46          static ARRAY_PINS_TRANSITION_TYPE  Array_Pin_CH_Old [HBL_LLI_NUM_ENCODER];
     47          
     48          typedef struct
     49          {
     50          	uint8 Filter_Sample;
     51          	uint8 Read_Attempt;
     52          	uint8 R_flag:1;
     53          	uint8 Channel:1;
     54          } ENCODER_PARAMETER_TYPE;
     55          
     56          static ENCODER_PARAMETER_TYPE Encoder_Input_Param [HBL_LLI_NUM_ENCODER];
     57          
     58          static ENCODER_DATA_TYPE EncoderLLI_Data [HBL_LLI_NUM_ENCODER];
     59          
     60          static uint8 EncoderLLI_Allocation;
     61          
     62          #define ENCODERLOWINPUT_CFG0_NREAD_MASK      0x07
     63          #define ENCODERLOWINPUT_CFG0_AUTO_MASK       0x80
     64          
     65          #define ENCODERLOWINPUT_CFG1_INVERT          0x80
     66          #define ENCODERLOWINPUT_CFG1_RFLAG           0x40
     67          #define ENCODERLOWINPUT_CFG1_PULLUP          0x20
     68          
     69          #define TYPE_ROTATION_1						1
     70          #define TYPE_ROTATION_2						2
     71          
     72          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     73          static void ResetArrayPinChOld (HBL_LLI_TYPE * input, uint8 pinvalLoc, uint8 pinval2Loc);
     74          
     75          //=====================================================================================================================
     76          //-------------------------------------- Public Functions -------------------------------------------------------------
     77          //=====================================================================================================================
     78          //---------------------------------------------------------------------------------------------------------------------
     79          /**
     80           * @brief      It Initializes the module DigitalLowLevel and its variables
     81           */
     82          
     83          void EncoderLLI__Initialize (void)
     84          {
     85              memset(&EncoderLLI_Data,0,sizeof(EncoderLLI_Data));
     86              EncoderLLI_Allocation = 0;
     87          }
     88          
     89          //---------------------------------------------------------------------------------------------------------------------
     90          /**
     91           * @brief
     92           * @return
     93           */
     94          uint8 EncoderLLI__Allocate (void)
     95          {
     96              uint8 retval = HBL_ALLOCATION_INVALID;
     97          
     98              if (EncoderLLI_Allocation < HBL_LLI_NUM_ENCODER)
     99              {
    100                  retval = EncoderLLI_Allocation;
    101                  EncoderLLI_Allocation++;
    102              }
    103              return (retval);
    104          }
    105          
    106          //---------------------------------------------------------------------------------------------------------------------
    107          /**
    108           *  @brief
    109           *
    110           */
    111          PASS_FAIL_TYPE EncoderLLI__InitializeInstance (HBL_LLI_TYPE * input)
    112          {
    113              GPIO_PIN_MODE_TYPE type;
    114              uint8 virtual_pin;
    115              uint8 virtual_pin2;
    116              uint8 pinval;
    117              uint8 pinval2;
    118              uint8 digitalcfg1;
    119          
    120              if (input->Data_Index < EncoderLLI_Allocation)
    121              {
    122          		type = INPUT_FLOAT;
    123          
    124          		virtual_pin  = input->Pin_Ptr[0];
    125          		virtual_pin2 = input->Pin_Ptr[1];
    126          
    127          		digitalcfg1 = input->Parameter_Ptr.Data[1];
    128          
    129          		if (digitalcfg1 & ENCODERLOWINPUT_CFG1_PULLUP)
    130          		{   // This Flag is important in case we have Encoder with internal PullUp you don't have check.
    131          			type = INPUT_PULLUP;
    132          		}
    133          
    134          		Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, type);
    135          		Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin, type);
    136          
    137          		pinval  = Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    138          		pinval2 = Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin);
    139          
    140          		Array_Pin_CH_Old [input->Data_Index].Pin_CH1_Old = pinval;
    141          		Array_Pin_CH_Old [input->Data_Index].Pin_CH2_Old = pinval2;
    142          		Array_Pin_CH_Old [input->Data_Index].Latch_CHx  = 0;
    143          		Array_Pin_CH_Old [input->Data_Index].Rotation_Type 	 = 0;
    144          		Array_Pin_CH_Old [input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_RESET;
    145          
    146                   return (PASS);
    147              }
    148              else
    149              {
    150                  return (FAIL);
    151              }
    152          }
    153          
    154          //---------------------------------------------------------------------------------------------------------------------
    155          /**
    156           *
    157           * @param input
    158           * @param data
    159           * @return
    160           */
    161          void * EncoderLLI__Get (HBL_LLI_TYPE * input)
    162          {
    163              if (input->Data_Index < EncoderLLI_Allocation)
    164              {
    165                  return ((void *) &EncoderLLI_Data[input->Data_Index]);
    166              }
    167              else
    168              {
    169                  return (NULL);
    170              }
    171          }
    172          
    173          //---------------------------------------------------------------------------------------------------------------------
    174          /**
    175           *
    176           * @param input
    177           * @return
    178           */
    179          BOOL_TYPE EncoderLLI__AsynchProcess (HBL_LLI_TYPE * input)
    180          {
    181          	BOOL_TYPE retval;
    182              uint8 pinval;
    183              uint8 pinval2;
    184              uint8 digitalcfg0;
    185              uint8 digitalcfg1;
    186              uint8 virtual_pin;
    187              uint8 virtual_pin2;
    188              uint8 nsamples;
    189          
    190              retval = FALSE;
    191          
    192              if (input->Data_Index < EncoderLLI_Allocation)
    193              {
    194                  virtual_pin = input->Pin_Ptr[0];
    195                  virtual_pin2 = input->Pin_Ptr[1];
    196          
    197                  digitalcfg0 = input->Parameter_Ptr.Data[0];
    198                  digitalcfg1 = input->Parameter_Ptr.Data[1];
    199          
    200                  pinval = Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    201                  pinval2 = Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin);
    202          
    203                  nsamples = 1 << (digitalcfg0 & ENCODERLOWINPUT_CFG0_NREAD_MASK);
    204          
    205                  Encoder_Input_Param[input->Data_Index].Filter_Sample = nsamples;
    206          
    207                  // Inverted logic flag enabled - swap TRUE to FALSE
    208                  if (digitalcfg1 & ENCODERLOWINPUT_CFG1_INVERT)
    209                  {
    210                      pinval ^= TRUE;
    211                      pinval2 ^= TRUE;
    212                  }
    213          
    214                  if (digitalcfg1 & ENCODERLOWINPUT_CFG1_RFLAG)
    215                  {
    216                      Encoder_Input_Param[input->Data_Index].R_flag = 1;
    217                  }
    218          
    219                  if ((Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old != pinval) &&
    220                      (Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old == pinval2) &&
    221                      (Array_Pin_CH_Old[input->Data_Index].Latch_CHx == 0) )
    222                  {
    223                      Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_WAIT;
    224                      Array_Pin_CH_Old[input->Data_Index].Rotation_Type = TYPE_ROTATION_1;
    225                      Encoder_Input_Param[input->Data_Index].Read_Attempt++;
    226          
    227                      if (Encoder_Input_Param[input->Data_Index].Read_Attempt >= Encoder_Input_Param[input->Data_Index].Filter_Sample)
    228                      {
    229                          Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old = pinval;
    230                          Array_Pin_CH_Old[input->Data_Index].Latch_CHx = 1;
    231                          Encoder_Input_Param[input->Data_Index].Read_Attempt = 0;
    232                      }
    233          
    234                      retval = FALSE;
    235          	    }
    236                  else if ((Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old != pinval2) &&
    237                           (Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old == pinval) &&
    238                           (Array_Pin_CH_Old[input->Data_Index].Latch_CHx == 0))
    239                  {
    240                      Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_WAIT;
    241          
    242                      Array_Pin_CH_Old[input->Data_Index].Rotation_Type = TYPE_ROTATION_2;
    243          
    244                      Encoder_Input_Param[input->Data_Index].Read_Attempt++;
    245          
    246                      if (Encoder_Input_Param[input->Data_Index].Read_Attempt >= Encoder_Input_Param[input->Data_Index].Filter_Sample)
    247                      {
    248                          Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old = pinval2;
    249                          Array_Pin_CH_Old[input->Data_Index].Latch_CHx = 1;
    250                          Encoder_Input_Param[input->Data_Index].Read_Attempt = 0;
    251                      }
    252          
    253                      retval = FALSE;
    254                  }
    255                  else
    256                  {
    257                      ResetArrayPinChOld(input, pinval, pinval2);
    258                  }
    259          
    260                  if ((Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps == ENCODER_MACHINE_WAIT) &&
    261                      (Array_Pin_CH_Old[input->Data_Index].Rotation_Type == TYPE_ROTATION_1) &&
    262                      (pinval == pinval2))
    263                  {
    264                      Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_DONE;
    265                      Encoder_Input_Param[input->Data_Index].Channel = 1;
    266          
    267                      Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old = pinval;
    268                      Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old = pinval2;
    269                      Array_Pin_CH_Old[input->Data_Index].Latch_CHx = 0;
    270                      Encoder_Input_Param[input->Data_Index].Read_Attempt = 0;
    271                  }
    272                  else if ((Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps == ENCODER_MACHINE_WAIT) &&
    273                           (Array_Pin_CH_Old[input->Data_Index].Rotation_Type == TYPE_ROTATION_2) &&
    274                           (pinval == pinval2))
    275                  {
    276                      Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_DONE;
    277                      Encoder_Input_Param[input->Data_Index].Channel = 0;
    278          
    279                      Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old = pinval;
    280                      Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old = pinval2;
    281                      Array_Pin_CH_Old[input->Data_Index].Latch_CHx = 0;
    282                      Encoder_Input_Param[input->Data_Index].Read_Attempt = 0;
    283                  }
    284          
    285                  if (Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps == ENCODER_MACHINE_DONE)
    286                  {
    287                      EncoderLLI_Data[input->Data_Index].Pending = 1;
    288          
    289                      if (Encoder_Input_Param[input->Data_Index].R_flag == TRUE)
    290                      {
    291                          EncoderLLI_Data[input->Data_Index].Rotation = ~Encoder_Input_Param[input->Data_Index].Channel;
    292                      }
    293                      else
    294                      {
    295                          EncoderLLI_Data[input->Data_Index].Rotation = Encoder_Input_Param[input->Data_Index].Channel;
    296                      }
    297          
    298                      ResetArrayPinChOld(input, pinval, pinval2);
    299          
    300                      retval = TRUE;
    301                  }
    302                  else
    303                  {
    304                      ResetArrayPinChOld(input, pinval, pinval2);
    305                      retval = FALSE;
    306                  }
    307              }
    308          
    309              return (retval);
    310          }
    311          
    312          //=====================================================================================================================
    313          //-------------------------------------- Private Functions ------------------------------------------------------------
    314          //=====================================================================================================================
    315          
    316          //---------------------------------------------------------------------------------------------------------------------
    317          /**
    318           * @brief
    319           * @param   input
    320           * @param   pinvalLoc
    321           * @param   pinval2Loc
    322           */
    323          static void ResetArrayPinChOld (HBL_LLI_TYPE * input, uint8 pinvalLoc, uint8 pinval2Loc)
    324          {
    325          	Array_Pin_CH_Old[input->Data_Index].Machine_Enc_Filter_Steps = ENCODER_MACHINE_RESET;
    326          	Array_Pin_CH_Old[input->Data_Index].Rotation_Type = 0;
    327          	Array_Pin_CH_Old[input->Data_Index].Pin_CH1_Old = pinvalLoc;
    328          	Array_Pin_CH_Old[input->Data_Index].Pin_CH2_Old = pinval2Loc;
    329          	Array_Pin_CH_Old[input->Data_Index].Latch_CHx = 0;
    330          	Encoder_Input_Param[input->Data_Index].Read_Attempt = 0;
    331          }
