     76          PASS_FAIL_TYPE DoorSwitchGI__InitializeInstance(HBL_GI_TYPE * generic_input, uint8 lli_sequence)
     77          {
     78          	PASS_FAIL_TYPE retval;
     79          
     80          	retval = FAIL;
     81          
     82          	if(generic_input->Data_Index < DoorSwitchGI_Allocation)
     83          	{
     84          		DoorSwitchGI_LLI_Sequence[generic_input->Data_Index] = lli_sequence;
     85          		retval = PASS;
     86          	}
     87              return(retval);}
