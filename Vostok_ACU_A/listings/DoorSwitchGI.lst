     43           */
     44          void DoorSwitchGI__Initialize(void)
     45          {
     46              DoorSwitchGI_Allocation = 0;
     47              memset(DoorSwitchGI_LLI_Sequence, 0, sizeof(DoorSwitchGI_LLI_Sequence));
     48          }
