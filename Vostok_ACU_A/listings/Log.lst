     47          #ifndef LOG_RATE_CHECK_PERIOD
     48              //! The period over which the message rate is checked.
     49              //! This is also the period between two published messages when the message rate is exceeded.
     50              //! Each count represents one call to the Log__Background() function.
     51              //! Typically, 1 count equals 25ms, or 40 counts equals 1 second.
     52              #define LOG_RATE_CHECK_PERIOD 80
     53          #endif
     54          
     55          #ifndef LOG_MAX_RATE
     56              //! As long as more than LOG_MAX_RATE log messages are generated over the LOG_RATE_CHECK_PERIOD,
     57              //! the Log module will slow the publication rate down to one message per LOG_RATE_CHECK_PERIOD.
     58              #define LOG_MAX_RATE 18
     59          #endif
     60          
