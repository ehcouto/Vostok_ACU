    538                              Gpio__PinWrite(I2C_2_SCL_PORT, I2C_2_SCL_PORTBIT, FALSE);
    539                              Micro__DelayNumNops(10);
    540                              Gpio__PinWrite(I2C_2_SCL_PORT, I2C_2_SCL_PORTBIT, TRUE);
    541                              Micro__DelayNumNops(10);
    542          
    543                              //read the status of the SDA line
    544                              aux = Gpio__PinRead(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT);
    545                              count++;
    546                          }
    547          
    548                          response = (BOOL_TYPE)aux;
    549          
    550                          I2c2_Ack_Error = I2C_ERROR_NONE;
    551          
    552                          if (aux == FALSE)
    553                          {
    554                              //If the SDA line is still read as low then log the BUS_LOCK error
    555                              I2c2_Ack_Error = I2C_ERROR_BUS_LOCKED;
    556                          }
    557          
    558                          Gpio__PinConfig(I2C_2_SCL_PORT, I2C_2_SCL_PORTBIT, SPECIAL_FUNCTION_OPEN_DRAIN);   //Configure SCL line for I2C2
    559                          Gpio__PinConfig(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT, SPECIAL_FUNCTION_OPEN_DRAIN);   //Configure SDA line for I2C2
    560                      }
    561                  #endif
    562          
    563                  #if (I2C3_FEATURE == ENABLED)
