     17          @startuml
     18          	title Tank Fill State Machine
     19          	'terminate function unused
     20          
     21          	[*] --> INITIALIZE
     22          
     23          	INITIALIZE --> FILL_WATER: StartTankFill
     24          	INITIALIZE --> FILL_COMPLETE: FillCompleted
     25          
     26          	INITIALIZE: entry / InitializeTankFillVariables
     27          
     28          	FILL_WATER --> NO_WATER: NoWaterDetected
     29          	FILL_WATER --> TANK_FILL_DELAY: WaterFillOver
     30          
     31          	FILL_WATER: entry / FillWaterInitialCheck
     32          	FILL_WATER: do / FillWater
     33          
     34          	TANK_FILL_DELAY: entry / StartDelayTimer
     35          	TANK_FILL_DELAY: do / WaitForTankFillDelay
     36          
     37          	TANK_FILL_DELAY --> AFTER_FILL_CHECK_SUBCYCLE: AfterFillWaterCheckNeeded
     38          	TANK_FILL_DELAY --> FILL_COMPLETE: FillCompleted / UpdateStatistics
     39          
     40          	AFTER_FILL_CHECK_SUBCYCLE --> FILL_COMPLETE: FillCompleted / UpdateStatistics
     41          	AFTER_FILL_CHECK_SUBCYCLE: entry / ResetAFSubcycleExecution
     42          
     43          	AFTER_FILL_CHECK_SUBCYCLE: do / WaitAFSubcycleExecution
     44          
     45          	NO_WATER --> FILL_WATER: RestartFill
     46          	NO_WATER: entry / SetH2OAlarm
     47          	NO_WATER: do / WaitForPauseEnd
     48          
     49          @enduml
     50          */
