   \                                 In section .text, align 2, keep-with-next
   1172          void Spi__SetConfiguration(SPI_ENUM_DEF spi,SPI_POLARITY_TYPE pol,SPI_EDGE_TYPE edge,SPI_ORDER_TYPE order)
