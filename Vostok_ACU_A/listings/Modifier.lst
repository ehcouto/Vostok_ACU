    118          // -- Private Structure Type Declarations --
    119          
    120          //! A union of all data types (up to 32-bit).
    121          //! Note: This works because the micro is little-endian.
    122          //! Allows a float32 type to be carried in an sint32 type.
    123          typedef union MODIFIER_DATA32_UNION
    124          {
    125              uint8 UInt8;
    126              uint16 UInt16;
    127              uint32 UInt32;
    128              sint8 SInt8;
    129              sint16 SInt16;
    130              sint32 SInt32;
    131              float32 Float32;
    132          } MODIFIER_DATA32_TYPE;
    133          CT_ASSERT(sizeof(MODIFIER_DATA32_TYPE) == sizeof(sint32));
    134          
    135          //! Setting file parameters used by the Modifier module.
    136          typedef PACKED const struct MODIFIER_SF_PARAMETERS_STRUCT
    137          {
    138              MODIFIER_DTV_TYPE Dtv                             : 3;
    139              MODIFIER_OVERALL_OPERATION_TYPE Overall_Operation : 3;
    140              uint8 Unused1                                     : 1;
    141              BOOL_TYPE More_Modifications                      : 1;
    142          
    143              MODIFIER_OPERATOR_TYPE Action   : 3;
    144              BOOL_TYPE Is_Percentage         : 1;            //!< 1 = Indicates that the Operand is a percentage.
    145              DATATYPE_TYPE Type              : 4;            //!< The type of the operand.
    146          
    147              ACU_VARIABLE_ID_TYPE Variable_Index;
    148              uint8 Variable_Offset;
    149          
    150              MODIFIER_DATA32_TYPE Operand;
    151          } MODIFIER_SF_PARAMETERS_TYPE;
    152          
    153          //! Struct that represents the Level 2 table for a Modifier.
    154          //! When needed it is referenced on the Level 1 table.
    155          typedef PACKED const struct MODIFIER_SF_TABLE_HEADER_STRUCT
    156          {
    157              uint8 Search_Method             : 3;            //!< Search method to find the operand (x) in the table data.
    158              uint8 Unused1                   : 5;
    159              uint8 Number_Of_Items;                          //!< Number of (x,y) points present in the table data.
    160          } MODIFIER_SF_TABLE_HEADER_TYPE;
