   1890          static void API221HandleMotorEventAC(API221_EVENT_TYPE event)
   1891          {
   1892          	switch (event.Event)
   1893          	{
   1894          		case API221_EVENT_STOPPED:
   1895          			if (SystemTimers__NVCheckTimer(&AC_Wait_MCU_Reset_Timer_Handle) != SYSTEMTIMERS_STATE_RUNNING)
