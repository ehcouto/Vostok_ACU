    530          /**
    531           * @brief   Execute Fine turning to get the measuring bridge balance.
    532           */
    533          static void ExecuteFineTuning(void)
    534          {
    535              uint16 duty;
    536          
    537              if(Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status > 0)
    538              {
    539                  duty = AbsoluteHumidityPWMGetDuty() - 1;
    540          
    541                  if(Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter > 0)
    542                  {
    543                      Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter = 0;
    544                  }
    545                  else if(Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter > SCHAR_MIN)
    546                  {
    547                      Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter--;
    548                  }
    549              }
    550              else
    551              {
    552                  duty = AbsoluteHumidityPWMGetDuty() + 1;
    553          
    554                  if(Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter < 0)
    555                  {
    556                      Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter = 0;
    557                  }
    558                  else if(Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter < SCHAR_MAX)
    559                  {
    560                      Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter++;
    561                  }
    562              }
    563          
    564              AbsoluteHumidityPWMSetDuty(duty);
    565          
    566              Absolute_Humidity_LLI_Data[LLI_Index].Feedback_Status = 0;
    567          }
