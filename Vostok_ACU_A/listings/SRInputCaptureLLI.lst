     51          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     52          #define SRINPUTCAPTURELLI_AUTO_FEATURE_MIN_FREQUENCY          2
     53          #define SRINPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY          150
     54          
     55          #define SRINPUTCAPTURELLI_AUTO_FEATURE_FREQUENCY_HYS          30
     56          #define SRINPUTCAPTURELLI_AUTO_FEATURE_DOWN_PERIOD_HYS       (1000000 / (SRINPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY))
     57          #define SRINPUTCAPTURELLI_AUTO_FEATURE_UP_PERIOD_HYS         (1000000 / (SRINPUTCAPTURELLI_AUTO_FEATURE_MAX_FREQUENCY-SRINPUTCAPTURELLI_AUTO_FEATURE_FREQUENCY_HYS))
     58          #define MAX_INVALID_SAMPLE_COUNT                             255
     59          
     60          PACKED typedef struct
     61          {
     62              uint8 N_Read:3;
     63              uint8 Unused_1:5;
     64              uint8 Delta:4;
     65              uint8 Unused_2:4;
     66              uint8 Time_Out;
     67              uint8 Sampling_Time;
     68              uint16 Minimum_Period;
     69              uint16 Maximum_Period;
     70              uint16 Minimum_Duty;
     71              uint16 Maximum_Duty;
     72              uint16 Filter_Period;
     73              uint16 Filter_Duty;
     74              uint8 Base_Period;
     75          } SRINPUTCAPTURELLI_PARAMETERS_TYPE;
     76          
     77          PACKED typedef struct
     78          {
     79              SRINPUTCAPTURE_PUBLIC_TYPE Public_Data;
     80              uint32 Accumulator_Period;
     81              uint32 Accumulator_Duty;
     82              uint16 Filtered_Period;
     83              uint16 Filtered_Duty;
     84              BOOL_TYPE Continue_mode;
     85              BOOL_TYPE Filter_Initialized;
     86              uint8 Private_Valid_Sample_Count;
     87              uint8 Private_Invalid_Sample_Count;
     88              uint8 Private_Current_Count;
     89              uint32 Sampling_Timeout;
     90              uint32 Timeout;
     91              TIMER_PARAMETER_TYPE Timer_Parameter;
     92          }SRINPUTCAPTURE_DATA_TYPE;
