    216          #if (API019_BOARD_DATA_FEEDBACK == ENABLED)
    217          //---------------------------------------------------------------------------------------------------------------------
    218          /**
    219           * @brief Handles opcode API019PRODUCTINFO_OP_REQ_PUB_BOARD_DATA feedback
    220           * @param node_id
    221           * @param board
    222           * @param board_data
    223           */
    224          void ProductInfo__BoardDataFeedback(uint8 node_id,uint8 board ,API019_BOARD_DATA_TYPE *board_data, API019_PROJECT_TYPE *project_ids)
    225          {
    226              //initialize the Project ID list with invalid IDs
    227              memset(&External_Board[board].Project_IDs, API019_PROJECT_NOT_AVAILABLE, PRODUCTINFO_EXTERNAL_BOARD_PROJECTS_NUM);
    228          
    229              if(node_id == WIN_ACU_ADDRESS)
    230              {
    231                  if(board < PRODUCTINFO_EXTERNAL_BOARDS_NUM)
    232                  {
    233                      memcpy(&External_Board[board].Data, board_data, sizeof(API019_BOARD_DATA_TYPE));
    234                      if(project_ids != NULL)
    235                      {
    236                          memcpy(&External_Board[board].Project_IDs, project_ids, External_Board[board].Data.Board_Num_Projects);
    237                      }
    238                  }
    239              }
    240          }
    241          
    242          //---------------------------------------------------------------------------------------------------------------------
    243          /**
    244           * @brief Handles opcode API019PRODUCTINFO_OP_REQ_PUB_PROJECT_DATA feedback
    245           * @param node_id
    246           * @param board
    247           * @param project
    248           * @param project_data
    249           */
    250          void ProductInfo__ProjectDataFeedback(uint8 node_id,uint8 board,API019_PROJECT_TYPE project,API019_PROJECT_DATA_TYPE *project_data)
    251          {
    252              if(node_id == WIN_ACU_ADDRESS)
    253              {
    254                  if(board < PRODUCTINFO_EXTERNAL_BOARDS_NUM)
    255                  {
    256                      if(project == API019_PROJECT_FIRMWARE)
    257                      {
    258                          memcpy(&External_Board_Project_Data[board][project], project_data, sizeof(API019_PROJECT_DATA_TYPE));
    259                      }
    260                      else if(project == API019_PROJECT_SETTINGFILE)
    261                      {
    262                          memcpy(&External_Board_Project_Data[board][1], project_data, sizeof(API019_PROJECT_DATA_TYPE));
    263                      }
    264                  }
    265              }
    266          }
    267          #endif
