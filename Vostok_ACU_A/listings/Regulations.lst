     90          
     91          //! Maximum number of regulations that can be handled by the module. Can be overridden for project specific purposes.
     92          //! This value is validated during initialization to ensure the firmware can handle the number of regulations defined
     93          //! in the setting file.
     94          #ifndef REGULATION_MAX_NUM
     95              #define REGULATION_MAX_NUM      41
     96          #endif
     97          //! Ensure number of regulations does not exceed the max payload size for Reveal to prevent the need for multiple messages
     98          //! Reducing the reveal payload by 5 to allow for additional bytes in the payload that aren't a regulation index
     99          CT_ASSERT(REGULATION_MAX_NUM <= REVEAL_PAYLOAD_SIZE - 5);
