    408          //---------------------------------------------------------------------------------------------------------------------
    409          /**
    410           *    @brief    This method initializes the ADC Engine.
    411           *    @details  This method initializes the Atod module variable and resets the entire ADC related variable.
    412           *              This method is called in the Initialization_Tasks (SRMain_prm.h),
    413           *              should be called after SRGpio__Initialize().
    414           *              This must be called before calling any other Atod API’s.
    415           */

   \                                 In section .text, align 2, keep-with-next
    416          void Atod__EngineInitialize(void)
    417          {
   \                     Atod__EngineInitialize: (+1)
   \   00000000   0xB4F0             PUSH     {R4-R7}
    418              #if (ATOD_SR_FEATURE_TEST == ENABLED)
    419                  SR_SET_BYTE(Atod_Exception_Debounce_Count, 0);
    420                  SRData__Fill(&Atod_Channel_Debounce_Count, &N_Atod_Channel_Debounce_Count, 0, sizeof(Atod_Channel_Debounce_Count));
    421              #endif
