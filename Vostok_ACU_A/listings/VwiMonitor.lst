     92          /**
     93           * 	@brief 		Main handler for VwiMonitor
     94           */

   \                                 In section .text, align 2, keep-with-next
     95          void VwiMonitor__Execute(void)
     96          {
     97          #if(VWI_CLIENT_FEATURE == ENABLED)
     98          	uint8 label = (Selector__GetCycleState(0, 0, (Interpreter__GetCurrentStatement(0)).Cycle));
     99          
    100          	//In case of cycle is running or we have some fault and we will need VWI information
    101          	if((label == CYCLE_STATE_RUN) || (label == CYCLE_STATE_FAULT))
    102          	{
    103          		if(VwiMonitor_Callback_Active == FALSE)
    104          		{
    105          			API221MotionCtrl__RegisterForEvents(API221HandleMotorEvent);
    106          			VwiMonitor_Callback_Active = TRUE;
    107          		}
    108          	}
    109          	else
    110          	{
    111          		//Unsubscribe Motor state and also turn off remote data
    112          		if(VwiMonitor_Callback_Active == TRUE)
    113          		{
    114          			API221MotionCtrl__UnregisterForEvents(API221HandleMotorEvent);
    115          			VwiMonitor_Callback_Active = FALSE;
    116          
    117          			Vwi__RemoteChannelEnable(MOTOR_0, MCISENSORSDW_AI_VWI_CHANNEL_0, FALSE);
    118          			Vwi__RemoteChannelEnable(MOTOR_0, MCISENSORSDW_AI_VWI_CHANNEL_1, FALSE);
    119          			Vwi__RemoteChannelEnable(MOTOR_1, MCISENSORSDW_AI_VWI_CHANNEL_0, FALSE);
    120          			Vwi__RemoteChannelEnable(MOTOR_1, MCISENSORSDW_AI_VWI_CHANNEL_1, FALSE);
    121          		}
    122          	}
    123          #endif // (VWI_CLIENT_FEATURE == ENABLED)
    124          }
   \                     VwiMonitor__Execute: (+1)
   \   00000000   0x4770             BX       LR               ;; return
