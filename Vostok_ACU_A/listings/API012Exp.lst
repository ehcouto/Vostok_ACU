    286          /**
    287           * @brief This method parses messages target to the API017 sent to a broadcast or exclusively to this node for Reveal 4.x.
    288           * @param buffer contains the Wide package that contains the message
    289           * @return REVEAL_RECIPE_STATUS_TYPE that express the result of the parsing.
    290           */

   \                                 In section .text, align 2, keep-with-next
    291          REVEAL_RECIPE_STATUS_TYPE API012Exp__CommandParser(REVEAL_MSG_TYPE * buffer)
    292          {
    293              REVEAL_RECIPE_STATUS_TYPE retval;
    294              #if (SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)
    295                  uint32 pattern;
    296              #endif
    297          
    298              #if ((SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)&&(API012EXP_HMI_EVENT_BASED == DISABLED))
    299                  uint16 offset;
    300                  uint8 object_index;
    301              #endif
    302          
    303              retval = NVO_RS_READY;
    304          
    305              switch ((API012EXP_OPCODE_TYPE)buffer->op_code)
    306              {
    307                  #if (SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)
    308          
    309                  #if(FEATURE_DYNAMIC_LED_GROUPS == ENABLED)
    310                      case API012EXP_CREATE_LED_GROUP:
    311                          /*
    312                           payload[0] = index of the new LED group
    313                           payload[1] = group length
    314                           &payload[2] = pointer to the list of LEDs to be assigned to the new group
    315                           */
    316                          if(FALSE == LedDynamicGroups__CreateGroup(buffer->payload[0], buffer->payload[1], &(buffer->payload[2])))
    317                          {
    318                              retval = NVO_RS_UNSUP_INVALID_PARAM;
    319                          }
    320                          break;
    321                  #endif
    322          
    323                  #if(FEATURE_DYNAMIC_ANIMATIONS == ENABLED)
    324                      case API012EXP_CREATE_LED_ANIMATION:
    325                          /*
    326                           payload[0] = index of the new LED animation
    327                           &payload[1] = pointer to the structure containing new animation paramEters
    328                                        (identical to THE setting file animation structrure)
    329                           */
    330                          if(FALSE == LedDynamicAnimations__CreateAnimation(buffer->payload[0], &(buffer->payload[1])))
    331                          {
    332                              retval = NVO_RS_UNSUP_INVALID_PARAM;
    333                          }
    334                          break;
    335                  #endif
    336          
    337                  #if (API012EXP_HMI_EVENT_BASED == DISABLED)
    338                      case API012EXP_REQ_HMI_PUB_GIS:
    339                          PublishHMIGIs(buffer->node_id);
    340                          break;
    341          
    342                      case API012EXP_SET_VIEW_ELEMENTS:
    343                          offset = Utilities__ConvertArrayTo16bits(buffer->payload);
    344          
    345                          for (object_index = 2; object_index < buffer->size; object_index++)
    346                          {
    347                              HblHmi__SetObject(VISUAL_OBJECT_LED,
    348                                                offset + object_index - 2,
    349                                                1,
    350                                                (uint16)buffer->payload[object_index],HBLHMI_LED_PRIORITY_EMBEDDED);
    351                          }
    352                          break;
    353                  #else
    354                      case API012EXP_HMI_GI_EVENT:
    355                          retval = GiCommandParser(buffer);
    356                          break;
    357                      case API012EXP_HMI_LED_EVENT:
    358                          retval = LedCommandParser(buffer);
    359                          break;
    360                      case API012EXP_HMI_LAST_STORED_GI_EVENT:
    361                          PublishLastGiEvent();
    362                          break;
    363                  #endif
    364          
    365                      case API012EXP_PLAY_SOUND:
    366                          HblHmi__PlaySoundSimple(buffer->payload[0], (SOUND_VOLUME_TYPE)buffer->payload[1]);
    367                          break;
    368          
    369                      case API012EXP_SET_VOLUME:
    370                          HblHmi__SetVolume((SOUND_VOLUME_TYPE)buffer->payload[0]);
    371                          break;
    372          
    373                      case API012EXP_STOP_SOUND:
    374                          HblHmi__StopAllSound();
    375                          break;
    376          
    377                      case API012EXP_PLAY_ANIMATION:
    378                          pattern = Utilities__ConvertArrayTo32bits(&(buffer->payload[2]));
    379                          LedAnimationMgr__Start((LED_ANIMATIONS_ENUM_TYPE)buffer->payload[0], (uint16)(buffer->payload[1]), pattern, buffer->payload[6]);
    380                          break;
    381          
    382                      case API012EXP_STOP_ANIMATION:
    383                          if(buffer->payload[0] != 0xFF)
    384                          {
    385                              pattern = Utilities__ConvertArrayTo32bits(&(buffer->payload[1]));
    386                              LedAnimationMgr__Stop(buffer->payload[0], pattern);
    387                          }
    388                          else
    389                          {
    390                              LedAnimationMgr__StopAll();
    391                          }
    392                          break;
    393                  #endif  //(SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)
    394          
    395                  #if (SYSTEM_ACU_EXPANSION_HANDLING == ENABLED)
    396                      case API012EXP_REQ_ACU_PUB_GIS:
    397                          PublishACUGIs(buffer->node_id);
    398                          break;
    399                  #endif
    400          
    401                  default:
    402                      retval = NVO_RS_UNSUP_OP_CODE;
    403                      break;
    404              }
    405          
    406              return (retval);
   \                     API012Exp__CommandParser: (+1)
   \   00000000   0x2005             MOVS     R0,#+5
   \   00000002   0x4770             BX       LR               ;; return
    407          }
