     76          //! The number of times the Estimator__Background() function gets called every second.
     77          #define ESTIMATOR_CALLS_PER_SECOND 10
     78          
     79          //! The API used to publish estimated time information when ESTIMATOR_TRACE is ENABLED.
     80          #define ESTIMATOR_DEBUG_API 4
     81          
     82          //! Number of seconds difference from one calculation to the next that will trigger a publication
     83          //! of debug data.
     84          #define ESTIMATOR_DEBUG_DIFF_SECS_TO_PUBLISH 5
     85          
     86          //! Maximum number of entries that will fit in a single Reveal payload.
     87          //! Time entries are uint16 and consume 2 bytes each.
     88          //! Prediction entries are a pair of uint8 and consume 2 bytes each.
     89          #define ESTIMATOR_DEBUG_MAX_ENTRIES_PER_PAYLOAD ((REVEAL_PAYLOAD_SIZE - 1) / 2)
     90          
     91          //! The OpCode used to publish estimated phase times when ESTIMATOR_TRACE is ENABLED.
     92          #define ESTIMATOR_DEBUG_OPCODE_PHASE_TIMES 11
     93          
     94          //! The OpCode used to publish predicted statement execution when ESTIMATOR_TRACE is ENABLED.
     95          #define ESTIMATOR_DEBUG_OPCODE_STATEMENTS 12
     96          
     97          //! The maximum number of statments to store when the Trace feature is enabled.
     98          #define ESTIMATOR_MAX_STATEMENTS 400
     99          
    100          //! The maximum number of Bytes for statements to store when the Trace feature is enabled.
    101          #define ESTIMATOR_MAX_STATEMENT_BYTES (ESTIMATOR_MAX_STATEMENTS * 2)
    102          
    103          //! The maximum number of times to store when the Trace feature is enabled.
    104          #define ESTIMATOR_MAX_PHASES 60
    105          
    106          //! The maximum number of seconds that will be estimated for a single cycle.
    107          // Value must be a uint16 value.
    108          // 36000 seconds == 10 hours
    109          // 54000 seconds == 15 hours
    110          #define MAXIMUM_ESTIMATED_SECONDS 54000
    111          
    112          //! The maximum number of statements that will be evaluated before assuming an infinite loop in the cycle.
    113          #ifndef MAX_STATEMENTS_PER_CYCLE
    114              #define MAX_STATEMENTS_PER_CYCLE 1000
    115          #endif
