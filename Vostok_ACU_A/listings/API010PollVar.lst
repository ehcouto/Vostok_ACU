    251          
    252              #ifdef HMI_VARIABLE_ID_USERS_ENUM
    253                  API010_DATA_CONTROL_TYPE HMI_Control[API010_FIXED_VARS_HMI_COUNT];
    254              #endif
    255          
    256              //! A value that saves the time of the last periodic publication.
    257              uint8 Publication_Counter;
    258          
    259              #if(API010_ON_CHANGE_ACU_VARIABLE_BUFFER_SIZE > 0U)
    260                  //! Offsets into the Last_Sent_ACU_Var[] array for each variable.
