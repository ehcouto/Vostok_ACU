     33          #define CONDUCTIVITYLLI_CFG0_PULLUP                             0x20
     34          #define CONDUCTIVITYLLI_CFG1_AUTO                               0x80
     35          
     36          #define CONDUCTIVITYLLI_CFG1_N_READ_MASK                        0x07
     37          
     38          #define CONDUCTIVITY_VALID_FREQUENCY                            200
     39          #define CONDUCTIVITY_FREQUENCY_RESOLUTION_PERCENTAGE            10
     40          #define CONDUCTIVITYLLI_N_READ                                  100
     41          
     42          //Valid Duty boundaries in percentage
     43          #define CONDUCTIVITY_VALID_MINIMUM_DUTY                         850
     44          #define CONDUCTIVITY_VALID_MAXIMUM_DUTY                         8500
     45          #define CONDUCTIVITY_THRESHOLD_DUTY                             3800
     46          
     47          #define CONDUCTIVITY_VALID_MINIMUM_FREQUENCY                    (CONDUCTIVITY_VALID_FREQUENCY - ((CONDUCTIVITY_VALID_FREQUENCY * CONDUCTIVITY_FREQUENCY_RESOLUTION_PERCENTAGE)/100))
     48          #define CONDUCTIVITY_VALID_MAXIMUM_FREQUENCY                    (CONDUCTIVITY_VALID_FREQUENCY + ((CONDUCTIVITY_VALID_FREQUENCY * CONDUCTIVITY_FREQUENCY_RESOLUTION_PERCENTAGE)/100))
