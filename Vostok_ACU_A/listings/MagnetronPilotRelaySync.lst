    501          //-------------------------------------- Private Functions ------------------------------------------------------------
    502          //=====================================================================================================================
    503          
    504          //---------------------------------------------------------------------------------------------------------------------
    505          /**
    506           *
    507           */
    508          static void OffEntry(void)
    509          {
    510              MWRelayOff();
    511          }
    512          
    513          //---------------------------------------------------------------------------------------------------------------------
    514          /**
    515           *
    516           */
    517          static void OffPendingDo(void)
    518          {
    519              if (Relay_Sync_Data[Pilot_Index].Zero_Cross_Start_Found == TRUE)
    520              {
    521                  Relay_Sync_Data[Pilot_Index].Relay_Off_Counter++;
    522          
    523                  if (Relay_Sync_Data[Pilot_Index].Relay_Off_Counter == (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point - Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay))
    524                  {
    525                      MWRelayOff();
    526                  }
    527          
    528                  if ((Relay_Sync_Data[Pilot_Index].Relay_Off_Counter <= (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point + WINDOW_END_OFF)) && (Relay_Sync_Data[Pilot_Index].Relay_Off_Counter >= (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point + WINDOW_START_OFF)))
    529                  {
    530                      Relay_Sync_Data[Pilot_Index].Majority_Feedback_State += MwRelayReadFeedbackSignal();
    531          
    532                      /** Relay delay time during off is only evaluated at last sample in window. */
    533                      if (Relay_Sync_Data[Pilot_Index].Relay_Off_Counter == Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point + WINDOW_END_OFF)
    534                      {
    535                          /** Regardless of relay delay size, relay stays off. */
    536                          EventOff();
    537          
    538                          uint8 off_state_feedback;
    539          
    540                          if (Relay_Sync_Data[Pilot_Index].Majority_Feedback_State >= FEEDBACK_SAMPLE_SIZE)
    541                          {
    542                              off_state_feedback = TRUE;
    543                          }
    544                          else
    545                          {
    546                              off_state_feedback = FALSE;
    547                          }
    548          
    549                          /** Relay delay time determined */
    550                          if (Relay_Sync_Data[Pilot_Index].MW_Relay_Off_Sync == SYNC_FOUND)
    551                          {
    552                              if (off_state_feedback == TRUE)
    553                              {
    554                                  /** Relay off delay too short, not synchronized anymore? */
    555                                  Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay += ADJUST_SHORT_OFF_DELAY;
    556          
    557                                  /** If verifying delay time, this is normal otherwise something is wrong */
    558                                  if (Relay_Sync_Data[Pilot_Index].Verifying_Delay_Time == TRUE)
    559                                  {
    560                                      Relay_Sync_Data[Pilot_Index].Ok_Off_Counter = 0;
    561                                      Relay_Sync_Data[Pilot_Index].Verifying_Delay_Time = FALSE;
    562                                  }
    563                                  else
    564                                  {
    565                                      Relay_Sync_Data[Pilot_Index].MW_Relay_Off_Sync = SYNC_NOT_FOUND;
    566                                  }
    567                              }
    568                              else
    569                              {
    570                                  Relay_Sync_Data[Pilot_Index].Ok_Off_Counter++;
    571                                  if (Relay_Sync_Data[Pilot_Index].Ok_Off_Counter > VERIFICATION_COUNTER)
    572                                  {
    573                                      /** Shorten relay delay and flag that we are verifying the time */
    574                                      Relay_Sync_Data[Pilot_Index].Verifying_Delay_Time = TRUE;
    575                                      Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay -= ADJUST_LONG_OFF_DELAY;
    576                                  }
    577                              }
    578          
    579                          }
    580          
    581                          /** Relay delay time not yet determined */
    582                          if (Relay_Sync_Data[Pilot_Index].MW_Relay_Off_Sync == SYNC_NOT_FOUND)
    583                          {
    584                              /** Feedback on means too short relay delay */
    585                              if (off_state_feedback == FALSE)
    586                              {
    587                                  /** Relay off delay too long */
    588                                  Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay -= ADJUST_LONG_OFF_DELAY;
    589          
    590                                  if (Relay_Sync_Data[Pilot_Index].Previous_Feedback_State != 0)
    591                                  {
    592                                      /** In this case, we have found our delay time. */
    593                                      Relay_Sync_Data[Pilot_Index].MW_Relay_Off_Sync = SYNC_FOUND;
    594                                  }
    595                              }
    596                              /**  Feedback is off in window. Delay too short */
    597                              else
    598                              {
    599                                  Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay += ADJUST_SHORT_OFF_DELAY;
    600                              }
    601                              Relay_Sync_Data[Pilot_Index].Previous_Feedback_State = off_state_feedback;
    602                          }
    603          
    604                          Relay_Sync_Data[Pilot_Index].Majority_Feedback_State = 0;
    605                      }
    606                  }
    607              }
    608          }
    609          
    610          //---------------------------------------------------------------------------------------------------------------------
    611          /**
    612           *
    613           */
    614          static void OnEntry(void)
    615          {
    616              MWRelayOn();
    617          }
    618          
    619          //---------------------------------------------------------------------------------------------------------------------
    620          /**
    621           *
    622           */
    623          static void OnPendingDo(void)
    624          {
    625              if (Relay_Sync_Data[Pilot_Index].Peak_Start_Found == TRUE)
    626              {
    627                  Relay_Sync_Data[Pilot_Index].Relay_On_Counter++;
    628          
    629                  if (Relay_Sync_Data[Pilot_Index].Relay_On_Counter == (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point - Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay))
    630                  {
    631                      MWRelayOn();
    632                  }
    633          
    634                  if ((Relay_Sync_Data[Pilot_Index].Relay_On_Counter <= (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point + WINDOW_END_ON)) && (Relay_Sync_Data[Pilot_Index].Relay_On_Counter >= (Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point - WINDOW_START_ON)))
    635                  {
    636                      if (Relay_Sync_Data[Pilot_Index].MW_Relay_On_Sync == SYNC_NOT_FOUND)
    637                      {
    638                          MWRelayOff();
    639                      }
    640          
    641                      if (MwRelayReadFeedbackSignal())
    642                      {
    643                          /** Feedback ok at first sample. Leave on and adjust */
    644                          if (Relay_Sync_Data[Pilot_Index].Relay_On_Counter == Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point - WINDOW_START_ON)
    645                          {
    646                              EventOn();
    647                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay - ADJUST_LONG_ON_DELAY;
    648                              Relay_Sync_Data[Pilot_Index].MW_Relay_On_Sync = SYNC_NOT_FOUND;
    649          
    650                          }
    651                          else
    652                          {
    653                              EventOn();
    654                              /** Adjust for feedback on time relative to where in the allowed window the feedback is found */
    655                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = (Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay + (Relay_Sync_Data[Pilot_Index].Relay_On_Counter - Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point));
    656                              Relay_Sync_Data[Pilot_Index].MW_Relay_On_Sync = SYNC_FOUND;
    657                          }
    658                      }
    659                      else
    660                      {
    661                          if (Relay_Sync_Data[Pilot_Index].Relay_On_Counter == Relay_Sync_Data[Pilot_Index].Intend_Relay_Switch_Point + WINDOW_END_ON)
    662                          {
    663                              EventOff();
    664                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay + ADJUST_SHORT_ON_DELAY;
    665                              Relay_Sync_Data[Pilot_Index].MW_Relay_On_Sync = SYNC_NOT_FOUND;
    666                          }
    667                      }
    668                  }
    669              }
    670          }
    671          
    672          //---------------------------------------------------------------------------------------------------------------------
    673          /**
    674           *  @brief      It Initializes the MW relay and it's variales
    675           *
    676           */
    677          static void MwRelayInitialize(void)
    678          {
    679              MWRelayOff();
    680          
    681              /**
    682              * @brief Cold start assumption.
    683              *        Relay delay not synchronized.
    684              *        Mains signal frequency not known.
    685              */
    686              Relay_Sync_Data[Pilot_Index].MW_Relay_On_Sync = SYNC_NOT_FOUND;
    687              Relay_Sync_Data[Pilot_Index].MW_Relay_Off_Sync = SYNC_NOT_FOUND;
    688              Relay_Sync_Data[Pilot_Index].Relay_On_Counter = 0;
    689              Relay_Sync_Data[Pilot_Index].Relay_Off_Counter = 0;
    690              Relay_Sync_Data[Pilot_Index].Error_Present = FALSE;
    691              Relay_Sync_Data[Pilot_Index].Error_Changed = FALSE;
    692              Relay_Sync_Data[Pilot_Index].Error_Counter = 0;
    693              Relay_Sync_Data[Pilot_Index].Relay_Stable_Delay = 60;  //delay 1s for error detection after power on.
    694              Relay_Sync_Data[Pilot_Index].Ok_Off_Counter = 0;
    695              Relay_Sync_Data[Pilot_Index].Verifying_Delay_Time = FALSE;
    696          }
    697          
    698          //----------------------------------------------------------------------------------------------
    699          /**
    700          *    @brief    Samples the feedback signal at a specified time decided by the
    701          *              package MwRelaySync.
    702          *    @details  Performs sampling of the MW Relay feedback signal in relation to the mains
    703          *              signal. Decision of the feedback state is taken with majority that 2 of 3
    704          *              samples is determined low state.
    705          *    @param    void
    706          *
    707          *    @return   State of feedback signal.
    708          *    @retval   0   Feedback signal not present
    709          *    @retval   1   Feedback signal present
    710          */
    711          static uint8 MwRelayReadFeedbackSignal(void)
    712          {
    713              uint8 mw_fb_pinState = 0;
    714          
    715              uint8 table_index = Relay_Sync_Data[Pilot_Index].MW_Feedback_Pin;
    716              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    717              {
    718                  mw_fb_pinState = Gpio__PinRead(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin);
    719              }
    720          
    721              if (Relay_Sync_Data[Pilot_Index].MW_FB_Active_High == FALSE)
    722              {
    723                  mw_fb_pinState  ^= (BOOL_TYPE) 1;
    724              }
    725          
    726              return (mw_fb_pinState);
    727          }
    728          
    729          //----------------------------------------------------------------------------------------------
    730          /**
    731           *  @brief      It try to turn on MW Relay at proper timing.
    732           */
    733          static void MwRelayOnSyncStart(void)
    734          {
    735              if (Relay_Sync_Data[Pilot_Index].Error_Present == FALSE)
    736              {
    737                  if((Relay_Sync_Data[Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_ON) && (Relay_Sync_Data[Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_ON_PENDING))
    738                  {
    739                      if (MagnetronPilotMainsSampler__GetMainsFrequencyStatus(Pilot_Index) == MAINS_FREQ_OK)
    740                      {
    741                          if (Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay < RELAY_ON_LOW_LIMIT)
    742                          {
    743                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = RELAY_ON_LOW_LIMIT;
    744                              MwRelayInitialize();
    745                          }
    746          
    747                          if (Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay > RELAY_ON_HIGH_LIMIT)
    748                          {
    749                              LOG_ADD_EXCEPTION(MW_RELAY_ON_DELAY_EXCEED_LIMITATION, Pilot_Index);
    750                              Fault__ConditionDetected(XCATEGORY_MAGNETRON_RELAY_SYNCHRONIZATION_FAILURE);
    751          
    752                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_On_Delay = RELAY_ON_LOW_LIMIT;
    753                              MwRelayInitialize();
    754                          }
    755          
    756                          Relay_Sync_Data[Pilot_Index].Relay_On_Counter = 0;
    757                          Relay_Sync_Data[Pilot_Index].Peak_Start_Found = FALSE;
    758                          EventOnPending();
    759                      }
    760                  }
    761              }
    762          }
    763          
    764          //----------------------------------------------------------------------------------------------
    765          /**
    766           *  @brief      It try to turn off MW Relay at proper timing.
    767           */
    768          static void MwRelayOffSyncStart(void)
    769          {
    770              if(IsMWRelayOn())
    771              {
    772                  if(Relay_Sync_Data[Pilot_Index].Door_Open_Detected == TRUE)
    773                  {
    774                      EventOff();
    775                  }
    776                  else if (MagnetronPilotMainsSampler__GetMainsFrequencyStatus(Pilot_Index) == MAINS_FREQ_ERROR)
    777                  {
    778                      EventOff();
    779                  }
    780                  else
    781                  {
    782                      if((Relay_Sync_Data[Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF) && (Relay_Sync_Data[Pilot_Index].MW_Relay_State != STATE_MAGNETRON_PILOT_RELAY_SYNC_OFF_PENDING))
    783                      {
    784                          if (Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay < RELAY_OFF_LOW_LIMIT)
    785                          {
    786                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay = RELAY_OFF_LOW_LIMIT;
    787                              MwRelayInitialize();
    788                          }
    789          
    790                          if (Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay > RELAY_OFF_HIGH_LIMIT)
    791                          {
    792                              LOG_ADD_EXCEPTION(MW_RELAY_OFF_DELAY_EXCEED_LIMITATION, Pilot_Index);
    793          
    794                              Relay_Sync_Data[Pilot_Index].Dynamic_Relay_Off_Delay = RELAY_OFF_LOW_LIMIT;
    795                              MwRelayInitialize();
    796                          }
    797          
    798                          Relay_Sync_Data[Pilot_Index].Relay_Off_Counter = 0;
    799                          Relay_Sync_Data[Pilot_Index].Zero_Cross_Start_Found = FALSE;
    800                          EventOffPending();
    801                      }
    802                  }
    803              }
    804          }
