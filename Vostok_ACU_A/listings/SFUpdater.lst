    434          /**
    435           * @brief This is the handler called while in programming mode to manage the settingfile download process.
    436           * @return TRUE if a cold reset is required to continue; otherwise FALSE.
    437           */

   \                                 In section .text, align 2, keep-with-next
    438          BOOL_TYPE SFUpdater__Handler(void)
    439          {
    440              BOOL_TYPE retval;
    441          
    442              retval = FALSE;
    443          
    444              #if (SFUPDATER_MANAGE_SF_ID_DATA == ENABLED)
    445                  // Check if Programming Mode is engaged and SystemTimer is running; otherwise it's safer to reset and start over.
    446                  if ((Mode__IsProgrammingEngaged() != FALSE) &&
    447                      (Millis__ReachedTarget(&SFUpdater_Timer, 1000) == FALSE))
    448                  {
    449                      switch (SFUpdater_State)
    450                      {
    451                          case SFUPDATER_STATE_INITIALIZE:
    452                              SFUpdater_State = SFUPDATER_STATE_ERASE_FLASH;
