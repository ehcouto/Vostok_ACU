    703          //---------------------------------------------------------------------------------------------------------------------
    704          /**
    705           * Read the pixel data from the Melexis 90621 sensor.
    706           * This function reads and processes the received data.
    707           * It assumes that the read request was already made.
    708           */
    709          static void DoPixelsRead(void)
    710          {
    711              if (IsI2cIdle() == TRUE)
    712              {
    713                  if (I2c__Read(I2c_Infrared_Lli.Sf->I2c_Channel, (void*)I2c_Infrared_Lli.Sensor.Pixel, RAM_PIXEL_READ_SIZE) == TRUE)
    714                  {
    715                      EventReadComplete();
    716                  }
    717                  else
    718                  {
    719                      EventFail();
    720                  }
    721              }
    722              else if (GetMilliseconds() >= I2c_Infrared_Lli.Sf->Step_Period_Milliseconds)
    723              {
    724                  EventFail();
    725              }
    726          }
