    941          /**
    942           * @details
    943           *
    944           * @return
    945           */
    946          static BOOL_TYPE RequestSFData(void)
    947          {
    948              BOOL_TYPE completed = TRUE;
    949          
    950              if (SFUpdater_Data_Index < SFUpdater_Data_Size)
    951              {
    952                  uint16 remaining = SFUpdater_Data_Size - SFUpdater_Data_Index;
    953                  // -4 is because of the header of the API007_OP_REQ_PUB_SETTING_FILE_ID_DATA
    954                  uint16 max_payload_size = (uint16) SFUpdater_Reveal_Max_Size - 4U;
    955          
    956                  if(remaining > max_payload_size)
    957                  {
    958                      remaining = max_payload_size;
    959                  }
    960          
    961                  if (remaining > (uint8) SFUPDATER_REVEAL_DATA_ALIGNMENT)
    962                  {
    963                      remaining /= (uint8) SFUPDATER_REVEAL_DATA_ALIGNMENT;
    964                      remaining *= (uint8) SFUPDATER_REVEAL_DATA_ALIGNMENT;
    965                  }
    966          
    967                  #ifdef SFUPDATER_ENABLE_UNALIGNED_MEMORY_HANDLING
    968                      if(SFUpdater_Unaligned_Data_State != SFUPDATER_UNALIGNED_DATA_BUFFERING)
    969                      {
    970                          // Add data to the Buffer if data to get is less than FLASH_ALIGNMENT
    971                          if(remaining < (uint16) FLASH_ALIGNMENT)
    972                          {
    973                              SFUpdater_Flash_Buffer_Write_Index = 0;
    974                              SFUpdater_Unaligned_Data_State = SFUPDATER_UNALIGNED_DATA_BUFFERING;
    975                          }
    976                      }
    977                      else
    978                      {
    979                          uint16 buffer_to_fill = FLASH_ALIGNMENT - SFUpdater_Flash_Buffer_Write_Index;
    980                          // If already buffering and needs less than SFUPDATER_REVEAL_DATA_ALIGNMENT bytes, try to get them to align with Flash block
    981                          if(buffer_to_fill < SFUPDATER_REVEAL_DATA_ALIGNMENT)
    982                          {
    983                              remaining -= SFUPDATER_REVEAL_DATA_ALIGNMENT;
    984                              remaining += buffer_to_fill;
    985                          }
    986                      }
    987          
    988                      // Clear the buffer when the last section transfer has been completed and flash buffer is not full
    989                      if((remaining + SFUpdater_Data_Index) >= SFUpdater_Data_Size)
    990                      {
    991                          uint8 next_section_index    = SFUpdater_Section_Index + 1;
    992          
    993                          if ((SFUPDATER_SECTIONS[next_section_index] == SF_ID_END) &&
    994                              ((SFUpdater_Flash_Buffer_Write_Index + remaining) < FLASH_ALIGNMENT))
    995                          {
    996                              memset(&SFUpdater_Flash_Buffer[SFUpdater_Flash_Buffer_Write_Index + remaining], SFUPDATER_FLASH_DEFAULT_VALUE,
    997                                  FLASH_ALIGNMENT - (SFUpdater_Flash_Buffer_Write_Index + remaining));
    998                              SFUpdater_Unaligned_Data_State = SFUPDATER_UNALIGNED_DATA_BUFFER_WRITE;
    999                          }
   1000                      }
   1001                  #endif
   1002          
   1003                  if (API007Data__RequestSettingFileIDData(WIN_ACU_ADDRESS, SFUPDATER_SECTIONS[SFUpdater_Section_Index], SFUpdater_Data_Index, (uint8) remaining) != FALSE)
   1004                  {
   1005                      SFUpdater_Data_Index += remaining;
   1006                  }
   1007          
   1008                  completed = FALSE;
   1009              }
   1010          
   1011              return(completed);
   1012          }
   1013          #endif
