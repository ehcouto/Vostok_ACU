    907          /**
    908           * Write the configuration value to the Melexis 90621 Sensor.
    909           */
    910          static void WriteConfiguration(void)
    911          {
    912              // Write the trim value to the Melexis 90621 Sensor.
    913              I2c_Infrared_Lli.Config.Cfg_Reg.Field.IR_Refresh_Rate = I2c_Infrared_Lli.Sf->IR_Refresh_Rate;
    914              I2c_Infrared_Lli.Config.Cfg_Reg.Field.Bit_Resolution = I2c_Infrared_Lli.Sf->Bit_Resolution;
    915              I2c_Infrared_Lli.Config.Cfg_Reg.Field.Step_Mode = TRUE;
    916              I2c_Infrared_Lli.Config.Cfg_Reg.Field.Sleep_Mode = FALSE;
    917              I2c_Infrared_Lli.Config.Cfg_Reg.Field.Configuration_Loaded = TRUE;
    918              I2c_Infrared_Lli.Config.Cfg_Reg.Field.I2C_400KHz_Limit = TRUE;
    919              I2c_Infrared_Lli.Config.Cfg_Reg.Field.EEPROM_Disabled = FALSE;
    920              // 0x55 is the check byte used to send redundant data for error checking.
    921              if (WriteMelexisValue(MLX_CMD_WRITE_CONFIG, I2c_Infrared_Lli.Config.Cfg_Reg.Whole, 0x55) == FALSE)
    922              {
    923                  EventFail();
    924              }
    925          }
