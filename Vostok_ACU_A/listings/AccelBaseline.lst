    290          /**
    291           * Run the AccelBaseline module's state machine.
    292           * Check for a command that is taking too long to run and re-initialize the module if necessary.
    293           */
    294          void AccelBaseline__Background5ms(void)
    295          {
    296              if (Accel_Baseline_State != STATE_ACCEL_BASELINE_NONE)
    297              {
    298                  AccelBaselineExecute();
    299                  if (Accel_Baseline_State != STATE_ACCEL_BASELINE_IDLE)
    300                  {
    301                      uint32 elapsed_time = Millis__GetFreeRunningCounter() - Accel_Baseline.Start_Time;
    302                      if (elapsed_time >= Accel_Baseline.Timeout_Milliseconds)
    303                      {
    304                          LOG_ADD_EXCEPTION(COMMAND_TOOK_TOO_LONG, Accel_Baseline_State);
    305                          EventFailed();
    306                      }
    307                  }
    308              }
    309          }
