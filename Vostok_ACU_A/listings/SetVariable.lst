     98          
     99          	uint8 Bit_Position;
    100          	//! Second word
    101          	ACU_VARIABLE_ID_TYPE Variable_Index;		//! Index to the Variable on the Variable module (Look at Variable_prm.h and Variable_prv.h)
    102          	uint8 Variable_Offset;						//! Offset to access a Variable on the Variable Module. If Variable is an Array, the offset is the index of the Variable inside the Array. If it is a regulation, it is the position on the Regulation Array.
    103          }SETVARIABLE_BIT_OPERATION_TYPE;
