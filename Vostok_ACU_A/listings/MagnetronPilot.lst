    466          /**
    467           *
    468           */
    469          static void OffDo(void)
    470          {
    471              switch (Magnetron_Pilot_Data[Pilot_Index].Processed)
    472              {
    473                  case MAGNETRON_PILOT_REQUEST_ON:
    474                      EventOn();
    475                      break;
    476          
    477                  case MAGNETRON_PILOT_REQUEST_TURBO:
    478                      EventTurbo();
    479                      break;
    480          
    481                  default:
    482                      break;
    483              }
    484          }
    485          
    486          //---------------------------------------------------------------------------------------------------------------------
    487          /**
    488           *
    489           */
    490          static void OnDo(void)
    491          {
    492              switch (Magnetron_Pilot_Data[Pilot_Index].Processed)
    493              {
    494                  case MAGNETRON_PILOT_REQUEST_OFF:
    495                      EventOff();
    496                      break;
    497          
    498                  case MAGNETRON_PILOT_REQUEST_TURBO:
    499                      EventTurbo();
    500                      break;
    501          
    502                  default:
    503                      break;
    504              }
    505          }
    506          
    507          //---------------------------------------------------------------------------------------------------------------------
    508          /**
    509           *
    510           */
    511          static void TurboDo(void)
    512          {
    513              switch (Magnetron_Pilot_Data[Pilot_Index].Processed)
    514              {
    515                  case MAGNETRON_PILOT_REQUEST_OFF:
    516                      EventOff();
    517                      break;
    518          
    519                  case MAGNETRON_PILOT_REQUEST_ON:
    520                      EventOn();
    521                      break;
    522          
    523                  default:
    524                      break;
    525              }
    526          }
