    266          /**
    267           * @brief  Configures the specified port-pin into the Alternate function.
    268           */
    269          #define GPIO__PIN_COFIG_AF(PORT, PORTBIT, AF)\
    270          {\
    271              if ((PORT < GPIO_PORT_NUM) && (PORTBIT < GPIO_MAX_PIN))\
    272              {\
    273                  (*(volatile GPIO_DEF *)GPIO_PORT_LIST[PORT]).AFR[PORTBIT >> 0x03] = (*(volatile GPIO_DEF *)GPIO_PORT_LIST[PORT]).AFR[PORTBIT >> 0x03] | ((uint32)(AF) << ((uint32)((uint32)PORTBIT & (uint32)0x07) << 2));\
    274              }\
    275          }\
