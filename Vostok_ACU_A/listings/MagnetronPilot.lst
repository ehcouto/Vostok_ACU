    258          /**
    259           *  @brief      Set magnetron pilot instance request.
    260           *
    261           *  @param      HBL_LOAD_TYPE *load - Pointer to associated magnetron load instance.
    262           *
    263           *  @param      void *data - Pointer to request data. Pass argument as MAGNETRON_PILOT_REQUEST_TYPE *.
    264           *
    265           *  @return     PASS_FAIL_TYPE result - Result of magnetron pilot request.
    266           *  @retval     PASS - Instance request succeeded.
    267           *  @retval     FAIL - Instance request failed.
    268           */
    269          PASS_FAIL_TYPE MagnetronPilot__Request(HBL_LOAD_TYPE *load, void *data)
    270          {
    271              PASS_FAIL_TYPE result = FAIL;
    272          
    273              if (load->Pilot_Data_Index < Magnetron_Pilot_Allocation)
    274              {
    275                  Magnetron_Pilot_Data[load->Pilot_Data_Index].Requested = *((MAGNETRON_PILOT_REQUEST_TYPE *)data);
    276          
    277                  result = PASS;
    278              }
    279          
    280              return (result);
    281          }
