    148          //---------------------------------------------------------------------------------------------------------------------
    149          /**
    150           *  @brief      It Initializes the module DigitalLowLevel and its variables
    151           *
    152           */
    153          PASS_FAIL_TYPE SRInputCaptureLLI__InitializeInstance(HBL_LLI_TYPE * input)
    154          {
    155              PASS_FAIL_TYPE ret_status = FAIL;
    156          
    157              if (SRData__CheckByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation) == SRDATA_OK)
    158              {
    159                  if (input->Data_Index < SRInputCaptureLLI_Allocation)
    160                  {
    161                      SRINPUTCAPTURE_DATA_TYPE *data = (SRINPUTCAPTURE_DATA_TYPE *)&SRInputCaptureLLI_Data[input->Data_Index]; //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    162                      SRINPUTCAPTURE_DATA_TYPE *n_data = (SRINPUTCAPTURE_DATA_TYPE *)&N_SRInputCaptureLLI_Data[input->Data_Index]; //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    163          
    164                      if (SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRInputCaptureLLI_Data[0])) == SRDATA_OK) //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    165                      {
    166                          MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    167                          uint32 current_time = SRTimerReference__GetTimer();
    168                          SRINPUTCAPTURELLI_PARAMETERS_TYPE *parameters = (SRINPUTCAPTURELLI_PARAMETERS_TYPE *)input->Parameter_Ptr.Data; //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    169                          VIRTUALPIN_TYPE *virtual_pin_ptr = (void *) &VIRTUALPIN_TABLE[input->Pin_Ptr[0]];
    170          
    171                          SRData__UpdateLong(&data->Timeout, &n_data->Timeout, current_time + (parameters->Time_Out * 5));
    172                          SRData__UpdateLong(&data->Sampling_Timeout, &n_data->Sampling_Timeout, current_time + (parameters->Sampling_Time * 5));
    173                          SRData__UpdateByte((void *) &data->Continue_mode, (void *) &n_data->Continue_mode, TRUE);
    174                          SRData__UpdateByte((void *) &data->Filter_Initialized, (void *) &n_data->Filter_Initialized, FALSE);
    175          
    176                          // Initialize Timer
    177                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    178                          SRData__UpdateByte((void *) &data->Timer_Parameter.Timer, (void *) &n_data->Timer_Parameter.Timer, virtual_pin_ptr->device);
    179                          SRData__UpdateByte((void *) &data->Timer_Parameter.Channel, (void *) &n_data->Timer_Parameter.Channel, virtual_pin_ptr->param0);
    180                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_INPUT_CAPTURE);
    181                          SRData__UpdateByte((void *) &data->Timer_Parameter.Port, (void *) &n_data->Timer_Parameter.Port, virtual_pin_ptr->port);
    182                          SRData__UpdateByte((void *) &data->Timer_Parameter.Pin, (void *) &n_data->Timer_Parameter.Pin, virtual_pin_ptr->pin);
    183                          SRData__UpdateByte((void *) &data->Timer_Parameter.Pin_ReMap, (void *) &n_data->Timer_Parameter.Pin_ReMap, virtual_pin_ptr->pin_remap);
    184                          SRData__UpdateByte((void *) &data->Timer_Parameter.Polarity, (void *) &n_data->Timer_Parameter.Polarity, TIMER_POLARITY_ACTIVE_HIGH);
    185          
    186                          //Configure Continuous reading
    187                          ret_status =  Timer__Config(&data->Timer_Parameter);
    188                          ret_status |= Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    189                          ret_status &= Timer__ConfigCheck(&data->Timer_Parameter);
    190                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    191                      }
    192                  }
    193              }
    194          
    195              return (ret_status);
    196          }
