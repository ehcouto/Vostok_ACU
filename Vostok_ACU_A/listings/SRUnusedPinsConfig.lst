     42          
     43          //-------------------------------------- Default defines ---------------------------------------------------------------
     44          
     45          #ifndef SR_UNUSED_PINS_CONFIG_COUNT_ERROR_IN_PERCENTAGE
     46              #define SR_UNUSED_PINS_CONFIG_COUNT_ERROR_IN_PERCENTAGE                    (10)
     47          #endif
     48          
     49          // This option shows time by which SRUnusedpinsConfig Handler runs, Its in milliseconds.
     50          // #define SR_UNUSED_PINS_CONFIG_HANDLER_TIME 5 is 5mS
     51          #define SR_UNUSED_PINS_CONFIG_HANDLER_TIME                                                 (5)
     52          
     53          //---------------------------------------------------------------------------------------------------------------------
     54          // its used to generate exception in case handler gets missed by certain percentage of count
     55          // Mentioned in SRUnusedpinsConfig_prv.h file SR_UNUSED_PINS_CONFIG_COUNT_ERROR_IN_PERCENTAGE
     56          // SRUnusedPinsConfig__Monitor used to check SRUnusedPinsConfig__Handler5ms is not getting missed
     57          // and executing correct number of times.
     58          //---------------------------------------------------------------------------------------------------------------------
     59          
     60          // This option shows time by which SRUnusedpinsConfig monitor runs, Its in milliseconds.
     61          
     62          #define SR_UNUSED_PINS_CONFIG_MONITOR_HANDLER_TIME                               (100)
     63          
     64          
     65          // below Macros mainly used to calculate number if times Handler (5mS) will get executed before next
     66          // run of SRUnusedPinsConfig__Monitor.
     67          
     68          #define SR_UNUSED_PINS_CONFIG_MONITOR_ABSOLUTE_COUNT    \
     69                              (SR_UNUSED_PINS_CONFIG_MONITOR_HANDLER_TIME / SR_UNUSED_PINS_CONFIG_HANDLER_TIME)
     70          
     71          // This Macro calculates error count from percentage
     72          
     73          #define SR_UNUSED_PINS_CONFIG_MONITOR_ERROR_COUNT          \
     74                              (( SR_UNUSED_PINS_CONFIG_MONITOR_ABSOLUTE_COUNT * SR_UNUSED_PINS_CONFIG_COUNT_ERROR_IN_PERCENTAGE ) / 100 )
     75          
     76          // This Macro calculates max allowed count of SRUnusedPinsConfig__Handler5ms execution before next
     77          // SRUnusedPinsConfig__Monitor run / Max number of allowed times pins have been checked for configuration
     78          
     79          #define SR_UNUSED_PINS_CONFIG_HANDLER_MAX_COUNT                       \
     80                              ( SR_UNUSED_PINS_CONFIG_MONITOR_ABSOLUTE_COUNT + SR_UNUSED_PINS_CONFIG_MONITOR_ERROR_COUNT )
     81          
     82          // This Macro calculates min allowed count of SRUnusedpinsConfig SRUnusedPinsConfig__Handler5ms execution before next
     83          // SRUnusedPinsConfig__Monitor run / Min number of allowed times pins have been checked for configuration
     84          
     85          #define SR_UNUSED_PINS_CONFIG_HANDLER_MIN_COUNT                        \
     86                              ( SR_UNUSED_PINS_CONFIG_MONITOR_ABSOLUTE_COUNT -  SR_UNUSED_PINS_CONFIG_MONITOR_ERROR_COUNT )
     87          
     88          
     89          // typedef struct, format of Unused Pins parameters
     90          typedef struct SR_UNUSED_PINS_PARAM_STRUCT
     91          {
     92              uint8   Virtual_Pin_Index;              /*  pin index from  VIRTUALPIN_LIST */
     93              uint8   Gpio_Type:7;                        /* Enum of GPIO_PIN_MODE_TYPE */
     94              uint8   Is_High:1;                            /* in status  should be high or low ( only if Pins are output ) */
     95          } SR_UNUSED_PINS_PARAM_TYPE;
     96          
     97          //! definition of the unused pins configuration.
     98          static const SR_UNUSED_PINS_PARAM_TYPE SR_UNUSED_PINS_TABLE[] = SR_UNUSED_PINS_CONFIG_LIST;
     99          
    100          //-------------------------------------- Variables ---------------------------------------------------------------
    101          //! Keeps track of how many times pins have been checked for Configuration.
    102          static uint8 Unused_Pins_Config_Count;
    103          //! Flag to skip first time SRUnusedPinsConfig__Monitor.
    104          static uint8 Skip_First_Monitor;
    105          
    106          //-------------------------------------- inverted Variables ---------------------------------------------------------------
    107          //! Inverted memory for the Class B variable,  Keeps track of how many times pins have been checked
    108          //!  for Configuration.
    109          static uint8 N_Unused_Pins_Config_Count;
    110          //! Inverted memory for the Class B variable,  Flag to skip first time SRUnusedPinsConfig__Monitor.
    111          static uint8 N_Skip_First_Monitor;
    112          
    113          
    114          //! Macro to calculate number of pin entries in SR_UNUSED_PINS_TABLE
    115          #define NUMBER_OF_UNUSED_PINS_TO_CONFIG  ELEMENTS_IN_ARRAY(SR_UNUSED_PINS_TABLE)
    116          
    117          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
    118          static void DoUnusedPinsUpdate( uint8 unused_pins_table_index );
    119          static void ConfigUnusedPins( void );
    120          
    121          
    122          
    123          //=====================================================================================================================
    124          //-------------------------------------- Public Functions -------------------------------------------------------------
    125          //=====================================================================================================================
    126          
    127          //---------------------------------------------------------------------------------------------------------------------
    128          /**
    129           *  @brief      It Initializes the module SRUnusedPinsConfig and its variables.
    130           *                    It also initializes / configures Unused pin status.
    131           *
    132           */
    133          void SRUnusedPinsConfig__Initialize(void)
    134          {
    135              //Init variable and flags
    136              SR_SET_BYTE(Unused_Pins_Config_Count, 0);
    137              SR_SET_BYTE(Skip_First_Monitor, 1);
    138          
    139              //Configure and set Unused pin status in initialization. Pins not verified here as first time configuration.
    140              ConfigUnusedPins();
    141          
    142              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    143                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_INIT_PHASE, SRTASKSEQUENCE_INIT_SRCHECKUNUSEDPINS);
    144              #endif
    145          }
    146          
    147          
    148          /**
    149           *  @brief      It validates configuration, data integrity of pins and reconfigure unused pins
    150           *                    This should run at 5mS handler
    151           *
    152           */
    153          void SRUnusedPinsConfig__Handler5ms( void )
    154          {
    155              uint8 table_index;
    156          
    157              // Check configuration and status of each pin entry  in SR_UNUSED_PINS_TABLE
    158              for( table_index = 0; table_index < NUMBER_OF_UNUSED_PINS_TO_CONFIG ; table_index++  )
    159              {
    160                  // Check Virtual Pin Index is within limit
    161                  SR_UNUSED_PINS_PARAM_TYPE *cur_param_ptr =
    162                              (SR_UNUSED_PINS_PARAM_TYPE *)&SR_UNUSED_PINS_TABLE[ table_index ];
    163                 if(cur_param_ptr->Virtual_Pin_Index < VirtualPin__GetNumOf())
    164                 {
    165                     // Get Port and Pin from Virtual Pin Table
    166                     VIRTUALPIN_TYPE *pin_ptr = (void *) &VIRTUALPIN_TABLE[cur_param_ptr->Virtual_Pin_Index];
    167          
    168                     // Check pin configuration & status of pins mentioned in SR_UNUSED_PINS_TABLE.
    169                     // If Configuration or status is not changed reconfigure & refresh pin.
    170                     // If there is difference in actual and expected Pins configuration or status of Pins, Gpio module
    171                     // will generate Exception
    172                     if(TRUE == Gpio__CheckConfig(pin_ptr->port, pin_ptr->pin,
    173                                     (GPIO_PIN_MODE_TYPE)cur_param_ptr->Gpio_Type, (BOOL_TYPE)cur_param_ptr->Is_High))
    174                     {
    175                         // Update the pins.
    176                         DoUnusedPinsUpdate( table_index );
    177                     }
    178                 }
    179              }
    180          
    181              // Check data integrity & Increment count for number of times pins gets configured.
    182              SR_CHECK_BYTE( Unused_Pins_Config_Count );
    183              SR_SET_BYTE( Unused_Pins_Config_Count, Unused_Pins_Config_Count + 1 );
    184              //If data overflow generate exception
    185              if( 0xFF == Unused_Pins_Config_Count )
    186              {
    187                  SRException__Queue( SREXCEPTION_ASSYNCHRONOUS_TASK_OVERRUN, (uint32)Unused_Pins_Config_Count, 0 );
    188              }
    189          }
    190          
    191          
    192          /**
    193           *  @brief      Monitors @100mS
    194           *                    It checks count of number of time pins got refreshed, tracks SRUnusedPinsConfig__Handler5ms
    195           *                    with 100mS SRUnusedPinsConfig__Monitor.
    196           *                    If Unused_Pins_Config_Count goes beyond error count this method will generate exception
    197           *
    198           */
    199          void SRUnusedPinsConfig__Monitor( void )
    200          {
    201          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    202              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRCHECKUNUSEDPINS_ENTER);
    203          #endif
    204          
    205              // Check data Integrity
    206              SR_CHECK_BYTE( Skip_First_Monitor );
    207              // skip first time as Async task and App mgr task are not in sync which leads to
    208              // error in Unused_Pins_Config_Count
    209              if(0 == Skip_First_Monitor)
    210              {
    211                  SR_CHECK_BYTE( Unused_Pins_Config_Count );
    212                  // Validate number of times pins refreshed is within limits if not generate exception
    213                  if( ( SR_UNUSED_PINS_CONFIG_HANDLER_MAX_COUNT < Unused_Pins_Config_Count ) ||
    214                  ( SR_UNUSED_PINS_CONFIG_HANDLER_MIN_COUNT > Unused_Pins_Config_Count ) )
    215                  {
    216                      SRException__Queue( SREXCEPTION_ASSYNCHRONOUS_TASK_OVERRUN, (uint32)Unused_Pins_Config_Count, 0 );
    217                  }
    218              }
    219          
    220              // Clear Flag and Count
    221              SR_SET_BYTE( Unused_Pins_Config_Count, 0 );
    222              SR_SET_BYTE( Skip_First_Monitor, 0 );
    223          
    224          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    225              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRCHECKUNUSEDPINS_EXIT);
    226          #endif
    227          }
