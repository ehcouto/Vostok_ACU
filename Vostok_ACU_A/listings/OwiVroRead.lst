    118          //! The maximum number of duty cycle samples to be acquired during the process.
    119          #define DUTYCYCLE_SAMPLES_MAX_NUM 					8
    120          
    121          // DishAuxVar_AverageWithRejection(), used in Owi Vro Read, support a maximum of AVEARAGE_WITH_REJ_MAX_SUPPORTED_SAMPLES_NUM,
