     64          //  --- Compile-Time Assertions ---------------------------------------------------------------------------------------
     65          
     66          
     67          // If cycle statistics are saved, there must be at least one saved cycle for every appliance compartment.
     68          CT_ASSERT((STATISTICS_SAVED_CYCLES == 0) || (STATISTICS_SAVED_CYCLES >= APPLIANCE_MAX_COMPARTMENTS));
     69          
     70          // The number of saved last cycles must be less than or equal to the number of saved cycles.
     71          CT_ASSERT((0 <= STATISTICS_SAVED_LAST_CYCLES) && (STATISTICS_SAVED_LAST_CYCLES <= STATISTICS_SAVED_CYCLES));
     72          
     73          // The statistics data structure must store at least 5 faults.
     74          CT_ASSERT(STATISTICS_SAVED_FAULTS >= 5);
     75          
     76          // The number of saved fault black box data must be less than or equal to the number of saved faults.
     77          CT_ASSERT((0 <= STATISTICS_SAVED_FAULT_BLACK_BOX) && (STATISTICS_SAVED_FAULT_BLACK_BOX <= STATISTICS_SAVED_FAULTS));
     78          
     79          // The statistics data structure must store at least 5 pre-faults.
     80          CT_ASSERT(STATISTICS_SAVED_PRE_FAULTS >= 5);
     81          
     82          // The number of saved pre-fault black box data must be less than or equal to the number of saved pre-faults.
     83          CT_ASSERT((0 <= STATISTICS_SAVED_PRE_FAULT_BLACK_BOX) && (STATISTICS_SAVED_PRE_FAULT_BLACK_BOX <= STATISTICS_SAVED_PRE_FAULTS));
     84          
     85          #if (STATISTICS_SAVED_CYCLE_REGULATIONS > 0)
     86              // The number of regulations saved must match the number of function IDs defined.
     87              CT_ASSERT(ELEMENTS_IN_ARRAY(STATISTICS_CYCLE_REGULATION_FUNCTION_IDS) == STATISTICS_SAVED_CYCLE_REGULATIONS);
     88          #endif
     89          
