    119          /**
    120           * @brief      It Initializes the module SRTriacFeedbackLLI and its variables
    121           */
    122          void SRTriacFeedbackLLI__Initialize(void)
    123          {
    124              SRData__UpdateByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation, 0);
    125              SRData__Fill(SRTriacFeedbackLLI_Data, N_SRTriacFeedbackLLI_Data, 0, sizeof(SRTriacFeedbackLLI_Data));
    126          
    127              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    128                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRTRIACFEEDBACK_LLI);
    129              #endif
    130          }
