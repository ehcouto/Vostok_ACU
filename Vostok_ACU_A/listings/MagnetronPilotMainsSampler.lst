    306          //=====================================================================================================================
    307          //-------------------------------------- Private Functions ------------------------------------------------------------
    308          //=====================================================================================================================
    309          //---------------------------------------------------------------------------------------------------------------------
    310          /**
    311           *  @brief calculate the zero cross point and peak point from mains high rise
    312           *  when L+ and mains signal is in same phase,
    313           *      "Zero_Cross_LH_Cnt1" means the zero cross point from N to L,
    314           *      "Zero_Cross_HL_Cnt2" means the zero cross point from L to N,
    315           *      "L_Pos_Cnt" means the peak point of L
    316           *      "L_Neg_Cnt" means the peak point of N
    317           * when L+ and mains signal is in reverse phase,
    318           *      "Zero_Cross_LH_Cnt1" means the zero cross point from L to N,
    319           *      "Zero_Cross_HL_Cnt2" means the zero cross point from N to L,
    320           *      "L_Pos_Cnt" means the peak point of N
    321           *      "L_Neg_Cnt" means the peak point of L
    322           */
    323          static void MainsSamplerRecalcEvents(uint8 count)
    324          {
    325              uint8 half_mains_period;
    326              sint8 zero_cross_slot;
    327          
    328              if ((count < Mains_Sampler_Data[Pilot_Index].Max_L_Pos_Count) && (count > Mains_Sampler_Data[Pilot_Index].Min_L_Pos_Count))
    329              {
    330                  // recalc zero cross
    331                  half_mains_period = Mains_Sampler_Data[Pilot_Index].Mains_Period / 2;
    332          
    333                  zero_cross_slot = ((count - half_mains_period)/2);
    334                  Mains_Sampler_Data[Pilot_Index].Zero_Cross_HL_Cnt2 = (half_mains_period + zero_cross_slot);
    335          
    336                  if (count > half_mains_period) //mains high width > AC high width
    337                  {
    338                      Mains_Sampler_Data[Pilot_Index].Zero_Cross_LH_Cnt1 = zero_cross_slot;
    339                  }
    340                  else
    341                  {
    342                      Mains_Sampler_Data[Pilot_Index].Zero_Cross_LH_Cnt1 = (Mains_Sampler_Data[Pilot_Index].Zero_Cross_HL_Cnt2 + half_mains_period);
    343                  }
    344          
    345                  //recalc positive peak and negative peak
    346                  Mains_Sampler_Data[Pilot_Index].L_Pos_Cnt = (count/2);
    347                  Mains_Sampler_Data[Pilot_Index].L_Neg_Cnt = (Mains_Sampler_Data[Pilot_Index].L_Pos_Cnt + (Mains_Sampler_Data[Pilot_Index].Mains_Period / 2));
    348              }
    349          }
    350          
    351          //---------------------------------------------------------------------------------------------------------------------
    352          /**
    353           *  @brief      It detect the mains lost state
    354           *
    355           */
    356          static void MainsSamplerMainsLostDetection(void)
    357          {
    358              Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter++;
    359              if (Mains_Sampler_Data[Pilot_Index].Mains_Detect_State != MAINS_DETECT_STATE_LOST)
    360              {
    361                  if (Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter >= MAINS_LOST_COUNT)
    362                  {
    363                      Mains_Sampler_Data[Pilot_Index].Mains_Detect_State = MAINS_DETECT_STATE_LOST;
    364                      Mains_Sampler_Data[Pilot_Index].Mains_Detect_State_Changed = TRUE;
    365                      Mains_Sampler_Data[Pilot_Index].Mains_Period_Resume_Counter = 0;
    366                  }
    367          
    368                  if (Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter == MAINS_EARLY_WARNING_COUNT)
    369                  {
    370                      Mains_Sampler_Data[Pilot_Index].Mains_Detect_Early_Warning = TRUE;
    371                  }
    372              }
    373          }
    374          
    375          //---------------------------------------------------------------------------------------------------------------------
    376          /**
    377           *  @brief      It detect the mains found state
    378           *
    379           */
    380          static void MainsSamplerMainsFoundDetection(void)
    381          {
    382              if(Mains_Sampler_Data[Pilot_Index].Mains_Detect_State == MAINS_DETECT_STATE_FOUND)
    383              {
    384                  Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter = 0;
    385              }
    386              else
    387              {
    388                  if(Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter <= MAINS_RESUME_COUNT)
    389                  {
    390                      Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter = 0;
    391                      Mains_Sampler_Data[Pilot_Index].Mains_Period_Resume_Counter++;
    392                      if(Mains_Sampler_Data[Pilot_Index].Mains_Period_Resume_Counter > 5) //!< 6 zero crosses needed to approve mains
    393                      {
    394                          Mains_Sampler_Data[Pilot_Index].Mains_Detect_State = MAINS_DETECT_STATE_FOUND;
    395                          Mains_Sampler_Data[Pilot_Index].Mains_Detect_State_Changed = TRUE;
    396                      }
    397                  }
    398                  else
    399                  {
    400                      Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter = 0;
    401                      Mains_Sampler_Data[Pilot_Index].Mains_Period_Resume_Counter = 0;
    402                  }
    403              }
    404          }
    405          
