    723                      SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_ATOD_ENGINECLASSB_CHECK_ENTER);
    724                  #endif
    725          
    726                  //-----------------------------------------------------------------------------------------------------------------
    727                  // CLASS B Test : Reading the Internal Reference voltage periodically
    728                  //
    729                  //In order to be sure that a valid analog data has been measured, the Atod__EngineClassBCheck() function measures
    730                  //the "Internal Power Block" as reference. This mechanism checks if ADC has proper accuracy
    731                  //and embedded channel multiplexer works properly
    732                  //-----------------------------------------------------------------------------------------------------------------
    733                  //measure internal reference voltage to detect inaccuracy of ADC conversion
    734                  uint16 internal_ref = Atod__Convert(ADC_VREF_CHANNEL, ATOD_RESOLUTION_10BITS);
    735          
    736                  //Check for the range
    737                  if( (internal_ref < ATOD_INTERNAL_REF_MIN_COUNT) || (internal_ref > ATOD_INTERNAL_REF_MAX_COUNT) )
    738                  {
    739                      SR_CHECK_BYTE(Atod_Exception_Debounce_Count);
    740          
    741                      SR_SET_BYTE(Atod_Exception_Debounce_Count, Atod_Exception_Debounce_Count + 1);
    742          
    743                      if(Atod_Exception_Debounce_Count > MAX_INTERNAL_REF_DEBOUNCE)
    744                      {
    745                          SR_SET_BYTE(Atod_Exception_Debounce_Count, 0);
    746          
    747                          //generate an exception if the ADC value read from the "Internal Power Block" is out of range
    748                          SRException__Queue(SREXCEPTION_ATOD_STUCK, internal_ref, Atod_Exception_Debounce_Count);
    749                          retval = FAIL;
    750                      }
    751                  }
    752                  else
    753                  {
    754                      SR_SET_BYTE(Atod_Exception_Debounce_Count, 0);
    755                  }
    756          
    757                  #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    758                      SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_ATOD_ENGINECLASSB_CHECK_EXIT);
    759                  #endif
    760              #endif
    761          
    762              return(retval);
