     91          // Verify that the LOG_MODULE_MESSAGE_ID_TYPE exactly overlaps the concatenation of the
     92          // LOG_MODULE_ID_TYPE and the LOG_MESSAGE_ID_TYPE.
     93          CT_ASSERT(sizeof(LOG_MODULE_MESSAGE_ID_TYPE) == (sizeof(LOG_MODULE_ID_TYPE) + sizeof(LOG_MESSAGE_ID_TYPE)));
