    111          /**
    112           *  @brief      It Initializes the module MultiDriverPilot and its variables
    113           *
    114           */
    115          void MultiDriverPilot__Initialize(void)
    116          {
    117              #if (MULTIDRIVER_NUM_REGISTERED_PILOT > 0)
    118                  MultiDriverPilot_Allocation = 0;
    119                  memset(&MultiDriverPilot_Data,0,sizeof(MultiDriverPilot_Data));
    120              #endif
    121          }
    122          
    123          //---------------------------------------------------------------------------------------------------------------------
    124          /**
    125           * @brief
    126           * @return
    127           */
    128          uint8 MultiDriverPilot__Allocate(void)
    129          {
    130              uint8 retval;
    131              retval = 0xFF;
    132          
    133              #if (MULTIDRIVER_NUM_REGISTERED_PILOT > 0)
    134                  if (MultiDriverPilot_Allocation < HBL_PILOT_NUM_MULTIDRIVER)
    135                  {
    136                      retval = MultiDriverPilot_Allocation;
    137                      MultiDriverPilot_Allocation++;
    138                  }
    139              #endif
    140          
    141              return (retval);
    142          }
    143          
    144          //---------------------------------------------------------------------------------------------------------------------
    145          /**
    146           *
    147           * @param load
    148           */
    149          PASS_FAIL_TYPE MultiDriverPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    150          {
    151              PASS_FAIL_TYPE retval;
    152              uint8 index;
    153              uint8 handler_index;
    154              MULTIDRIVERPILOT_PARAMETERS_TYPE *parameters;
    155          
    156              retval = FAIL;
    157          
    158              #if (MULTIDRIVER_NUM_REGISTERED_PILOT > 0)
    159                  if (load->Pilot_Data_Index < MultiDriverPilot_Allocation)
    160                  {
    161                      parameters = (MULTIDRIVERPILOT_PARAMETERS_TYPE *)load->Parameter_Ptr.Data;
    162          
    163                      if (load->Pilot_Type == HBL_PILOT_MULTIDRIVER_2)
    164                      {
    165                          MultiDriverPilot_Data[load->Pilot_Data_Index].Max_Pilot = 2;
    166                      }
    167                      else if (load->Pilot_Type == HBL_PILOT_MULTIDRIVER_3)
    168                      {
    169                          MultiDriverPilot_Data[load->Pilot_Data_Index].Max_Pilot = 3;
    170                      }
    171                      else if (load->Pilot_Type == HBL_PILOT_MULTIDRIVER_4)
    172                      {
    173                          MultiDriverPilot_Data[load->Pilot_Data_Index].Max_Pilot = 4;
    174                      }
    175          
    176                      for (index = 0; index < MultiDriverPilot_Data[load->Pilot_Data_Index].Max_Pilot; index++)
    177                      {
    178                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Load_Id				   = load->Load_Id;
    179                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type               = parameters[index].Pilot_Type;
    180                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset = parameters[index].Pilot_Type_Params_Offset;
    181                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pin_Ptr                  = &(load->Pin_Ptr[index]);
    182          
    183                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Hi_Low_Activation_Bitmap =  (load->Hi_Low_Activation_Bitmap >> index) & 0x01;
    184          
    185          
    186                          if (MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset != NO_PARAMETER_OFFSET)
    187                          {
    188                              SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type_Params_Offset, &MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr);
    189                          }
    190                          else
    191                          {
    192                              MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr.Data = NULL;
    193                              MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Parameter_Ptr.Length = 0;
    194                          }
    195          
    196          
    197                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Data_Index = 0xFF;
    198                          MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Handler_Index= HBL_INDEX_INVALID;
    199          
    200                          for (handler_index = 0; handler_index < MULTIDRIVER_NUM_REGISTERED_PILOT; handler_index++)
    201                          {
    202                              if (MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Type == MULTIDRIVER__PILOT_HANDLERS[handler_index].Pilot)
    203                              {
    204                              	MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Handler_Index  = handler_index;
    205                                  MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index].Pilot_Data_Index  = MULTIDRIVER__PILOT_HANDLERS[handler_index].Allocate();
    206                                  retval  = MULTIDRIVER__PILOT_HANDLERS[handler_index].InitializeInstance(&MultiDriverPilot_Data[load->Pilot_Data_Index].Load[index]);
    207                                  break;
    208                              }
    209                          }
    210                      }
    211                  }
    212          
    213              #endif
    214          
    215              return (retval);
    216          }
