     51          uint8  ProbeLpsGI__Allocate(void)
     52          {
     53              uint8 retval;
     54              retval = 0xFF;
     55              if ( ProbeLpsGI_Allocation < HBL_GI_NUM_PROBE_LPS)
     56              {
     57                  retval =  ProbeLpsGI_Allocation;
     58                  ProbeLpsGI_Allocation++;
     59          
     60              }
     61              return (retval);
     62          }
