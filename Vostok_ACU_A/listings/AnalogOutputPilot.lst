    335          //=====================================================================================================================
    336          //-------------------------------------- Private Functions ------------------------------------------------------------
    337          //=====================================================================================================================
    338          
    339          
    340          //---------------------------------------------------------------------------------------------------------------------
    341          /**
    342           *  @brief      Provides Dtoa value from a percentage
    343           *
    344           *  @param      uint16 percent - Percentage value, from 0 to PARAM_MAX_PERCENT
    345           *  @param      uint16 max_vlaue - Maximum Dtoa value (depends on resolution)
    346           *
    347           *  @return     uint16 dtoa_value - Value in Dtoa resolution
    348           */
    349          
    350          uint16 DtoaValueFromPercent(uint16 percent, uint16 max_value)
    351          {
    352          	uint16 dtoa_value = (((percent * max_value) + (PARAM_MAX_PERCENT/2)) / PARAM_MAX_PERCENT);
    353          
    354          	if (dtoa_value >= max_value)
    355          	{
    356          		dtoa_value = max_value - 1;
    357          	}
    358          
    359          	return(dtoa_value);
    360          }
