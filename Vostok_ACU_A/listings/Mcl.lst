    749           */
    750          void Mci__Emulate_Error(uint8 fault)
    751          {
    752          	Mcl_Quantities.MciSlfac_Last_Failure = (MCI_ERROR_TYPE)fault;
    753          
    754              if(Mcl_Quantities.MciSlfac_Last_Failure >= UNDER_VOLTAGE)
    755              {
