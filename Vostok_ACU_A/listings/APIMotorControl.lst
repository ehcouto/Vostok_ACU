    782          /**
    783           * @brief       Get all the digital inputs. It parses the command from Reveal, builds up the
    784           *              buffer and sends it back to the communication buffer.
    785           * @param       buffer a point to the incoming Reveal buffer
    786           * @return      TRUE: The variable was successfully changed.
    787           *              FALSE: The variable could not be changed.
    788           */
    789          uint8 Get_Digital(REVEAL_MSG_TYPE *buffer)
    790          {
    791              uint8 ret_val;
    792              MOTOR_ENUM_TYPE motor_index;
    793          
    794              ret_val = FALSE;                                // By default, the feedback is always false.
    795          
    796              if(buffer->sdu_length == 3)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
    797              {
    798                  // Recover the data from the Reveal buffer
    799                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
    800          
    801                  // Check the sanity of the motor index
    802                  if(motor_index < API220_NR_OF_CONNECTED_MOTORS)
    803                  {
    804                      // Invoke the publishing method with the required feedback
    805                      Publish_Digital_Input(motor_index, Mci_Digital_Inputs[motor_index]);
    806          
    807                      ret_val = TRUE;                         // Command is accepted
    808                  }
    809              }
    810          
    811              return(ret_val);
    812          }
    813          
