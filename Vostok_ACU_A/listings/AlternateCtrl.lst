   1902          			EventCheckTargetSpeedTrue();
   1903          			break;
   1904          		case API221_EVENT_DEBLOCKING_READY:
   1905          			if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_0)
   1906          			{
   1907          				PumpControl__SetWashPumpDeblockingReady(TRUE);
   1908          			}
   1909          			else if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_1)
   1910          			{
   1911          				PumpControl__SetDrainPumpDeblockingReady(TRUE);
   1912          			}
   1913          			break;
   1914          		default:
   1915          			// Ignore all other events
   1916          			break;
   1917          	}
