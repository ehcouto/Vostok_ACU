   1379          
   1380          //---------------------------------------------------------------------------------------------------------------------
   1381          /**
   1382           * Request an analog input for a specified motor from the remote device.
   1383           * The caller can use synchronized data and polling to know when the requested value has been received.
   1384           * @param client_motor = The value used to uniquely identify the system device on the client.
   1385           * @param channel = The analog input channel whose value is requested.
   1386           * @return TRUE if the request was sent. Otherwise, FALSE.
   1387           */
   1388          BOOL_TYPE API221MotionCtrl__RequestAnalogData(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8 channel)
   1389          {
   1390              BOOL_TYPE result = FALSE;
   1391              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1392                  (channel >= MAX_CHANNELS_PER_MOTOR))
   1393              {
   1394                  LOG_ADD_EXCEPTION(REQ_ANALOG_DATA_INVALID_PARAMS, COMBINE_BYTES(client_motor, channel));
   1395              }
   1396              else
   1397              {
   1398                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1399                  uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1400                  #if (API221_SERVER_FEATURE == ENABLED)
   1401                      if (motor_node == WIN_NODE)
   1402                      {
   1403                          #ifdef API221_READ_ANALOG_DATA
   1404                              sint32 value = API221_READ_ANALOG_DATA(server_motor, channel);
   1405                              StoreAnalogInput(client_motor, channel, value);
   1406                              result = TRUE;
   1407                          #endif
   1408                      }
   1409                      else
   1410                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1411                  {
   1412                      REVEAL_COMMAND_TYPE* cmd = Reveal__NewCommand(API221MOTIONCTRL_NUM, API221_CMD_REQUEST_ANALOG_DATA, motor_node, 2);
   1413                      result = (BOOL_TYPE)((Reveal__AddDataU8(cmd, server_motor) == PASS) &&
   1414                                           (Reveal__AddDataU8(cmd, channel) == PASS) &&
   1415                                           (Reveal__QueueCommand(cmd) == TRUE));
   1416                  }
   1417              }
   1418              return result;
   1419          }
   1420          
   1421          //---------------------------------------------------------------------------------------------------------------------
   1422          /**
   1423           * Request all failure flags from the node that controls the specified motor.
   1424           * @param client_motor = The value used to uniquely identify the system motor on the client.
   1425           * @param failures_handler = Pointer to a function that can handle the motor failure flags message.
   1426           * @return TRUE if the request was sent. Otherwise, FALSE.
   1427           */
   1428          BOOL_TYPE API221MotionCtrl__RequestFailureFlags(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, API221_FAILURES_HANDLER_TYPE failures_handler)
   1429          {
   1430              BOOL_TYPE result = FALSE;
   1431              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1432                  (failures_handler == NULL))
   1433              {
   1434                  LOG_ADD_EXCEPTION(REQ_FAILURES_INVALID_PARAMS, COMBINE_BYTES(client_motor, (failures_handler == NULL)));
   1435              }
   1436              else
   1437              {
   1438                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1439                  uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1440                  #if (API221_SERVER_FEATURE == ENABLED)
   1441                      if (motor_node == WIN_NODE)
   1442                      {
   1443                          #ifdef API221_READ_FAILURE_FLAGS
   1444                              if (server_motor < API221_SERVER_MOTOR_COUNT)
   1445                              {
   1446                                  failures_handler(client_motor, Api221.Failure_Flags[server_motor]);
   1447                                  result = TRUE;
   1448                              }
   1449                          #endif
   1450                      }
   1451                      else
   1452                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1453                  {
   1454                      API221_FAILURES_HANDLER_TYPE* handlers = Api221.Failures_Handler[client_motor];
   1455                      for (uint8 handler_index = 0; handler_index < API221_MAX_FAILURE_EVENT_HANDLERS; handler_index++)
   1456                      {
   1457                          if ((handlers[handler_index] == NULL) ||
   1458                              (handlers[handler_index] == failures_handler))
   1459                          {
   1460                              // Found an open slot for a failure flags handler.
   1461                              result = TRUE;                      // Assume that the request was already sent.
   1462                              if (handler_index == 0)
   1463                              {
   1464                                  // Since this is the first request, send the request message.
   1465                                  result = Reveal__QueueMessageU8(API221MOTIONCTRL_NUM, API221_CMD_REQUEST_FAILURE_FLAGS, motor_node, TRUE, FALSE, server_motor);
   1466                              }
   1467                              if (result == TRUE)
   1468                              {
   1469                                  handlers[handler_index] = failures_handler;
   1470                              }
   1471                              break;                              // Break out of the for() loop.
   1472                          }
   1473                      }
   1474                  }
   1475              }
   1476              return result;
   1477          }
   1478          
   1479          //---------------------------------------------------------------------------------------------------------------------
   1480          /**
   1481           * Request the current settings for the periodic data feature.
   1482           * @param client_motor = Used to identify the server based on just one of the motors that it controls.
   1483           * @param per_data_status_handler = Pointer to a function that can handle the periodic data status message.
   1484           * @return TRUE if the request was sent. Otherwise FALSE.
   1485           */
   1486          BOOL_TYPE API221MotionCtrl__RequestPeriodicDataStatus(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, API221_PER_DATA_STATUS_HANDLER_TYPE per_data_status_handler)
   1487          {
   1488              BOOL_TYPE result = FALSE;
   1489          
   1490              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1491                  (per_data_status_handler == NULL))
   1492              {
   1493                  LOG_ADD_EXCEPTION(REQ_PER_DATA_STATUS_INVALID_PARAMS, COMBINE_BYTES(client_motor, (per_data_status_handler == NULL)));
   1494              }
   1495              else
   1496              {
   1497                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1498                  #if (API221_SERVER_FEATURE == ENABLED)
   1499                      if (motor_node == WIN_NODE)
   1500                      {
   1501                          uint16 millisecond_period = Api221.Publication_Period * API221_MS_PER_CALL_TO_BACKGROUND;
   1502                          per_data_status_handler(millisecond_period, Api221.Requested, API221_SERVER_MOTOR_COUNT);
   1503                          result = TRUE;
   1504                      }
   1505                      else
   1506                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1507                  if (Api221.Periodic_Data_Status_Handler == NULL)
   1508                  {
   1509                      result = Reveal__QueueMessageNoData(API221MOTIONCTRL_NUM, API221_CMD_REQUEST_PERIODIC_DATA_STATUS, motor_node, TRUE, FALSE);
   1510                      if (result == TRUE)
   1511                      {
   1512                          Api221.Periodic_Data_Status_Handler = per_data_status_handler;
   1513                      }
   1514                  }
   1515              }
   1516              return result;
   1517          }
   1518          
   1519          //---------------------------------------------------------------------------------------------------------------------
   1520          /**
   1521           * Request the current status of a motor.
   1522           * @param client_motor = Motor for which the status is being requested.
   1523           * @param motor_status_handler = Pointer to a function that can handle the motor status message.
   1524           * @return TRUE if the request was sent. Otherwise FALSE.
   1525           */
   1526          BOOL_TYPE API221MotionCtrl__RequestStatus(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, API221_MOTOR_STATUS_HANDLER_TYPE motor_status_handler)
   1527          {
   1528              BOOL_TYPE result = FALSE;
   1529              if ((client_motor >= API221_SYSTEM_MOTOR_COUNT) ||
   1530                  (motor_status_handler == NULL))
   1531              {
   1532                  LOG_ADD_EXCEPTION(REQ_STATUS_INVALID_PARAMS, COMBINE_BYTES(client_motor, (motor_status_handler == NULL)));
   1533              }
   1534              else
   1535              {
   1536                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1537                  API221_CLIENT_MOTOR_INDEX_TYPE server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1538                  #if (API221_SERVER_FEATURE == ENABLED)
   1539                      if (motor_node == WIN_NODE)
   1540                      {
   1541                          motor_status_handler(server_motor, Api221.Status_Flags[server_motor]);
   1542                          result = TRUE;
   1543                      }
   1544                      else
   1545                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1546                  {
   1547                      API221_MOTOR_STATUS_HANDLER_TYPE* handlers = Api221.Motor_Status_Handler[client_motor];
   1548                      for (uint8 handler_index = 0; handler_index < API221_MAX_STATUS_EVENT_HANDLERS; handler_index++)
   1549                      {
   1550                          if ((handlers[handler_index] == NULL) ||
   1551                              (handlers[handler_index] == motor_status_handler))
   1552                          {
   1553                              if (handler_index == 0)
   1554                              {
   1555                                  result = Reveal__QueueMessageU8(API221MOTIONCTRL_NUM, API221_CMD_REQUEST_MOTOR_STATUS, motor_node, TRUE, FALSE, server_motor);
   1556                              }
   1557                              else
   1558                              {
   1559                                  result = TRUE;
   1560                              }
   1561                              if (result == TRUE)
   1562                              {
   1563                                  handlers[handler_index] = motor_status_handler;
   1564                              }
   1565                              break;                          // Break out of the for() loop.
   1566                          }
   1567                      }
   1568                  }
   1569              }
   1570              return result;
   1571          }
   1572          
   1573          //---------------------------------------------------------------------------------------------------------------------
   1574          /**
   1575           * Set the data publication period for data that is periodically published by a motor controller.
   1576           * If the requested data publication period is not supported, the motor controller will NAK the command.
   1577           * Note that only one period is supported at a time. So, if a motor controller controls two
   1578           * motors, then the last requested data publication period will be used for both motors.
   1579           * @param client_motor = The value used to uniquely identify the system device on the client.
   1580           * @param milliseconds = The requested number of milliseconds between publishing periodic data.
   1581           * @return TRUE if the request was sent. Otherwise, FALSE.
   1582           */
   1583          BOOL_TYPE API221MotionCtrl__SetDataPublicationPeriod(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint16 milliseconds)
   1584          {
   1585              BOOL_TYPE result = FALSE;
   1586              if (client_motor >= API221_SYSTEM_MOTOR_COUNT)
   1587              {
   1588                  LOG_ADD_EXCEPTION(SET_PERIOD_INVALID_PARAMS, COMBINE_BYTES(client_motor, 0));
   1589              }
   1590              else
   1591              {
   1592                  uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1593                  #if (API221_SERVER_FEATURE == ENABLED)
   1594                      if (motor_node == WIN_NODE)
   1595                      {
   1596                          #ifdef API221_READ_ANALOG_DATA
   1597                              result = SetPublicationPeriod(motor_node, milliseconds);
   1598                          #endif
   1599                          if (result == FALSE)
   1600                          {
   1601                              LOG_ADD_EXCEPTION(SET_PERIOD_INVALID_PARAMS, COMBINE_BYTES(client_motor, milliseconds));
   1602                          }
   1603                      }
   1604                      else
   1605                  #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1606                  {
   1607                      result = Reveal__QueueMessageU16(API221MOTIONCTRL_NUM, API221_CMD_SET_DATA_PUBLICATION_PERIOD, motor_node, TRUE, FALSE, milliseconds);
   1608                  }
   1609              }
   1610              return result;
   1611          }
   1612          
   1613          //---------------------------------------------------------------------------------------------------------------------
   1614          /**
   1615           * Synchronize the client so that it can receive only new samples of the analog inputs as they are received.
   1616           * @param client_motor = The value used to uniquely identify the system motor on the client.
   1617           * @param channel = The analog input channel whose value is requested.
   1618           * @param sync = Pointer to a byte used to synchronize the client.
   1619           */
   1620          void API221MotionCtrl__SynchronizeData(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8 channel, uint8* sync)
   1621          {
   1622              #if (API221_STORED_ANALOG_INPUTS > 0)
   1623                  for (uint8 i = 0; i < API221_STORED_ANALOG_INPUTS; i++)
   1624                  {
   1625                      API221_STORED_DATA_TYPE* stored = &Api221.Data[i];
   1626                      if ((channel == stored->Channel) && (client_motor == stored->Motor))
   1627                      {
   1628                          *sync = stored->Sequence;
   1629                          return;
   1630                      }
   1631                  }
   1632              #endif      // #if (API221_STORED_ANALOG_INPUTS > 0)
   1633              *sync = UCHAR_MAX;                              // Consider any data found as new data.
   1634          }
   1635          
   1636          //---------------------------------------------------------------------------------------------------------------------
   1637          /**
   1638           * Unregister for motor events received on the communications bus.
   1639           * @param event_handler = Pointer to a function that handles motor events.
   1640           */
   1641          void API221MotionCtrl__UnregisterForEvents(API221_EVENT_MOTOR_HANDLER_TYPE event_handler)
   1642          {
   1643              Callback__Unregister(&Api221_Callback, (CALLBACK_HANDLER_TYPE)(void*)event_handler);
   1644          }
   1645          #endif      // #if (API221_CLIENT_FEATURE == ENABLED)
