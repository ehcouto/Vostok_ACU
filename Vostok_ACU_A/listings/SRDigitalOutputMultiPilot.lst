    322          //---------------------------------------------------------------------------------------------------------------------
    323          /**
    324           * @brief	Handler for SRDigitalOutputMultiPilot execution
    325           *
    326           * It checks SRDigitalOutputMultiPilot_Allocation integrity and all SRDigitalOutputMultiPilot_Data instances allocated
    327           * It sets SRTASKSEQUENCE_APPL_SRDIGITALOUTPUTMULTIPILOT_CHECKS step in SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    328           *
    329           */
    330          void SRDigitalOutputMultiPilot__Handler(void)
    331          {
    332              if (SRData__CheckByte(&SRDigitalOutputMultiPilot_Allocation, &N_SRDigitalOutputMultiPilot_Allocation) != SRDATA_OK)
    333              {
    334              	SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, 0xFF);
    335              }
    336              else
    337              {
    338                  uint8 index;
    339          
    340                  for(index = 0; index < HBL_PILOT_NUM_SRDIGITALOUTPUTMULTI; index++)
    341                  {
    342                  	if (SRData__CheckArray(&SRDigitalOutputMultiPilot_Data[index], &N_SRDigitalOutputMultiPilot_Data[index], sizeof(SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE)) != SRDATA_OK)
    343                      {
    344                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, index);
    345                          break;
    346                      }
    347                  }
    348              }
    349          
    350          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    351              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRDIGITALOUTPUTMULTIPILOT_CHECKS);
    352          #endif
    353          
    354          
    355          }
    356          //=====================================================================================================================
    357          //-------------------------------------- Private Functions ------------------------------------------------------------
    358          //=====================================================================================================================
    359          
    360          //---------------------------------------------------------------------------------------------------------------------
    361          /**
    362           * @brief	Updates output pins according to Processed value
    363           *
    364           *
    365           *
    366           *
    367           */
    368          void DoPinsUpdate(HBL_LOAD_TYPE * load)
    369          {
    370              SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *ptr = &SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    371              SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *n_ptr = &N_SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    372              uint8 virtual_pin = load->Pin_Ptr[0];
    373              uint8 virtual_pin2 = load->Pin_Ptr[1];
    374              uint8 pin_val;
    375          
    376              pin_val = ptr->Processed;
    377              // Config bit 0 (0x10) inverts status on pin 1 only
    378              pin_val ^= ptr->Processed >> 4;
    379              // Invert pin value according to Hi Low Activation Bitmap
    380              pin_val ^= ~load->Hi_Low_Activation_Bitmap;
    381              pin_val &= 0x01;
    382              Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE)pin_val);
    383              SRData__UpdateByte(&ptr->Last_Pin_1_Value, &n_ptr->Last_Pin_1_Value, pin_val);
    384          
    385              pin_val = ptr->Processed;
    386              // Config bit 1 (0x20) inverts status on pin 2 only
    387              pin_val ^= ptr->Processed >> 5;
    388              // Invert pin value according to Hi Low Activation Bitmap
    389              pin_val ^= ~(load->Hi_Low_Activation_Bitmap >> 1);
    390              pin_val &= 0x01;
    391              Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin2].port, VIRTUALPIN_TABLE[virtual_pin2].pin,(BOOL_TYPE)pin_val);
    392              SRData__UpdateByte(&ptr->Last_Pin_2_Value, &n_ptr->Last_Pin_2_Value, pin_val);
    393          
    394          }
    395          
    396          //---------------------------------------------------------------------------------------------------------------------
    397          /**
    398           * @brief	Handler for SRDigitalOutputMultiPilot execution
    399           *
    400           * It checks SRDigitalOutputMultiPilot_Allocation integrity and all SRDigitalOutputMultiPilot_Data instances allocated
    401           * It sets SRTASKSEQUENCE_APPL_SRDIGITALOUTPUTMULTIPILOT_CHECKS step in SRTASKSEQUENCE_APPL_SAFETY_THREAD sequence
    402           *
    403           */
    404          BOOL_TYPE CheckItem(uint8 index)
    405          {
    406              BOOL_TYPE retval = FALSE;
    407          
    408              if (SRData__CheckByte(&SRDigitalOutputMultiPilot_Allocation, &N_SRDigitalOutputMultiPilot_Allocation) != SRDATA_OK)
    409              {
    410                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, 0xFF);
    411              }
    412              else
    413              {
    414                  if (index < SRDigitalOutputMultiPilot_Allocation)
    415                  {
    416                      if (SRData__CheckArray(&SRDigitalOutputMultiPilot_Data[index], &N_SRDigitalOutputMultiPilot_Data[index], sizeof(SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE)) != SRDATA_OK)
    417                      {
    418                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, index);
    419                      }
    420                      else
    421                      {
    422                          retval = TRUE;
    423                      }
    424                  }
    425              }
    426          
    427              return (retval);
    428          }
    429          
    430          #endif


 

 


