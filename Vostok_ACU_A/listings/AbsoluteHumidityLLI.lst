    200          /**
    201           * @brief	Initializes the AbsoluteHumidityLLI module and its variables
    202           */
    203          void AbsoluteHumidityLLI__Initialize(void)
    204          {
    205              Absolute_Humidity_LLI_Allocation = 0;
    206              memset(&Absolute_Humidity_LLI_Data,0,sizeof(Absolute_Humidity_LLI_Data));
    207          }
