    386          //---------------------------------------------------------------------------------------------------------------------
    387          /**
    388           * @brief   Initialize an instance of the LLI by extracting parameter data and initializing variables.
    389           * @param   input: data related to the instance of the LLI
    390           * @param   PASS if the initialization was successful, else FAIL
    391           */
    392          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    393          PASS_FAIL_TYPE I2CRHTSensorLLI__InitializeHumidityInstance(HBL_LLI_TYPE * input)
    394          {
    395          	PASS_FAIL_TYPE retval = FAIL;
    396          
    397              if (input->Data_Index < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR)
    398              {
    399                  I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    400          
    401                  switch (param_ptr->Device_Type)
    402                  {
    403                      #if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    404                      case SHT2X_RHT_DEVICE_TYPE:
    405                      	I2CHumidity_Device_Data_Remap[input->Data_Index] = SHT2XHumidity_Allocation;
    406          
    407                          if (SHT2XHumidity_Allocation < SHT2X_TOTAL_HUMIDITY_CHANNELS_USED)
    408                          {
    409                              SHT2XHumidity_Data[I2CHumidity_Device_Data_Remap[input->Data_Index]].I2cMgr_Device_Handle = I2cMgr__GetDeviceHandle(param_ptr->I2C_Channel);
    410          
    411                              if (SHT2XHumidity_Data[I2CHumidity_Device_Data_Remap[input->Data_Index]].I2cMgr_Device_Handle != I2CMGR_HANDLE_INVALID)
    412                              {
    413                                  //Initialize Device related Variables
    414                              	retval = (PASS_FAIL_TYPE)I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address);
    415                              	if(retval)
    416                              	{
    417                              		SHT2X_Instance_Handler_ID = &(input->Parameter_Ptr);
    418                              		SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    419                              		SHT2XHumidity_Allocation++;
    420                              		SHT2X_Total_Sensor++;
    421                              		retval = PASS;
    422                              	}
    423                              }
    424                          }
    425                          break;
    426                      #endif
    427          
    428                      default:
    429                          break;
    430                  }
    431              }
    432          	return (retval);
    433          }
    434          #endif
    435          
    436          //---------------------------------------------------------------------------------------------------------------------
    437          /**
    438           * @brief   Initialize an instance of the LLI by extracting parameter data and initializing variables.
    439           * @param   input: data related to the instance of the LLI
    440           * @param   PASS if the initialization was successful, else FAIL
    441           */
    442          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
    443          PASS_FAIL_TYPE I2CRHTSensorLLI__InitializeTemperatureInstance(HBL_LLI_TYPE * input)
    444          {
    445              PASS_FAIL_TYPE retval = FAIL;
    446          
    447              if (input->Data_Index < HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR)
    448              {
    449                  I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    450          
    451                  switch (param_ptr->Device_Type)
    452                  {
    453                      #if (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    454                      case SHT2X_RHT_DEVICE_TYPE:
    455                      	I2CTemperature_Device_Data_Remap[input->Data_Index] = SHT2XTemperature_Allocation;
    456                          if (SHT2XTemperature_Allocation < SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED)
    457                          {
    458                          	SHT2XTemperature_Data[I2CTemperature_Device_Data_Remap[input->Data_Index]].I2cMgr_Device_Handle = I2cMgr__GetDeviceHandle(param_ptr->I2C_Channel);
    459          
    460                              if (SHT2XTemperature_Data[I2CTemperature_Device_Data_Remap[input->Data_Index]].I2cMgr_Device_Handle != I2CMGR_HANDLE_INVALID)
    461                              {
    462                              	//Initialize Device related Variables
    463                              	retval = (PASS_FAIL_TYPE)I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address);
    464                              	if(retval)
    465                              	{
    466                              		SHT2X_Instance_Handler_ID = &input->Parameter_Ptr;
    467                              		SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    468                              		SHT2XTemperature_Allocation++;
    469                              		SHT2X_Total_Sensor++;
    470                              		retval = PASS;
    471                              	}
    472                              }
    473                          }
    474                          break;
    475                      #endif
    476          
    477                      default:
    478                          break;
    479                  }
    480              }
    481              return (retval);
    482          }
    483          #endif
    484          //---------------------------------------------------------------------------------------------------------------------
    485          /**
    486           * @brief   Retrieves the current value of the LLI
    487           * @param   input: data related to the instance of the LLI
    488           * @return  The current value of the LLI
    489           */
    490          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    491          void * I2CRHTSensorLLI__GetHumidity(HBL_LLI_TYPE * input)
    492          {
    493          	I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    494          
    495          	switch (param_ptr->Device_Type)
    496          	{
    497          	#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    498          		case SHT2X_RHT_DEVICE_TYPE:
    499          			return ((void *)&SHT2XHumidity_Data[I2CHumidity_Device_Data_Remap[input->Data_Index]].Sensor_I2C_Relative_Humidity);
    500          	#endif
    501          
    502          		default:
    503          			return NULL;
    504          		}
    505          }
    506          #endif
    507          
    508          //---------------------------------------------------------------------------------------------------------------------
    509          /**
    510           * @brief   Retrieves the current value of the LLI
    511           * @param   input: data related to the instance of the LLI
    512           * @return  The current value of the LLI
    513           */
    514          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
    515          void * I2CRHTSensorLLI__GetTemperature(HBL_LLI_TYPE * input)
    516          {
    517              I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    518          
    519              switch (param_ptr->Device_Type)
    520              {
    521               #if (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    522               	 case SHT2X_RHT_DEVICE_TYPE:
    523               		Temperature_Q15_Format = ((SHT2XTemperature_Data[I2CTemperature_Device_Data_Remap[input->Data_Index]].Sensor_I2C_Tempearture_Celcius)*SHRT_MAX)/TEMPERATURE_BASE_SCALE;
    524               		return ((void *)&Temperature_Q15_Format);
    525          	#endif
    526          
    527                  default:
    528                  	 return NULL;
    529               }
    530          }
    531          #endif
    532          
    533          //---------------------------------------------------------------------------------------------------------------------
    534          /**
    535           * @brief   Asynchronous processing of a the LLI
    536           * @param   input: data related to the instance of the LLI
    537           * @return  PASS if the LLI was successfully processed, else FAIL
    538           */
    539          BOOL_TYPE I2CRHTSensorLLI__AsynchProcess(HBL_LLI_TYPE * input)
    540          {
    541          	BOOL_TYPE retval = FALSE;
    542          
    543              if ((input->Data_Index < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR) || (input->Data_Index < HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR))
    544              {
    545          		I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    546          
    547                  switch (param_ptr->Device_Type)
    548                  {
    549          			#if ((SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0) || (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0))
    550                      case SHT2X_RHT_DEVICE_TYPE:
    551                          if(SHT2X_Instance_Handler_ID == &(input->Parameter_Ptr))
    552                          {
    553                              SHT2xCounterHandler();
    554                              SHT2XResetHandler(input);
    555                          }
    556                          break;
    557                      #endif
    558          
    559                      default:
    560                          break;
    561                  }
    562                  retval = TRUE;
    563              }
    564          	return (retval);
    565          }
    566          
    567          //---------------------------------------------------------------------------------------------------------------------
    568          /**
    569           * @brief - This API is called at every 1ms
    570           * @param   input: data related to the instance of the LLI
    571           * @return  PASS if the OneMsProcess was successfully processed, else FAIL
    572           */
    573          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0) && (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
    574          BOOL_TYPE I2CRHTSensorLLI__OneMsProcess(HBL_LLI_TYPE * input)
    575          {
    576          	BOOL_TYPE retval = FALSE;
    577          	I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    578          
    579          	// This is to make sure to process the algorithm per device in sequentially
    580          	if(SHT2X_Instance_Handler_ID == &(input->Parameter_Ptr))
    581             	{
    582          		SHT2X_State_Delay_Counter++;
    583          
    584          		switch (param_ptr->Device_Type)
    585          		{
    586          			#if ((SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0) || (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0))
    587          				case SHT2X_RHT_DEVICE_TYPE:
    588          				switch (SHT2X_Device_State)
    589          				{
    590          				/**
    591          				 * Below state machine Handles the reading of the Humidity
    592          				 */
    593          				#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    594          				case I2C_HUMIDITY_SENSOR_STATE_WRITE:
    595          					if(I2cMgr__RequestBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
    596          					{
    597          						SHT2X_Device_State = I2C_ERROR_STATE;
    598          						if(I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address) == TRUE)
    599          						{
    600          							if(I2c__Write(param_ptr->I2C_Channel, SHT2X_TRIG_RH_MEASUREMENT_POLL,SHT2X_Write_Buffer, 0) == TRUE)     // trigger a humidity measurement
    601          							{
    602          								SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE_WAIT;
    603          								SHT2XI2C_TimeOut = DELAY_20_MS;
    604          								SHT2XI2C_Retry = DELAY_5_MS;
    605          							}
    606          						}
    607          					}
    608          					break;
    609          
    610          				case I2C_HUMIDITY_SENSOR_STATE_WRITE_WAIT:
    611          					if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_ERROR)) == I2C_ERROR_ACK)
    612          					{
    613          
    614          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    615          							I2cMgr__ReleaseBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle);
    616          					}
    617          					else
    618          					{
    619          						if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_STATE)) == I2C_STATE_IDLE)
    620          						{
    621          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_DELAY;
    622          							SHT2XI2C_Retry = DELAY_20_MS;
    623          							SHT2XI2C_TimeOut = DELAY_20_MS;
    624          							I2cMgr__ReleaseBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle);
    625          						}
    626          					}
    627          					break;
    628          
    629          				case I2C_HUMIDITY_SENSOR_STATE_DELAY:
    630          					if (SHT2XI2C_Retry > 0)
    631          					{
    632          						SHT2XI2C_Retry--;
    633          						SHT2XI2C_TimeOut = DELAY_20_MS;
    634          					}
    635          					else
    636          					{
    637          						SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_REQUEST;
    638          						SHT2XI2C_Retry = DELAY_2_MS;
    639          					}
    640          					break;
    641          				case I2C_HUMIDITY_SENSOR_STATE_REQUEST:
    642          					if(I2cMgr__RequestBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
    643          					{
    644          						I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address);
    645          						I2c__RequestRead(param_ptr->I2C_Channel, SHT2X_I2C_REQUEST_READ_BUFFER_SIZE);
    646          						SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_READ;
    647          					}
    648          					break;
    649          
    650          				case I2C_HUMIDITY_SENSOR_STATE_READ:
    651          					if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_ERROR)) == I2C_ERROR_ACK)
    652          					{
    653          						if (SHT2XI2C_Retry > 0)
    654          						{
    655          							SHT2XI2C_Retry--;
    656          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_REQUEST;
    657          							I2cMgr__ReleaseBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle);
    658          						}
    659          						else
    660          						{
    661          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    662          							I2cMgr__ReleaseBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle);
    663          						}
    664          					}
    665          					else
    666          					{
    667          						if (I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_STATE) == I2C_STATE_IDLE)
    668          						{
    669          							I2c__Read(param_ptr->I2C_Channel, &SHT2X_Read_Buffer[1], SHT2X_I2C_READ_BUFFER_SIZE);
    670          							I2cMgr__ReleaseBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle);
    671          							SHT2X_Read_Buffer[0] = (SHT2X_I2C_ADDRESS_WRITE | 1);
    672          
    673          							SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage = (uint16)SHT2X_Read_Buffer[1];
    674          							SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage <<= 8;  // Shift to MSB Byte
    675          							SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage |= SHT2X_Read_Buffer[2];
    676          							SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage = SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage & 0xfffC; // blank the last two bits-- status bits
    677          							// get the data into the HumidithI2c_Buffer variable.
    678          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_INACTIVE_DELAY;
    679          
    680          
    681          							//Process the Humidity value
    682          							RHRawToPercent(input);
    683          							ProcessRHValue(input);
    684          
    685          							sint16 remain_time = (SHT2X_SAMPLING_RATE_IN_MS / SHT2X_Total_Sensor) - SHT2X_State_Delay_Counter;
    686          
    687          							if(remain_time > 0)
    688          							{
    689          								SHT2XI2C_Retry = remain_time;
    690          								SHT2XI2C_TimeOut = remain_time + DELAY_5_MS;
    691          							}
    692          							else
    693          							{
    694          								SHT2XI2C_Retry = 0;
    695          								SHT2XI2C_TimeOut = DELAY_20_MS;
    696          							}
    697          						}
    698          					}
    699          					break;
    700          
    701          				case I2C_HUMIDITY_SENSOR_STATE_INACTIVE_DELAY:
    702          					if(SHT2XI2C_Retry > 0)
    703          					{
    704          						SHT2XI2C_Retry--;
    705          					}
    706          					else
    707          					{
    708          						SHT2XI2C_TimeOut = DELAY_20_MS;
    709          						#if (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    710          						if(SHT2XTemperature_Allocation > 0)
    711          						{
    712          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    713          						}
    714          						else
    715          						{
    716          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    717          						}
    718          						#else
    719          						SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    720          						#endif
    721          						SHT2X_State_Delay_Counter = 0;
    722          					}
    723          					break;
    724          
    725          				#endif
    726          
    727          					/**
    728          					 * Below state machine Handles the reading of the temperature
    729          					 */
    730          				#if (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    731          				case I2C_TEMP_SENSOR_STATE_WRITE:
    732          					if(I2cMgr__RequestBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
    733          					{
    734          						SHT2X_Device_State = I2C_ERROR_STATE;
    735          						if(I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address) == TRUE )
    736          						{
    737          							if(I2c__Write(param_ptr->I2C_Channel, SHT2X_TRIG_T_MEASUREMENT_POLL,SHT2X_Write_Buffer, 0) == TRUE )     // trigger a humidity measurement
    738          							{
    739          								SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE_WAIT;
    740          								SHT2XI2C_TimeOut = DELAY_20_MS;
    741          								SHT2XI2C_Retry = DELAY_5_MS;
    742          							}
    743          						}
    744          					}
    745          					break;
    746          
    747          				case I2C_TEMP_SENSOR_STATE_WRITE_WAIT:
    748          					if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_ERROR)) == I2C_ERROR_ACK)
    749          					{
    750          						SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    751          						I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
    752          					}
    753          					else
    754          					{
    755          						if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_STATE)) == I2C_STATE_IDLE)
    756          						{
    757          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_DELAY;
    758          							SHT2XI2C_Retry = DELAY_20_MS;
    759          							SHT2XI2C_TimeOut = DELAY_20_MS;
    760          							I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
    761          						}
    762          					}
    763          					break;
    764          
    765          				case I2C_TEMP_SENSOR_STATE_DELAY:
    766          					if (SHT2XI2C_Retry > 0)
    767          					{
    768          						SHT2XI2C_Retry--;
    769          						SHT2XI2C_TimeOut = DELAY_20_MS;
    770          					}
    771          					else
    772          					{
    773          						SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_REQUEST;
    774          						SHT2XI2C_Retry = DELAY_1_MS;
    775          					}
    776          					break;
    777          
    778          				case I2C_TEMP_SENSOR_STATE_REQUEST:
    779          					if(I2cMgr__RequestBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
    780          					{
    781          						I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address);
    782          						I2c__RequestRead(param_ptr->I2C_Channel, SHT2X_I2C_REQUEST_READ_BUFFER_SIZE);
    783          						SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_READ;
    784          					}
    785          					break;
    786          
    787          				case I2C_TEMP_SENSOR_STATE_READ:
    788          					if ((I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_ERROR)) == I2C_ERROR_ACK)
    789          					{
    790          						if (SHT2XI2C_Retry > 0)
    791          						{
    792          							SHT2XI2C_Retry--;
    793          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_REQUEST;
    794          							I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
    795          						}
    796          						else
    797          						{
    798          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    799          							I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
    800          						}
    801          					}
    802          					else
    803          					{
    804          						if (I2c__GetStatus(param_ptr->I2C_Channel, I2C_STATUS_STATE) == I2C_STATE_IDLE)
    805          						{
    806          							//	I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, param_ptr->I2C_Address_Type, param_ptr->Slave_Address);
    807          							I2c__Read(param_ptr->I2C_Channel, &SHT2X_Read_Buffer[1], SHT2X_I2C_READ_BUFFER_SIZE);
    808          							I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
    809          							SHT2X_Read_Buffer[0] = (SHT2X_I2C_ADDRESS_WRITE | 1);
    810          							// get the data into the I2CTemperature_Data variable.
    811          							SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data = (uint16) SHT2X_Read_Buffer[1];
    812          							SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data <<= 8; // Shift to MSB Byte
    813          							SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data |= SHT2X_Read_Buffer[2];
    814          							SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data = SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data & 0xfffc; // blank last two bits status bits
    815          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_INACTIVE_DELAY;
    816          
    817          
    818          							//Process the Temperature value
    819          							TempRawToPercent(input);
    820          							ProcessTempValue(input);
    821          
    822          							sint16 remain_time = (SHT2X_SAMPLING_RATE_IN_MS / SHT2X_Total_Sensor) - SHT2X_State_Delay_Counter;
    823          
    824          							if(remain_time > 0)
    825          							{
    826          								SHT2XI2C_Retry = remain_time;
    827          								SHT2XI2C_TimeOut = remain_time + DELAY_5_MS;
    828          							}
    829          							else
    830          							{
    831          								SHT2XI2C_Retry = 0;
    832          								SHT2XI2C_TimeOut = DELAY_20_MS;
    833          							}
    834          						}
    835          					}
    836          					break;
    837          
    838          				case I2C_TEMP_SENSOR_STATE_INACTIVE_DELAY:
    839          					if(SHT2XI2C_Retry > 0)
    840          					{
    841          						SHT2XI2C_Retry--;
    842          					}
    843          					else
    844          					{
    845          						SHT2XI2C_TimeOut = DELAY_20_MS;
    846          						#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    847          						if(SHT2XHumidity_Allocation > 0)
    848          						{
    849          							SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    850          						}
    851          						else
    852          						{
    853          							SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    854          						}
    855          						#else
    856          						SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    857          						#endif
    858          						SHT2X_State_Delay_Counter = 0;
    859          					}
    860          					break;
    861          
    862          				case I2C_ERROR_STATE:
    863          					if(I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address) == TRUE)
    864          					{
    865          						#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    866          							if(SHT2XHumidity_Allocation > 0)
    867          							{
    868          								SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    869          							}
    870          						#elif (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    871          							if(SHT2XTemperature_Allocation > 0)
    872          							{
    873          								SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    874          							}
    875          						#endif
    876          					}
    877          					break;
    878          
    879          				#endif
    880          
    881          				default:
    882          
    883          					#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    884          					if(SHT2XHumidity_Allocation > 0)
    885          					{
    886          						SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    887          					}
    888          					#elif (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    889          					if(SHT2XTemperature_Allocation > 0)
    890          					{
    891          						SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    892          					}
    893          					#endif
    894          					SHT2X_State_Delay_Counter = 0;
    895          					break;
    896          				}
    897          				break;
    898          				#endif
    899          				// Add New dvice type here
    900          				default:
    901          					break;
    902          		}
    903          		retval = TRUE;
    904              }
    905          
    906           // THis below code is to observe the timeout and initialize the SHT2X sensor initialization state
    907          	#if ((SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0) || (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0))
    908          		if (SHT2XI2C_TimeOut != 0)
    909          		{
    910          			if(SHT2X_Total_Sensor > 0)
    911          			{
    912          				SHT2XI2C_TimeOut--;
    913          			}
    914          		}
    915          		else
    916          		{
    917          		#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
    918          				if(SHT2XHumidity_Allocation > 0)
    919          				{
    920          					SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
    921          				}
    922          		#elif (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
    923          				if(SHT2XTemperature_Allocation > 0)
    924          				{
    925          					SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
    926          				}
    927          		#endif
    928          		}
    929          	#endif
    930          
    931          	return (retval);
    932          }
    933          #endif
    934          
    935          //=====================================================================================================================
    936          //-------------------------------------- Private Functions ------------------------------------------------------------
    937          //=====================================================================================================================
    938          /**
    939           * @brief   This function convert raw value to percentage value
    940           *          Formula for conversion is given in Datasheet SHT20,
    941           *          section 6.1 Relative Humidity Conversion, page 10
    942           * @param   input: data related to the instance of the LLI
    943           */
    944          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    945          static void RHRawToPercent (HBL_LLI_TYPE * input)
    946          {
    947              uint16 hum_us = 0;
    948              uint32 hum_ul = 0;
    949          
    950              hum_ul = ((uint32) SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Raw_Percentage * 125);
    951              hum_us = (uint16) (hum_ul / 65536);
    952              SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Percentage = hum_us - 6;
    953          }
    954          #endif
    955          //---------------------------------------------------------------------------------------------------------------------
    956          /**
    957           * @brief   this function is accumulation raw percentage value, taking average and the checking for error status
    958           * @param   input: data related to the instance of the LLI
    959           */
    960          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    961          static void ProcessRHValue(HBL_LLI_TYPE * input)
    962          {
    963          	if (input->Data_Index < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR)
    964          	{
    965                  I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    966          
    967                  if((SHT2XI2C_Forced_Reset == FALSE) && (SHT2X_After_Reset_Stable_Counter == 0))  //  This check is to maker sure not to take the reading when RHT chip is reseting
    968                  {																																					 // The RHT after reset delay time is running
    969          			if (SHT2XHumidity_Data[input->Data_Index].Index_Average < param_ptr->Automic_Reading)
    970          			{
    971          				SHT2XHumidity_Data[input->Data_Index].Index_Average++;    // Increment number of sample @ 1sec
    972          				SHT2XHumidity_Data[input->Data_Index].AD_RH_Buffer += SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_RH_Percentage; // accumulate sample
    973          			}
    974          			else
    975          			{   // take average of accumulated samples
    976          				SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Relative_Humidity = (uint8)(SHT2XHumidity_Data[input->Data_Index].AD_RH_Buffer / param_ptr->Automic_Reading); //
    977          
    978          
    979          				CheckRHNeedToReset(input);
    980          
    981          				SHT2XHumidity_Data[input->Data_Index].Index_Average = 0; // clear counter
    982          				SHT2XHumidity_Data[input->Data_Index].AD_RH_Buffer = 0; // clear previous value
    983          			}
    984          		}
    985          	}
    986          }
    987          #endif
    988          
    989          //---------------------------------------------------------------------------------------------------------------------
    990          /**
    991           * @brief   This is primarily being done due to the fact that I2C Sensor behaves random after few days / hours of operation.
    992           *          Originally was resolved by Doing every 12 Hr I2C Chip reset. Now failure was seen that Sensor give abnormal value
    993           *          and recovers after 12 hrs which affects product operation
    994           * @param   input: data related to the instance of the LLI
    995           */
    996          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0)
    997          static void CheckRHNeedToReset(HBL_LLI_TYPE * input)
    998          {
    999          	if((abs(SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Relative_Humidity - SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Previous_Relative_Humidity) >= SHT2X_I2C_RESET_HMUIDTY_DELTA) && //  monitor the RH delta for the failure of sensor
   1000          	   (SHT2X_Powerup_Stable_Counter == 0))                                  // this check is there to wait for Power up stable time and after that only need to detect the logic for the reset
   1001          	{
   1002          		SHT2XI2C_Forced_Reset = TRUE;
   1003          		SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Relative_Humidity = SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Previous_Relative_Humidity;
   1004          		LOG_ADD_EVENT(SHT2X_RHT_WRONG_HUMIDITY_READING, SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Previous_Relative_Humidity);
   1005          	}
   1006          	else
   1007          	{
   1008          		SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Previous_Relative_Humidity = SHT2XHumidity_Data[input->Data_Index].Sensor_I2C_Relative_Humidity; //if sensor is not detect as error state then assign the current trading to previous reading
   1009          	}
   1010          }
   1011          #endif
   1012          
   1013          //---------------------------------------------------------------------------------------------------------------------
   1014          /**
   1015           * @brief   This function convert raw value to percentage value
   1016           *          Formula for conversion is given in Datasheet SHT20,
   1017           *          section 6.1 Relative Humidity Conversion, page 10
   1018           * @param   input: data related to the instance of the LLI
   1019           *
   1020           */
   1021          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
   1022          static void TempRawToPercent (HBL_LLI_TYPE * input)
   1023          {
   1024          	float32 temp_us = 0;
   1025          	float32 temp_ul = 0;
   1026          
   1027          	temp_ul =  SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Data * 175.72;
   1028          	temp_us = (temp_ul / 65536);
   1029          	SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Celcius= (sint16)(temp_us - 46.85);
   1030          }
   1031          #endif
   1032          //---------------------------------------------------------------------------------------------------------------------
   1033          /**
   1034           * @brief   this function is accumulation raw percentage value, taking average and the checking for error status
   1035           * @param   input: data related to the instance of the LLI
   1036           */
   1037          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
   1038          static void ProcessTempValue(HBL_LLI_TYPE * input)
   1039          {
   1040          	if(input->Data_Index < HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR)
   1041          	{
   1042          		I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
   1043          
   1044          		if((SHT2XI2C_Forced_Reset == FALSE) && (SHT2X_After_Reset_Stable_Counter == 0))    //  This check is to maker sure not to take the reading when RHT chip is reseting
   1045          		{																																					 // The RHT after reset delay time is running
   1046          			if (SHT2XTemperature_Data[input->Data_Index].Index_Average < param_ptr->Automic_Reading)
   1047          			{
   1048          				SHT2XTemperature_Data[input->Data_Index].Index_Average++;    // Increment number of sample @ 1sec
   1049          				SHT2XTemperature_Data[input->Data_Index].Buffer += SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Raw_Celcius;// accumulate sample
   1050          			}
   1051          			else
   1052          			{   // take average of accumulated samples
   1053          				SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Celcius = (uint8)(SHT2XTemperature_Data[input->Data_Index].Buffer / param_ptr->Automic_Reading);
   1054          				ChecTempNeedToReset(input);
   1055          				SHT2XTemperature_Data[input->Data_Index].Index_Average = 0; // clear counter
   1056          				SHT2XTemperature_Data[input->Data_Index].Buffer = 0; // clear previous value
   1057          			}
   1058          		}
   1059          	}
   1060          }
   1061          #endif
   1062          
   1063          //---------------------------------------------------------------------------------------------------------------------
   1064          /**
   1065           * @brief   This is primarily being done due to the fact that I2C Sensor behaves random after few days / hours of operation.
   1066           *          Originally was resolved by Doing every 12 Hr I2C Chip reset. Now failure was seen that Sensor give abnormal value
   1067           *          and recovers after 12 hrs which affects product operation
   1068           * @param   input: data related to the instance of the LLI
   1069           */
   1070          #if (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
   1071          static void ChecTempNeedToReset(HBL_LLI_TYPE * input)
   1072          {
   1073          	if((abs(SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Celcius - SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Previous_Celcius) >= SHT2X_I2C_RESET_TEMPERATURE_DELTA)&&  //  monitor the temperature delta for the failure of sensor
   1074          	   (SHT2X_Powerup_Stable_Counter == 0))                                  // this check is there to wait for Power up stable time and after that only need to detect the logic for the reset
   1075          	{
   1076          		SHT2XI2C_Forced_Reset = TRUE;
   1077          		SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Celcius = SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Previous_Celcius;  // if Sensor error is detected then take the previous correct reading for application
   1078          		LOG_ADD_EVENT(SHT2X_RHT_WRONG_TEMEPRATURE_READING, SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Previous_Celcius);
   1079          	}
   1080          	else
   1081          	{
   1082          		SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Previous_Celcius = SHT2XTemperature_Data[input->Data_Index].Sensor_I2C_Tempearture_Celcius;  //if sensor is not detect as error state then assign the current trading to previous reading
   1083          	}
   1084          }
   1085          #endif
   1086          
   1087          //---------------------------------------------------------------------------------------------------------------------
   1088          /**
   1089           * @brief   this function Handle the RHT2x Chip Reset Logic.
   1090           * @param   input: data related to the instance of the LLI
   1091           */
   1092          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0) || (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
   1093          static void SHT2XResetHandler(HBL_LLI_TYPE * input)
   1094          {
   1095          	if((SHT2X_Reset_Counter == 0) || (SHT2XI2C_Forced_Reset == TRUE))
   1096          	{
   1097          		I2C_RHT_SENSOR_PARAM_TYPE *param_ptr = (I2C_RHT_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
   1098          
   1099          		#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
   1100          			if(SHT2XHumidity_Allocation > 0)
   1101          			{
   1102          				if(I2cMgr__RequestBus(SHT2XHumidity_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
   1103          				{
   1104          		#elif (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
   1105          		if(SHT2XTemperature_Allocation > 0)
   1106          			{
   1107          				if(I2cMgr__RequestBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle) == TRUE)
   1108          				{
   1109          		#endif
   1110          				if(I2c__Initialize(param_ptr->I2C_Channel, param_ptr->I2C_Speed, I2C_ADDR_7BITS, param_ptr->Slave_Address) == TRUE )
   1111          				{
   1112          					if(I2c__Write(param_ptr->I2C_Channel, SHT2X_SOFT_RESET,SHT2X_Write_Buffer, 0) == TRUE )     // trigger a soft reset
   1113          					{
   1114          						if(SHT2XI2C_Forced_Reset == TRUE)      //  if the chip is reset due to temperature or Humidity delta then only we need to relaod the
   1115          						{                                                          //  Next reset Delay counter to not take the reading after Reset command
   1116          							SHT2XI2C_Forced_Reset = FALSE;
   1117          							SHT2X_After_Reset_Stable_Counter = SHT2X_NEXT_READ_DELAY_AFTER_RESET ;
   1118          						}
   1119          						SHT2X_Reset_Counter = SHT2X_I2C_RESET_TIME_TIMEOUT; // reload the next reset timeout timer
   1120          
   1121          						// Below code is added to reset the RHT2X state machine when I2C chip is reset
   1122          						#if (SHT2X_TOTAL_HUMIDITY_CHANNELS_USED != 0)
   1123          							if(SHT2XHumidity_Allocation > 0)
   1124          							{
   1125          								I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
   1126          								SHT2X_Device_State = I2C_HUMIDITY_SENSOR_STATE_WRITE;
   1127          							}
   1128          						#elif (SHT2X_TOTAL_TEMPERATURE_CHANNELS_USED != 0)
   1129          							if(SHT2XTemperature_Allocation > 0)
   1130          							{
   1131          								I2cMgr__ReleaseBus(SHT2XTemperature_Data[input->Data_Index].I2cMgr_Device_Handle);
   1132          								SHT2X_Device_State = I2C_TEMP_SENSOR_STATE_WRITE;
   1133          							}
   1134          						#endif
   1135          						SHT2X_State_Delay_Counter = 0;
   1136          					}
   1137          				}
   1138          			}
   1139          		}
   1140          	}
   1141          }
   1142          #endif
   1143          
   1144          //---------------------------------------------------------------------------------------------------------------------
   1145          /**
   1146           * @brief   this function Handle the RHT2x Counter for the Power up stable, Next read Delay, Reset timeuot after 6 hr
   1147           */
   1148          #if (HBL_LLI_NUM_I2C_RHT_HUMIDITY_SENSOR > 0) || (HBL_LLI_NUM_I2C_RHT_TEMPERATURE_SENSOR > 0)
   1149          void SHT2xCounterHandler(void)
   1150          {
   1151          	if(SHT2X_After_Reset_Stable_Counter > 0)
   1152          	{
   1153          		SHT2X_After_Reset_Stable_Counter--;
   1154          	}
   1155          
   1156          	if(SHT2X_Reset_Counter > 0)
   1157          	{
   1158          		SHT2X_Reset_Counter--;
   1159          	}
   1160          
   1161          	if(SHT2X_Powerup_Stable_Counter > 0)
   1162          	{
   1163          		SHT2X_Powerup_Stable_Counter--;
   1164          	}
   1165          }
   1166          #endif
   1167          
   1168          #endif //(HBL_LLI_NUM_I2C_RHT_SENSOR > 0)


 

 


