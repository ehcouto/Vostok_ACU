     62          	uint8  Unused							  :7;	//! Reserved for future expansions
     63          	uint8  Multiplyer_Delay; 						//!
     64          	uint16 Multiplier_Position_Unknown;			 	//!
     65          } VWI_ZONE_COMPENSATION_COMMON_PARAMS_TYPE;
     66          
     67          //! Setting file parameters structure for a Vwi Zone Compensation Multiplier
     68          typedef PACKED struct VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_STRUCT
     69          {
     70          	uint16 Multiplier_Pos;							//!
     71          } VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE;
     72          
