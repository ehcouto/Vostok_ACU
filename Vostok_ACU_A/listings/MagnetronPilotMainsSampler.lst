     89          /**
     90           *  @brief      It Initializes the module MagnetronPilotMainsSampler and its variables
     91           */
     92          void MagnetronPilotMainsSampler__Initialize(void)
     93          {
     94              Pilot_Index = 0;
     95              memset(Mains_Sampler_Data, 0, sizeof(Mains_Sampler_Data));
     96          }
     97          
     98          //---------------------------------------------------------------------------------------------------------------------
     99          /**
    100           *  @brief      Initialize magnetron pilot Mains Sampler instance.
    101           *
    102           *  @param      uint8 Pilot_Index - Index to associated magnetron Pilot instance.
    103           *              uint8 AC_Mains_Same_Phase - Flag to indicate AC and mains phase: True: Same Phase / False: Reversed Phaser.
    104           *              uint8 Mains_Feedback_Pin - Index into virtual pin table to find the Mains feedback signal.
    105           *
    106           *  @return     void
    107           */
    108          void MagnetronPilotMainsSampler__InitializeInstance(uint8 Parent_Pilot_Index, uint8 AC_Mains_Same_Phase, uint8 Mains_Feedback_Pin)
    109          {
    110              uint8 table_index;
    111          
    112              Pilot_Index = Parent_Pilot_Index;
    113          
    114              Mains_Sampler_Data[Pilot_Index].AC_Mains_Same_Phase = AC_Mains_Same_Phase;
    115              Mains_Sampler_Data[Pilot_Index].Mains_Feedback_Pin = Mains_Feedback_Pin;
    116          
    117              //! Initialize mains pin
    118              table_index = Mains_Sampler_Data[Pilot_Index].Mains_Feedback_Pin;
    119              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    120              {
    121                  Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    122              }
    123          
    124              //! Initialize mains parameter
    125              Mains_Sampler_Data[Pilot_Index].Mains_Period = ONE_PERIOD_COUNT_60HZ;
    126              Mains_Sampler_Data[Pilot_Index].Counter = MAX_COUNT_60HZ;
    127              Mains_Sampler_Data[Pilot_Index].High_Counter = 0;
    128              Mains_Sampler_Data[Pilot_Index].Low_Counter = MAX_COUNT_60HZ;
    129              Mains_Sampler_Data[Pilot_Index].Max_Count = MAX_COUNT_50HZ;
    130              Mains_Sampler_Data[Pilot_Index].Min_High_Level_Count = MIN_HIGH_LEVEL_COUNT_60HZ;
    131              Mains_Sampler_Data[Pilot_Index].Min_Low_Level_Count = MIN_LOW_LEVEL_COUNT_60HZ;
    132              Mains_Sampler_Data[Pilot_Index].Max_L_Pos_Count = MAX_L_POS_COUNT_50HZ;
    133              Mains_Sampler_Data[Pilot_Index].Min_L_Pos_Count = MIN_L_POS_COUNT_60HZ;
    134              Mains_Sampler_Data[Pilot_Index].High_Pulse = 0;
    135              Mains_Sampler_Data[Pilot_Index].Mains_Detect_State = MAINS_DETECT_STATE_UNKNOWN;
    136              Mains_Sampler_Data[Pilot_Index].Mains_Detect_State_Changed = FALSE;
    137              Mains_Sampler_Data[Pilot_Index].Mains_Detect_Early_Warning = FALSE;
    138              Mains_Sampler_Data[Pilot_Index].Mains_Freq_State = MAINS_FREQ_ERROR;
    139              Mains_Sampler_Data[Pilot_Index].Mains_Period_Wait_Counter = 0;
    140              Mains_Sampler_Data[Pilot_Index].Mains_Period_Resume_Counter = 0;
    141              MainsSamplerRecalcEvents(DEFAULT_L_POS_COUNT_60HZ);
    142          }
    143          
    144          //---------------------------------------------------------------------------------------------------------------------
    145          /**
    146           *  @brief      Handler called at every 200us.
    147           */
    148          void MagnetronPilotMainsSampler__200usHandler(uint8 Parent_Pilot_Index)
    149          {
    150              //! Save Pilot_Index before entering interrupt handler
    151              uint8 Pilot_Index_Bak = Pilot_Index;
    152          
    153              Pilot_Index = Parent_Pilot_Index;
    154          
    155              uint8 mains_pinState = 0;
    156              uint8 table_index = Mains_Sampler_Data[Pilot_Index].Mains_Feedback_Pin;
    157              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    158              {
    159                  mains_pinState = Gpio__PinRead(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin);
    160              }
    161          
    162              if (Mains_Sampler_Data[Pilot_Index].High_Pulse == TRUE)
    163              {
    164                  Mains_Sampler_Data[Pilot_Index].High_Counter++;
    165          
    166                  if (mains_pinState == 0)
    167                  {
    168                      if (Mains_Sampler_Data[Pilot_Index].High_Counter > Mains_Sampler_Data[Pilot_Index].Min_High_Level_Count) // the condition of accepting the fall edge coming.
    169                      {
    170                          MainsSamplerRecalcEvents(Mains_Sampler_Data[Pilot_Index].Counter);
    171                          Mains_Sampler_Data[Pilot_Index].Low_Counter = 0;
    172                          Mains_Sampler_Data[Pilot_Index].High_Pulse = FALSE;
    173                      }
    174                  }
    175              }
    176              else
    177              {
    178                  Mains_Sampler_Data[Pilot_Index].Low_Counter++;
    179          
    180                  if (mains_pinState == 1)
    181                  {
    182                      if (Mains_Sampler_Data[Pilot_Index].Low_Counter > Mains_Sampler_Data[Pilot_Index].Min_Low_Level_Count) // the condition of accepting the rise edge coming.
    183                      {
    184                          if (Mains_Sampler_Data[Pilot_Index].Mains_Period < Mains_Sampler_Data[Pilot_Index].Counter)
    185                          {
    186                              ++Mains_Sampler_Data[Pilot_Index].Mains_Period;
    187                          }
    188                          else if (Mains_Sampler_Data[Pilot_Index].Mains_Period > Mains_Sampler_Data[Pilot_Index].Counter)
    189                          {
    190                              --Mains_Sampler_Data[Pilot_Index].Mains_Period;
    191                          }
    192          
    193                          if (((Mains_Sampler_Data[Pilot_Index].Mains_Period >= MAINS_LOW_LIMIT_60HZ) && (Mains_Sampler_Data[Pilot_Index].Mains_Period <= MAINS_HIGH_LIMIT_60HZ)) ||
    194                              ((Mains_Sampler_Data[Pilot_Index].Mains_Period >= MAINS_LOW_LIMIT_50HZ) && (Mains_Sampler_Data[Pilot_Index].Mains_Period <= MAINS_HIGH_LIMIT_50HZ)))
    195                          {
    196                              Mains_Sampler_Data[Pilot_Index].Mains_Freq_State = MAINS_FREQ_OK;
    197                              MAINS_PERIOD_SYNC(Pilot_Index, Mains_Sampler_Data[Pilot_Index].Mains_Period);
    198                          }
    199                          else
    200                          {
    201                              Mains_Sampler_Data[Pilot_Index].Mains_Freq_State = MAINS_FREQ_ERROR;
    202                          }
    203          
    204                          Mains_Sampler_Data[Pilot_Index].Counter = 0;
    205                          Mains_Sampler_Data[Pilot_Index].High_Counter = 0;
    206                          Mains_Sampler_Data[Pilot_Index].High_Pulse = TRUE;
    207                      }
    208                  }
    209              }
    210          
    211              MAINS_EVENT_TYPE mains_event = MAINS_NO_EVENT;
    212          
    213              MainsSamplerMainsLostDetection();
    214          
    215              if (Mains_Sampler_Data[Pilot_Index].Counter == Mains_Sampler_Data[Pilot_Index].Zero_Cross_LH_Cnt1)
    216              {
    217                  mains_event = ((Mains_Sampler_Data[Pilot_Index].AC_Mains_Same_Phase == TRUE) ? MAINS_ANGLE_0_EVENT : MAINS_ANGLE_180_EVENT);
    218                  MainsSamplerMainsFoundDetection();
    219              }
    220              else if (Mains_Sampler_Data[Pilot_Index].Counter == Mains_Sampler_Data[Pilot_Index].L_Pos_Cnt && Mains_Sampler_Data[Pilot_Index].High_Pulse == TRUE)
    221              {
    222                  mains_event = ((Mains_Sampler_Data[Pilot_Index].AC_Mains_Same_Phase == TRUE) ? MAINS_ANGLE_90_EVENT : MAINS_ANGLE_270_EVENT);
    223              }
    224              else if (Mains_Sampler_Data[Pilot_Index].Counter == Mains_Sampler_Data[Pilot_Index].Zero_Cross_HL_Cnt2)
    225              {
    226                  mains_event = ((Mains_Sampler_Data[Pilot_Index].AC_Mains_Same_Phase == TRUE) ? MAINS_ANGLE_180_EVENT : MAINS_ANGLE_0_EVENT);
    227                  MainsSamplerMainsFoundDetection();
    228              }
    229              else if (Mains_Sampler_Data[Pilot_Index].Counter == Mains_Sampler_Data[Pilot_Index].L_Neg_Cnt && Mains_Sampler_Data[Pilot_Index].High_Pulse == FALSE)
    230              {
    231                  mains_event = ((Mains_Sampler_Data[Pilot_Index].AC_Mains_Same_Phase == TRUE) ? MAINS_ANGLE_270_EVENT : MAINS_ANGLE_90_EVENT);
    232              }
    233          
    234              MAINS_EVENT_HANDLER(Pilot_Index, mains_event);
    235          
    236              if (Mains_Sampler_Data[Pilot_Index].Counter < Mains_Sampler_Data[Pilot_Index].Max_Count)
    237              {
    238                  Mains_Sampler_Data[Pilot_Index].Counter++;
    239              }
    240          
    241              if (Mains_Sampler_Data[Pilot_Index].Low_Counter > Mains_Sampler_Data[Pilot_Index].Max_Count)
    242              {
    243                  Mains_Sampler_Data[Pilot_Index].Low_Counter = Mains_Sampler_Data[Pilot_Index].Max_Count;
    244              }
    245          
    246              if (Mains_Sampler_Data[Pilot_Index].High_Counter > Mains_Sampler_Data[Pilot_Index].Max_Count)
    247              {
    248                  Mains_Sampler_Data[Pilot_Index].High_Counter = Mains_Sampler_Data[Pilot_Index].Max_Count;
    249              }
    250          
    251              //! Restore Pilot_Index before exiting interrupt handler
    252              Pilot_Index = Pilot_Index_Bak;
    253          }
    254          
    255          //---------------------------------------------------------------------------------------------------------------------
    256          /**
    257           * @brief      Handler called at every 5ms.
    258           * @param      load
    259           * @return
    260           */
    261          //---------------------------------------------------------------------------------------------------------------------
    262          void MagnetronPilotMainsSampler__AsynchHandler(uint8 Parent_Pilot_Index)
    263          {
    264              Pilot_Index = Parent_Pilot_Index;
    265          
    266              //! Check if there is mains error msg needed to be published
    267              if (Mains_Sampler_Data[Pilot_Index].Mains_Detect_State_Changed == TRUE)
    268              {
    269                  Mains_Sampler_Data[Pilot_Index].Mains_Detect_State_Changed = FALSE;
    270                  if (Mains_Sampler_Data[Pilot_Index].Mains_Detect_State == MAINS_DETECT_STATE_FOUND)
    271                  {
    272                      LOG_ADD_EXCEPTION(MAINS_SIGNAL_FOUND, Pilot_Index);
    273                  }
    274                  else
    275                  {
    276                      LOG_ADD_EXCEPTION(MAINS_SIGNAL_LOST, Pilot_Index);
    277                  }
    278              }
    279          
    280              if (Mains_Sampler_Data[Pilot_Index].Mains_Detect_Early_Warning == TRUE)
    281              {
    282                  Mains_Sampler_Data[Pilot_Index].Mains_Detect_Early_Warning = FALSE;
    283                  LOG_ADD_EXCEPTION(MAINS_SIGNAL_EARLY_WARNING, Pilot_Index);
    284              }
    285          }
    286          
    287          //---------------------------------------------------------------------------------------------------------------------
    288          /**
    289           * @brief      It return the mains detection status
    290           * @param      Pilot
    291           * @return
    292           */
    293          //---------------------------------------------------------------------------------------------------------------------
    294          MAINS_FREQUENCY_TYPE MagnetronPilotMainsSampler__GetMainsFrequencyStatus(uint8 Parent_Pilot_Index)
    295          {
    296              MAINS_FREQUENCY_TYPE state = MAINS_FREQ_ERROR;
    297          
    298              if (Mains_Sampler_Data[Pilot_Index].Mains_Detect_State == MAINS_DETECT_STATE_FOUND)
    299              {
    300                  state = Mains_Sampler_Data[Parent_Pilot_Index].Mains_Freq_State;
    301              }
    302          
    303              return state;
    304          }
