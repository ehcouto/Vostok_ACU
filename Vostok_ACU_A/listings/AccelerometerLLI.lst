    461          //---------------------------------------------------------------------------------------------------------------------
    462          /**
    463           *
    464           */
    465          static void SetDeviceInfo(void)
    466          {
    467              uint8 device_id = AccelDiscover__GetId();
    468          
    469              if (device_id == 0x33)
    470              {
    471                  AccelerometerLLI_Public.Device = ACCELEROMETER_DEVICE_LISxDH;
    472                  AccelerometerLLI_Public.Id = device_id;
    473                  LISxDH__Initialize(AccelerometerLLI_SF_Param);
    474              }
    475              else if (device_id == 0x86)
    476              {
    477                  AccelerometerLLI_Public.Device = ACCELEROMETER_DEVICE_FXLS8974;
    478                  AccelerometerLLI_Public.Id = device_id;
    479                  FXLS8974__Initialize((FXLS8974_SF_PARAM_TYPE *)AccelerometerLLI_SF_Param);
    480              }
    481              else
    482              {
    483                  // TODO: What to do if the device is not recognized?
    484              }
    485          
    486              SetOutputDataRate(AccelerometerLLI_SF_Param->Data_Rate);
    487              // For FVT, need to force the Accelerometer to be enabled; it can be disabled as needed later
    488              AccelerometerLLI__Enable();
    489          }
