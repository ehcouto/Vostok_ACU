    189          {
    190              API221_NO_OPCODE                        = 0,
    191              API221_CMD_REQUEST_FAILURE_FLAGS        = 1,    //!< Request all failure flags
    192              API221_CMD_CLEAR_FAILURE_FLAGS          = 2,    //!< Clear all failure flags
    193              API221_CMD_KEEP_RUNNING                 = 3,    //!< Keep the previous command activated
    194              API221_CMD_STOP                         = 4,    //!< Stop the motor
    195              API221_CMD_RUN                          = 5,    //!< Start to run the motor
    196              API221_CMD_SET_MOTION_BEHAVIOR          = 6,    //!< Start a platform-specific motion behavior
    197              API221_CMD_REQUEST_MOTOR_STATUS         = 7,    //!< Request the current status of the motor
    198              API221_CMD_REQUEST_ANALOG_DATA          = 8,    //!< Request an analog input value
    199              API221_CMD_SET_DATA_PUBLICATION_PERIOD  = 9,    //!< Set the publication data rate for periodic data
    200              API221_CMD_ADD_PERIODIC_DATA_CHANNELS   = 10,   //!< Add a set of analog input values to the periodic data
    201              API221_CMD_REMOVE_PERIODIC_DATA_CHANNELS= 11,   //!< Remove a set of analog input values from the periodic data
    202              API221_CMD_REQUEST_PERIODIC_DATA_STATUS = 12,   //!< Request the status of the periodic data publication
    203              API221_CMD_WASH                         = 13,   //!< Start the wash motion.
    204              API221_CMD_ROTATE_X_DEGREES             = 14,   //!< Start the rotate X degrees motion.
    205              API221_CMD_PULSE_IMMEDIATE              = 15,   //!< Start a new pulse now.
    206              API221_CMD_PULSE_MODIFY                 = 16,   //!< Modify the currently running pulse.
    207              API221_CMD_PULSE_QUEUE                  = 17,   //!< Queue the next pulse.
