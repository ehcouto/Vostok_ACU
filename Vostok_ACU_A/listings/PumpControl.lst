    800          	/*
    801          	API221_STS_ANY_ERROR_FOUND      = 0,             Any error found?
    802          	API221_STS_IS_MOTOR_STOPPED     = 1,             Is motor stopped?
    803          	API221_STS_REACHED_TARGET       = 2,             Target velocity == reference velocity
    804          	API221_STS_IS_IDLE              = 3,             Is the motor idle? If the speed is zero, no error found...
