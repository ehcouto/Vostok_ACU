    182          
    183          //---------------------------------------------------------------------------------------------------------------------
    184          /**
    185           * This method parses API020 feedbacks sent to a broadcast or exclusively to this node.
    186           * The function will ignore messages that do not satisfy the stringent Class B requirements:
    187           *      - The opcode of the message must match the opcode used by the Receive Channel
    188           *      - The sequence number must match the expected sequence number based on the previously received sequence number
    189           *      - The message must have originated from the expected source address for the Receive Channel
    190           *      - The source address in the message must match the expected source address for the Receive Channel
    191           *      - The destination address must match this node's bus address.
    192           *      - The safety data must be 0 to 11 bytes
    193           *      - The CRC at the end of the payload must be correct.
    194           * The function will only accept the data as valid if:
    195           *      - The last two messages were sequential (no lost message)
    196           *      - The time between the last two messages was less than the Receive Channel's timeout period.
    197           * @param fbk = Pointer to the received feedback message.
    198           */
    199          void SRAPI020Safety__FeedbackParser(REVEAL_MSG_TYPE * fbk)
    200          {
    201              #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    202                  uint8 size = fbk->size;
    203                  if ((API020_PACKET_OVERHEAD <= size) && (size <= sizeof(API020_SAFETY_PACKET_TYPE)))
    204                  {
    205                      // Check for a correct CRC, a potentially valid Sequence Number, and a correct destination node.
    206                      uint8 crc8 = Crc8(UCHAR_MAX, fbk->payload, size - 1);
    207                      API020_SAFETY_PACKET_TYPE* packet = (API020_SAFETY_PACKET_TYPE*)(void*)fbk->payload;
    208                      if ((fbk->payload[size - 1] == crc8) &&         // if CRC is valid, and...
    209                          (packet->Sequence != SEQUENCE_INVALID) &&   // if sequence is potentially valid, and...
    210                          (packet->Dst_Addr == WIN_NODE_DEF))         // if message is intended for this bus address
    211                      {
    212                          // Look for the RX channel used to receive this Class B data.
    213                          for (uint8 rx_channel = 0; rx_channel < API020_NUMBER_OF_RX_CHANNELS; rx_channel++)
    214                          {
    215                              API020_RX_CONFIG_TYPE const* config = &API020_RX_CHANNEL[rx_channel];
    216                              if (((fbk->node_id == config->Node) ||
    217                                   (fbk->node_id == WIN_TOOL_ADDRESS)) &&                     // if received from expected node, and...
    218                                  (fbk->op_code == config->Op_Code) &&                        // if received expected opcode, and...
    219                                  (fbk->size == API020_PACKET_OVERHEAD + config->Length) &&   // if received expected number of bytes, and...
    220                                  ((packet->Src_Addr == config->Node) ||
    221                                   (packet->Src_Addr == WIN_TOOL_ADDRESS)))                   // if source node in the message matches expected source node.
    222                              {
    223                                  SaveSafetyData(rx_channel, packet->Sequence, packet->Data);
    224                                  break;                      // Break out of the for() loop.
    225                              }
    226                          }
    227                      }
    228                  }
    229              #endif      // #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    230          }
    231          
    232          
    233          #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    234          //---------------------------------------------------------------------------------------------------------------------
    235          /**
    236           * Get the most recently received Class B Safety Data if it's validity has been maintained.
    237           * @param rx_channel = The Receive Channel whose Class B Safety Data is requested.
    238           * @param data = Pointer to a buffer to fill with the secure Class B Safety Data.
    239           * @return TRUE if and only if the Receive Channel messages have preserved the sequence.
    240           */
    241          BOOL_TYPE SRAPI020Safety__GetRxValue(API020_RX_CHANNEL_INDEX_TYPE rx_channel, void* data)
    242          {
    243              uint8 sequence;
    244              BOOL_TYPE updated;
    245              return SRAPI020Safety__GetRxValueAndUpdatedFlag(rx_channel, data, &sequence, &updated);
    246          }
    247          
    248          
    249          //---------------------------------------------------------------------------------------------------------------------
    250          /**
    251           * Get the most recently received Class B Safety Data if it's validity has been maintained.
    252           *
    253           *	@startuml{SRAPI020Safety_Sequence_Use_Case_For_Reading_New_Data.jpg}
    254           *		title SRAPI020Safety__GetRxValueAndUpdatedFlag Use Case For Reading New Data
    255           *
    256           *		participant Application
    257           *		participant SRAPI020Safety
    258           *
    259           *		== Initialize the Application defined *sequence variable ==
    260           *		Application -> SRAPI020Safety : SRAPI020Safety__GetRxValueAndUpdatedFlag(rx_channel, * data, * sequence, * updated)
    261           *		activate Application
    262           *		activate SRAPI020Safety
    263           *		deactivate Application
    264           *		deactivate SRAPI020Safety
    265           *
    266           *		== Application periodically polls the SRAPI020Safety module for new data ==
    267           *		loop periodically called
    268           *			Application -> SRAPI020Safety : SRAPI020Safety__GetRxValueAndUpdatedFlag(rx_channel, * data, * sequence, * updated)
    269           *			activate SRAPI020Safety
    270           *			alt sequence preserved
    271           *				Application <-- SRAPI020Safety : TRUE
    272           *				deactivate SRAPI020Safety
    273           *				activate Application
    274           *				alt *updated == TRUE
    275           *					Application --> Application : "*data" contains new values that need to be processed
    276           *				end
    277           *				deactivate Application
    278           *			end
    279           *		end
    280           *	@enduml
    281           *
    282           * NOTE: this function is written to be thread safe.
    283           * @param rx_channel = The Receive Channel whose Class B Safety Data is requested.
    284           * @param data = Pointer to a buffer to fill with the secure Class B Safety Data.
    285           * @param sequence = Pointer to a byte that is used by this function. No application use.
    286           * @param updated = Pointer to a value that this function sets.
    287           *                  Set to FALSE if the data returned is not from a new API020 message.
    288           *                  Set to TRUE if the data returned is from a new API020 message.
    289           * @return TRUE if and only if the Receive Channel messages have preserved the sequence.
    290           */
    291          BOOL_TYPE SRAPI020Safety__GetRxValueAndUpdatedFlag(API020_RX_CHANNEL_INDEX_TYPE rx_channel, void* data, uint8* sequence, BOOL_TYPE* updated)
    292          {
    293              *updated = FALSE;
    294              if (( rx_channel < API020_NUMBER_OF_RX_CHANNELS ) &&
    295              	( API020_RX_CHANNEL[rx_channel].Length <= MAX_CLASSB_DATA_SIZE ))	// prevent overflow of the stack variable data_copy
    296          	{
    297              	// create a copy of all the data from RAM on the stack to minimize the amount of time interrupts are disabled
    298              	MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    299              	MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    300          
    301                  uint8 rx_sequence_valid = Api020.Rx_Sequence_Valid[rx_channel];
    302                  uint8 n_rx_sequence_valid = N_Api020.Rx_Sequence_Valid[rx_channel];
    303          
    304                  uint32 rx_time = Api020.Rx_Time[rx_channel];
    305                  uint32 n_rx_time = N_Api020.Rx_Time[rx_channel];
    306          
    307          		API020_RX_CONFIG_TYPE const* config = &API020_RX_CHANNEL[rx_channel];
    308          		uint8 data_copy[MAX_CLASSB_DATA_SIZE];
    309          		memcpy(&data_copy, config->Address, config->Length);
    310          		uint8 n_data_copy[MAX_CLASSB_DATA_SIZE];
    311          		memcpy(&n_data_copy, config->N_Address, config->Length);
    312          
    313          		uint8 rx_expected_sequence = Api020.Rx_Expected_Sequence[rx_channel];
    314          		uint8 n_rx_expected_sequence = N_Api020.Rx_Expected_Sequence[rx_channel];
    315          
    316          		MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    317          
    318          		// check the integrity of the SR variables
    319          		(void)SRData__CheckByte(&rx_sequence_valid, &n_rx_sequence_valid);
    320          
    321                  // Check whether the RX channel has preserved the required message sequence.
    322          		if ( rx_sequence_valid == TRUE )
    323          		{
    324          
    325                      // Determine how long it has been since the last received message.
    326          			(void)SRData__CheckLong(&rx_time, &n_rx_time);
    327                      uint32 milliseconds = SRTimerReference__GetTimer() - rx_time;
    328          
    329                      // Check whether the most recently received message is still valid.
    330                      if (milliseconds < config->Period)
    331                      {
    332          				(void)SRData__CheckByte(&rx_expected_sequence, &n_rx_expected_sequence);
    333                          if (*sequence != rx_expected_sequence)
    334                          {
    335                              *updated = TRUE;
    336                              *sequence = rx_expected_sequence;
    337                          }
    338                          // Return the recently received data.
    339          				(void)SRData__CheckArray(data_copy, n_data_copy, config->Length);
    340                          memcpy(data, data_copy, config->Length);
    341                          return TRUE;
    342                      }
    343          		}
    344              }
    345          	
    346              *sequence = SEQUENCE_LOST;
    347              return FALSE;
    348          }
    349          #endif      // #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    350          
    351          
    352          
    353          
    354          
    355          
    356          #if (API020_NUMBER_OF_TX_CHANNELS > 0)
    357          //---------------------------------------------------------------------------------------------------------------------
    358          /**
    359           * Transmit the next sequential message on the specified Transmit Channel.
    360           * @param tx_channel = The Transmit Channel on which the message should be transmitted.
    361           * @param data = Pointer to the data to send on the transmit channel.
    362           * @return TRUE if and only if Reveal was able to build and queue the message.
    363           */
    364          BOOL_TYPE SRAPI020Safety__SetTxValue(API020_TX_CHANNEL_INDEX_TYPE tx_channel, void* data)
    365          {
    366              BOOL_TYPE result = FALSE;
    367              if (tx_channel < API020_NUMBER_OF_TX_CHANNELS)
    368              {
    369                  // Determine the next Sequence Number value.
    370                  (void)SR_CHECK_BYTE(Api020.Tx_Next_Sequence[tx_channel]);
    371                  uint8 sequence = Api020.Tx_Next_Sequence[tx_channel];
    372          
    373                  // Determine the time since the last message was sent.
    374                  (void)SR_CHECK_LONG(Api020.Tx_Time[tx_channel]);
    375                  uint32 now = SRTimerReference__GetTimer();
    376          
    377                  // If it has been too long since the last message, then break the sequence.
    378                  API020_TX_CONFIG_TYPE const* config = &API020_TX_CHANNEL[tx_channel];
    379                  if (sequence != SEQUENCE_RESET)
    380                  {
    381                      uint32 milliseconds = now - Api020.Tx_Time[tx_channel];
    382                      if (milliseconds >= config->Period)
    383                      {
    384                          sequence = SEQUENCE_LOST;
    385                      }
    386                  }
    387          
    388                  // Transmit the packet.
    389                  if (config->Node == WIN_NODE_DEF)
    390                  {
    391                      #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    392                          // Find the receive channel that receives this safety data.
    393                          for (uint8 rx_channel = 0; rx_channel < API020_NUMBER_OF_RX_CHANNELS; rx_channel++)
    394                          {
    395                              if ((API020_RX_CHANNEL[rx_channel].Node == WIN_NODE_DEF) &&
    396                                  (API020_RX_CHANNEL[rx_channel].Op_Code == config->Op_Code) &&
    397                                  (API020_RX_CHANNEL[rx_channel].Length == config->Length))
    398                              {
    399                                  SaveSafetyData(rx_channel, sequence, data);
    400                                  result = TRUE;
    401                                  break;                      // Break out of the for() loop.
    402                              }
    403                          }
    404                      #endif      // #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    405                  }
    406                  else
    407                  {
    408                      // Build the packet for this transmit channel.
    409                      API020_SAFETY_PACKET_TYPE packet;
    410                      packet.Sequence = sequence;
    411                      packet.Src_Addr = WIN_NODE_DEF;
    412                      packet.Dst_Addr = config->Node;
    413                      memcpy(&packet.Data, data, config->Length);
    414                      uint8 size = API020_PACKET_OVERHEAD + config->Length;
    415                      packet.Data[config->Length] = Crc8(UCHAR_MAX, (uint8*)(void*)&packet, size - 1);
    416          
    417                      REVEAL_COMMAND_TYPE* msg = Reveal__PriorityNewFeedback(API020SAFETY_NUM, config->Op_Code, config->Node, size);
    418                      if ((Reveal__AddDataU8Buffer(msg, (uint8*)(void*)&packet, size) == PASS) &&
    419                          (Reveal__QueueCommand(msg) == TRUE))
    420                      {
    421                          result = TRUE;
    422                      }
    423                  }
    424                  if (result == TRUE)
    425                  {
    426                      // Successfully passed to receiving node, so update transmit variables.
    427                      sequence = (sequence < SEQUENCE_LAST) ? sequence + 1 : SEQUENCE_FIRST;
    428                      SR_SET_BYTE(Api020.Tx_Next_Sequence[tx_channel], sequence);
    429                      SR_SET_LONG(Api020.Tx_Time[tx_channel], now);
    430                  }
    431              }
    432              return result;
    433          }
    434          #endif      // #if (API020_NUMBER_OF_TX_CHANNELS > 0)
    435          
    436          
    437          //=====================================================================================================================
    438          //  --- Private Functions ---------------------------------------------------------------------------------------------
    439          //=====================================================================================================================
    440          
    441          
    442          #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    443          //---------------------------------------------------------------------------------------------------------------------
    444          /**
    445           * Save the received safety data.
    446           * @param rx_channel = The receive channel to which the safety data is related.
    447           *                     Used as an index into the API020_RX_CHANNEL[rx_channel] array.
    448           * @param sequence = The sequence of the newly received data.
    449           * @param data = The safety data that was received.
    450           */
    451          static void SaveSafetyData(uint8 rx_channel, uint8 sequence, void* data)
    452          {
    453              // Get the time since the last message.
    454              (void)SR_CHECK_LONG(Api020.Rx_Time[rx_channel]);
    455              uint32 now = SRTimerReference__GetTimer();
    456              uint32 milliseconds = now - Api020.Rx_Time[rx_channel];
    457          
    458              // Determine if the Class B packet sequence was preserved by this message.
    459              (void)SR_CHECK_BYTE(Api020.Rx_Expected_Sequence[rx_channel]);
    460              API020_RX_CONFIG_TYPE const* config = &API020_RX_CHANNEL[rx_channel];
    461              uint8 sequence_preserved = ((milliseconds <= config->Period) &&
    462                                          (sequence == Api020.Rx_Expected_Sequence[rx_channel]));
    463              if (sequence_preserved)
    464              {
    465                  // This is a valid packet received in the expected sequence.
    466                  // Save the received data.
    467                  SRData__UpdateArray(config->Address, config->N_Address, data, config->Length);
    468              }
    469          
    470              // Determine the next expected Sequence Number for this RX channel.
    471              sequence = (sequence < SEQUENCE_LAST) ? sequence + 1 : SEQUENCE_FIRST;
    472          
    473              // Save the RX channel status information.
    474              SR_SET_BYTE(Api020.Rx_Expected_Sequence[rx_channel], sequence);
    475              SR_SET_LONG(Api020.Rx_Time[rx_channel], now);
    476              SR_SET_BYTE(Api020.Rx_Sequence_Valid[rx_channel], sequence_preserved);
    477          }
    478          #endif      // #if (API020_NUMBER_OF_RX_CHANNELS > 0)
    479          
    480          
    481          #endif      // #if (API020SAFETY_FEATURE == ENABLED)
    482          


 

 


