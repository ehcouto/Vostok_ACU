    494          /**
    495           * Get the number of milliseconds since the StartTimer() function was called.
    496           * @return The number of milliseconds since the StartTimer() function was called.
    497           */
    498          static uint16 GetMilliseconds(void)
    499          {
    500              return (uint16)(Millis__GetFreeRunningCounter() - I2c_Infrared_Lli.Start_Milliseconds);
    501          }
    502          
    503          
    504          //---------------------------------------------------------------------------------------------------------------------
    505          /**
    506           * Determine whether the I2C bus is idle and ready for the next message.
    507           * @return TRUE if the I2C bus is idle and ready for the next message; otherwise FALSE.
    508           */
    509          static BOOL_TYPE IsI2cIdle(void)
    510          {
    511              return (BOOL_TYPE)(I2c__GetStatus(I2c_Infrared_Lli.Sf->I2c_Channel, I2C_STATUS_STATE) == I2C_STATE_IDLE);
    512          }
    513          
    514          
    515          //---------------------------------------------------------------------------------------------------------------------
    516          /**
    517           * Read RAM data from the Melexis 90621 sensor.
    518           * @param address = The address of the first value to read.
    519           * @param size = The number of bytes to read. Must be an even number.
    520           * @return TRUE if request was successful.
    521           */
    522          static BOOL_TYPE ReadMelexisValues(uint8 address, uint8 size)
    523          {
    524              // Write buffer consists of address, step size, and number of values to read.
    525              uint8 write_buffer[] = { MLX_CMD_READ_RAM, address, ((size > 2) ? 1 : 0), size / sizeof(uint16) };
    526              return I2c__WriteThenRead(I2c_Infrared_Lli.Sf->I2c_Channel, write_buffer, sizeof(write_buffer), size);
    527          }
    528          
    529          
    530          //---------------------------------------------------------------------------------------------------------------------
    531          /**
    532           * Write a checked 16-bit value to a Melexis 90621 sensor RAM address.
    533           * The value is sent with redundant data to reduce the likelihood of communication failures.
    534           * @param command = The command to send to the Melexis 90621 sensor.
    535           * @param value = The 16-bit value to write.
    536           * @param check = Redundant data generator for better communication robustness.
    537           * @return TRUE if the message was successfully queued.
    538           */
    539          static BOOL_TYPE WriteMelexisValue(MELEXIS_CMD_TYPE command, uint16 value, uint8 check)
    540          {
    541              uint8 write_buffer[] =
    542              {
    543                  (uint8)(LOBYTE(value) - check),
    544                  (uint8)(LOBYTE(value)),
    545                  (uint8)(HIBYTE(value) - check),
    546                  (uint8)(HIBYTE(value))
    547              };
    548              return I2c__Write(I2c_Infrared_Lli.Sf->I2c_Channel, command, write_buffer, sizeof(write_buffer));
    549          }
