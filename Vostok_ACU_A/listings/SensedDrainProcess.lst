   1037          /**
   1038           * Handle events published through API221.
   1039           * This function is called by the communication thread.
   1040           * @param event = The event that was published through API221.
   1041           */
   1042          static void API221HandleMotorEvent(API221_EVENT_TYPE event)
   1043          {
   1044          	switch (event.Event)
   1045          	{
   1046          		 case API221_EVENT_STOPPED:
   1047          		 	 {
   1048          				 if (event.Motor == MOTOR_0)
   1049          				 {
   1050          					 WM_IsStopped = TRUE;
   1051          					 WM_ReachedTargetSpeed = FALSE;
   1052          				 }
   1053          				 else if (event.Motor == MOTOR_1)
   1054          				 {
   1055          					 DM_IsStopped = TRUE;
   1056          					 DM_ReachedTargetSpeed = FALSE;
   1057          				 }
   1058          		 	 }
   1059          			break;
   1060          		 case API221_EVENT_REACHED_TARGET:
   1061          			 {
   1062          				 if (event.Motor == MOTOR_0)
   1063          				 {
   1064          					 WM_IsStopped = FALSE;
   1065          					 WM_ReachedTargetSpeed = TRUE;
   1066          				 }
   1067          				 else if (event.Motor == MOTOR_1)
   1068          				 {
   1069          					 DM_IsStopped = FALSE;
   1070          					 DM_ReachedTargetSpeed = TRUE;
   1071          				 }
   1072          			 }
   1073          			break;
   1074          		 case API221_EVENT_RAMP_STARTED:
   1075          			 {
   1076          				 if (event.Motor == MOTOR_0)
   1077          				 {
   1078          					 WM_IsStopped = FALSE;
   1079          					 WM_ReachedTargetSpeed = FALSE;
   1080          				 }
   1081          				 else if (event.Motor == MOTOR_1)
   1082          				 {
   1083          					 DM_IsStopped = FALSE;
   1084          					 DM_ReachedTargetSpeed = FALSE;
   1085          				 }
   1086          			 }
   1087          			 break;
   1088          		default:
   1089          			// Ignore all other events
   1090          			break;
   1091          	}
   1092          }
