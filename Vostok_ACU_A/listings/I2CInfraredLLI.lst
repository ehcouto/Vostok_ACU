    728          
    729          //---------------------------------------------------------------------------------------------------------------------
    730          /**
    731           * Read the status from the Melexis 90621 sensor.
    732           * This function reads and processes the received data.
    733           * It assumes that the read request was already made.
    734           */
    735          static void DoStatusRead(void)
    736          {
    737              if (IsI2cIdle() == TRUE)
    738              {
    739                  // Get the status register from the Melexis 90621 sensor.
    740                  if (I2c__Read(I2c_Infrared_Lli.Sf->I2c_Channel,
    741                                (void*)(&I2c_Infrared_Lli.Config.Cfg_Reg.Whole),
    742                                sizeof(I2c_Infrared_Lli.Config.Cfg_Reg.Whole)) == TRUE)
    743                  {
    744                      if (I2c_Infrared_Lli.Config.Cfg_Reg.Field.Configuration_Loaded == FALSE)
    745                      {
    746                          // The Melexis 90621 sensor experienced a reset.
    747                          EventPowerOnReset();
    748                      }
    749                      else if (I2c_Infrared_Lli.Config.Cfg_Reg.Field.Measuring == FALSE)
    750                      {
    751                          // The Melexis 90621 sensor finished acquiring pixel data.
    752                          EventDataReady();
    753                      }
    754                      else
    755                      {
    756                          // The Melexis 90621 sensor is still acquiring data.
    757                          EventReadComplete();
    758                      }
    759                  }
    760                  else
    761                  {
    762                      EventFail();
    763                  }
    764              }
    765              else if (GetMilliseconds() >= I2c_Infrared_Lli.Sf->Step_Period_Milliseconds)
    766              {
    767                  EventFail();
    768              }
    769          }
