     35          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     36          #if (HBL_LLI_NUM_ANALOG >  0)
     37              #define MULTIINPUT_REGISTERED_LLI_ANALOG 1
     38          #else
     39              #define MULTIINPUT_REGISTERED_LLI_ANALOG 0
     40          #endif
     41          
     42          #if (HBL_LLI_NUM_DIGITAL > 0)
     43              #define MULTIINPUT_REGISTERED_LLI_DIGITAL 1
     44          #else
     45              #define MULTIINPUT_REGISTERED_LLI_ANALOG 0
     46          #endif
     47          
     48          #if (HBL_LLI_NUM_FEEDBACK > 0)
     49              #define MULTIINPUT_REGISTERED_LLI_FEEDBACK 1
     50          #else
     51              #define MULTIINPUT_REGISTERED_LLI_FEEDBACK 0
     52          #endif
     53          
     54          //! Defines the number of LLI register definitions that will be supported based on the supported LLIs that are available in the system
     55          #define MULTIINPUT_NUM_REGISTERED_INPUTS (MULTIINPUT_REGISTERED_LLI_ANALOG + MULTIINPUT_REGISTERED_LLI_DIGITAL + MULTIINPUT_REGISTERED_LLI_FEEDBACK)
     56          
     57          //! Maximum number of inputs that can be defined for a MultiInput LLI
     58          #define MULTIINPUTLLI_MAX_INPUTS   4
     59          
     60          //! Definition of parameters taken from GESE used for a MultiInput LLI
     61          typedef struct
     62          {
     63              HBL_LLI_ENUM_TYPE LLI_ID;
     64              uint8 LLI_Params_Offset;
     65          }MULTIINPUTLLI_PARAMETERS_TYPE;
     66          
     67          //! Definition of module data used to process a MultiInput LLI
     68          PACKED typedef struct
     69          {
     70              HBL_LLI_TYPE LLI_Data[MULTIINPUTLLI_MAX_INPUTS];
     71              uint8 Num_Of_Inputs;
     72          }MULTIINPUTLLI_CONFIG_TYPE;
     73          
     74          //! Counts the number of MultiInput LLIs that are allocated for use. Used to know when the limitation in the firmware has been reached.
     75          static uint8 MultiInputLLI_Allocation;
     76          
     77          //! Module data used to process a MultiInput LLI
     78          static MULTIINPUTLLI_CONFIG_TYPE MultiInputLLI_Config[HBL_LLI_NUM_MULTIINPUT];
     79          
     80          //! Stores the data related to each input in each MultiInput LLI
     81          static MULTIINPUTLLI_DATA_TYPE MultiInputLLI_Data[HBL_LLI_NUM_MULTIINPUT][MULTIINPUTLLI_MAX_INPUTS];
     82          
     83          //! Definition of the supported LLI register definitions
     84          static const HBL_LLI_HANDLER_HOOK_TYPE MULTIINPUT_LLI_HANDLERS[MULTIINPUT_NUM_REGISTERED_INPUTS]  = {
     85                                                                                                                  #if (HBL_LLI_NUM_DIGITAL > 0)
     86                                                                                                                      {DIGITAL_LLI_REGISTER,  HBL_LLI_DIGITAL}
     87                                                                                                                  #endif
     88          
     89                                                                                                                  #if (HBL_LLI_NUM_ANALOG > 0)
     90                                                                                                                      ,{ANALOG_LLI_REGISTER,   HBL_LLI_ANALOG}
     91                                                                                                                  #endif
     92          
     93                                                                                                                  #if (HBL_LLI_NUM_FEEDBACK > 0)
     94                                                                                                                      ,{FEEDBACK_LLI_REGISTER, HBL_LLI_FEEDBACK}
     95                                                                                                                  #endif
     96                                                                                                               };
