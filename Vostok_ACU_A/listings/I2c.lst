    851          /**
    852           *    @brief    It is used to write on I2c bus in blocking way
    853           *
    854           *    @details  This method is used to perform I2c write operation in blocking way i.e. it initiates the data transfer
    855           *              and waits till the data transfer is complete
    856           *    @param    i2c              : I2C modules i.e. I2c1 or I2c2 device
    857           *    @param    internal_address : Defines the slave address in which data will be written
    858           *    @param    buf              : It points to the buffer which contains the data to be written
    859           *    @param    size             : It defines the amount of bytes should be written
    860           *    @return   BOOL_TYPE
    861           *      @retval   TRUE(1)  = It means write operation with the devices connected to I2C bus in blocking way is successful
    862           *      @retval   FALSE(0) = It means write operation with the devices connected to I2C bus in blocking way is unsuccessful
    863           *    @image html I2c__BlockingWrite.jpg
    864           */

   \                                 In section .text, align 2, keep-with-next
    865          BOOL_TYPE I2c__BlockingWrite(I2C_ENUM_TYPE i2c,uint8 internal_address, uint8 * buf,uint16 size)
    866          {
    867              #if ((I2C1_FEATURE == ENABLED) || (I2C2_FEATURE == ENABLED) || (I2C3_FEATURE == ENABLED))
    868          
    869                  BOOL_TYPE response;
    870                  I2C_STATE_TYPE state;
    871          
    872                  response = I2c__Write(i2c, internal_address, buf, size);
    873          
    874                  if (response == TRUE)
    875                  {
    876                      state = I2C_STATE_BUSY;
    877          
    878                      while (state == I2C_STATE_BUSY)
    879                      {
    880                          state  = (I2C_STATE_TYPE)I2c__GetStatus(i2c, I2C_STATUS_STATE);
    881                      }
    882          
    883                      if (I2c__GetStatus(i2c, I2C_STATUS_ERROR) == I2C_ERROR_NONE)
    884                      {
    885                          response = TRUE;
    886                      }
    887                      else
    888                      {
    889                          response = FALSE;
    890                      }
    891                  }
    892                  return (response);
    893          
    894              #else
    895                  return (FALSE);
