    823           *  @brief      It Turn off actual MW Relay
    824           */
    825          static void MWRelayOff(void)
    826          {
    827              Relay_Sync_Data[Pilot_Index].MW_Relay_Pin_State = OFF;
    828          
    829              uint8 table_index = Relay_Sync_Data[Pilot_Index].MW_Relay_Pin;
    830              if (VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    831              {
    832                  Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, FALSE);
    833              }
    834          }
    835          
    836          //----------------------------------------------------------------------------------------------
    837          /**
    838           *  @brief      It return MW Relay state
