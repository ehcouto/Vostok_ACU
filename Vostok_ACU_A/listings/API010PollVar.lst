    174          //! Methods of data extraction supported by API010.
    175          typedef enum API010_ACQUISITION_METHOD_ENUM
    176          {
    177              API010_METHOD_REVEAL = 0,
    178              API010_METHOD_SPI,
    179              API010_METHOD_DIRECT_SERIAL,
    180              API010_METHOD_SIZE
    181          } API010_METHOD_TYPE;
    182          
    183          //! All the API010 command and feedback OpCodes.
    184          typedef enum API010_OPCODE_ENUM
    185          {
    186              API010_CMD_REQUEST_SPECIFIC_VARIABLE            = 1,    //!< Request data for one specific variable.
    187              API010_FBK_PUBLISH_SPECIFIC_VARIABLE            = 2,    //!< Publish data for one specific variable.
    188              API010_CMD_ENABLE_PERIODIC_DATA                 = 3,    //!< Enable or disable the periodic publication of selected variables.
    189              API010_FBK_PUBLISH_DATA_STREAM                  = 4,    //!< Publish the data with the selected variables.
    190              API010_CMD_DESELECT_ALL_VARIABLES               = 5,    //!< Remove all variables from the list of published variables.
    191              API010_CMD_SELECT_ALL_VARIABLES                 = 6,    //!< Add all variables to the list of published variables.
    192              API010_CMD_DESELECT_SPECIFIC_VARIABLES          = 7,    //!< Remove specific variables from the list of published variables.
    193              API010_CMD_SELECT_SPECIFIC_VARIABLES            = 8,    //!< Add specific variables to the list of published variables.
    194              API010_CMD_SETUP_PERIODIC_PUBLICATION           = 9,    //!< Setup the publication period and the method of sending variables.
    195              API010_CMD_DEFINE_MEMORY_MAPPED_VARIABLE        = 10,   //!< Add a single memory-mapped variable.
    196              API010_CMD_UNDEFINE_MEMORY_MAPPED_VARIABLE      = 11,   //!< Remove memory-mapped variable(s).
    197              API010_CMD_CONFIGURE_ON_CHANGE_BEHAVIOR         = 12,   //!< Specify that a variable be published (or not) on change.
    198              API010_CMD_REQUEST_FIXED_VARIABLE_METADATA      = 13,   //!< Request a fixed variable's metadata.
    199              API010_FBK_PUBLISH_FIXED_VARIABLE_METADATA      = 14,   //!< Publish a fixed variable's metadata.
    200              API010_CMD_DESELECT_SPECIFIC_HMI_VARIABLES      = 15,   //!< Remove specific HMI variables from the list of published variables.
    201              API010_CMD_SELECT_SPECIFIC_HMI_VARIABLES        = 16,   //!< Add specific HMI variables to the list of published variables.
    202              API010_CMD_REQUEST_ACQUISITION_CONFIGURATION    = 18,   //!< Request the API010 acquisition state.
    203              API010_FBK_PUBLISH_ACQUISITION_CONFIGURATION    = 19,   //!< Publish the API010 acquisition state.
    204              API010_CMD_REQUEST_NUM_OF_VARIABLES             = 20,   //!< Request the number of fixed and memory-mapped variables.
    205              API010_FBK_PUBLISH_NUM_OF_VARIABLES             = 21,   //!< Publish the number of fixed and memory-mapped variables.
    206              API010_CMD_WRITE_FIXED_VARIABLE_VALUE           = 22,   //!< Set the value of a writable variable.
    207              API010_CMD_WRITE_FIXED_HMI_VARIABLE_VALUE       = 23,   //!< Set the value of a writable HMI variable.
    208          } API010_OPCODE_TYPE;
