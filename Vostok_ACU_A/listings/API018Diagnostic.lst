    111          // -- Private Structure Type Declarations --
    112          
    113          //! Data structure for the variables required by the API018Diagnostic module.
    114          typedef struct API018_DIAGNOSTIC_DATA_STRUCT
    115          {
    116              #if (API018_SERVER_FEATURE == ENABLED)
    117                  //! The offset into the section of the statistics data being sent.
    118                  //! This value is used to remember at what position (mid structure) the next statistics data packet should start.
    119                  uint16 Sending_Section_Offset;
    120          
    121                  //! The offset into the full set of statistics data being sent.
    122                  //! This value is used as the 2nd & 3rd bytes (big-endian) of every statistics data packet.
    123                  uint16 Sending_Total_Offset;
    124          
    125                  //! This is the section of the statistics data that was requested.
    126                  //! A value of 255 indicates that all sections were requested.
    127                  //! Refer to API018_SECTION_TYPE for section numbers.
    128                  //! This value is used as the first byte of every statistics data packet.
    129                  API018_SECTION_TYPE Requested_Sections;
    130          
    131                  //! These are the sections of the statistics data that are being published.
    132                  //! Each bit represents a section. Refer to API018_SECTION_TYPE for bit values.
    133                  //! As the sections are sent out, the bits are cleared.
    134                  uint8 Sending_Sections_Mask;
    135          
    136                  //! The node that requested the statistics data.
    137                  uint8 Requesting_Node;
    138              #else   /* if only API018_CLIENT_FEATURE is ENABLED */
    139                  //! An array of error codes that have occurred on the server.
    140                  API018_ERROR_CODE_TYPE Error_Codes[API018_MAX_STORED_FAULTS];
    141                  //! A structure that holds the common lifetime data
    142                  API018_COMMON_LIFETIME_TYPE Common_Lifetime_Data;
    143              #endif
    144              #if (API018_CLIENT_FEATURE == ENABLED)
    145                  //! The number of error codes received and stored in the Error_Codes[] array.
    146                  uint8 Number_Of_Error_Codes;
    147              #endif
    148          } API018_DIAGNOSTIC_DATA_TYPE;
    149          
    150          //! The data structure repeated for each statistics section in the header section.
    151          typedef struct API018_HEADER_ENTRY_STRUCT
    152          {
    153              uint8 Number_Of_Elements;
    154              uint8 Size_Of_Elements;
    155          } API018_HEADER_ENTRY_TYPE;
