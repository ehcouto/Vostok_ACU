    201          /**
    202           * Takes care of store(requirement specifies when the value has to be stored, i.e. each second or each minute)
    203           * and restore (after a power failure) action of the timer reference
    204           * This function should be called from the lowest priority thread.
    205           */

   \                                 In section .text, align 2, keep-with-next
    206          void Millis__SlowHandler(void)
    207          {
    208              #if ((MILLIS_SUPPORT_NV_TIMERS == ENABLED) && (SYSTEM_ACU_HANDLING == DISABLED))
    209                  if (Init_Complete)
    210                  {
    211                      if (Millis__ReachedTargetSeconds(&Millis_Store_Timer, MILLIS_SAVE_PERIOD_SECONDS))
    212                      {
    213                          Stored_Milliseconds = Milliseconds;
    214                          // Prepare for the next update
    215                          Millis__RestartSecondsPeriod(&Millis_Store_Timer, MILLIS_SAVE_PERIOD_SECONDS);
    216                      }
    217                  }
    218                  else
    219                  {
    220                      if ((Mode__GetMode() == MODE_NORMAL) &&
    221                          (Mode__GetSubMode() == SUBMODE_NORMAL_SUPERVISOR) &&
    222                          (IS_MILLIS_DATA_RESTORED() == TRUE))
    223                      {
    224                          Milliseconds = Stored_Milliseconds;
    225                          Init_Complete = TRUE;
    226                      }
    227                      else
    228                      {
    229                          if (Milliseconds >= MILLIS_START_UP_TIMEOUT)
    230                          {
    231                              Init_Complete = TRUE;
    232                          }
    233                      }
    234          
    235                      if (Init_Complete)
