      1          /**
      2           *  @file
      3           *
      4           *  @brief      Module responsible to engage EOL and Service routines requested from API005 or FUNC_ID_TEST_CYCLE regulation.
      5           *              Also responsible of monitoring the execution of the Test Cycles and store the result.
      6           *
      7          
      8              @startuml{TestMgr_SM.png}
      9                  title Test Manager State Machine
     10                  '' Trace = EVENT
     11                  ' use state = Test_Manager_State
     12          
     13                  ' Each state shall check for request to allow switching from EOL to Service or Service to EOL.
     14                  State TEST_CYCLE_INACTIVE
     15                  State TEST_CYCLE_SERVICE_ACTIVE
     16                  State TEST_CYCLE_EOL_ACTIVE
     17          
     18                  [*] --> TEST_CYCLE_INACTIVE
     19          
     20                  ' TEST_CYCLE_INACTIVE State
     21                      TEST_CYCLE_INACTIVE: do /CheckForRequest()
     22                      TEST_CYCLE_INACTIVE --> TEST_CYCLE_SERVICE_ACTIVE: evEngageService
     23                      TEST_CYCLE_INACTIVE --> TEST_CYCLE_EOL_ACTIVE: evEngageEol
     24          
     25                  ' TEST_CYCLE_SERVICE_ACTIVE State
     26                      TEST_CYCLE_SERVICE_ACTIVE: do / CheckForRequest() \n\t CheckForCycleEnd()
     27                      TEST_CYCLE_SERVICE_ACTIVE: entry ActiveEntry
     28                      TEST_CYCLE_SERVICE_ACTIVE: exit / ServiceExit
     29                      TEST_CYCLE_SERVICE_ACTIVE --> TEST_CYCLE_INACTIVE: evEnd
     30                      TEST_CYCLE_SERVICE_ACTIVE --> TEST_CYCLE_EOL_ACTIVE: evEngageEol
     31          
     32                  ' TEST_CYCLE_EOL_ACTIVE State
     33                      TEST_CYCLE_EOL_ACTIVE: do / CheckForRequest() \n\t CheckForCycleEnd()
     34                      TEST_CYCLE_EOL_ACTIVE: entry ActiveEntry
     35                      TEST_CYCLE_EOL_ACTIVE: exit / EolExit
     36                      TEST_CYCLE_EOL_ACTIVE --> TEST_CYCLE_INACTIVE: evEnd
     37                      TEST_CYCLE_EOL_ACTIVE --> TEST_CYCLE_SERVICE_ACTIVE: evEngageService
     38          
     39              @enduml
     40          
     41           *  @copyright  Copyright 2015-2017 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     42           */
