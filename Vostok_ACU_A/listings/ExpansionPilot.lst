    192          /**
    193           *  @brief      Get expansion pilot instance processed request.
    194           *
    195           *  @param      HBL_LOAD_TYPE *load - Pointer to associated expansion load instance.
    196           *
    197           *  @return     void *processed - Processed instance request.
    198           *  @retval     Address of processed instance request. Cast it using *((uint8 *)ptr) to get values.
    199           *  @retval     NULL - Invalid load index.
    200           */
    201          void * ExpansionPilot__GetProcessed(HBL_LOAD_TYPE *load)
    202          {
    203              void *processed;
    204          
    205              processed = NULL;
    206          
    207              if (load != NULL)
    208              {
    209                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
    210                  {
    211                      processed =  &(Expansion_Pilot_Data[load->Pilot_Data_Index].Processed);
    212                  }
    213              }
    214          
    215              return (processed);
    216          }
    217          
    218          void * ExpansionPilot__GetStatus(HBL_LOAD_TYPE *load)
    219          {
    220              void *status;
    221              uint8 *commLoads;
    222              uint8 expansion_load_index;
    223          
    224              status = NULL;
    225          
    226              if (load != NULL)
    227              {
    228                  if (load->Pilot_Data_Index < Expansion_Pilot_Allocation)
    229                  {
    230                      commLoads = API012Exp__GetExpansionLoadsStatus();
    231                      expansion_load_index = GetExpansionLoadIndex(load);
    232                      status = &commLoads[expansion_load_index];
    233                  }
    234              }
    235          
    236              return (status);
    237          }
