     60          /**
     61           *  @brief      It Initializes the module SRDigitalOutputMultiPilot and its variables
     62           *
     63           */
     64          void SRDigitalOutputMultiPilot__Initialize(void)
     65          {
     66              SRData__UpdateByte(&SRDigitalOutputMultiPilot_Allocation, &N_SRDigitalOutputMultiPilot_Allocation , 0);
     67              memset(SRDigitalOutputMultiPilot_Data,0,sizeof(SRDigitalOutputMultiPilot_Data));
     68              memset(N_SRDigitalOutputMultiPilot_Data,0xFF,sizeof(N_SRDigitalOutputMultiPilot_Data));
     69          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     70              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRDIGITALOUTPUTMULTIPILOT);
     71          #endif
