     77          /**
     78           * @brief      It Initializes the module Dtoa and its variables
     79           *
     80           */

   \                                 In section .text, align 2, keep-with-next
     81          void Dtoa__Initialize(void)
     82          {
     83              #if ((DTOA_CH1_FEATURE == ENABLED) || (DTOA_CH2_FEATURE == ENABLED))
     84                  //Reset the DAC engine
     85                  RCC.APBRSTR1 |= RCC_APBRSTR1_DAC1RST;
     86                  RCC.APBRSTR1 &= (uint32)(~RCC_APBRSTR1_DAC1RST);
     87          
     88                  //Enable the DAC device in the APB1 bus
     89                  RCC.APBENR1 |= RCC_APBENR1_DAC1EN;
     90              #endif
     91          }
   \                     Dtoa__Initialize: (+1)
   \   00000000   0x4770             BX       LR               ;; return
