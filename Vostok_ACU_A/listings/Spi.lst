   1174              #if ((SPI_1_FEATURE == ENABLED) || (SPI_2_FEATURE == ENABLED) || (SPI_3_FEATURE == ENABLED))
   1175          
   1176                  #if (SPI_1_FEATURE == ENABLED)
   1177                      if (spi == SPI1)
   1178                      {
   1179                          SPI_1.CR1 &= (uint16)((~SPI_CR1_SPE)&(~SPI_CR1_LSBFIRST)&(~SPI_CR1_CPOL)&(~SPI_CR1_CPHA));  //keep it disable until the end of the configuration
   1180          
   1181                          //Order, Polarity and Edge
   1182                          SPI_1.CR1 |= (((order & 0x01 ) << SPI_CR1_LSBFIRST_POS ) | ((pol & 0x01 ) << SPI_CR1_CPOL_POS ) | (edge & 0x01 ));
   1183                          SPI_1.CR1 |= SPI_CR1_SPE;
   1184                      }
   1185                  #endif
   1186          
   1187                  #if (SPI_2_FEATURE == ENABLED)
   1188                      if (spi == SPI2)
   1189                      {
   1190                          SPI_2.CR1 &= (uint16)((~SPI_CR1_SPE)&(~SPI_CR1_LSBFIRST)&(~SPI_CR1_CPOL)&(~SPI_CR1_CPHA));  //keep it disable until the end of the configuration
   1191          
   1192                          //Order, Polarity and Edge
   1193                          SPI_2.CR1 |= (((order & 0x01 ) << SPI_CR1_LSBFIRST_POS ) | ((pol & 0x01 ) << SPI_CR1_CPOL_POS ) | (edge & 0x01 ));
   1194                          SPI_2.CR1 |= SPI_CR1_SPE;
   1195                      }
   1196                  #endif
   1197          
   1198                  #if (SPI_3_FEATURE == ENABLED)
   1199                      if (spi == SPI3)
   1200                      {
   1201                          SPI_3.CR1 &= (uint16)((~SPI_CR1_SPE)&(~SPI_CR1_LSBFIRST)&(~SPI_CR1_CPOL)&(~SPI_CR1_CPHA));  //keep it disable until the end of the configuration
   1202          
   1203                          //Order, Polarity and Edge
   1204                          SPI_3.CR1 |= (((order & 0x01 ) << SPI_CR1_LSBFIRST_POS ) | ((pol & 0x01 ) << SPI_CR1_CPOL_POS ) | (edge & 0x01 ));
