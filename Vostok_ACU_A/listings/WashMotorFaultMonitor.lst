    530                      (void)SystemTimers__NVSetTimerMS(&Wait_Clear_Fault_Timer_Handle, 500,SYSTEMTIMERS_TYPE_DOWN_COUNTER);
    531                  }
    532                  else if (motor == MOTOR_1)
    533                  {
    534                      VSDrainMotorFaultMonitor__SetDrainMotorFailures(failures);
    535                      VSDrainMotorFaultMonitor__SetDrainMotorFailureFlag(TRUE);
    536                  }
    537              }
    538          
    539          }
    540          
    541          //---------------------------------------------------------------------------------------------------------------------
    542          /**
    543           * Handle events published through API221.
    544           * This function is called by the communication thread.
    545           * @param event = The event that was published through API221.
    546           */
    547          static void API221HandleMotorEventFailure(API221_EVENT_TYPE event)
    548          {
    549              switch (event.Event)
    550              {
    551          		case API221_EVENT_ERROR:
    552          		{
    553          			(void)API221MotionCtrl__RequestFailureFlags(event.Motor, API221ApplReceivedFailureFlags);
    554          		}
    555          		break;
    556          
    557          		case API221_EVENT_REMOVED_ERROR:
    558          		{
    559          			if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_0)
    560          			{
    561          				SystemTimers__NVResetTimer(&Wait_Clear_Fault_Timer_Handle);
    562          			}
    563          			else if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_1)
    564          			{
    565          				VSDrainMotorFaultMonitor__ResetTimerClearMotorFailureFlag();
    566          			}
    567          			// Keep requesting failures until all errors are cleaned
    568          			(void)API221MotionCtrl__RequestFailureFlags(event.Motor, API221ApplReceivedFailureFlags);
    569          		}
    570          		break;
    571          
    572          		default:
    573          			// Ignore all other events
    574          			break;
    575              }
    576          
    577          }
