    729          //---------------------------------------------------------------------------------------------------------------------
    730          /**
    731           * Capture accelerometer points and perform the self-test.
    732           */
    733          static void SelfTestMeasure(void)
    734          {
    735              sint16 vector[3];
    736              while ((Accel_Baseline.Samples < ACCEL_SELF_TEST_SAMPLES) &&
    737                     (LISxDH__Read(vector)))
    738              {
    739                  Accel_Baseline.Samples++;
    740                  if (0 < Accel_Baseline.Samples)             // Discard first samples while accelerometer stabilizes.
    741                  {
    742                      // Add the new accelerometer XYZ point to the running sum of raw points.
    743                      for (uint8 axis = 0; axis < 3U; axis++)
    744                      {
    745                          Accel_Baseline.Sum[axis] += vector[axis];
    746                      }
    747                  }
    748              }
    749              if (Accel_Baseline.Samples >= ACCEL_SELF_TEST_SAMPLES)
    750              {
    751                  // Save the self-test point in one of the Point[][] positions.
    752                  for (uint8 axis = 0; axis < 3U; axis++)
    753                  {
    754                      Accel_Baseline.Point[Accel_Baseline.Average_Index][axis] = Accel_Baseline.Sum[axis] / Accel_Baseline.Samples;
    755                  }
    756          
    757                  BOOL_TYPE test_passed = TRUE;
    758                  if (Accel_Baseline.Average_Index > 0U)       // If 0, then it is the baseline, so skip the test.
    759                  {
    760                      // Compare the new point to the baseline Point[0].
    761                      for (uint8 axis = 0; axis < 3U; axis++)
    762                      {
    763                          // Check that the test's displacement is in the expected range.
    764                          uint16 delta = abs(Accel_Baseline.Point[Accel_Baseline.Average_Index][axis] - Accel_Baseline.Point[0][axis]);
    765                          if ((delta < ACCEL_SELF_TEST_MIN_DEFLECTION) || (ACCEL_SELF_TEST_MAX_DEFLECTION < delta))
    766                          {
    767                              test_passed = FALSE;
    768                          }
    769                      }
    770                  }
    771          
    772                  // Manage test result.
    773                  if (test_passed)
    774                  {
    775                      EventPassed();
    776                  }
    777                  else
    778                  {
    779                      EventFailed();
    780                  }
    781              }
    782          }
