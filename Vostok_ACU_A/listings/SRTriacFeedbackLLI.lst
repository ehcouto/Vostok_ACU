C:\Data\Nucleus_Dev\Vostok_ACU_A\source\XCategory\Hbl\all\LLIHandler\SRTriacFeedbackLLI\SRTriacFeedbackLLI.c
      1          /**
      2           *  @file       SRTriacFeedbackLLI.c
      3           *
      4           *  @brief      Module for SRTriacFeedbackLLI reading - detects a Nominal/Double grid frequency or a Digital level
      5           *
      6           *  @details    This module track an input and decode it as level (Low or High) or frequency (grid frequency or its double).
      7           *
      8           *              In order to detect a frequency two event must be measured without additional spurious event.
      9           *              After this, the module is capable of rejecting an arbitrary number of spurious event.
     10           *
     11           *              The read of the level at the end of this time window is performed via a simple read.
     12           *
     13           *              Macros available to configure the module:
     14           *
     15           *               TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY:
     16           *                  (Default 45) Minimum mains frequency allowed
     17           *
     18           *               TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY:
     19           *                  (Default 65) Maximum mains frequency allowed
     20           *
     21           *
     22           *	@defgroup	CLASS_B
     23           *
     24           *  @copyright  Copyright 2019 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     25           */
     26          //---------------------------------------------------------------------------------------------------------------------
     27          //---------------------------------------------------------------------------------------------------------------------
     28          
     29          
     30          //-------------------------------------- Include Files ----------------------------------------------------------------
     31          #include "SRTriacFeedbackLLI.h"
     32          
     33          #if (HBL_LLI_NUM_SRTRIACFEEDBACK > 0)
     34          #include "Gpio.h"
     35          #include "Micro.h"
     36          #include "SRData.h"
     37          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     38              #include "SRTaskSequence.h"
     39          #endif
     40          #include "VirtualPin.h"
     41          
     42          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     43          
     44          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     45          #define DEFAULT_NUM_SAMPLES                 16
     46          #define MIN_NUM_SAMPLES                     8
     47          #define SAMPLES_NOISE_THRESHOLD             2
     48          
     49          // Minimum frequency allowed
     50          #ifndef SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY
     51              #define SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY   45
     52          #endif
     53          
     54          // Maximum frequency allowed
     55          #ifndef SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY
     56              #define SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY   65
     57          #endif
     58          
     59          #define TIME_MSEC_IN_ONE_SEC                (1000)
     60          
     61          #define MINIMUM_DURATION_ALLOWED            (TIME_MSEC_IN_ONE_SEC / SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY)
     62          #define MAXIMUM_DURATION_ALLOWED            ((TIME_MSEC_IN_ONE_SEC / SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY) + 1)
     63          
     64          #define MINIMUM_HALF_DURATION_ALLOWED       ((TIME_MSEC_IN_ONE_SEC / (2 * SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY)))
     65          #define MAXIMUM_HALF_DURATION_ALLOWED       ((TIME_MSEC_IN_ONE_SEC / (2 * SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY)) + 1)
     66          
     67          #define LAST_FREQUENCY_EVENT_TIMEOUT        ((3 * TIME_MSEC_IN_ONE_SEC) / (2 * SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY))
     68          
     69          typedef struct
     70          {
     71              uint8 N_Read:3;
     72              uint8 Unused_0:5;
     73              uint8 Unused_1:5;
     74              uint8 Pull_Up:1;
     75              uint8 Unused_2:1;
     76              uint8 Inverted:1;
     77          } SRTRIACFEEDBACKLLI_PARAM_TYPE;
     78          
     79          typedef struct
     80          {
     81              // Buffer of Gpio samples collected
     82              uint16 Pin_Buffer;
     83              // Sampling Sequence counter - updated on each 1ms sample
     84              uint8 Sampling_Counter;
     85              // last Sampling Sequence counter reference of the last Asynch iteration
     86              uint8 Async_Sampling_Reference;
     87              // Frequency detection in progress
     88              BOOL_TYPE Is_Detecting_Frequency;
     89              // Double frequency detection in progress
     90              BOOL_TYPE Is_Detecting_Double_Frequency;
     91              // Sampling Sequence counter reference of the last frequency event detected
     92              uint8 Last_Frequency_Event_Reference;
     93              // Time (in ms) between last two frequency events detected
     94              uint8 Time_Between_Frequency_Events;
     95              // Counter of High / Low pin level event detected: it increments on a new High value event, decrements on a new Low value event
     96              sint8 Level_Counter;
     97              // Counter of valid Frequency event detected: it increments when valid Frequency events have been detected
     98              uint8 Frequency_Counter;
     99              // Counter of Double Frequency event detected: it increments if a valid double frequency event happened
    100              uint8 Double_Frequency_Counter;
    101              // Current Feedback LLI value (0, 1, 2, 3)
    102              SRTRIAC_FEEDBACK_LLI_OUTPUT_TYPE Value;
    103          } SRTRIACFEEDBACKLLI_DATA_TYPE;
    104          
    105          static SRTRIACFEEDBACKLLI_DATA_TYPE SRTriacFeedbackLLI_Data[HBL_LLI_NUM_SRTRIACFEEDBACK];
    106          static uint8 SRTriacFeedbackLLI_Allocation;
    107          static SRTRIACFEEDBACKLLI_DATA_TYPE N_SRTriacFeedbackLLI_Data[HBL_LLI_NUM_SRTRIACFEEDBACK];
    108          static uint8 N_SRTriacFeedbackLLI_Allocation;
    109          
    110          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
    111          static void UpdateLastFrequencyTimingEvents(SRTRIACFEEDBACKLLI_DATA_TYPE *data_ptr, SRTRIACFEEDBACKLLI_DATA_TYPE *n_data_ptr, uint8 new_frequency_reference);
