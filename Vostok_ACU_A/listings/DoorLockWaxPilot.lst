    355          //---------------------------------------------------------------------------------------------------------------------
    356          /**
    357           *  @brief      Asynchronous process for DoorLockWaxPilot.
    358           *
    359           *	@detail     Asynchronous process handles status transition and consistency check for door lock status
    360           *
    361           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    362           *
    363           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot asynch execution.
    364           *  @retval     PASS - Execution succeeded.
    365           *  @retval     FAIL - Execution failed.
    366           */
    367          PASS_FAIL_TYPE DoorLockWaxPilot__AsynchProcess(HBL_LOAD_TYPE * load)
    368          {
    369          	DOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    370          	DOORLOCKWAXPILOT_DATA_TYPE *ptr;
    371          	HBL_CONSISTENCY_TYPE lock_feedback;
    372          	HBL_LOAD_STATUS_TYPE tmp_load;
    373          	PASS_FAIL_TYPE retval = FAIL;
    374          	BOOL_TYPE pin_val = FALSE;
    375          	uint8 index = load->Pilot_Data_Index;
    376          
    377              if (index < DoorLockWaxPilot_Allocation)
    378              {
    379              	ptr = &DoorLockWaxPilot_Data[index];
    380              	param_ptr = (DOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    381              	tmp_load.Load.Cur_Reg = ptr->Processed;
    382              	// Prevent use of TRN table when DoorLock status is OFF;
    383              	// during INITIALIZE consider Processed target like it has been already reached
    384              	if ( (ptr->Processed != 0) &&
    385              		(ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE))
    386              	{
    387              		tmp_load.Load.Status = ptr->PilotStatus.Load.Status;
    388              	}
    389              	else
    390              	{
    391              		tmp_load.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    392              	}
    393              	lock_feedback.Byte = Hbl__GetOwnLoadConsistency(load, tmp_load.Byte);
    394              	retval = PASS;
    395          
    396              	switch(ptr->Status)
    397              	{
    398              	case DOORLOCKWAX_STATUS_DOOR_LOCKING:
    399              		pin_val = TRUE;
    400              		if (ptr->Counter == 0)
    401              		{
    402          		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED;
    403              		}
    404              		else
    405              		{
    406                  		if ( (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) &&
    407                  				(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_OFF))
    408                  		{
    409              		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_LOCKED;
    410              		    	ptr->Counter = (param_ptr->Duty_On + param_ptr->Duty_Off) * 10;
    411                  		}
    412          
    413              		}
    414              		break;
    415          
    416          
    417              	case DOORLOCKWAX_STATUS_DOOR_UNLOCKING:
    418              		if (ptr->Counter == 0)
    419              		{
    420          		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED;
    421              		}
    422              		else
    423              		{
    424                  		if ( (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) &&
    425                  			(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON) &&
    426          					(lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON_ALTERNATE) )
    427                  		{
    428              		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_UNLOCKED;
    429              		    	ptr->Counter = 0;
    430                  		}
    431          
    432              		}
    433              		break;
    434          
    435              	case DOORLOCKWAX_STATUS_DOOR_LOCKED:
    436              		if (param_ptr->Duty_On == 0)
    437              		{
    438          				pin_val = TRUE;
    439              		}
    440              		else
    441              		{
    442                  		if (ptr->Counter == 0)
    443                  		{
    444              		    	ptr->Counter = (param_ptr->Duty_On + param_ptr->Duty_Off) * 10;
    445                  		}
    446                  		else if (ptr->Counter >= (param_ptr->Duty_Off * 10))
    447              			{
    448              				pin_val = TRUE;
    449              			}
    450              		}
    451          
    452              		break;
    453          
    454              	case DOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    455              	case DOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED:
    456              	case DOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED:
    457              		break;
    458          
    459              	default:
    460              		if (ptr->Counter == 0)
    461              		{
    462              			if (ptr->Processed == OFF)
    463              			{
    464              				// Check if door feedback value is fine
    465                      		if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    466                      				(lock_feedback.Byte == HBL_CONSISTENCY_TABLE_INVALID))
    467                      		{
    468                      			// Door already unlocked
    469                  		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_UNLOCKED;
    470                  		    	ptr->Counter = 0;
    471                      		}
    472                      		else
    473                      		{
    474                      			// Door is going to be unlocked
    475                  		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_UNLOCKING;
    476                  		    	ptr->Counter = ENDIANS16_STON(param_ptr->Unlock_Timeout);
    477                      		}
    478              			}
    479              			else
    480              			{
    481              				// Check if door feedback value is fine
    482                      		if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    483                      				(lock_feedback.Byte == HBL_CONSISTENCY_TABLE_INVALID))
    484                      		{
    485                      			// Door already locked
    486                  		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_LOCKED;
    487                  		    	ptr->Counter = (param_ptr->Duty_On + param_ptr->Duty_Off) * 10;
    488                      		}
    489                      		else
    490                      		{
    491                      			// Door is going to be locked
    492                  		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_LOCKING;
    493                  		    	ptr->Counter = ENDIANS16_STON(param_ptr->Lock_Timeout);
    494                      		}
    495              			}
    496              		}
    497              		break;
    498          
    499              	}
    500          
    501              	switch(ptr->Status)
    502              	{
    503              	case DOORLOCKWAX_STATUS_DOOR_LOCKED:
    504              	case DOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    505              		ptr->PilotStatus.Load.Status = ((pin_val == TRUE) ? HBL_LOAD_STATUS_TARGET_ALT_TABLE : HBL_LOAD_STATUS_TARGET_COMPLETED);
    506              		ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    507              		break;
    508          
    509              	case DOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED:
    510              	case DOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED:
    511              		ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_FAILURE;
    512              		ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    513              		break;
    514          
    515              	default:
    516              		if (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE)
    517              		{
    518              			ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    519              		}
    520              	}
    521              }
    522          
    523          	return(retval);
    524          }
    525          
    526          //---------------------------------------------------------------------------------------------------------------------
    527          /**
    528           *  @brief      One millisecond process for DoorLockWaxPilot.
    529           *
    530           *	@detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    531           *
    532           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    533           *
    534           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot 1ms execution.
    535           *  @retval     PASS - Execution succeeded.
    536           *  @retval     FAIL - Execution failed.
    537           */
    538          PASS_FAIL_TYPE DoorLockWaxPilot__Handler1ms(HBL_LOAD_TYPE * load)
    539          {
    540          	DOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    541          	DOORLOCKWAXPILOT_DATA_TYPE *ptr;
    542          	uint8 virtual_pin;
    543          	PASS_FAIL_TYPE retval = FAIL;
    544          	BOOL_TYPE pin_val = FALSE;
    545          	BOOL_TYPE pin_fbk_val = FALSE;
    546          	uint8 index = load->Pilot_Data_Index;
    547          
    548              if (index < DoorLockWaxPilot_Allocation)
    549              {
    550              	param_ptr = (DOORLOCKWAXPILOT_PARAM_TYPE *)(load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    551              	ptr = &DoorLockWaxPilot_Data[index];
    552              	retval = PASS;
    553          
    554              	if (ptr->Fbk_Pin < VirtualPin__GetNumOf())
    555              	{
    556              		pin_fbk_val = Gpio__PinRead(VIRTUALPIN_TABLE[ptr->Fbk_Pin].port, VIRTUALPIN_TABLE[ptr->Fbk_Pin].pin);
    557              	}
    558          
    559              	if (pin_fbk_val != ptr->Fbk_Last_Pin_Value)
    560              	{
    561              		if (pin_fbk_val == TRUE)
    562              		{
    563              	    	if ( (ptr->Fbk_Counter >= DOORLOCKWAX_MIN_PERIOD_MS) &&
    564              					(ptr->Fbk_Counter <= DOORLOCKWAX_MAX_PERIOD_MS))
    565              			{
    566              	    		if (ptr->Debounce)
    567              	    		{
    568              	    			ptr->Debounce--;
    569              	    		}
    570              	    		else
    571              	    		{
    572              	    			sint8 tmp_offset = (2*ptr->Fbk_Last_Counter - ptr->Fbk_Counter)/4;
    573          						if (tmp_offset < 0)
    574          						{
    575          							tmp_offset += (ptr->Fbk_Period / 2);
    576          						}
    577          	    	    		ptr->Fbk_Offset =  tmp_offset; //lint !e926 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    578              	    			ptr->Fbk_Period = ptr->Fbk_Counter;
    579          
    580              	    		}
    581              			}
    582              	    	else
    583              	    	{
    584              	    		ptr->Debounce = DOORLOCKWAX_MAX_DEBOUNCE;
    585              	    	}
    586                  		ptr->Fbk_Timeout_Counter = 0;
    587                  		ptr->Fbk_Counter= 0;
    588              		}
    589              		else
    590              		{
    591                  		ptr->Fbk_Last_Counter = ptr->Fbk_Counter;
    592              		}
    593          
    594              		ptr->Fbk_Last_Pin_Value =  pin_fbk_val;
    595              	}
    596              	else if (ptr->Fbk_Timeout_Counter > (param_ptr->Filter_Time*DOORLOCKWAX_TIMING_REF))
    597              	{
    598          			ptr->Debounce = DOORLOCKWAX_MAX_DEBOUNCE;
    599              		if (ptr->Fbk_Counter >= ptr->Fbk_Period)
    600          			{
    601                  		ptr->Fbk_Counter = 0;
    602          			}
    603              	}
    604              	else
    605              	{
    606              		ptr->Fbk_Timeout_Counter++;
    607              	}
    608          		ptr->Fbk_Counter++;
    609          
    610              	switch(ptr->Status)
    611              	{
    612              	case DOORLOCKWAX_STATUS_DOOR_LOCKING:
    613              		pin_val = TRUE;
    614              		break;
    615          
    616              	case DOORLOCKWAX_STATUS_DOOR_LOCKED:
    617          			if ((param_ptr->Duty_On == 0) ||
    618          				(ptr->Counter >= (param_ptr->Duty_Off * 10)))
    619          			{
    620          				pin_val = TRUE;
    621          			}
    622              		break;
    623          
    624              	default:
    625              		break;
    626              	}
    627          
    628          		if (ptr->Wait_Trigger)
    629          		{
    630          			if ((ptr->Fbk_Counter == ptr->Fbk_Offset) ||
    631          				(ptr->Fbk_Counter == ptr->Fbk_Offset + (ptr->Fbk_Period / 2)))
    632          			{
    633          				ptr->Wait_Trigger = 0;
    634          			}
    635          			else
    636          			{
    637          				pin_val = FALSE;
    638          			}
    639          		}
    640          
    641              	if (ptr->TimingRef > 0)
    642              	{
    643              		ptr->TimingRef--;
    644              	}
    645              	else
    646              	{
    647              		ptr->TimingRef = DOORLOCKWAX_TIMING_REF;
    648              		if (ptr->Counter > 0)
    649              		{
    650          				ptr->Counter--;
    651              		}
    652              	}
    653          
    654          		pin_val ^= ~load->Hi_Low_Activation_Bitmap;
    655          		pin_val &= 0x01;
    656                  virtual_pin = (*load->Pin_Ptr);
    657          		Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    658          
    659              }
    660          
    661              return(retval);
    662          }
