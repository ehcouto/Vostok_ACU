      1          /**
      2           *  @file		Regenerate.c
      3           *
      4           *  @brief		A process that implements the Water Softener Regeneration algorithm
      5           *
      6           *  @details	To neutralize the limestone's effects, the dishwasher is equipped with a water softener whose resins,
      7           *  			cycle after cycle, gradually run out. To restore the resins' functionality a process called 'regeneration'
      8           *  			has to be executed, which makes water flow through the salt tank and then through the resins of the the water
      9           *  			softener.
     10           *  			This process, when called inside the cycle, checks the conditions to run a regeneration and if they are satisfied
     11           *  			executes the regeneration itself.
     12           *
     13           *
     14             @startuml{Regenerate State Machine.jpg}
     15                  title Regenerate State Machine
     16                  ' Use state = Regenerate_Data.State
     17          
     18          		[*] --> INITIALIZE
     19          
     20          		INITIALIZE : do / InitializeDo()
     21          		INITIALIZE --> OPEN_REG_VALVE_1 : evStartRegenerate
     22                  INITIALIZE --> REGENERATION_COMPLETE : evSkipRegeneration
     23          
     24          		OPEN_REG_VALVE_1 : entry / OpenRegenerationValve1Entry()
     25          		OPEN_REG_VALVE_1 : do / OpenRegenerationValve1Do()
     26          		OPEN_REG_VALVE_1 --> OPEN_REG_AND_FILL_VALVE : evDelayRvFvOnExpired
     27                  OPEN_REG_VALVE_1 --> REGENERATION_COMPLETE : evSkipRegeneration
     28          
     29          		OPEN_REG_AND_FILL_VALVE : entry / OpenRegenerationAndFillValveEntry()
     30          		OPEN_REG_AND_FILL_VALVE : do / OpenRegenerationAndFillValveDo()
     31          		OPEN_REG_AND_FILL_VALVE --> OPEN_REG_VALVE_2 : evRegenerationWaterLoaded
     32                  OPEN_REG_AND_FILL_VALVE --> REGENERATION_COMPLETE : evSkipRegeneration
     33          
     34          		OPEN_REG_VALVE_2 : entry / OpenRegenerationValve2Entry()
     35          		OPEN_REG_VALVE_2 : do / OpenRegenerationValve2Do()
     36          		OPEN_REG_VALVE_2 --> REGENERATION_CLOSURE : evDelayFvRvOffExpired
     37                  OPEN_REG_VALVE_2 --> REGENERATION_COMPLETE : evSkipRegeneration
     38          
     39          		REGENERATION_CLOSURE : entry / RegenerationClosureEntry()
     40          		REGENERATION_CLOSURE : do / RegenerationClosureDo()
     41          		REGENERATION_CLOSURE --> REGENERATION_CLOSURE : evRestartClosureState
     42          		REGENERATION_CLOSURE --> REGENERATION_COMPLETE : evRegenerationProcessCompleted
     43          
     44              @enduml
     45           *
     46           *  @copyright  Copyright 2017-$Date$. Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     47           */
