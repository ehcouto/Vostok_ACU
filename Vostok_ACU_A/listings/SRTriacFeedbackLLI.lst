    213          /**
    214           * @brief    Handler for SRTriacFeedbackLLI execution; this call (and sequence) checks SRTriacFeedbackLLI_Data and SRTriacFeedbackLLI_Allocation integrity
    215           */
    216          void SRTriacFeedbackLLI__Handler(void)
    217          {
    218              (void) SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    219              (void) SRData__CheckArrayNonBlocking(SRTriacFeedbackLLI_Data, N_SRTriacFeedbackLLI_Data, sizeof(SRTriacFeedbackLLI_Data));
    220          
    221          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    222              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRTRIACFEEDBACK_CHECKS);
    223          #endif
    224          
    225          }
    226          
    227          //---------------------------------------------------------------------------------------------------------------------
    228          /**
    229           * @brief   Process function to read on Asynch Process (5ms) - it detects High or Low values if no Frequency event occurs and updates LLI
    230           * @param input     pointer to HBL_LLI_TYPE structure instance
    231           * @return  TRUE if a new sample is ready, FALSE otherwise
    232           */
    233          BOOL_TYPE SRTriacFeedbackLLI__AsynchProcess(HBL_LLI_TYPE * input)
    234          {
    235              BOOL_TYPE retval = FALSE;
    236          
    237              (void)SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    238              if (input->Data_Index < SRTriacFeedbackLLI_Allocation)
    239              {
    240                  SRTRIACFEEDBACKLLI_DATA_TYPE *data = &SRTriacFeedbackLLI_Data[input->Data_Index];
    241                  SRTRIACFEEDBACKLLI_DATA_TYPE *n_data = &N_SRTriacFeedbackLLI_Data[input->Data_Index];
    242                  SRTRIACFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *) input->Parameter_Ptr.Data;
    243                  uint8 n_read = DEFAULT_NUM_SAMPLES;
    244                  // Minimum number of samples to give priority between level (High / Low) or Frequency detection
    245                  uint8 level_freq_threshold = (uint8) (DEFAULT_NUM_SAMPLES / 2);
    246          
    247                  if(feedback_param != NULL)
    248                  {
    249                      uint8 param_read = 1U << ((uint8) feedback_param->N_Read);
    250                      if (param_read <= (uint8) MIN_NUM_SAMPLES)
    251                      {
    252                          param_read = (uint8) MIN_NUM_SAMPLES;
    253                      }
    254                      n_read = param_read;
    255                      level_freq_threshold = param_read / 2U;
    256                  }
    257          
    258                  (void) SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRTriacFeedbackLLI_Data[0]));
    259                  // Update Feedback values if there are new samples coming from  1ms Process
    260                  if(data->Async_Sampling_Reference != data->Sampling_Counter)
    261                  {
    262                      MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    263                      uint16 local_pin_buffer;
    264                      BOOL_TYPE valid_freq_detected = FALSE;
    265                      sint8 pin_value_counter = 0;
    266                      sint8 local_level_counter;
    267                      uint8 local_sampling_counter;
    268                      uint8 local_double_freq_counter;
    269                      uint8 local_freq_counter;
    270                      uint8 num_samples;
    271                      uint8 sample_reference;
    272          
    273                      // Take a snapshot of pin buffer and sample counter to prevent concurrent updates from OneMsProcess function
    274                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    275                      local_sampling_counter = data->Sampling_Counter;
    276                      local_pin_buffer = data->Pin_Buffer;
    277                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    278          
    279                      // Get number of samples to process with a limit to 10 samples
    280                      // This limit comes from the falling edge transition pattern checks
    281                      num_samples = (uint8) (local_sampling_counter - data->Async_Sampling_Reference);
    282                      if(num_samples > 10U)
    283                      {
    284                          num_samples = 10U;
    285                      }
    286                      sample_reference = data->Async_Sampling_Reference + num_samples;
    287          
    288                      // Collects high, low pin value occurrences and detects a frequency signal through falling edge transitions:
    289                      // - It counts number of High and Low new samples collected
    290                      // - It detects a falling edge transition through a pattern detection:
    291                      //   - last 4 ms for a clean falling edge transition with a 2ms debounce for each edge (2ms ON, 2ms OFF)
    292                      //   - last 6 ms for a clean Charge pump signal (3 times: 1ms ON, 1ms OFF)
    293                      //   - last 6 ms for a noisy falling edge transition with a 2ms debounce for each steady edge (2ms ON, 1ms OFF, 1 ms ON, 2ms OFF)
    294                      //   - last 8 ms for a very noisy falling edge transition with a 2ms debounce for each steady edge (2ms ON, 1ms OFF, 1 ms ON, 1ms OFF, 1 ms ON, 2ms OFF)
    295                      // - When a frequency signal has been detected:
    296                      //   - it saves frequency time reference
    297                      //   - it updates the time between frequency event to estimate the cycle (period) time
    298                      for(uint8 i = 0; i < num_samples; i++)
    299                      {
    300                          uint16 pin_value = (local_pin_buffer & 0x01U);
    301          
    302                          // Update Level counter: increment if High pin value, decrement if Low pin value
    303                          if(pin_value != 0U)
    304                          {
    305                              pin_value_counter++;
    306                          }
    307                          else
    308                          {
    309                              pin_value_counter--;
    310                          }
    311          
    312                          // Find a frequency event based to a falling edge transition patterns, including noisy ones
    313                          if ((local_pin_buffer & 0x0FU) == 0x0CU)          // Check if a falling edge event occur with 2ms debounce (2 ON - 2 OFF)
    314                          {
    315                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 2U);
    316                          }
    317                          else if((local_pin_buffer & 0x1FU) == 0x04U)      // Check if a falling edge event occur with 1 ms spikes (2 OFF, 1 ON, 2 OFF)
    318                          {
    319                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 2U);
    320                          }
    321                          else if((local_pin_buffer & 0x1FU) == 0x1BU)      // Check if a falling edge event occur with 1 ms spikes (2 ON, 1 OFF, 2 ON)
    322                          {
    323                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 3U);
    324                          }
    325                          else if  ((local_pin_buffer & 0x3FU) == 0x34U)      // Check if a falling edge event occur with 2ms debounce and 1 ms spikes (2 ON, 1 OFF, 1 ON, 2 OFF)
    326                          {
    327                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 3U);
    328                          }
    329                          else if ((local_pin_buffer & 0xFFU) == 0xD4U)         // Check if a falling edge event occur with 2ms debounce and 1 ms spikes (2 ON, 1 OFF,1 ON, 1 OFF, 1 ON, 2 OFF)
    330                          {
    331                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 4U);
    332                          }
    333          
    334                          sample_reference--;
    335                          local_pin_buffer >>= 1U;
    336                      }
    337                      // Update Async Sampling Reference for the next execution
    338                      SRData__UpdateByte(&data->Async_Sampling_Reference, &n_data->Async_Sampling_Reference, local_sampling_counter);
    339          
    340                      // Check if no double frequency signal detected after LAST_FREQUENCY_EVENT_TIMEOUT / 2
    341                      // If no frequency events for more than timeout, switch to frequency detection
    342                      if((uint8) (local_sampling_counter - data->Last_Frequency_Event_Reference) >= (uint8) (LAST_FREQUENCY_EVENT_TIMEOUT / 2))
    343                      {
    344                          SRData__UpdateByte((void *) &data->Is_Detecting_Double_Frequency,(void *)  &n_data->Is_Detecting_Double_Frequency,(uint8) FALSE);
    345                      }
    346          
    347                      // Check if no frequency signal detected after LAST_FREQUENCY_EVENT_TIMEOUT
    348                      // If no frequency events for more than timeout, switch to level detection
    349                      if((uint8) (local_sampling_counter - data->Last_Frequency_Event_Reference) >= (uint8) LAST_FREQUENCY_EVENT_TIMEOUT)
    350                      {
    351                          SRData__UpdateByte((void *) &data->Is_Detecting_Frequency,(void *)  &n_data->Is_Detecting_Frequency,(uint8) FALSE);
    352                          SRData__UpdateByte(&data->Time_Between_Frequency_Events, &n_data->Time_Between_Frequency_Events, 0);
    353                      }
    354          
    355                     // Take a snapshot of Frequency, Double Frequency, Level event counters to
    356                     local_freq_counter = data->Frequency_Counter;
    357                     local_double_freq_counter = data->Double_Frequency_Counter;
    358                     local_level_counter = data->Level_Counter;
    359          
    360                      // Frequency detection: it checks if a valid frequency signal has been detected
    361                      // Valid frequency signals are Charge Pump and Mains (AC Signal) like frequency signal
    362                      if(data->Is_Detecting_Frequency)
    363                      {
    364                          SRTRIAC_FEEDBACK_LLI_OUTPUT_TYPE new_value = SRTRIAC_UNKNOWN_UNKNOWN_VALUE;
    365                          BOOL_TYPE is_mains_freq;
    366          
    367                          // Valid AC Signal frequency events happen within duration range - e.g. 45 Hz (22.22ms) - 65 Hz (15.38ms) range
    368                          is_mains_freq = (BOOL_TYPE) (data->Time_Between_Frequency_Events >= (uint8) MINIMUM_DURATION_ALLOWED);
    369                          is_mains_freq = (BOOL_TYPE) (is_mains_freq && (data->Time_Between_Frequency_Events <= (uint8) MAXIMUM_DURATION_ALLOWED));
    370          
    371                          if(is_mains_freq || data->Is_Detecting_Double_Frequency)
    372                          {
    373                              valid_freq_detected = TRUE;
    374          
    375                              // Increment the Double counter if Time between Frequency Events is less than the Mains frequency
    376                              if(data->Is_Detecting_Double_Frequency)
    377                              {
    378                                  local_double_freq_counter++;
    379                                  // If the number of Frequency event occurrences becomes higher than the half of valid samples to collect
    380                                  // Frequency detection takes precedence over Level and double frequency detection
    381                                  if(local_double_freq_counter >= level_freq_threshold)
    382                                  {
    383                                      local_level_counter = 0;
    384                                      local_freq_counter = 0;
    385                                  }
    386          
    387                                  // Update LLI value to Frequency (Phase / Opp.Phase) if number of valid samples have been collected
    388                                  if(local_double_freq_counter >= n_read)
    389                                  {
    390                                      new_value = SRTRIAC_FB_LLI_DOUBLE_GRID_FREQ;
    391                                  }
    392                              }
    393                              else
    394                              {
    395                                  local_freq_counter++;
    396                                  // If the number of Frequency event occurrences becomes higher than the half of valid samples to collect
    397                                  // Frequency detection takes precedence over Level and double frequency detection
    398                                  if(local_freq_counter >= level_freq_threshold)
    399                                  {
    400                                      local_level_counter = 0;
    401                                      local_double_freq_counter = 0;
    402                                  }
    403          
    404                                  // Update LLI value to Frequency (Phase / Opp.Phase) if number of valid samples have been collected
    405                                  if(local_freq_counter >= n_read)
    406                                  {
    407                                      new_value = SRTRIAC_FB_LLI_NOMINAL_GRID_FREQ;
    408                                  }
    409                              }
    410                          }
    411          
    412                          // Update LLI value to Frequency (Phase / Opp.Phase) if number of valid samples have been collected
    413                          if(new_value != SRTRIAC_UNKNOWN_UNKNOWN_VALUE)
    414                          {
    415                              SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) new_value);
    416                              local_freq_counter = 0;
    417                              local_double_freq_counter = 0;
    418                              retval = TRUE;
    419                          }
    420                      }
    421          
    422                      // If not valid Frequency signal has been detected, High / Low detection algorithm is performed
    423                      if(!valid_freq_detected)
    424                      {
    425                          // High value level event: Level counter is a positive number, higher than pin noise threshold
    426                          if(pin_value_counter >= SAMPLES_NOISE_THRESHOLD)
    427                          {
    428                              local_level_counter++;
    429                          }
    430                          // Low value level event: Level counter is a negative number, lower than pin noise threshold
    431                          else if(pin_value_counter <= -SAMPLES_NOISE_THRESHOLD)
    432                          {
    433                              local_level_counter--;
    434                          }
    435          
    436                          // If the number of High/Low value Level event occurrences becomes higher than the half of valid samples to collect
    437                          // Level detection takes precedence over Frequency detection
    438                          if((local_level_counter >= (sint8) level_freq_threshold) ||
    439                              (local_level_counter <= -((sint8) level_freq_threshold)))
    440                          {
    441                              local_freq_counter = 0;
    442                              local_double_freq_counter = 0;
    443                          }
    444          
    445                          // Update LLI value to High if number of valid samples have been collected
    446                          if(local_level_counter >= (sint8) n_read)
    447                          {
    448                              SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) SRTRIAC_FB_LLI_1_VALUE);
    449                              local_level_counter = 0;
    450                              retval = TRUE;
    451                          }
    452          
    453                          // Update LLI value to Low if number of valid samples have been collected
    454                          if(local_level_counter <= -((sint8) n_read))
    455                          {
    456                              SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) SRTRIAC_FB_LLI_0_VALUE);
    457                              local_level_counter = 0;
    458                              retval = TRUE;
    459                          }
    460                      }
    461          
    462                      SRData__UpdateByte(&data->Frequency_Counter, &n_data->Frequency_Counter, local_freq_counter);
    463                      SRData__UpdateByte(&data->Double_Frequency_Counter, &n_data->Double_Frequency_Counter, local_double_freq_counter);
    464                      SRData__UpdateByte((void *) &data->Level_Counter, (void *) &n_data->Level_Counter, (uint8) local_level_counter);
    465                  }
    466              }
    467          
    468              return(retval);
    469          }
    470          
    471          //---------------------------------------------------------------------------------------------------------------------
    472          /**
    473           *  @brief      Executes SRTriacFeedbackLLI 1ms sampling
    474           * @param       input - Hbl LLI Data structure of the instance to process
    475           * @return      FALSE    this process never updates LLI Sequence ID
    476           */
    477          BOOL_TYPE SRTriacFeedbackLLI__OneMsProcess(HBL_LLI_TYPE * input)
    478          {
    479              (void) SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    480              if (input->Data_Index < SRTriacFeedbackLLI_Allocation)
    481              {
    482                  SRTRIACFEEDBACKLLI_DATA_TYPE *data = &SRTriacFeedbackLLI_Data[input->Data_Index];
    483                  SRTRIACFEEDBACKLLI_DATA_TYPE *n_data = &N_SRTriacFeedbackLLI_Data[input->Data_Index];
    484                  SRTRIACFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *) input->Parameter_Ptr.Data;
    485                  uint8 virtual_pin = input->Pin_Ptr[0];
    486                  GPIO_PIN_MODE_TYPE type = INPUT_FLOAT;
    487          
    488                  // Check if Pull up configuration to match Gpio__CheckConfig
    489                  if((feedback_param != NULL) &&
    490                      ((uint8) feedback_param->Pull_Up != 0U))
    491                  {
    492                      type = INPUT_PULLUP;
    493                  }
    494          
    495                  if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, type, FALSE))
    496                  {
    497                      uint8 pin_value = (uint8) Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    498                      uint16 pin_buffer;
    499          
    500                      // Inverted logic flag enabled
    501                      if((feedback_param != NULL) &&
    502                          ((uint8) feedback_param->Inverted != 0U))
    503                      {
    504                          pin_value = (pin_value == 0U) ? 1U : 0U;
    505                      }
    506          
    507                      // Update pin buffer with a new sample
    508                      (void) SRData__CheckShort(&data->Pin_Buffer, &n_data->Pin_Buffer);
    509                      pin_buffer = data->Pin_Buffer;
    510                      pin_buffer  <<= 1U;
    511                      pin_buffer |= (uint16) pin_value & 0x01U;
    512                      SRData__UpdateShort(&data->Pin_Buffer, &n_data->Pin_Buffer, pin_buffer);
    513          
    514                      // Update sampling counter
    515                      (void) SRData__CheckByte(&data->Sampling_Counter, &n_data->Sampling_Counter);
    516                      SRData__UpdateByte(&data->Sampling_Counter, &n_data->Sampling_Counter, data->Sampling_Counter + 1U);
    517                  }
    518              }
    519              return(FALSE);
    520          }
    521          
    522          //=====================================================================================================================
    523          //-------------------------------------- Private Functions ------------------------------------------------------------
    524          //=====================================================================================================================
    525          
    526          /*
    527           *
    528           */
    529          static void UpdateLastFrequencyTimingEvents(SRTRIACFEEDBACKLLI_DATA_TYPE *data_ptr, SRTRIACFEEDBACKLLI_DATA_TYPE *n_data_ptr, uint8 new_frequency_reference)
    530          {
    531              if(data_ptr->Is_Detecting_Frequency)
    532              {
    533                  BOOL_TYPE is_double_freq;
    534                  SRData__UpdateByte(&data_ptr->Time_Between_Frequency_Events, &n_data_ptr->Time_Between_Frequency_Events, new_frequency_reference - data_ptr->Last_Frequency_Event_Reference);
    535                  // Valid AC Signal frequency events happen within half of durationr range - e.g. 45 Hz (11.11ms) - 65 Hz (7.38ms) range
    536                  is_double_freq = (BOOL_TYPE) (data_ptr->Time_Between_Frequency_Events >= (uint8) MINIMUM_HALF_DURATION_ALLOWED);
    537                  is_double_freq = (BOOL_TYPE) (is_double_freq && (data_ptr->Time_Between_Frequency_Events <= (uint8) MAXIMUM_HALF_DURATION_ALLOWED));
    538                  SRData__UpdateByte((void *) &data_ptr->Is_Detecting_Double_Frequency,(void *)  &n_data_ptr->Is_Detecting_Double_Frequency,(uint8) is_double_freq);
    539              }
    540              SRData__UpdateByte(&data_ptr->Last_Frequency_Event_Reference, &n_data_ptr->Last_Frequency_Event_Reference, new_frequency_reference);
    541              SRData__UpdateByte((void *) &data_ptr->Is_Detecting_Frequency,(void *)  &n_data_ptr->Is_Detecting_Frequency,(uint8) TRUE);
    542          }
