    493          /**
    494           *
    495           */
    496          static void WaitForDiscovery(void)
    497          {
    498              AccelDiscover__Execute();
    499          
    500              if (AccelDiscover__IsComplete() == TRUE)
    501              {
    502                  EventDeviceIdentified();
    503              }
    504          }
