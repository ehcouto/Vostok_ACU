    285          /**
    286           * Pin setting required for FXLS8974 accelerometer
    287           */
    288          static void SetBootModeHigh(void)
    289          {
    290              Gpio__PinWrite(BOOT_MODE_PORT, BOOT_MODE_PIN, TRUE);
    291          }
    292          
    293          
    294          //---------------------------------------------------------------------------------------------------------------------
    295          /**
    296           * Pin setting required for FXLS8974 accelerometer
    297           */
    298          static void SetBootModeLow(void)
    299          {
    300              Gpio__PinConfig(BOOT_MODE_PORT, BOOT_MODE_PIN, OUTPUT_PUSHPULL);
    301              Gpio__PinWrite(BOOT_MODE_PORT, BOOT_MODE_PIN, FALSE);
    302          }
    303          
    304          
    305          //---------------------------------------------------------------------------------------------------------------------
    306          /**
    307           * Pin setting required for FXLS8974 accelerometer to use I2C/SPI communication
    308           */
    309          static void SetInterfaceMode(void)
    310          {
    311              Gpio__PinConfig(INTERFACE_SELECT_PORT, INTERFACE_SELECT_PIN, OUTPUT_PUSHPULL);
    312          #if (SPI_ENABLED == 1)
    313              Gpio__PinWrite(INTERFACE_SELECT_PORT, INTERFACE_SELECT_PIN, TRUE);                 // Pin high for SPI communication
    314          #else
    315              Gpio__PinWrite(INTERFACE_SELECT_PORT, INTERFACE_SELECT_PIN, FALSE);                // Pin low for I2C communication
    316          #endif
    317          }
    318          
    319          
    320          //---------------------------------------------------------------------------------------------------------------------
    321          /**
    322           * Start the timer to measure a potential timeout.
    323           */
    324          static void StartTimer(void)
    325          {
    326              AccelDiscover.Timer = 0;
    327          }
    328          
    329          
    330          //---------------------------------------------------------------------------------------------------------------------
    331          /**
    332           *
    333           */
    334          static void WaitForBootComplete(void)
    335          {
    336              if (AccelDiscover.Timer > ACCEL_TIME_BOOT_UP)
    337              {
    338                  EventBootComplete();
    339              }
    340          }
    341          
    342          
    343          //---------------------------------------------------------------------------------------------------------------------
    344          /**
    345           *
    346           */
    347          static void WaitForIdentity(void)
    348          {
    349              // Check if the accelerometer data has been received.
    350          #if (SPI_ENABLED == 1)
    351              if (Spi__GetStatus((SPI_ENUM_DEF)AccelDiscover.Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
    352              {
    353                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high now that transmission is complete
    354          #else
    355              if (I2c__GetStatus((I2C_ENUM_TYPE)AccelDiscover.Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
    356              {
    357          #endif
    358                  // Read the data that was received
    359                  uint8 data[3];
    360          #if (SPI_ENABLED == 1)
    361                  uint8 num_read_bytes = 2;               // Default value satisfies LISxDH accelerometer
    362                  if (AccelDiscover.Device_Index == 0U)    // NXP
    363                  {
    364                      num_read_bytes = 3;
    365                  }
    366          
    367                  if (Spi__Read((SPI_ENUM_DEF)AccelDiscover.Port, (void*)data, num_read_bytes))
    368          #else
    369                  if (I2c__Read((I2C_ENUM_TYPE)AccelDiscover.Port, (void*)data, sizeof(data)))
    370          #endif
    371                  {
    372                      // Check if the device ID received matches the expected ID
    373          #if (SPI_ENABLED == 1)
    374                      uint8 data_byte_position = 1;           // Default value satisfies LISxDH accelerometer
    375                      if (AccelDiscover.Device_Index == 0U)   // NXP
    376                      {
    377                          data_byte_position = 2;
    378                      }
    379          
    380                      if (data[data_byte_position] == ACCEL_DEVICE_IDS[AccelDiscover.Device_Index])
    381          #else
    382                      if (data[0] == ACCEL_DEVICE_IDS[AccelDiscover.Device_Index])
    383          #endif
    384                      {
    385          #if (SPI_ENABLED == 1)
    386                          AccelDiscover.Id = data[data_byte_position];
    387          #else
    388                          AccelDiscover.Id = data[0];
    389          #endif
    390                          EventIdentityReceived();
    391                      }
    392                      else
    393                      {
    394                          // Try the next device
    395                          AccelDiscover.Device_Index++;
    396                          if (AccelDiscover.Device_Index >= NUM_DEVICES)
    397                          {
    398                              AccelDiscover.Device_Index = 0;
    399                          }
    400                          EventWrongIdentity();
    401                      }
    402                  }
    403              }
    404          
    405              if (AccelDiscover.Timer > I2C_TIMEOUT_READY)
    406              {
    407                  EventTimeout();
    408          
    409                  // Try the next device
    410                  AccelDiscover.Device_Index++;
    411                  if (AccelDiscover.Device_Index >= NUM_DEVICES)
    412                  {
    413                      AccelDiscover.Device_Index = 0;
    414                  }
    415              }
    416          }
    417          
    418          
    419          //---------------------------------------------------------------------------------------------------------------------
    420          /**
    421           *
    422           */
    423          static void WaitForTimer(void)
    424          {
    425              if (AccelDiscover.Timer > 100U)
    426              {
    427                  EventTimerExpired();
    428              }
    429          }
