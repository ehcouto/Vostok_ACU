     39          #define SRDOORLOCKWAX_INITIAL_PERIOD        20
     40          #define SRDOORLOCKWAX_TIMING_REF			10
     41          #define SRDOORLOCKWAX_MAX_DEBOUNCE			2
     42          
     43          #define ZC_ALLOWED_MIN_FREQUENCY            45
     44          #define ZC_ALLOWED_MAX_FREQUENCY            65
     45          
     46          // Minimum and maximum period from ZeroCross frequency boundaries set - Round to near
     47          #define SRDOORLOCKWAX_MIN_PERIOD_MS		((2000+ZC_ALLOWED_MAX_FREQUENCY)/(ZC_ALLOWED_MAX_FREQUENCY*2))
     48          #define SRDOORLOCKWAX_MAX_PERIOD_MS		((2000+ZC_ALLOWED_MIN_FREQUENCY)/(ZC_ALLOWED_MIN_FREQUENCY*2))
     49          
     50          
     51          typedef enum SRDOORLOCKWAX_STATUS_ENUM
     52          {
     53          	SRDOORLOCKWAX_STATUS_INIT,
     54          	SRDOORLOCKWAX_STATUS_DOOR_UNLOCKED,
     55          	SRDOORLOCKWAX_STATUS_DOOR_LOCKING,
     56          	SRDOORLOCKWAX_STATUS_DOOR_LOCKING_FAILED,
     57          	SRDOORLOCKWAX_STATUS_DOOR_LOCKED,
     58          	SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING,
     59          	SRDOORLOCKWAX_STATUS_DOOR_UNLOCKING_FAILED
     60          } SRDOORLOCKWAX_STATUS_TYPE;
     61          
     62          PACKED typedef struct
     63          {
     64          	uint8 Requested;
     65          	uint8 Processed;
     66          	HBL_LOAD_STATUS_TYPE PilotStatus;
     67          	SRDOORLOCKWAX_STATUS_TYPE Status;
     68          	uint16 Counter;
     69          	uint16 Fbk_Timeout_Counter;
     70          	uint8 Fbk_Counter;
     71          	uint8 Fbk_Last_Counter;
     72          	uint8 Fbk_Period;
     73          	sint8 Fbk_Offset;
     74          	uint8 Fbk_Last_Pin_Value;
     75          	uint8 Last_Pin_Out_Value;
     76          	uint8 Wait_Trigger;
     77          	uint8 Debounce;
     78          	uint8 TimingRef;
     79          	uint8 Fbk_Pin;
     80          } SRDOORLOCKWAXPILOT_DATA_TYPE;
     81          
     82          typedef struct
     83          {
     84          	uint16 Unlock_Timeout;
     85          	uint16 Lock_Timeout;
     86          	uint8 Duty_On;
     87          	uint8 Duty_Off;
     88          	uint8 Filter_Time;
     89          	uint8 Unused;
     90          } SRDOORLOCKWAXPILOT_PARAM_TYPE;
