    110          //! The time required for the Accelerometer to initialize itself.
    111          //! NOTE: This value is based on the call rate of LISxDH__Background()
    112          #define ACCEL_TIME_BOOT_UP          20U
    113          
    114          //! The timeout after which the module decides that the I2C bus will never become available.
    115          //! NOTE: This value is based on the call rate of LISxDH__Background()
    116          #define I2C_TIMEOUT_READY           100U // 100 * 200us = 20ms
    117          
    118          //! Number of accelerometers that can be discovered by this module
    119          #define NUM_DEVICES 2U
    120          
    121          //! The command sent to the accelerometer to request the device identification data
    122          #if (SPI_ENABLED == 1)
    123          // RW bit shall be 1 for a read command; MS bit shall be 0 to read only 1 register
    124          static const uint8 ACCEL_IDENTIFY_REGISTERS[NUM_DEVICES] =
    125          {
    126              0x93,   // NXP FXLS8974
    127              0x8F    // ST LISxDH
    128          };
    129          #else
    130          //! WARNING! The order of content in this list must match the order in ACCEL_IDENTIFY_REGISTERS (this could be refactored to remove this dependency)
    131          static const uint8 ACCEL_IDENTIFY_REGISTERS[NUM_DEVICES] =
    132          {
    133              0x13,   // NXP FXLS8974
    134              0x0F    // ST LISxDH
    135          };
    136          #endif
    137          
    138          //! List of expected device IDs
    139          //! WARNING! The order of content in this list must match the order in ACCEL_IDENTIFY_REGISTERS (this could be refactored to remove this dependency)
    140          static const uint8 ACCEL_DEVICE_IDS[NUM_DEVICES] =
    141          {
    142              0x86,   // NXP FXLS8974
    143              0x33    // ST LISxDH
    144          };
