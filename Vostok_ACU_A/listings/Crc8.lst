     69          /**
     70           *  @brief  	This method calculates a CRC8-Maxim 1 Wire based on a data table
     71           *
     72           *  @param		init	initial value for the crc
     73           *  @param		buf		pointer to the data array
     74           *  @param		size	size of the buffer
     75           *  @return     unsigned char Result of the calculation
     76           */

   \                                 In section .text, align 4, keep-with-next
     77          uint8 Crc8(uint8 init,uint8 * buf, uint8 size)
     78          {
   \                     Crc8: (+1)
   \   00000000   0xB430             PUSH     {R4,R5}
     79          	uint8 crc;
     80          	uint8 count;
     81          	crc = init;
     82          	for ( count = 0 ; count < size ; count++)
   \   00000002   0x2300             MOVS     R3,#+0
   \   00000004   0xE006             B        ??Crc8_0
     83          	{
     84          		crc = CRC8_TABLE[(crc ^buf[count] )];
   \                     ??Crc8_1: (+1)
   \   00000006   0xBF00             Nop      
   \   00000008   0x....             ADR.N    R4,CRC8_TABLE
   \   0000000A   0xB2DB             UXTB     R3,R3
   \   0000000C   0x5CCD             LDRB     R5,[R1, R3]
   \   0000000E   0x4045             EORS     R5,R5,R0
   \   00000010   0x5D60             LDRB     R0,[R4, R5]
     85          	}
   \   00000012   0x1C5B             ADDS     R3,R3,#+1
   \                     ??Crc8_0: (+1)
   \   00000014   0x001C             MOVS     R4,R3
   \   00000016   0x0015             MOVS     R5,R2
   \   00000018   0xB2E4             UXTB     R4,R4
   \   0000001A   0x42AC             CMP      R4,R5
   \   0000001C   0xD3F3             BCC      ??Crc8_1
     86          	return (crc);
   \   0000001E   0xBC30             POP      {R4,R5}
   \   00000020   0x4770             BX       LR               ;; return
     87          }
     88          
     89          //---------------------------------------------------------------------------------------------------------------------
     90          /**
     91           * @brief This method process one step CRC8-Maxim 1 Wire process
     92           * @param previews is the previews crc value
     93           * @param data is the data to be used in the calculation in the crc
     94           * @return result of the crc computation.
     95           */

   \                                 In section .text, align 4, keep-with-next
     96          uint8 Crc8__ProcessByte(uint8 previews,uint8 data)
     97          {
     98              return (CRC8_TABLE[(previews ^ data )]);
   \                     Crc8__ProcessByte: (+1)
   \   00000000   0x....             ADR.N    R2,CRC8_TABLE
   \   00000002   0x4041             EORS     R1,R1,R0
   \   00000004   0x5C50             LDRB     R0,[R2, R1]
   \   00000006   0x4770             BX       LR               ;; return
     99          }
