    484                              // Master Mode Enable, Spi Enabled.
    485                              SPI_2.CR1 = SPI_2_CR1_BR | SPI_2_CR1_CPOL | SPI_2_CR1_CPHA | SPI_2_CR1_LSBFIRST | SPI_CR1_SSM | SPI_CR1_SSI | SPI_CR1_MSTR | SPI_CR1_BIDIMODE | SPI_CR1_BIDIOE;
