    565              if (I2c__Initialize(I2c_Infrared_Lli.Sf->I2c_Channel, I2C_400KHZ, I2C_ADDR_7BITS, MLX_EEPROM_DEVICE_ADDRESS) == TRUE)
    566              {
    567                  EventProceed();
    568              }
    569              else
    570              {
    571                  EventFail();
    572              }
    573          }
