    889          /**
    890           * @brief   This API is been called from the API007Data__FeedbackParser() in response of API007_OP_REQ_READ_NVDATA command from server
    891           *
    892           * @details Enabled only for client side
    893           *
    894           * @param index - Read index
    895           * @param size - Number of Read data size
    896           * @param data_ptr - Source data memory location
    897           */
    898          void API007NVData__ReceivedRead(uint16 index ,uint16 size, uint8 * data_ptr)
    899          {
    900              #if(API007NVDATA_CLIENT_FEATURE == ENABLED)
    901                  if ((index + size) <= API007NVDATA_DATA_SECTION_SIZE)
    902                  {
    903                      memcpy(API007NVDATA_DATA_SECTION_START + index, data_ptr, size);
    904          
    905                      API007NVData_Client_Data_Index = index + size;
    906                      API007NVData_Client_Server_Fbk = RECEIVED_READ_NVDATA_FBK_PASS;
    907                  }
    908                  else
    909                  {
    910                      API007NVData_Client_Server_Fbk = RECEIVED_READ_NVDATA_FBK_FAILED;
    911                  }
    912              #endif//(API007NVDATA_CLIENT_FEATURE == ENABLED)
    913          }
