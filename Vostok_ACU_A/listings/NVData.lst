     84              // The following definitions will determine how the appliance segment data will be restored after a reset
     85              // The values are obscure to eliminate any impact from an inadvertent change to the variable.
     86              #define APPLIANCE_SEGMENT_CORRUPT   0xC3    //!< Indicates the appliance segment should be reported as corrupt
     87              #define APPLIANCE_SEGMENT_RESTORE   0xE8    //!< Indicates the appliance segment should be restored through the normal process
     88          
     89              //! Indicates whether the appliance segment should be reported as corrupt, ignoring the normal process used to restore the data.
     90              //! Unique values are used to eliminate an impact from an inadvertent change to the variable.
     91              //! A value of APPLIANCE_SEGMENT_CORRUPT means the segment should get corrupted on the next reset.
     92              //! A value of APPLIANCE_SEGMENT_RESTORE means the segment should be restored through the normal process on the next reset.
