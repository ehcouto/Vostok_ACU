    789          /**
    790           *    @brief    Updates a register based on a mask
    791           *    @param    current
    792           *    @param    mask
    793           *    @param    value
    794           *    @return   uint8 updated value
    795           */

   \                                 In section .text, align 2, keep-with-next
    796          static uint32 UpdateMaskedRegister(uint32 current,uint32 mask, uint32 value)
    797          {
    798              uint32 reg;
    799              uint32 aux;
    800          
    801              aux = mask & (~value);                      //It generates a sub-mask to clear bits
    802              reg = current & (~aux);
    803              aux = mask & value;                         //It generates a sub-mask to set bits
    804              reg = reg | aux;                            //It sets the bits supposed to be set
    805              return (reg);
