    376          //---------------------------------------------------------------------------------------------------------------------
    377          /**
    378           *    @brief    It clear the state machines which are meant for I2C communication
    379           *    @details  A software reset can be performed by disabling the I2c peripheral for at least 3 APB clock cycles and
    380           *              then turning it Enabled
    381           *    @param    i2c : I2c module i.e. I2c1 or I2c2 device
    382           *
    383           *    @image html I2c__Clear.jpg
    384           */

   \                                 In section .text, align 2, keep-with-next
    385          void I2c__Clear(I2C_ENUM_TYPE i2c)
    386          {
    387              #if ((I2C1_FEATURE == ENABLED) || (I2C2_FEATURE == ENABLED) || (I2C3_FEATURE == ENABLED))
    388          
    389                  #if (I2C1_FEATURE == ENABLED)
    390                      if (i2c == I2C1)
    391                      {
    392                          // A software reset can be performed by disabling the I2c peripheral for at least 3 APB clock cycles and
    393                          // then turning it Enabled
    394                          // Turn-off the I2c1
    395                          I2C_1.CR1 &= (uint32)(~I2C_CR1_PE);
    396          
    397                          //Clear the NBYTES
    398                          I2C_1.CR2 &= (uint32)(~I2C_CR2_NBYTES);
    399          
    400                          I2c1_TxPointer = 0;
    401                          I2c1_RxPointer = 0;
    402                          I2c1_Ack_Error = I2C_ERROR_NONE;
    403          
    404                          //Enable the I2c2
    405                          I2C_1.CR1 |= I2C_CR1_PE;
    406                      }
    407                  #endif
    408          
    409                  #if (I2C2_FEATURE == ENABLED)
    410                      if (i2c == I2C2)
    411                      {
    412                          // A software reset can be performed by disabling the I2c peripheral for at least 3 APB clock cycles and
    413                          // then turning it Enabled
    414                          // Turn-off the I2c1
    415                          I2C_2.CR1 &= (uint32)(~I2C_CR1_PE);
    416          
    417                          //Clear the NBYTES
    418                          I2C_2.CR2 &= (uint32)(~I2C_CR2_NBYTES);
    419          
    420                          I2c2_TxPointer = 0;
    421                          I2c2_RxPointer = 0;
    422                          I2c2_Ack_Error = I2C_ERROR_NONE;
    423          
    424                          //Enable the I2c2
    425                          I2C_2.CR1 |= I2C_CR1_PE;
    426                      }
    427                  #endif
    428          
    429                  #if (I2C3_FEATURE == ENABLED)
    430                      if (i2c == I2C3)
    431                      {
    432                          // A software reset can be performed by disabling the I2c peripheral for at least 3 APB clock cycles and
    433                          // then turning it Enabled
    434                          // Turn-off the I2c1
    435                          I2C_3.CR1 &= (uint32)(~I2C_CR1_PE);
    436          
    437                          //Clear the NBYTES
    438                          I2C_3.CR2 &= (uint32)(~I2C_CR2_NBYTES);
    439          
    440                          I2c3_TxPointer = 0;
    441                          I2c3_RxPointer = 0;
    442                          I2c3_Ack_Error = I2C_ERROR_NONE;
