    434          //---------------------------------------------------------------------------------------------------------------------
    435          /**
    436           * Initialize the Accelerometer variables.
    437           */
    438          void LISxDH__Initialize(LISXDH_SF_PARAM_TYPE * param_ptr)
    439          {
    440          #if ACCELEROMETER_ENABLED == 1
    441              // Clear all module RAM variables.
    442              memset(&LISxDH, 0, sizeof(LISxDH));
    443          
    444              #if (ACCEL_COMM_TEST == ENABLED)
    445                  // Clear the failure indicator.
    446                  ACCEL_FAILURE_INDICATOR_OFF();
    447                  ACCEL_FAILURE_INDICATOR_CONFIG();
    448                  LISxDH.Mode_Requested = LISXDH_MODE_400HZ;
    449              #endif
    450          
    451              if (param_ptr == NULL)
    452              {
    453                  LISxDH.SF_Param_Ptr = &ACCELEROMETERLLI_DEFAULT_SF_PARAM;
    454              }
    455              else
    456              {
    457                  LISxDH.SF_Param_Ptr = param_ptr;
    458              }
    459          
    460              // Configure the chip select pin
    461              Gpio__PinConfig(SPI_CS_PORT, SPI_CS_PIN, OUTPUT_PUSHPULL);
    462          #if (SPI_ENABLED == 0)
    463              // For I2C, the chip select line must be tied high (per the datasheet)
    464              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);
    465          #endif
    466          
    467              // Start the state machine.
    468              LisxdhInitialize();
    469          #endif
    470          }
    471          
    472          
    473          //---------------------------------------------------------------------------------------------------------------------
    474          /**
    475           * Execute the background function for the LISxDH module.
    476           */
    477          void LISxDH__Background(void)
    478          {
    479          #if ACCELEROMETER_ENABLED == 1
    480              // Update the local time keeping variable.
    481              LISxDH.Timer++;
    482          
    483              // Run the state machine.
    484              LisxdhExecute();
    485          
    486              #if (ACCEL_COMM_TEST == ENABLED)
    487                  if (LISxDH.Failure_Indicator_Timer > 0)
    488                  {
    489                      LISxDH.Failure_Indicator_Timer--;
    490                      ACCEL_FAILURE_INDICATOR_ON();
    491                  }
    492                  else
    493                  {
    494                      ACCEL_FAILURE_INDICATOR_OFF();
    495                  }
    496          
    497                  LISxDH.Reference_Counter++;
    498              #endif
    499          #endif
    500          }
    501          
    502          
    503          //---------------------------------------------------------------------------------------------------------------------
    504          /**
    505           * Request that the accelerometer be disabled.
    506           */
    507          void LISxDH__Disable(void)
    508          {
    509          #if ((ACCELEROMETER_ENABLED == 1) && (ACCEL_COMM_TEST == DISABLED))
    510              LISxDH.Mode_Requested = LISXDH_MODE_DISABLED;
    511          #endif
    512          }
    513          
    514          
    515          //---------------------------------------------------------------------------------------------------------------------
    516          /**
    517           * Request that the accelerometer be enabled.
    518           * @param mode = The type of operation that is desired.
    519           */
    520          void LISxDH__Enable(LISXDH_MODE_TYPE mode)
    521          {
    522          #if ACCELEROMETER_ENABLED == 1
    523              // Save the requested state. The state machine will react if necessary.
    524              if (mode < LISXDH_MODE_COUNT)
    525              {
    526                  LISxDH.Mode_Requested = mode;
    527              }
    528          #endif
    529          }
    530          
    531          
    532          //---------------------------------------------------------------------------------------------------------------------
    533          /**
    534           * Flush any data currently in the Points[] queue.
    535           */
    536          void LISxDH__FlushData(void)
    537          {
    538          #if ACCELEROMETER_ENABLED == 1
    539              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    540              MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();       // Save and disable interrupts
    541              uint8 read_index = LISxDH.Read + LISxDH.Number_Of_Points;
    542              if (read_index >= LISXDH_MAX_POINTS)
    543              {
    544                  read_index -= LISXDH_MAX_POINTS;
    545              }
    546              LISxDH.Read = read_index;
    547              LISxDH.Number_Of_Points = 0;
    548              MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();    // Restore interrupts
    549          #endif
    550          }
    551          
    552          
    553          //---------------------------------------------------------------------------------------------------------------------
    554          /**
    555           * Get the status of the LISxDH module.
    556           * @return The status of the LISxDH module.
    557           */
    558          ACCELEROMETER_STATUS_TYPE LISxDH__GetStatus(void)
    559          {
    560          #if ACCELEROMETER_ENABLED == 1
    561              switch (Lisxdh_State)
    562              {
    563                  case STATE_LISXDH_BOOT_DELAY:
    564                  case STATE_LISXDH_RESTART:
    565                      return ACCELEROMETER_INITIALIZING;
    566          
    567                  case STATE_LISXDH_LOW_POWER_MODE:
    568                      return ACCELEROMETER_DISABLED;
    569          
    570                  case STATE_LISXDH_APP_BUFFER_FULL:
    571                      return ACCELEROMETER_BUFFER_FULL;
    572          
    573                  case STATE_LISXDH_HIGH_RES_MODE:
    574                  case STATE_LISXDH_READ_DATA:
    575                  case STATE_LISXDH_READ_TEMP:
    576                      return ACCELEROMETER_ACQUIRING;
    577          
    578                  case STATE_LISXDH_NONE:
    579                  default:
    580                      return ACCELEROMETER_UNKNOWN;
    581              }
    582          #else
    583              return ACCELEROMETER_DISABLED;
    584          #endif
    585          }
    586          
    587          
    588          //---------------------------------------------------------------------------------------------------------------------
    589          /**
    590           *
    591           * @return  Temperature variation from a reference temperature in Celsius
    592           */
    593          sint8 LISxDH__GetTemperatureDelta(void)
    594          {
    595              return(LISxDH.Temperature_Delta);
    596          }
    597          
    598          
    599          //---------------------------------------------------------------------------------------------------------------------
    600          /**
    601           * Read a single XYZ acceleration vector from the Accelerometer module's buffer.
    602           * @param vector = Pointer to an array of three signed 16-bit values for the XYZ data.
    603           *                 Each point is stored as a signed Q4.8 fixed-point value.
    604           * @return TRUE if vector was updated with a single XYZ point. FALSE if the buffer is empty.
    605           */
    606          BOOL_TYPE LISxDH__Read(sint16* vector)
    607          {
    608              BOOL_TYPE retval = FALSE;
    609          #if ACCELEROMETER_ENABLED == 1
    610              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    611          
    612              if (LISxDH.Number_Of_Points > 0U)
    613              {
    614                  memcpy(vector, LISxDH.Points[LISxDH.Read], 6);
    615          
    616                  // Adjust the read pointer and the number of accelerometer points.
    617                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();       // Save and disable interrupts
    618                  LISxDH.Read++;
    619                  if (LISxDH.Read >= LISXDH_MAX_POINTS)
    620                  {
    621                      LISxDH.Read = 0;
    622                  }
    623                  LISxDH.Number_Of_Points--;
    624                  //Restore Interrupts
    625                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();    // Restore interrupts
    626                  retval = TRUE;
    627              }
    628          #endif
    629              return(retval);
    630          }
    631          
    632          
    633          //=====================================================================================================================
    634          //  --- Private Functions ---------------------------------------------------------------------------------------------
    635          //=====================================================================================================================
    636          
    637          
    638          //=====================================================================================================================
    639          //  --- Private State Machine Customization Functions -----------------------------------------------------------------
    640          //=====================================================================================================================
    641          
    642          
    643          //---------------------------------------------------------------------------------------------------------------------
    644          /**
    645           * Send configuration data to the accelerometer to disable it.
    646           */
    647          static void AccelDisable(void)
    648          {
    649              if (LISxDH.Mode_Requested == LISXDH_MODE_DISABLED)
    650              {
    651                  // Send disable command to the accelerometer.
    652          #if (SPI_ENABLED == 1)
    653                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);     // Pull chip select low during transmission
    654                  (void)Spi__Write((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)ACCEL_CMD_DISABLE, sizeof(ACCEL_CMD_DISABLE));
    655          #else
    656                  I2c__Write((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, ACCEL_MULTIPLE_BYTES | ACCEL_REG_CTRL_1,
    657                             (void*)ACCEL_CMD_DISABLE, sizeof(ACCEL_CMD_DISABLE));
    658          #endif
    659                  LISxDH.Mode_Processed = LISXDH_MODE_DISABLED;
    660              }
    661              LISxDH.Number_Of_Points = 0;
    662          }
    663          
    664          
    665          //---------------------------------------------------------------------------------------------------------------------
    666          /**
    667           * Send configuration data to the accelerometer to enable it.
    668           */
    669          static void AccelEnable(void)
    670          {
    671              if (LISxDH.Mode_Requested == LISXDH_MODE_NORMAL)
    672              {
    673                  #if (SPI_ENABLED == 1)
    674                      Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
    675                  #endif
    676          
    677                  // Send enable commands to the accelerometer.
    678                  StartTimer();
    679          
    680                  // Determine the value to de-scale the reading so that the units are always 1mg/digit
    681          
    682                  const uint8 SCALE_FACTOR[] = {1, 2, 4, 8};       /* Scale = 0 (2g), Scale = 1 (4g), Scale = 2 (8g), Scale = 3 (16g) */
    683                  const uint8 RESOLUTION_FACTOR[] = {16, 4, 1};    /* Res = 0 (8 bits), Res = 1 (10 bits), Res = 2 (12 bits) */
    684                  LISxDH.Scale_Factor = SCALE_FACTOR[LISxDH.SF_Param_Ptr->Scale] * RESOLUTION_FACTOR[LISxDH.SF_Param_Ptr->Resolution];
    685          
    686                  LISXDH_SF_PARAM_TYPE * ptr;                 // Create local variable to make code more readable
    687                  ptr = LISxDH.SF_Param_Ptr;
    688                  uint8 enable_command[6] = {0,0,0,0,0,0};    // 6 registers: TEMP_CFG_REG + CTRL_REG1 to CTRL_REG5
    689          
    690                  // Set configuration for TEMP_CFG_REG
    691                  enable_command[0] = 0xC0;                   // Enable Temperature reading
    692          
    693                  // Set configuration for CTRL_REG1
    694                  enable_command[1] = ((uint8)ptr->Data_Rate << 4) | ((uint8)ptr->Z_Axis_Enabled << 2) | ((uint8)ptr->Y_Axis_Enabled << 1) | ((uint8)ptr->X_Axis_Enabled);
    695          
    696                  // Set configuration for CTRL_REG3
    697                  if ((uint8)ptr->Trigger_Source == 0U)       // INT1
    698                  {
    699                      enable_command[3] = 0x10;               // Use Data Ready 1 interrupt
    700                  }
    701          
    702                  // Set configuration for CTRL_REG4
    703                  enable_command[4] = ((uint8)ptr->Block_Update << 7U) | ((uint8)ptr->Big_Endian << 6U) | ((uint8)ptr->Scale << 4U);
    704          
    705                  if (ptr->Resolution == 2U)
    706                  {
    707                      enable_command[4] |= (1U << 3U);          // Set High Resolution bit
    708                  }
    709          
    710                  // Set configuration for CTRL_REG5
    711                  if (ptr->Fifo_Mode == 1U)
    712                  {
    713                      enable_command[5] = (1U << 6U);
    714                  }
    715          
    716                  // NOTE: The FIFO_CTRL_REG (2Eh) register is not configured
    717                  // Default behavior will be Bypass mode for the FIFO and a trigger event using INT1
    718                  // FM1-FM0 bits should be set based on the Fifo_Mode parameter
    719                  // TR bit should be set based on the Trigger_Source parameter
    720          
    721          #if (SPI_ENABLED == 1)
    722                  // Need to add the register address to the data for SPI as there is no argument in Spi__Write that automatically appends this
    723                  uint8 spi_command[7];
    724                  spi_command[0] = MS_MULTIPLE | ACCEL_REG_TEMP_CFG;
    725                  for (uint8 index = 0; index < 6U; index++)
    726                  {
    727                      spi_command[index + 1U] = enable_command[index];
    728                  }
    729                  (void)Spi__Write((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)spi_command, sizeof(spi_command));
    730          #else
    731                  I2c__Write((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, ACCEL_MULTIPLE_BYTES | ACCEL_REG_TEMP_CFG,
    732                             (void*)enable_command, sizeof(enable_command));
    733          #endif
    734                  LISxDH.Mode_Processed = LISxDH.Mode_Requested;
    735              }
    736              else if ((LISxDH.Mode_Requested == LISXDH_MODE_ST_REF) ||
    737                       (LISxDH.Mode_Requested == LISXDH_MODE_ST_0) ||
    738                       (LISxDH.Mode_Requested == LISXDH_MODE_ST_1))
    739              {
    740                  // Send enable commands to the accelerometer.
    741                  StartTimer();
    742                  uint8 index = (uint8)LISxDH.Mode_Requested - 2U; // Adjust index into ACCEL_CMD_SELF_TEST_ENABLE table based on LISXDH_MODE_TYPE
    743          
    744                  // No scaling during self test
    745                  LISxDH.Scale_Factor = 1;
    746          
    747          #if (SPI_ENABLED == 1)
    748                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);     // Pull chip select low during transmission
    749                  (void)Spi__Write((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)ACCEL_CMD_SELF_TEST_ENABLE[index], sizeof(ACCEL_CMD_SELF_TEST_ENABLE[index]));
    750          #else
    751                  I2c__Write((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, ACCEL_MULTIPLE_BYTES | ACCEL_REG_CTRL_1,
    752                             (void*)ACCEL_CMD_SELF_TEST_ENABLE[index], sizeof(ACCEL_CMD_SELF_TEST_ENABLE[index]));
    753          #endif
    754                  LISxDH.Mode_Processed = LISxDH.Mode_Requested;
    755              }
    756          }
    757          
    758          
    759          //---------------------------------------------------------------------------------------------------------------------
    760          /**
    761           * Initialize the microcontroller peripherals used by the Accelerometer module.
    762           */
    763          static void AccelHwInit(void)
    764          {
    765          #if (SPI_ENABLED == 1)
    766              Spi__Initialize((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port);
    767              Spi__SetConfiguration((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, SPI_POLARITY_SCK_IDLE_1, SPI_EDGE_SECOND, SPI_ODER_MSB_FIRST);
    768              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high (reset CS)
    769          #else
    770              // Setup the I2C peripheral.
    771              // NOTE: The I2C module includes the I2C R/W bit as part of the address.
    772              I2c__Initialize((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, (I2C_SPEED_TYPE)LISxDH.SF_Param_Ptr->I2C_Speed, I2C_ADDR_7BITS, (LISxDH.SF_Param_Ptr->I2C_Address << 1));
    773          
    774          #endif
    775          
    776              // Perform any necessary custom configuration.
    777              LISXDH_CUSTOM_CONFIGURATION();
    778          }
    779          
    780          
    781          //---------------------------------------------------------------------------------------------------------------------
    782          /**
    783           * Send a command to the accelerometer to read a single XYZ data point.
    784           */
    785          static void AccelReadOneShot(void)
    786          {
    787          #if (SPI_ENABLED == 1)
    788          
    789              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
    790              (void)Spi__Write((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)ACCEL_CMD_READ, sizeof(ACCEL_CMD_READ));
    791          #else
    792              I2c__WriteThenRead((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port,
    793                                 (void*)ACCEL_CMD_READ, sizeof(ACCEL_CMD_READ),
    794                                 sizeof(ACCEL_READ_REGISTERS_TYPE));
    795          #endif
    796          }
    797          
    798          
    799          //---------------------------------------------------------------------------------------------------------------------
    800          /**
    801           *
    802           */
    803          static void AccelReadTemp(void)
    804          {
    805          #if (SPI_ENABLED == 1)
    806              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
    807              (void)Spi__Write((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)ACCEL_CMD_READ_TEMPERATURE, sizeof(ACCEL_CMD_READ_TEMPERATURE));
    808          #else
    809              I2c__WriteThenRead((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port,
    810                                 (void*)ACCEL_CMD_READ_TEMPERATURE, sizeof(ACCEL_CMD_READ_TEMPERATURE),
    811                                 sizeof(ACCEL_READ_TEMPERATURE_TYPE));
    812          #endif
    813          }
    814          
    815          
    816          //---------------------------------------------------------------------------------------------------------------------
    817          /**
    818           * Determine if the application buffer is full.
    819           */
    820          static void CheckAppBuffer(void)
    821          {
    822              if (LISxDH.Mode_Processed != LISxDH.Mode_Requested)
    823              {
    824                  EventDisable();
    825              }
    826              else if (LISxDH.Number_Of_Points < LISXDH_MAX_POINTS)
    827              {
    828                  EventBufferHasSpace();
    829              }
    830          }
    831          
    832          
    833          //---------------------------------------------------------------------------------------------------------------------
    834          /**
    835           * Enable the accelerometer if requested by the application.
    836           */
    837          static void CheckForEnable(void)
    838          {
    839              if (LISxDH.Mode_Requested != LISXDH_MODE_DISABLED)
    840              {
    841          #if (SPI_ENABLED == 1)
    842                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high to prepare for future messages
    843          #endif
    844                  EventEnable();
    845              }
    846          }
    847          
    848          
    849          //---------------------------------------------------------------------------------------------------------------------
    850          /**
    851           * Determine if a request has been made to disable the module.
    852           * @return TRUE if a request has been made to disable the module; otherwise FALSE.
    853           */
    854          static BOOL_TYPE IsDisableRequested(void)
    855          {
    856              return (BOOL_TYPE)(LISxDH.Mode_Requested == LISXDH_MODE_DISABLED);
    857          }
    858          
    859          
    860          //---------------------------------------------------------------------------------------------------------------------
    861          /**
    862           *
    863           * @return
    864           */
    865          static BOOL_TYPE ReadTemp(void)
    866          {
    867              LISxDH.Temperature_Read_Delay_Count++;
    868          
    869              if (LISxDH.Temperature_Read_Delay_Count >= 5U)
    870              {
    871                  LISxDH.Temperature_Read_Delay_Count = 0;
    872                  return(TRUE);
    873              }
    874              else
    875              {
    876                  return(FALSE);
    877              }
    878          }
    879          
    880          
    881          //---------------------------------------------------------------------------------------------------------------------
    882          /**
    883           * Send a log message to indicate that at least one XYZ data point was lost.
    884           * This message will occur when the data is received faster than the application can process it.
    885           */
    886          static void ReportTooMuchData(void)
    887          {
    888              LOG_ADD_EXCEPTION(TOO_MUCH_DATA, LISXDH_MAX_POINTS);
    889              ACCELEROMETER_DATA_OVERFLOW();
    890          }
    891          
    892          
    893          //---------------------------------------------------------------------------------------------------------------------
    894          /**
    895           * Start the timer to measure a potential timeout.
    896           */
    897          static void StartTimer(void)
    898          {
    899              LISxDH.Timer = 0;
    900          }
    901          
    902          
    903          //---------------------------------------------------------------------------------------------------------------------
    904          /**
    905           * Wait the necessary boot up time for the accelerometer hardware.
    906           */
    907          static void WaitForBootComplete(void)
    908          {
    909              if (LISxDH.Timer > ACCEL_TIME_BOOT_UP)
    910              {
    911                  EventBootComplete();
    912              }
    913          }
    914          
    915          
    916          //---------------------------------------------------------------------------------------------------------------------
    917          /**
    918           * Wait for the read process to complete on the I2C bus and then capture the acceleration data.
    919           */
    920          static void WaitForData(void)
    921          {
    922              // Check if the accelerometer data has been received.
    923          #if (SPI_ENABLED == 1)
    924              if (Spi__GetStatus((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
    925              {
    926                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high now that transmission is complete
    927          #else
    928              if (I2c__GetStatus((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
    929              {
    930          #endif
    931                  // Verify that there is space remaining in the application buffer for the new data.
    932                  #if (ACCEL_COMM_TEST == ENABLED)
    933                      if (LISxDH.Number_Of_Points >= LISXDH_MAX_POINTS)
    934                      {
    935                          LISxDH.Number_Of_Points = 0;
    936                      }
    937                  #endif
    938                  if (LISxDH.Number_Of_Points < LISXDH_MAX_POINTS)
    939                  {
    940                      // Read the data that was received
    941                      ACCEL_READ_REGISTERS_TYPE data;
    942          #if (SPI_ENABLED == 1)
    943                      (void)Spi__Read((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_READ_REGISTERS_TYPE));
    944          #else
    945                      if (I2c__Read((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_READ_REGISTERS_TYPE)) == TRUE)
    946          #endif
    947                      {
    948                          if (data.Overrun != 0U)
    949                          {
    950                              LOG_ADD_EXCEPTION(DETECTED_OVERRUN, COMBINE_NIBBLES(data.Overrun, data.Available));
    951                              ACCELEROMETER_DATA_OVERWRITTEN();
    952                          }
    953          
    954                          // Move the write_index to the next point in the circular buffer.
    955                          uint8 write_index = LISxDH.Read + LISxDH.Number_Of_Points;
    956                          if (write_index >= LISXDH_MAX_POINTS)
    957                          {
    958                              write_index -= LISXDH_MAX_POINTS;
    959                          }
    960          
    961                          // Copy the acceleration measurements for the application to use
    962                          // Transform the position of the axis data and the sign to match the orientation of the PCB
    963                          LISxDH.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_X)] = (TRANSFORM_MULTIPLIER(MAP_AXIS_X) * (data.Points[0] >> 4)) * LISxDH.Scale_Factor;
    964                          LISxDH.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_Y)] = (TRANSFORM_MULTIPLIER(MAP_AXIS_Y) * (data.Points[1] >> 4)) * LISxDH.Scale_Factor;
    965                          LISxDH.Points[write_index][TRANSFORM_AXIS(MAP_AXIS_Z)] = (TRANSFORM_MULTIPLIER(MAP_AXIS_Z) * (data.Points[2] >> 4)) * LISxDH.Scale_Factor;
    966                          LISxDH.Number_Of_Points++;
    967          
    968                          #if (ACCEL_COMM_TEST == ENABLED)
    969                              LISxDH.XYZ_Point_Counter++;
    970                          #endif
    971          
    972                          LISxDH.Failure_Counter = 0;     // Reset failure counter
    973                      }
    974          
    975                      // Check if there is new data available from the accelerometer.
    976                      if (LISXDH_IS_DATA_READY())
    977                      {
    978                          EventDataReady();
    979                          return;
    980                      }
    981                      else
    982                      {
    983                          EventReadComplete();
    984                          return;
    985                      }
    986                  }
    987                  else
    988                  {
    989                      // There is no space remaining in the application buffer.
    990                      EventAppBufferFull();
    991                      return;
    992                  }
    993              }
    994          
    995              if (LISxDH.Timer > I2C_TIMEOUT_READY)
    996              {
    997                  #if (ACCEL_COMM_TEST == ENABLED)
    998                      LISxDH.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
    999                      LISxDH.Failure_Indicator_Counter++;
   1000                  #endif
   1001                  LOG_ADD_EXCEPTION(ACCEL_NOT_RESPONDING, 0);
   1002                  LISxDH.Failure_Counter++;
   1003                  if (LISxDH.Failure_Counter >= LISXDH_MAX_FAILURES)
   1004                  {
   1005                      LISxDH.Failure_Counter = 0;
   1006                      ACCELEROMETER_NOT_RESPONDING();
   1007                  }
   1008                  EventTimeout();
   1009              }
   1010          }
   1011          
   1012          
   1013          //---------------------------------------------------------------------------------------------------------------------
   1014          /**
   1015           * Wait for the accelerometer to indicate that at least one XYZ data point is ready.
   1016           */
   1017          static void WaitForDataReady(void)
   1018          {
   1019          #if (SPI_ENABLED == 1)
   1020              if (Spi__GetStatus((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1021          #else
   1022              if (I2c__GetStatus((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1023          #endif
   1024              {
   1025                  if (LISxDH.Mode_Processed != LISxDH.Mode_Requested)
   1026                  {
   1027                      EventDisable();
   1028                      return;
   1029                  }
   1030                  else if (LISXDH_IS_DATA_READY())
   1031                  {
   1032                      EventDataReady();
   1033                      return;
   1034                  }
   1035              }
   1036          
   1037              if (LISxDH.Timer > ACCEL_TIMEOUT_NO_DATA)
   1038              {
   1039                  #if (ACCEL_COMM_TEST == ENABLED)
   1040                      LISxDH.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1041                      LISxDH.Failure_Indicator_Counter++;
   1042                  #endif
   1043                  LOG_ADD_EXCEPTION(NO_DATA_TIMEOUT, 0);
   1044                  LISxDH.Failure_Counter++;
   1045                  if (LISxDH.Failure_Counter >= LISXDH_MAX_FAILURES)
   1046                  {
   1047                      LISxDH.Failure_Counter = 0;
   1048                      ACCELEROMETER_OLD_DATA();
   1049                  }
   1050                  EventTimeout();
   1051              }
   1052          }
   1053          
   1054          
   1055          //---------------------------------------------------------------------------------------------------------------------
   1056          /**
   1057           * Wait for the I2C bus to become idle.
   1058           */
   1059          static void WaitForI2cReady(void)
   1060          {
   1061          #if (SPI_ENABLED == 1)
   1062              if (Spi__GetStatus((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1063              {        
   1064                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);       // Pull chip select high after transmission
   1065          #else
   1066              if (I2c__GetStatus((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1067              {
   1068          #endif
   1069          
   1070                  EventI2cReady();
   1071              }
   1072              else if (LISxDH.Timer > I2C_TIMEOUT_READY)
   1073              {
   1074                  #if (ACCEL_COMM_TEST == ENABLED)
   1075                      LISxDH.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1076                      LISxDH.Failure_Indicator_Counter++;
   1077                  #endif
   1078                  LOG_ADD_EXCEPTION(I2C_APPEARS_STUCK, Lisxdh_State);
   1079                  LISxDH.Failure_Counter++;
   1080                  if (LISxDH.Failure_Counter >= LISXDH_MAX_FAILURES)
   1081                  {
   1082                      LISxDH.Failure_Counter = 0;
   1083                      ACCELEROMETER_NOT_RESPONDING();
   1084                  }
   1085                  EventTimeout();
   1086              }
   1087          }
