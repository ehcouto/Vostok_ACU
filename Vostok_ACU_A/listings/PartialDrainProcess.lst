    437          
    438          /**
    439           * Handle events published through API221.
    440           * This function is called by the communication thread.
    441           * @param event = The event that was published through API221.
    442           */
    443          static void API221HandleMotorEvent(API221_EVENT_TYPE event)
    444          {
    445          	switch (event.Event)
    446          	{
    447          		 case API221_EVENT_STOPPED:
    448          		 	 {
    449          				 if (event.Motor == MOTOR_1)
    450          				 {
    451          					 DrainPump_IsStopped = TRUE;
    452          					 DrainPump_ReachedTargetSpeed = FALSE;
    453          				 }
    454          		 	 }
    455          			break;
    456          		 case API221_EVENT_REACHED_TARGET:
    457          			 {
    458          				 if (event.Motor == MOTOR_1)
    459          				 {
    460          					 DrainPump_IsStopped = FALSE;
    461          					 DrainPump_ReachedTargetSpeed = TRUE;
    462          				 }
    463          			 }
    464          			break;
    465          		 case API221_EVENT_RAMP_STARTED:
    466          			 {
    467          				 if (event.Motor == MOTOR_1)
    468          				 {
    469          					 DrainPump_IsStopped = FALSE;
    470          					 DrainPump_ReachedTargetSpeed = FALSE;
    471          				 }
    472          			 }
    473          			 break;
    474          		default:
    475          			// Ignore all other events
    476          			break;
    477          	}
    478          }
    479          
    480          
    481          //---------------------------------------------------------------------------------------------------------------------
    482          /**
    483           * Use ExternalEventExtEvMCUErrReceive (RECEIVE_ERROR and RECEIVE_NO_ERROR)
    484           * Process information received from MCU about FF
    485           * @param motor = The motor ID related to the FF received
    486           * @param status = bitmap of FF
    487           */
    488          static void API221ApplReceivedStatus (API221_CLIENT_MOTOR_INDEX_TYPE motor, uint32 status)
    489          {
    490          	if (motor == MOTOR_1) // Drain Motor
    491          	{
    492          		DrainPump_IsStopped = BIT_TEST(status,API221_STS_IS_MOTOR_STOPPED) ? (TRUE) : (FALSE);
    493          		DrainPump_ReachedTargetSpeed = BIT_TEST(status,API221_STS_REACHED_TARGET) ? (TRUE) : (FALSE);
    494          	}
    495          }
    496          
    497          #endif

