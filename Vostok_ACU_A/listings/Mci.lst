     40          	MCI_EVENT_GWS_INITIALIZED                        = 1,    //!< GWS Initialized and Parameters loaded!
     41          	MCI_EVENT_RIF_INITIALIZED                        = 2,    //!< RIF pump initialized (Active Power Module)
