    169          /**
    170           *  @brief      ActivateActualSpeedChannels
    171           *  @details    Function that active the wash pump and drain pump actual speed channels
    172           *
    173           */
    174          void ActivateActualSpeedChannels(void)
    175          {
    176          	uint32 Channel_Bit_Mask = 0;
    177          	BIT_SET(Channel_Bit_Mask,MCI_AI_ACTUAL_SPEED_S16);
    178          
    179          	if (MGD_Wash_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
    180          	{
    181          		(void)API221MotionCtrl__SetDataPublicationPeriod(MOTOR_0, 1000);
    182          		(void)API221MotionCtrl__AddPeriodicDataChannels(MOTOR_0,  Channel_Bit_Mask);
    183          	}
    184          
    185          	if (MGD_Drain_Pump_Pilot_Type == HBL_PILOT_EXTERNAL_MOTOR)
    186          	{
    187          		(void)API221MotionCtrl__SetDataPublicationPeriod(MOTOR_1, 1000);
    188          		(void)API221MotionCtrl__AddPeriodicDataChannels(MOTOR_1, Channel_Bit_Mask );
    189          	}
    190          }
    191          #endif /*((API221_CLIENT_FEATURE == ENABLED) && (API221_SERVER_FEATURE == DISABLED))*/
