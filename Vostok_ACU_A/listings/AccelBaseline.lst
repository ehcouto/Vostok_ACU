    417          //---------------------------------------------------------------------------------------------------------------------
    418          /**
    419           * Request that the module run the accelerometer self-test.
    420           * It is recommended that the self-test only be run after the baseline measurement is completed.
    421           * @return TRUE if the accelerometer self-test is scheduled; otherwise, FALSE.
    422           */
    423          BOOL_TYPE AccelBaseline__RunSelfTest(void)
    424          {
    425              BOOL_TYPE is_self_test_started = FALSE;
    426          
    427              if ((Accel_Baseline_State == STATE_ACCEL_BASELINE_IDLE) &&
    428                  (LISxDH__GetStatus() == ACCELEROMETER_DISABLED))
    429              {
    430                  EventSelfTest();
    431                  is_self_test_started = TRUE;
    432              }
    433              else
    434              {
    435                  LOG_ADD_EXCEPTION(SELF_TEST_NOT_AVAILABLE, Accel_Baseline_State);
    436                  is_self_test_started = FALSE;
    437              }
    438          
    439              return(is_self_test_started);
    440          }
