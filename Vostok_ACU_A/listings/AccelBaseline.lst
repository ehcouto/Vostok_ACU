    444          /**
    445           * Get the address of the measured baseline.
    446           * @return The address of the measured baseline.
    447           */
    448          void AccelBaseline__SetInitialBaseline(uint8* array, uint8 length)
    449          {
    450              sint16* nv_baseline = (sint16*)(void*)array;
    451              for (uint8 axis = 0; axis < 3U; axis++)
    452              {
    453                  if (length >= sizeof(sint16))
    454                  {
    455                      if (BIT_TEST(Accel_Baseline.Axis_Baseline_Updated, axis) == 0)
    456                      {
    457                          Accel_Baseline.Baseline[axis] = nv_baseline[axis];
    458                          BIT_SET(Accel_Baseline.Axis_Baseline_Recovered, axis);
    459                      }
    460                      length -= sizeof(sint16);
    461                  }
    462                  else
    463                  {
    464                      break;                              // Break out of the for() loop.
    465                  }
    466              }
    467          }
