    231          /**
    232           *  @brief      MC Handler
    233           *
    234           */

   \                                 In section .text, align 2, keep-with-next
    235          void MCUDebug_MCHandler(void)
    236          {
    237          #ifdef ENABLE_PILOT_MCI
    238          	PilotRelay();
    239          #endif
    240          
    241          #ifdef MCI_AUTOTESTING
    242          	My_Mcislfac_Fault = Mcl__GetErrorList();
    243          #endif
    244          
    245          #if (SIL_MODE == ENABLED)
    246          
    247          	Slow_Handler_Counter++;
    248          	if(Slow_Handler_Counter >= 125) //25ms at 5000Hz
    249          	{
    250          		Slow_Handler_Counter = 0;
    251          		Mci__SlowHandler();
    252          	}
    253          
    254          	Dbg_Control_Mode = (uint8)Mci__GetAnalog(MOTOR0, MCI_AI_INTERNAL_MCI_STATE);
    255          	Dbg_MciSlfac_Last_Failure = (uint8)Mci__GetErrorList(MOTOR0);
    256          	Dbg_Failure_State = (uint8)Mcl__GetDataSIL(MCL_GD_FAILURE_STATE);
    257          	Dbg_bemf_volt_tmp = (sint16)Mcl__GetDataSIL(MCL_GD_BACK_EMF);
    258          	Dbg_Mcl_Main_Counter = (uint16)Mcl__GetDataSIL(MCL_GD_MAIN_COUNTER);
    259          	Dbg_MciSlfac_Wash_Motor_Type = (uint8)Mcl__GetDataSIL(MCL_GD_MOTOR_TYPE);
    260          
    261          	//Digital Channels
    262          	My_GetDigital_0 = Mci__GetDigital(MOTOR0,MCI_DI_MOTOR_STOP);
    263          	My_GetDigital_1 = Mci__GetDigital(MOTOR0,MCI_DI_REACHED_TARGET_SPEED);
    264          	My_GetDigital_2 = Mci__GetDigital(MOTOR0,MCI_DI_IDLE);
    265          	My_GetDigital_3 = Mci__GetDigital(MOTOR0,MCI_DI_MOTOR_RUNNING);
    266          
    267          	// Analog Channels
    268          	My_GetAnalog_0 = Mci__GetAnalog(MOTOR0,MCI_AI_CURR_PHASE_P2P);
    269          	My_GetAnalog_1 = Mci__GetAnalog(MOTOR0,MCI_AI_VOLTAGE_PHASE_P2P);
    270          	My_GetAnalog_2 = Mci__GetAnalog(MOTOR0,MCI_AI_LOAD_TORQUE_S16);
    271          #endif
    272          }
