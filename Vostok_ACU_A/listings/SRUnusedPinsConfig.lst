     23          
     24          #include "SRSystemConfig.h"
     25          
     26          #if (SR_UNUSED_PINS_CONFIG_FEATURE == ENABLED)
     27          
     28          // -- This Module --
     29          #include "SRUnusedPinsConfig.h"
     30          #include "SRUnusedPinsConfig_prv.h"
     31          
     32          // -- Other Modules --
     33          #include "Gpio.h"
     34          #include "SRData.h"
     35          #include "SRException.h"
     36          #include "SRTaskSequence.h"
