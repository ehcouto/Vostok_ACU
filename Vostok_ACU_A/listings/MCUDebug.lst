    194          /**
    195           *  @brief      Slow Handler
    196           *
    197           */

   \                                 In section .text, align 2, keep-with-next
    198          void MCUDebug_SlowHandler(void)
    199          {
    200          #ifdef ENABLE_PILOT_MCI
    201          	if(BD_MotorControl == 1)
    202          	{
    203          		if(MCI_RUN(MOTOR0) == MCI_CMD_ACCEPTED)
    204          		{
    205          			//Pilot_Relay_Request = TRUE;
    206          			BD_MotorControl = -1;
    207          		}
    208          	}
    209          
    210          	if(BD_MotorControl == 2)
    211          	{
    212          		if(MCI_STOP(MOTOR0) == MCI_CMD_ACCEPTED)
    213          		{
    214          			//Pilot_Relay_Request = TRUE;
    215          			BD_MotorControl = -2;
    216          		}
    217          	}
    218          
    219          	if(BD_MotorControl == 127)
    220          	{
    221          		BD_MotorControl = -127;
    222          		Mci__SetWashMotorType(WM_SINGLE_SPEED_SYNCH_SPH_AW);
    223          	}
    224          #endif
    225          }
   \                     MCUDebug_SlowHandler: (+1)
   \   00000000   0x4770             BX       LR               ;; return
