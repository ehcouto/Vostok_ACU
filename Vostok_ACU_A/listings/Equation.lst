     87          // -- Private Enumerated Constant Declarations --
     88          
     89          //! The types of comparisons that can be made between two values on the equation stack.
     90          typedef enum COMPARE_ENUM
     91          {
     92              CMP_LT = 1,
     93              CMP_EQ = 2,
     94              CMP_GT = 4,
     95              CMP_LE = CMP_LT + CMP_EQ,
     96              CMP_GE = CMP_GT + CMP_EQ,
     97              CMP_NE = CMP_LT + CMP_GT
     98          } COMPARE_TYPE;
     99          
    100          //! The elements that make up equations.
    101          typedef enum ELEMENT_ENUM
    102          {
    103              ELEMENT_ZERO                    = 0x00,         // push(0)
    104              ELEMENT_ONE                     = 0x01,         // push(1)
    105              ELEMENT_NEGATIVE_ONE            = 0x02,         // push(-1)
    106              ELEMENT_ACU_VAR                 = 0x08,         // push(ACU_Var(index, offset))
    107              ELEMENT_HMI_VAR                 = 0x09,         // push(HMI_Var(index, offset))
    108              ELEMENT_STEP_VAR                = 0x0A,         // push(Step_Var(index))
    109              ELEMENT_CONST_UINT8             = 0x11,         // push(constant uint8)
    110              ELEMENT_CONST_UINT16            = 0x12,         // push(constant uint16)
    111              ELEMENT_CONST_UINT31            = 0x13,         // push(constant uint31)
    112              ELEMENT_CONST_SINT8             = 0x15,         // push(constant sint8)
    113              ELEMENT_CONST_SINT16            = 0x16,         // push(constant sint16)
    114              ELEMENT_CONST_SINT32            = 0x17,         // push(constant sint32)
    115              ELEMENT_BOOLEAN                 = 0x40,         // pop(a), push(BOOL(a))
    116              ELEMENT_NOT                     = 0x41,         // pop(a), push(NOT BOOL(a))
    117              ELEMENT_INVERT                  = 0x42,         // pop(a), push(~a)
    118              ELEMENT_NEGATE                  = 0x43,         // pop(a), push(-a)
    119              ELEMENT_ABSOLUTE_VALUE          = 0x44,         // pop(a), push(|a|)
    120              ELEMENT_SCALE                   = 0x45,         // pop(a), push(lroundf(constant float32 x a))
    121              ELEMENT_LESS_THAN               = 0x81,         // pop(b), pop(a), push(a < b)
    122              ELEMENT_EQUAL                   = 0x82,         // pop(b), pop(a), push(a == b)
    123              ELEMENT_LESS_OR_EQUAL           = 0x83,         // pop(b), pop(a), push(a <= b)
    124              ELEMENT_GREATER_THAN            = 0x84,         // pop(b), pop(a), push(a > b)
    125              ELEMENT_NOT_EQUAL               = 0x85,         // pop(b), pop(a), push(a != b)
    126              ELEMENT_GREATER_OR_EQUAL        = 0x86,         // pop(b), pop(a), push(a >= b)
    127              ELEMENT_MINIMUM                 = 0x88,         // pop(b), pop(a), push(min(a, b))
    128              ELEMENT_MAXIMUM                 = 0x89,         // pop(b), pop(a), push(max(a, b))
    129              ELEMENT_AND                     = 0x90,         // pop(b), pop(a), push(a AND b)
    130              ELEMENT_OR                      = 0x91,         // pop(b), pop(a), push(a OR b)
    131              ELEMENT_XOR                     = 0x92,         // pop(b), pop(a), push(a XOR b)
    132              ELEMENT_MULTIPLY                = 0xC0,         // pop(b), pop(a), push(a x b)
    133              ELEMENT_DIVIDE                  = 0xC1,         // pop(b), pop(a), push(a / b)
    134              ELEMENT_MODULUS                 = 0xC2,         // pop(b), pop(a), push(a % b)
    135              ELEMENT_ADD                     = 0xC3,         // pop(b), pop(a), push(a + b)
    136              ELEMENT_SUBTRACT                = 0xC4,         // pop(b), pop(a), push(a - b)
    137              ELEMENT_MAP                     = 0xE1,         // pop(Xn) for each dimension, y=map(X1,X2,...), push(y)
    138              ELEMENT_INVALID                 = 0xFF
    139          } ELEMENT_TYPE;
