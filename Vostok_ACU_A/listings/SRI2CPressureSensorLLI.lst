    125          /**
    126           * @brief   It Initializes the module I2CPressureSensor LLI and its variables
    127           */
    128          void SRI2CPressureSensorLLI__Initialize(void)
    129          {
    130              memset(Sr_I2c_Pressure_Data,0,sizeof(Sr_I2c_Pressure_Data));
    131          
    132              for (uint8 index = 0; index < HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR; index++)
    133              {
    134                  SRI2CPressureSensorLLI_Crc[index] = Crc8(0xFF, (uint8 *)(void *)&Sr_I2c_Pressure_Data[index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE));
    135              }
    136          
    137              SR_SET_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation,0);
    138          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    139              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRI2C_PRESSURE_SENSOR_LLI);
    140          #endif
    141          }
    142          
    143          //---------------------------------------------------------------------------------------------------------------------
    144          /**
    145           * @brief   Determines the destination (index) of the data for the LLI.
    146           * @return  Index to a local buffer where the data will reside.
    147           */
    148          uint8 SRI2CPressureSensorLLI__Allocate(void)
    149          {
    150              uint8 retval;
    151              retval = HBL_INDEX_INVALID;
    152              SR_CHECK_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation);
    153              if (Sr_I2CPressure_Sensor_LLI_Allocation < HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR)
    154              {
    155                  retval = Sr_I2CPressure_Sensor_LLI_Allocation;
    156                  SR_SET_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation,Sr_I2CPressure_Sensor_LLI_Allocation + 1U);
    157              }
    158              return (retval);
    159          }
    160          
    161          //---------------------------------------------------------------------------------------------------------------------
    162          /**
    163           * @brief   Initialize an instance of the LLI by extracting parameter data and initializing variables.
    164           * @param   input: data related to the instance of the LLI
    165           * @param   PASS if the initialization was successful, else FAIL
    166           */
    167          PASS_FAIL_TYPE SRI2CPressureSensorLLI__InitializeInstance(HBL_LLI_TYPE * input)
    168          {
    169              PASS_FAIL_TYPE retval = FAIL;
    170              I2C_PRESSURE_SENSOR_PARAM_TYPE *param_ptr;
    171              uint8 i2c_address = 0;
    172          
    173              SR_CHECK_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation);
    174              if (input->Data_Index < Sr_I2CPressure_Sensor_LLI_Allocation)
    175              {
    176                  param_ptr = (I2C_PRESSURE_SENSOR_PARAM_TYPE *) (void *)(input->Parameter_Ptr.Data);
    177          
    178                  const VIRTUALPIN_TYPE* pin_ptr = &(VIRTUALPIN_TABLE[input->Pin_Ptr[0]]);
    179          
    180                  i2c_address = (((pin_ptr->param0) << 1) & 0xFFU);
    181          
    182                  retval = (PASS_FAIL_TYPE)I2c__Initialize((I2C_ENUM_TYPE)pin_ptr->device, (I2C_SPEED_TYPE)pin_ptr->param1, I2C_ADDR_7BITS, i2c_address); // initialize I2C bus with this sensor
    183          
    184                  Sr_I2c_Pressure_Data[input->Data_Index].Settling_Timer = param_ptr->Initial_Time/ASYNCH_CALL_RATE;
    185          
    186                  Sr_I2c_Pressure_Data[input->Data_Index].Filter.Inverted_Alpha = param_ptr->Inverted_Alpha;
    187          
    188                  Sr_I2c_Pressure_Data[input->Data_Index].Communication_Fault_Debounce = param_ptr->Communication_Fault_Debounce;
    189          
    190                  Sr_I2c_Pressure_Data[input->Data_Index].Communication_Fault_Retries = param_ptr->Communication_Fault_Retries;
    191          
    192                  //Initialize filter
    193                  InitIirFilter((void *)&(Sr_I2c_Pressure_Data[input->Data_Index].Filter), PRESURE_SENSOR_INITIAL_FILTER_VALUE);
    194                  SRI2CPressureSensorLLI_Crc[input->Data_Index] = Crc8(0xFF, (uint8 *)(void *)&Sr_I2c_Pressure_Data[input->Data_Index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE));
    195              }
    196              return (retval);
    197          }
    198          
    199          //---------------------------------------------------------------------------------------------------------------------
    200          /**
    201           * @brief   Retrieves the current value of the LLI
    202           * @param   input: data related to the instance of the LLI
    203           * @retval  NULL = lli instance not allocated
    204           *          STABILIZING_PRESSURE = Filter is settling
    205           *          else Current LLI Value
    206           */
    207          void * SRI2CPressureSensorLLI__Get(HBL_LLI_TYPE * input)
    208          {
    209              void* ptr = NULL;
    210          
    211              SR_CHECK_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation);
    212          
    213              if (input->Data_Index < Sr_I2CPressure_Sensor_LLI_Allocation)
    214              {
    215                  MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    216                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    217                  BOOL_TYPE test_crc_match = ((SRI2CPressureSensorLLI_Crc[input->Data_Index] == (Crc8(0xFF, (uint8 *)(void *)&Sr_I2c_Pressure_Data[input->Data_Index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE)))) ? TRUE : FALSE);
    218                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    219          
    220                  if(test_crc_match == FALSE)
    221                  {
    222                      SRException__Queue(SREXCEPTION_SRCHECK_DATA_NOT_CONSISTENT,input->LLI_Handler_Index, input->Data_Index);
    223                  }
    224          
    225                  if (Sr_I2c_Pressure_Data[input->Data_Index].Settling_Timer == 0U)
    226                  {
    227          
    228                      if (Sr_I2c_Pressure_Data[input->Data_Index].Communication_Fault_Retry_Counter > Sr_I2c_Pressure_Data[input->Data_Index].Communication_Fault_Retries)
    229                      {
    230                          // Return unique pressure value if there is an I2c communication failure
    231                          ptr = (void *)&I2C_COMM_FAILURE_PRESSURE;
    232                      }
    233                      else
    234                      {
    235                          ptr =  ((void *)&Sr_I2c_Pressure_Data[input->Data_Index].Filter.Filtered_Value);
    236                      }
    237                  }
    238                  else
    239                  {
    240                      ptr = (void *)&STABILIZING_PRESSURE;
    241                  }
    242              }
    243              return ptr;
    244          }
    245          
    246          //---------------------------------------------------------------------------------------------------------------------
    247          /**
    248           * @brief   Asynchronous processing of a the LLI
    249           * @param   input: data related to the instance of the LLI
    250           * @return  PASS if the LLI was successfully processed, else FAIL
    251           */
    252          BOOL_TYPE SRI2CPressureSensorLLI__AsynchProcess(HBL_LLI_TYPE * input)
    253          {
    254              BOOL_TYPE retval = FALSE;
    255              I2C_PRESSURE_SENSOR_DATA_TYPE *ptr;
    256          
    257              SR_CHECK_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation);
    258              if (SRI2CPressureSensorLLI_Crc[input->Data_Index] == Crc8(0xFF, (uint8 *)(void *)&Sr_I2c_Pressure_Data[input->Data_Index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE)))
    259              {
    260                  if (input->Data_Index < Sr_I2CPressure_Sensor_LLI_Allocation)
    261                  {
    262                      ptr = &Sr_I2c_Pressure_Data[input->Data_Index];
    263          
    264                      ptr->Settling_Timer = (ptr->Settling_Timer > 0U) ? (ptr->Settling_Timer - 1U) : 0U;
    265          
    266                      const VIRTUALPIN_TYPE* pin_ptr = &(VIRTUALPIN_TABLE[input->Pin_Ptr[0]]);
    267          
    268                      switch(Sr_I2c_Pressure_Data[input->Data_Index].State)
    269                      {
    270                          case I2C_PRESSURE_SENSOR_REQUEST:
    271          
    272                              retval = I2c__RequestRead((I2C_ENUM_TYPE)pin_ptr->device, 2);                           // Request the reading to the device
    273                              ptr->State = I2C_PRESSURE_SENSOR_READ;
    274                              break;
    275          
    276                          case I2C_PRESSURE_SENSOR_READ:
    277          
    278                              if (I2c__GetStatus((I2C_ENUM_TYPE)pin_ptr->device,I2C_STATUS_STATE) == (uint16)I2C_STATE_IDLE)  // Check if bus is free
    279                              {
    280                                  retval = I2c__Read((I2C_ENUM_TYPE)pin_ptr->device, Sr_I2c_Pressure_Data[input->Data_Index].Buffer, sizeof(Sr_I2c_Pressure_Data[input->Data_Index].Buffer)); // Copy the I2c Rx buffer to the I2c_Pressure_Buffer
    281          
    282                                  ptr->Pressure  = (((uint16)ptr->Buffer[0]) << 8) | ptr->Buffer[1]; // Merge the pressure data bytes
    283                                  ptr->Pressure &= (uint16)0x3FFF;    // Mask off 2 status bits
    284          
    285                                  //Update Filter
    286                                  UpdateIirFilter((void *)&(ptr->Filter), (FILTER_DATA_TYPE)(ptr->Pressure));
    287          
    288                                  ptr->Communication_Fault_Debounce_Counter = 0;
    289                                  ptr->Communication_Fault_Retry_Counter = 0;
    290          
    291                                  ptr->State = I2C_PRESSURE_SENSOR_REQUEST;
    292                              }
    293                              else if (ptr->Communication_Fault_Retry_Counter <= ptr->Communication_Fault_Retries)    // Handle communication error
    294                              {
    295                                  // Max retries not reached; keep debouncing the communication error and/or attempting to recover the I2C communication
    296                                  if (ptr->Communication_Fault_Debounce_Counter < ptr->Communication_Fault_Debounce)
    297                                  {
    298                                      // No action; wait for debounce counter to expire or for communication to be restored
    299                                      ptr->Communication_Fault_Debounce_Counter++;
    300                                  }
    301                                  else if (ptr->Communication_Fault_Debounce_Counter >= ptr->Communication_Fault_Debounce)
    302                                  {
    303                                      // Attempt recovery of I2C communication and retry data request
    304                                      I2c__Clear((I2C_ENUM_TYPE)pin_ptr->device);
    305                                      (void)I2c__ResetBus((I2C_ENUM_TYPE)pin_ptr->device);
    306                                      ptr->Communication_Fault_Debounce_Counter = 0;
    307                                      ptr->Communication_Fault_Retry_Counter++;
    308                                      ptr->State = I2C_PRESSURE_SENSOR_REQUEST;
    309                                  }
    310                              }
    311                              else //ptr->Communication_Fault_Retry_Counter > SRI2cPressureSensorLLI_Param[input->Data_Index]->Communication_Fault_Retries
    312                              {
    313                                  //Attempt recovery of I2C communication and retry data request
    314                                  I2c__Clear((I2C_ENUM_TYPE)pin_ptr->device);
    315                                  (void)I2c__ResetBus((I2C_ENUM_TYPE)pin_ptr->device);
    316                                  ptr->State = I2C_PRESSURE_SENSOR_REQUEST;
    317                              }
    318          
    319                              break;
    320          
    321                          default:
    322                              // lint -fallthrough
    323                              break;
    324                      }
    325                      SRI2CPressureSensorLLI_Crc[input->Data_Index] = Crc8(0xFF, (uint8 *)(void *)&Sr_I2c_Pressure_Data[input->Data_Index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE));
    326                  }
    327              }
    328              else
    329              {
    330                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, input->LLI_Handler_Index, input->Data_Index);
    331              }
    332              return (retval);
    333          }
