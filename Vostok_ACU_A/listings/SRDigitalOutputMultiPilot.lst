    154          /**
    155           *  @brief      Set SRDigitalOutputMultiPilot instance request.
    156           *
    157           *  @param      HBL_LOAD_TYPE *load - Pointer to associated SRDigitalOutputMultiPilot instance.
    158           *
    159           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    160           *
    161           *  @return     PASS_FAIL_TYPE result - Result of SRDigitalOutputMultiPilot request.
    162           *  @retval     PASS - Instance request succeeded.
    163           *  @retval     FAIL - Instance request failed.
    164           */
    165          PASS_FAIL_TYPE SRDigitalOutputMultiPilot__Request(HBL_LOAD_TYPE * load,void * data)
    166          {
    167              PASS_FAIL_TYPE retval = FAIL;
    168          
    169              if (CheckItem(load->Pilot_Data_Index))
    170              {
    171                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *ptr = &SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    172                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *n_ptr = &N_SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    173          
    174                  SRData__UpdateByte(&ptr->Requested, &n_ptr->Requested, *((uint8 *)data));
    175                  retval = PASS;
    176              }
    177              return (retval);
    178          }
    179          
    180          //---------------------------------------------------------------------------------------------------------------------
    181          /**
    182           *  @brief      Process SRDigitalOutputMultiPilot instance.
    183           *
    184           *  @param      HBL_LOAD_TYPE *load - Pointer to SRDigitalOutputMultiPilot instance.
    185           *
    186           *  @return     PASS_FAIL_TYPE result - Result of SRDigitalOutputMultiPilot instance process.
    187           *  @retval     PASS - Instance process succeeded.
    188           *  @retval     FAIL - Instance process failed.
    189           */
    190          PASS_FAIL_TYPE SRDigitalOutputMultiPilot__Process(HBL_LOAD_TYPE * load)
    191          {
    192              PASS_FAIL_TYPE retval = FAIL;
    193              HBL_LOAD_STATUS_TYPE new_status;
    194          
    195              if (CheckItem(load->Pilot_Data_Index))
    196              {
    197                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *ptr = &SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    198                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *n_ptr = &N_SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    199          
    200                  SRData__UpdateByte(&ptr->Processed, &n_ptr->Processed, ptr->Requested);
    201                  if ((ptr->Processed >> 4) != 0)
    202                  {
    203                      new_status.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    204                  }
    205                  else
    206                  {
    207                      new_status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    208                  }
    209                  new_status.Load.Cur_Reg = ptr->Processed;
    210                  SRData__UpdateByte(&ptr->Status, &n_ptr->Status, new_status.Byte);
    211                  retval = PASS;
    212              }
    213              return (retval);
    214          }
