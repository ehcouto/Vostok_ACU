C:\Data\Nucleus_Dev\Vostok_ACU_A\source\XCategory\Application\acu\Supervisor\Supervisor.c
      1          /**
      2           *  @file
      3           *
      4           *  @brief      Supervises state transitions among the different operation modes of the product:
      5           *                  Programming, Run, Delay, END, PAUSE, FAULT, DELAY-PAUSE and Cancelling
      6           *
      7           *  @details
      8          
      9              @startuml{Supervisor_SQ.png}
     10                  title Supervisor Sequence Diagram
     11                  scale max 4096 height
     12                  autonumber
     13          
     14                  actor User
     15                  participant HMI
     16                  participant Regulations
     17                  participant Status
     18                  participant Supervisor
     19          
     20                  loop 100 milliseconds (embOS AppMgr Task call rate)
     21                      alt Supervisor_Data[].State == FSM_STATE_PROGRAMMING
     22                          User -> HMI : Select Delay (Start/Stop) Time
     23                          HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_HH, value)
     24                          HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_MM, value)
     25                          HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_SS, value)
     26                          note right : Any or all 3 regulations must be sent at the same time
     27                          loop function = FUNC_ID_DELAY_HH, FUNC_ID_DELAY_MM and FUNC_ID_DELAY_SS
     28                              Supervisor -> Regulations : GetValue(function)
     29                              Regulations --> Supervisor: value = hours, minutes or seconds
     30                              Supervisor -> Supervisor : Delay_Time = hours * 3600 + minutes * 60 + seconds
     31                          end
     32                          alt
     33                              User -> HMI : Select Start
     34                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_START_CONDITION)
     35                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
     36                              Regulations --> Supervisor: value = FS_START_CONDITION
     37                              alt Delay_Time == 0 && Selector != 0 && OK_TO_START
     38                                  Supervisor -> Supervisor : eventStart
     39                                  note right : Causes Supervisor to go to RUN state.
     40                              else Delay_Time != 0 && Selector != 0
     41                                  Supervisor -> Supervisor : eventDelay
     42                                  note right : Causes Supervisor to go to DELAY state.
     43                              end
     44                          else
     45                              User -> HMI : Select Cancel
     46                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
     47                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
     48                              Regulations --> Supervisor: value = FS_RESET_CONDITION
     49                              Supervisor -> Supervisor : eventReset, Delay_Time = 0
     50                              note right : Supervisor stays in PROGRAMMING state.
     51                          end
     52                      else Supervisor_Data[].State == FSM_STATE_DELAY
     53                          alt
     54                              User -> HMI : Select Start
     55                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESTART_CONDITION)
     56                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
     57                              Regulations --> Supervisor: value = FS_RESTART_CONDITION
     58                              Supervisor -> Supervisor : [OK_TO_START] eventStart, set Delay_Time to 0
     59                              note right : Causes Supervisor to go to RUN state.
     60                          else
     61                              User -> HMI : Select Cancel
     62                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
     63                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
     64                              Regulations --> Supervisor: value = FS_RESET_CONDITION
     65                              Supervisor -> Supervisor : eventReset, set Delay_Time to 0
     66                              note right : Causes Supervisor to go to PROGRAMMING state.
     67                          else
     68                              User -> HMI : Select Delay (Start/Stop) Time
     69                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_HH, value)
     70                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_MM, value)
     71                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_SS, value)
     72                              note right : Any or all 3 regulations must be sent at the same time
     73                              loop function = FUNC_ID_DELAY_HH, FUNC_ID_DELAY_MM and FUNC_ID_DELAY_SS
     74                                  Supervisor -> Regulations : GetValue(function)
     75                                  Regulations --> Supervisor: value = hours, minutes or seconds
     76                                  Supervisor -> Supervisor : Delay_Time = hours * 3600 + minutes * 60 + seconds
     77                                  note right : If Delay_Time set to 0, eventStart will be generated.
     78                              end
     79                          else
     80                              User -> HMI : Set Pause
     81                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_PAUSE_CONDITION)
     82                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
     83                              Regulations --> Supervisor: value = FS_PAUSE_CONDITION
     84                              Supervisor --> Supervisor: EventPause
     85                              note right : Causes Supervisor to go to DELAY_PAUSE state which reports PAUSE state and runs PAUSE cycle
     86                          end
     87                          Supervisor -> Supervisor : Decrement Delay_Time every 10 loops (1 second)
     88                          Status -> HMI : Delay_Time
     89                          alt Delay_Time == 0 && OK_TO_START
     90                              Supervisor -> Supervisor : eventStart
     91                              note right : Causes Supervisor to go to RUN state.
     92                          end
     93                      else Supervisor_Data[].State == FSM_STATE_DELAY_PAUSE
     94                          Supervisor --> Supervisor : Run Pause Cycle and report PAUSE state
     95                          alt
     96                              User -> HMI : Select Delay (Start/Stop) Time
     97                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_HH, value)
     98                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_MM, value)
     99                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_DELAY_SS, value)
    100                              note right : Any or all 3 regulations must be sent at the same time
    101                              loop function = FUNC_ID_DELAY_HH, FUNC_ID_DELAY_MM and FUNC_ID_DELAY_SS
    102                                  Supervisor -> Regulations : GetValue(function)
    103                                  Regulations --> Supervisor: value = hours, minutes or seconds
    104                                  Supervisor -> Supervisor : Delay_Time = hours * 3600 + minutes * 60 + seconds
    105                                  note right : If Delay_Time set to 0, eventStart will be generated when pause is resumed.
    106                              end
    107                          else
    108                              User -> HMI : Select Start
    109                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_START_CONDITION)
    110                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    111                              Regulations --> Supervisor: value = FS_START_CONDITION
    112                              alt OK_TO_START
    113                                  Supervisor -> Supervisor : eventResume
    114                              end
    115                              note right : Causes Supervisor to go back to Delay state.
    116                          else
    117                              User -> HMI : Select Cancel
    118                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
    119                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    120                              Regulations --> Supervisor: value = FS_RESET_CONDITION
    121                              Supervisor -> Supervisor : eventReset, set Delay_Time to 0
    122                              note right : Causes Supervisor to go to PROGRAMMING state.
    123                          end
    124                      else Supervisor_Data[].State == FSM_STATE_RUN
    125                          alt
    126                              User -> HMI : Select Cancel
    127                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
    128                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    129                              Regulations --> Supervisor: value = FS_RESET_CONDITION
    130                              Supervisor -> Supervisor : eventReset, ResetTasks
    131                              note right
    132                                  If (allowed RUN to CANCELLING transition) AND (Cancelling cycle can start)
    133                                  Supervisor goes to CANCELLING state
    134                                  else
    135                                  Supervisor goes to PROGRAMMING state.
    136                              end note
    137                          end
    138                      else Supervisor_Data[].State == FSM_STATE_END_OF_CYCLE
    139                          alt
    140                              User -> HMI : Select Cancel
    141                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
    142                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    143                              Regulations --> Supervisor: value = FS_RESET_CONDITION
    144                              Supervisor -> Supervisor : eventReset, ResetTasks
    145                              note right
    146                                  If (allowed END_OF_CYCLE to CANCELLING transition) AND (Cancelling cycle can start)
    147                                  Supervisor goes to CANCELLING state
    148                                  else
    149                                  Supervisor goes to PROGRAMMING state.
    150                              end note
    151                          end
    152                      else Supervisor_Data[].State == FSM_STATE_PAUSE
    153                          alt
    154                              User -> HMI : Select Start
    155                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_START_CONDITION)
    156                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    157                              Regulations --> Supervisor: value = FS_START_CONDITION
    158                              alt OK_TO_START
    159                                  Supervisor -> Supervisor : eventResume
    160                              end
    161                              note right
    162                                  If Cancelling cycle is current paused cycle
    163                                  Supervisor goes to CANCELLING state
    164                                  else
    165                                  Supervisor goes to RUN state.
    166                              end note
    167                          else
    168                              User -> HMI : Select Cancel
    169                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
    170                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    171                              Regulations --> Supervisor: value = FS_RESET_CONDITION
    172                              Supervisor -> Supervisor : eventReset
    173                              note right
    174                                  If (allowed PAUSE to CANCELLING transition) AND (Cancelling cycle can start)
    175                                  Supervisor goes to CANCELLING state
    176                                  else
    177                                  Supervisor goes to PROGRAMMING state.
    178                              end note
    179                          end
    180                      else Supervisor_Data[].State == FSM_STATE_CANCELLING
    181                          alt
    182                              User -> HMI : Select Pause
    183                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_PAUSE_CONDITION)
    184                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    185                              Regulations --> Supervisor: value = FS_PAUSE_CONDITION
    186                              Supervisor -> Supervisor : eventPause
    187                              note right : Causes Supervisor to go to PAUSE state and runs PAUSE cycle.
    188                          end
    189                      else Supervisor_Data[].State == FSM_STATE_FAULT
    190                          alt
    191                              User -> HMI : Select Reset Faulty Condition
    192                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_FAULT)
    193                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    194                              Regulations --> Supervisor: value = FS_RESET_FAULT
    195                              Supervisor -> Supervisor : evFaultReset
    196                              note right : Causes Supervisor to go to PROGRAMMING state.
    197                          else
    198                              User -> HMI : Select Cancel
    199                              HMI -> Regulations : SetRequestedIndex(FUNC_ID_START, FS_RESET_CONDITION)
    200                              Supervisor -> Regulations : GetValue(FUNC_ID_START)
    201                              Regulations --> Supervisor: value = FS_RESET_CONDITION
    202                              Supervisor -> Supervisor : eventReset
    203                              note right
    204                                  If (allowed FAULT to CANCELLING transition) AND (Cancelling cycle can start)
    205                                  Supervisor goes to CANCELLING state
    206                                  else
    207                                  Supervisor stays in FAULT state.
    208                              end note
    209                          end
    210                      end
    211                  end
    212              @enduml
    213          
    214              @startuml{Supervisor_SM.png}
    215                  title Supervisor State Machine
    216          
    217                  'developer variables = BOOL_TYPE * okay_to_start_cycle
    218          
    219                  [*] --> CheckForFaults
    220          
    221                  state CheckForFaults {
    222                      [*] --> CycleNotRunning
    223          
    224                      state CycleNotRunning {
    225                          [*] --> PROGRAMMING
    226          
    227                          PROGRAMMING :entry/\n\t ProgrammingEntry \n\t SetSystemStateProgramming
    228                          PROGRAMMING :do/\n\t UpdateOkayToStartCycle \n\t ProgrammingDo \n\t SetSystemStateProgramming
    229          
    230                          DELAY :entry/\n\t DelayEntry \n\t SetSystemStateDelay
    231                          DELAY :do/\n\t UpdateOkayToStartCycle \n\t DelayDo \n\t SetSystemStateDelay
    232          
    233                          DELAY_PAUSE :entry/\n\t DelayPauseEntry \n\t SetSystemStateDelayPause
    234                          DELAY_PAUSE :do/\n\t UpdateOkayToStartCycle \n\t DelayPauseDo \n\t SetSystemStateDelayPause
    235                          DELAY_PAUSE :exit /\n\t DelayPauseExit
    236          
    237                          PROGRAMMING -l-> DELAY : evDelay
    238                          DELAY -l-> DELAY_PAUSE : evPause
    239                          DELAY_PAUSE -r-> DELAY : evResume
    240                      }
    241          
    242                      state CycleRunning {
    243                          RUN :entry/\n\t RunEntry \n\t SetSystemStateRun
    244                          RUN :do/\n\t RunDo \n\t SetSystemStateRun
    245                          RUN :exit/\n\t RunExit
    246          
    247                          PAUSE :entry/\n\t PauseEntry \n\t SetSystemStatePause
    248                          PAUSE :do/\n\t UpdateOkayToStartCycle \n\t PauseDo \n\t SetSystemStatePause
    249                          PAUSE :exit/\n\t PauseExit
    250          
    251                          RUN -l-> PAUSE : evPause
    252                          PAUSE -r-> RUN : evResume \n/ Resume
    253                      }
    254          
    255                      END_OF_CYCLE :entry/\n\t EndEntry \n\t SetSystemStateEndOfCycle
    256                      END_OF_CYCLE :do/\n\t SetSystemStateEndOfCycle
    257          
    258                      state Cancel {
    259                          CANCELLING :entry/\n\t CancellingEntry \n\t SetSystemStateCancelling
    260                          CANCELLING :do/\n\t RunDo \n\t SetSystemStateCancelling
    261                          CANCELLING :exit/\n\t CancellingExit
    262          
    263                          PauseCancelling :entry/\n\t PauseEntry \n\t SetSystemStatePause
    264                          PauseCancelling :do/\n\t UpdateOkayToStartCycle \n\t PauseDo \n\t SetSystemStatePause
    265                          PauseCancelling :exit /\n\t PauseExit
    266          
    267                          CANCELLING -r-> PauseCancelling : evPause
    268                          PauseCancelling -l-> CANCELLING : evResume \n/ Resume
    269                      }
    270          
    271                      state JoinToProgramming <<join>>
    272                      state JoinToRun <<join>>
    273                      state JoinToCancel <<join>>
    274                  }
    275          
    276                  CycleNotRunning --> CycleNotRunning : evReset \n/ Reset
    277                  JoinToProgramming -u-> CycleNotRunning :/ Reset \n ResetTasks
    278          
    279                  PROGRAMMING --> JoinToRun : evStart
    280                  DELAY --> JoinToRun : evStart
    281                  JoinToRun --> RUN :/ Start
    282          
    283                  RUN --> END_OF_CYCLE : evEnd
    284                  RUN --> JoinToCancel : evReset \n[ IsCancelCycleEnabled ]
    285                  CycleRunning -u-> JoinToProgramming : evReset \n[ !IsCancelCycleEnabled ]
    286                  PAUSE --> JoinToCancel : evReset \n[ IsCancelCycleEnabled ]
    287                  JoinToCancel --> CANCELLING :/ StartCancellingCycle \n ResetTasks
    288          
    289                  END_OF_CYCLE -u-> CycleNotRunning : evReset \n/ Reset
    290                  CANCELLING -u-> JoinToProgramming : evEnd
    291                  Cancel -u-> JoinToProgramming : evReset
    292          
    293                  CheckForFaults --> FAULT : evFault
    294                  FAULT :entry/\n\t FaultEntry \n\t SetSystemStateFault
    295                  FAULT :do/\n\t FaultDo \n\t SetSystemStateFault
    296                  FAULT --> JoinToCancel : evFaultReset \n [ IsCancelCycleEnabled && IsCancellingToFaultEnabled ]
    297                  FAULT -u-> CheckForFaults : evFaultReset \n [ !IsCancelCycleEnabled || !IsCancellingToFaultEnabled ] \n/ Reset
    298                  FAULT --> FAULT : evFault
    299          
    300              @enduml
