   1095          //---------------------------------------------------------------------------------------------------------------------
   1096          /**
   1097           * Use ExternalEventExtEvMCUErrReceive (RECEIVE_ERROR and RECEIVE_NO_ERROR)
   1098           * Process information received from MCU about FF
   1099           * @param motor = The motor ID related to the FF received
   1100           * @param status = bitmap of FF
   1101           */
   1102          static void API221ApplReceivedStatus (API221_CLIENT_MOTOR_INDEX_TYPE motor, uint32 status)
   1103          {
   1104          	if (motor == MOTOR_0) // Wash Motor
   1105          	{
   1106          		WM_IsStopped = BIT_TEST(status,API221_STS_IS_MOTOR_STOPPED) ? (TRUE) : (FALSE);
   1107          		WM_ReachedTargetSpeed = BIT_TEST(status,API221_STS_REACHED_TARGET) ? (TRUE) : (FALSE);
   1108          	}
   1109          	else if (motor == MOTOR_1) // Drain Motor
   1110          	{
   1111          		DM_IsStopped = BIT_TEST(status,API221_STS_IS_MOTOR_STOPPED) ? (TRUE) : (FALSE);
   1112          		DM_ReachedTargetSpeed = BIT_TEST(status,API221_STS_REACHED_TARGET) ? (TRUE) : (FALSE);
   1113          	}
   1114          }
