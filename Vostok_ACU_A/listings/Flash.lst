     51          #define FLASH_HIGHBYTE_DEFAULT      ((uint16)0xff00)
     52          
     53          #define FLASH_TIMEOUT_VALUE         1000U          /*!< FLASH Execution Timeout, 1 s at 64MHz System Clock Speed*/
     54          #define FLASH_FAST_PGM_BYTES_SIZE   256
     55          #define FLASH_DWORD_PGM_BYTES_SIZE  8
     56          
     57          // This method  unlocks the  Flash memory
     58          // Flash should be unlocked before performing the write operation
     59          #define FLASH_UNLOCK_SEQUENCE()       {FLASH.KEYR = FLASH_FKEY1; FLASH.KEYR = FLASH_FKEY2;}
     60          
     61          // This method  locks the  Flash memory
     62          // should be called once the write operation is done in order to avoid unintentional write operation
     63          #define FLASH_LOCK_SEQUENCE()         {FLASH.CR |= FLASH_CR_LOCK;}
     64          
     65          #define BANK1_START_ADDRESS         0x08000000
     66          #define BANK2_START_ADDRESS_256KB   0x08020000
     67          #define BANK2_START_ADDRESS_512KB   0x08040000
     68          #define BANK2_START_PAGE_NUMBER     256
     69          
     70          #define FLASH_256KB_SIZE            (256*1024)
