     84          //---------------------------------------------------------------------------------------------------------------------
     85          /**
     86           *  @brief  Initializes the module SRDigitalLLI and its variables
     87           */
     88          void SRDigitalLLI__Initialize(void)
     89          {
     90              SRData__Fill(&SRDigitalLLI_Data, &N_SRDigitalLLI_Data, 0, sizeof(SRDigitalLLI_Data[0]) * HBL_LLI_NUM_SRDIGITAL);
     91          
     92              SR_SET_BYTE(SRDigitalLLI_Allocation, 0);
     93          
     94              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     95                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRDIGITAL_LLI);
     96              #endif
     97          }
     98          
     99          //---------------------------------------------------------------------------------------------------------------------
    100          /**
    101           * @brief   Determines the destination of the data for the input.
    102           * @return  Index to a local buffer where the data will reside.
    103           */
    104          uint8 SRDigitalLLI__Allocate(void)
    105          {
    106              uint8 retval = HBL_INDEX_INVALID;
    107          
    108              if ((SR_CHECK_BYTE(SRDigitalLLI_Allocation) == SRDATA_OK) &&
    109                  (SRDigitalLLI_Allocation < HBL_LLI_NUM_SRDIGITAL))
    110              {
    111                  retval = SRDigitalLLI_Allocation;
    112                  SR_SET_BYTE(SRDigitalLLI_Allocation, SRDigitalLLI_Allocation + 1);
    113              }
    114              return (retval);
    115          }
    116          
    117          //---------------------------------------------------------------------------------------------------------------------
    118          /**
    119           * @brief   Initialize an instance of the input.
    120           * @param   input: pointer to various data for the LLI, managed by the Hbl module
    121           * @return  PASS if the instance of the LLI was successfully initialized, else FALSE
    122           */
    123          PASS_FAIL_TYPE SRDigitalLLI__InitializeInstance(HBL_LLI_TYPE * input)
    124          {
    125              GPIO_PIN_MODE_TYPE type;
    126              uint8 digitalcfg1;
    127              uint8 virtual_pin;
    128              PASS_FAIL_TYPE retval = FAIL;
    129          
    130              if ((SR_CHECK_BYTE(SRDigitalLLI_Allocation) == SRDATA_OK) &&
    131                  (input->Data_Index < SRDigitalLLI_Allocation))
    132              {
    133                  virtual_pin = input->Pin_Ptr[0];
    134          
    135                  // Initialize the protected variables for this instance of the SRDigital LLI
    136                  SRData__UpdateByte((uint8 *)(void *)&SRDigitalLLI_Data[input->Data_Index].value, (uint8 *)(void *)&N_SRDigitalLLI_Data[input->Data_Index].value, FALSE);
    137                  SRData__UpdateByte((uint8 *)(void *)&SRDigitalLLI_Data[input->Data_Index].index, (uint8 *)(void *)&N_SRDigitalLLI_Data[input->Data_Index].index, 0);
    138                  SRData__UpdateByte((uint8 *)(void *)&SRDigitalLLI_Data[input->Data_Index].level_cnt, (uint8 *)(void *)&N_SRDigitalLLI_Data[input->Data_Index].level_cnt, 0);
    139          
    140                  // Grab the second byte of configuration data from the setting file
    141                  if(input->Parameter_Ptr.Data != NULL)
    142                  {
    143                      digitalcfg1 = input->Parameter_Ptr.Data[1];
    144                  }
    145                  else
    146                  {
    147                      digitalcfg1 = 0;
    148                  }
    149          
    150                  // Determine if the input has an internal pullup resistor enabled, else it is just floating
    151                  if (digitalcfg1 & SRDIGITALLOWINPUT_CFG1_PULLUP)
    152                  {
    153                      type = INPUT_PULLUP;
    154                  }
    155                  else
    156                  {
    157                      type = INPUT_FLOAT;
    158                  }
    159          
    160                  // Configure the gpio pin for the input
    161                  Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, type);
    162          
    163                  // Verify the configuration of the pin was set as expected
    164                  if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, type, FALSE) == TRUE)
    165                  {
    166                      retval = PASS;
    167                  }
    168              }
    169          
    170              return (retval);
    171          }
    172          
    173          //---------------------------------------------------------------------------------------------------------------------
    174          /**
    175           * @brief
    176           */
    177          void SRDigitalLLI__Handler(void)
    178          {
    179              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    180          
    181              if (SR_CHECK_BYTE(SRDigitalLLI_Allocation) != SRDATA_OK)
    182              {
    183                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0x00, 0xAB);
    184                  // System will reset after this exception occurs
    185              }
    186              else
    187              {
    188                  for (uint8 index = 0; index < HBL_LLI_NUM_SRDIGITAL; index++)
    189                  {
    190                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    191                      if (SRData__CheckArray((uint8 *)(void *)&SRDigitalLLI_Data[index], (uint8 *)(void *)&N_SRDigitalLLI_Data[index], sizeof(SRDigitalLLI_Data[0])) != SRDATA_OK)
    192                      {
    193                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0x01, index);
    194                          // System will reset after this exception occurs
    195                      }
    196                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    197                  }
    198              }
    199          
    200              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    201                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRDIGITAL_CHECK);
    202              #endif
    203          
    204          }
    205          //---------------------------------------------------------------------------------------------------------------------
    206          /**
    207           * @brief   Gets the data for one instance of an input.
    208           * @param   input: pointer to various data for the LLI, managed by the Hbl module
    209           * @return  Pointer to the SRDigitalLLI_Data buffer that contains the current state of the instance of the SRDigital LLI.
    210           */
    211          void * SRDigitalLLI__Get(HBL_LLI_TYPE * input)
    212          {
    213              if ((SR_CHECK_BYTE(SRDigitalLLI_Allocation) == SRDATA_OK) &&
    214                  (SRData__CheckArray((uint8 *)(void *)&SRDigitalLLI_Data[input->Data_Index], (uint8 *)(void *)&N_SRDigitalLLI_Data[input->Data_Index], sizeof(SRDigitalLLI_Data[0])) == SRDATA_OK) &&
    215                  (input->Data_Index < SRDigitalLLI_Allocation))
    216              {
    217                  return ((void *)&SRDigitalLLI_Data[input->Data_Index].value);
    218              }
    219              else
    220              {
    221                  return (NULL);
    222              }
    223          }
    224          
    225          //---------------------------------------------------------------------------------------------------------------------
    226          /**
    227           * @brief   Processing of the input state.
    228           * @param   input: pointer to various data for the LLI managed by the HblHmi module
    229           * @return  Always TRUE
    230           */
    231          BOOL_TYPE SRDigitalLLI__AsynchProcess(HBL_LLI_TYPE * input)
    232          {
    233              SRDIGITALLLI_DATA_TYPE data;
    234              BOOL_TYPE retval;
    235              BOOL_TYPE pinval;
    236              uint8 digitalcfg0;
    237              uint8 digitalcfg1;
    238              uint8 virtual_pin;
    239              uint8 nsamples;
    240              GPIO_PIN_MODE_TYPE gpio_type;
    241          
    242              retval = FALSE;
    243              digitalcfg0 = 0;
    244              digitalcfg1 = 0;
    245          
    246              if ((SR_CHECK_BYTE(SRDigitalLLI_Allocation) == SRDATA_OK) &&
    247                  (input->Data_Index < SRDigitalLLI_Allocation))
    248              {
    249                  virtual_pin = input->Pin_Ptr[0];
    250          
    251                  // Grab the configuration from the setting file
    252                  if(input->Parameter_Ptr.Data != NULL)
    253                  {
    254                      digitalcfg0 = input->Parameter_Ptr.Data[0];
    255                      digitalcfg1 = input->Parameter_Ptr.Data[1];
    256                  }
    257          
    258                  // Determine if the input has an internal pull up resistor enabled, else it is just floating
    259                  if (digitalcfg1 & SRDIGITALLOWINPUT_CFG1_PULLUP)
    260                  {
    261                      gpio_type = INPUT_PULLUP;
    262                  }
    263                  else
    264                  {
    265                      gpio_type = INPUT_FLOAT;
    266                  }
    267          
    268                  if (SRData__CheckArray(&SRDigitalLLI_Data[input->Data_Index], &N_SRDigitalLLI_Data[input->Data_Index],  sizeof(SRDigitalLLI_Data[0])) == SRDATA_OK)
    269                  {
    270                      data = SRDigitalLLI_Data[input->Data_Index];
    271          
    272                      // Verify the configuration of the pin has not been changed before reading the state of the pin
    273                      if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, gpio_type, FALSE) == FALSE)
    274                      {
    275                          SRException__Queue(SREXCEPTION_GPIO_CONFIGURATION_CORRUPTION, VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    276                      }
    277                      else
    278                      {
    279                          // Get the current state of the input from the gpio pin
    280                          pinval = Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    281          
    282                          // Setup the number of samples that will be required before updating the current state of the SRDigital LLI
    283                          nsamples = 1 << (digitalcfg0 & SRDIGITALLOWINPUT_CFG0_NREAD_MASK);
    284          
    285                          // Inverted logic flag enabled - swap TRUE to FALSE
    286                          if (digitalcfg1 & SRDIGITALLOWINPUT_CFG1_INVERT)
    287                          {
    288          //                    pinval ^= TRUE;
    289                              pinval = (BOOL_TYPE)(pinval ^ TRUE);
    290                          }
    291          
    292                          if (nsamples == 1)                  // If only 1 sample is required, update the current state of the SRDigital LLI
    293                          {
    294                              data.value = pinval;
    295                              retval = TRUE;
    296                          }
    297                          else                                // If more than 1 sample is required, manage multiple readings
    298                          {
    299                              data.index++;                   // Increment the index each time a new sample is taken
    300          
    301                              // Level detection
    302                              if (pinval == TRUE)             // Increment the level counter each time the sample is high
    303                              {
    304                                  data.level_cnt++;
    305                              }
    306          
    307                              if (data.index >= nsamples)     // Wait until the required number of samples has been taken before updating the current state of the SRDigital LLI
    308                              {
    309                                  if (data.level_cnt >= (nsamples - (nsamples / 4)))
    310                                  {
    311                                      data.value = TRUE;      // Update the current state of the SRDigital LLI to "TRUE" if at least 75% of the samples were high
    312                                  }
    313                                  else if (data.level_cnt <= (nsamples / 4))
    314                                  {
    315                                      data.value = FALSE;     // Update the current state of the SRDigital LLI to "FALSE" if 25% or less of the samples were low
    316                                  }
    317                                  else
    318                                  {
    319                                      /* Keep old state if the input signal is not steady based on the previous logic*/
    320                                  }
    321          
    322                                  // Reset variables to manage multiple readings
    323                                  data.level_cnt = 0;
    324                                  data.index = 0;
    325          
    326                                  retval = TRUE;
    327                              }
    328                          }
    329          
    330                          // Update protected variables that holds the data for the input
    331                          SRData__UpdateArray(&SRDigitalLLI_Data[input->Data_Index], &N_SRDigitalLLI_Data[input->Data_Index], &data, sizeof(SRDigitalLLI_Data[0]));
    332                      }
    333                  }
    334              }
    335          
    336              return (retval);
    337          }
