      1          /**
      2           *  @file
      3           *  @brief      LLI that provides an API but no data.
      4           *
      5           *  @details    This LLI can be registered with a Virtual GI that does not need data from an LLI.
      6           *              This will supply an LLI for GESE and HBL to meet API requirements.
      7           *
      8           *  @copyright  Copyright 2018 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
      9           */
     10          
     11          //  --- Include Files -------------------------------------------------------------------------------------------------
     12          
     13          //lint -e766 Suppress Info: header not used in module 'VirtualGI.c'
     14          #include "SystemConfig.h"
     15          
     16          #if (HBL_LLI_NUM_NONFUNCTIONAL > 0)
     17          #include "NonfunctionalLLI.h"
     18          
     19          //  --- Private Definitions -------------------------------------------------------------------------------------------
     20          //! Tracks the number of Nonfunctional LLI instances.
     21          static uint8 Allocation;
     22          
     23          //=====================================================================================================================
     24          //  --- Public Functions ----------------------------------------------------------------------------------------------
     25          //=====================================================================================================================
     26          //---------------------------------------------------------------------------------------------------------------------
     27          /**
     28          * Initialize the NonfunctionalLLI module's variables.
     29          */
     30          void NonfunctionalLLI__Initialize(void)
     31          {
     32              Allocation = 0;
     33          }
     34          
     35          //---------------------------------------------------------------------------------------------------------------------
     36          /**
     37           * Track number of Nonfunctional LLIs registered with Virtual GIs.
     38           *
     39           *  @return     uint8 result - Allocation result.
     40           *  @retval     0-254 - Nonfunctional LLI allocation instance.
     41           *  @retval     HBL_INDEX_INVALID - Allocation failed.
     42           */
     43          uint8 NonfunctionalLLI__Allocate(void)
     44          {
     45              uint8 index = HBL_INDEX_INVALID;
     46              if (Allocation < HBL_LLI_NUM_NONFUNCTIONAL)
     47              {
     48                  index = Allocation;
     49                  Allocation++;
     50              }
     51              return index;
     52          }
     53          
     54          //---------------------------------------------------------------------------------------------------------------------
     55          /**
     56           * Satisfy HBL Interface. No instance initialization required.
     57           *
     58           *  @param input = Pointer to the HBL data structure that references the LLI instance.
     59           *
     60           *  @return     PASS_FAIL_TYPE - Result of nonfunctional LLI instance initialization.
     61           *  @retval     PASS - Instance initialization always succeeds.
     62           */
     63          PASS_FAIL_TYPE NonfunctionalLLI__InitializeInstance(HBL_LLI_TYPE* input)
     64          {
     65              return (PASS);
     66          }
     67          
     68          //---------------------------------------------------------------------------------------------------------------------
     69          /**
     70           * Get nonfunctional LLI data.
     71           *
     72           * Note: A nonfunctional has no data by definition. To satisfy HBL we return a pointer to the allocation value.
     73           *
     74           *  @param input = Pointer to the HBL data structure that references the LLI instance.
     75           *  @return Address of Allocation - Indicates how many nonfunctional LLIs are allocated.
     76           */
     77          void* NonfunctionalLLI__Get(HBL_LLI_TYPE* input)
     78          {
     79              return (&Allocation);
     80          }
     81          
     82          //=====================================================================================================================
     83          //-------------------------------------- Private Functions ------------------------------------------------------------
     84          //=====================================================================================================================
     85          
     86          #endif // (HBL_LLI_NUM_NONFUNCTIONAL > 0)


 

 


