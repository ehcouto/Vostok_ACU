    280          /**
    281           *  @brief      Parses a command arrived from Reveal.
    282           *  @param      buffer - Pointer to the arrived buffer from Reveal.
    283           *  @return     return the status of the requested OpCode.
    284           */

   \                                 In section .text, align 2, keep-with-next
    285          REVEAL_RECIPE_STATUS_TYPE APIMotorControl__CommandParser(REVEAL_MSG_TYPE *buffer)
    286          {
    287              REVEAL_RECIPE_STATUS_TYPE retval;
    288          
    289              retval = NVO_RS_REJECTED;
    290          
    291              switch (buffer->op_code)
    292              {
    293          #ifndef API220_FVT_ONLY
    294                  case API220_OPCODE_MOTOR_CONTROL_RUN:
    295                      if(Run_Motor(buffer) == TRUE)
    296                      {
    297                          retval = NVO_RS_READY;
    298                      }
    299                      break;
    300          
    301                  case API220_OPCODE_MOTOR_CONTROL_STOP:
    302                      if(Stop_Motor(buffer) == TRUE)
    303                      {
    304                          retval = NVO_RS_READY;
    305                      }
    306                      break;
    307          
    308          
    309                  case API220_OPCODE_MOTOR_CONTROL_GET_DIGITAL:
    310                      if(Get_Digital(buffer) == TRUE)
    311                      {
    312                          retval = NVO_RS_READY;
    313                      }
    314                      break;
    315          
    316                  case API220_OPCODE_MOTOR_CONTROL_GET_ERROR:
    317                      if(Get_Error(buffer) == TRUE)
    318                      {
    319                          retval = NVO_RS_READY;
    320                      }
    321                      break;
    322          
    323                  case API220_OPCODE_MOTOR_CONTROL_SET_DIGITAL:
    324                      if(Set_Digital(buffer) == TRUE)
    325                      {
    326                          retval = NVO_RS_READY;
    327                      }
    328                      break;
    329          
    330          
    331                  case API220_OPCODE_MOTOR_CONTROL_GET_ANALOG:
    332                      if(Get_Analog(buffer) == TRUE)
    333                      {
    334                          retval = NVO_RS_READY;
    335                      }
    336                      break;
    337          
    338          
    339                  case API220_OPCODE_MOTOR_CONTROL_SET_ANALOG:
    340                      if(Set_Analog(buffer) == TRUE)
    341                      {
    342                          retval = NVO_RS_READY;
    343                      }
    344                      break;
    345          
    346          
    347                  case API220_OPCODE_MOTOR_CONTROL_MANUAL_CONTROL:
    348                      if(Manual_Control(buffer) == TRUE)
    349                      {
    350                          retval = NVO_RS_READY;
    351                      }
    352                      break;
    353          
    354          
    355                  case API220_OPCODE_MOTOR_CONTROL_PUBLISH_PERIOD:
    356                      if(Set_Data_Periodically_Publish(buffer) == TRUE)
    357                      {
    358                          retval = NVO_RS_READY;
    359                      }
    360                      break;
    361          #endif
    362          
    363          #if (MCI_FVT_TESTS == ENABLED)
    364          
    365                  case API220_OPCODE_MOTOR_CONTROL_FVT:
    366                      if(Api220_Fvt_Mode(buffer) == TRUE)
    367                      {
    368                          retval = NVO_RS_READY;
    369                      }
    370                      break;
    371          
    372          #endif
    373          
    374          #if(API220_DEBUG_MODE == ENABLED)
    375          
    376                  case API220_OPCODE_MOTOR_CONTROL_DEBUG:
    377                      if(Command_Api220_Debug_Mode(buffer) == TRUE)
    378                      {
    379                          retval = NVO_RS_READY;
    380                      }
    381                      break;
    382          
    383          #endif
    384          
    385                  default:
    386                      retval = NVO_RS_UNSUP_OP_CODE;
    387                      break;
    388              }
    389          
    390              return(retval);
