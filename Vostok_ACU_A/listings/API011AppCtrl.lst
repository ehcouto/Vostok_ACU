C:\Data\Nucleus_Dev\Vostok_ACU_A\source\XCategory\Application\all\API011AppCtr\API011AppCtrl.c
      1          /**
      2           *  @file       
      3           *
      4           *  @brief      API011 Implementation
      5           *
      6           *  @details    This API has 2 main functions:
      7           *                  - Implements the main communication between ACU and HMI (Regulations, Status)
      8           *                  - Implements get/set for the appliance Mode
      9           *              There is also support to get the number of cycles, the Status variables configuration
     10           *              and the position of a function in the function configuration.
     11           *
     12           @startuml{API011_Sequence_Diagram.png}
     13           hide footbox
     14           autonumber
     15           title API011 Sequence Diagram
     16           box "HMI"
     17           participant Application as app
     18           participant API011_HMI as hmi
     19           end box
     20          
     21           box "ACU"
     22           participant API011_ACU as acu
     23           end box
     24          
     25           alt Normal operation, no user activity or application changing regulations.
     26               loop 10s
     27               hmi -> acu : request regulations (API011 opcode: 4)
     28               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 1</b>
     29               hmi -> hmi : <b>API011_Num_Of_Consecutive_Status_Requests = 0</b>
     30               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     31               ... 5 secounds later ...
     32               hmi -> acu : request status (API011 opcode: 3)
     33               hmi -> hmi : <b>API011_Num_Of_Consecutive_Status_Requests = 1</b>
     34               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 0</b>
     35               acu -> hmi : publish status (API011 opcode: 3, feedback)
     36               end
     37          
     38          
     39           else ACU detect state change
     40          
     41               hmi -> acu : request regulations (API011 opcode: 4)
     42               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests++</b>
     43               hmi -> hmi : <b>API011_Num_Of_Consecutive_Status_Requests = 0</b>
     44               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     45               acu -> hmi : status change detected on ACU, publish status (API011 opcode: 3, feedback)
     46               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 0 </b>
     47               ... 5 secounds later ...
     48               hmi -> acu : request regulations (API011 opcode: 4)
     49               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests++</b>
     50               hmi -> hmi : <b>API011_Num_Of_Consecutive_Status_Requests = 0</b>
     51               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     52               acu -> hmi : status change detected on ACU, publish status (API011 opcode: 3, feedback)
     53               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 0 </b>
     54               loop Standard loop, see "Normal operation, no user activity or application changing regulations."
     55               end
     56          
     57          
     58           else HMI sets regulations
     59               hmi -> acu : set regulations (API011 opcode: 5)
     60               hmi -> hmi : API011_Num_Of_Consecutive_Regulations_Sets++
     61               hmi -> hmi : 100ms timeout
     62               hmi -> acu : request regulations (API011 opcode: 4)
     63               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets = 0</b>
     64               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests++</b>
     65               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     66               loop Standard loop, see "Normal operation, no user activity or application changing regulations."
     67               end
     68          
     69           else <b> ABNORMAL SITUATION! SHALL BE AVOIDED </b> \n HMI sets regulations continuously. \n HMI sets regulations with period greater than 100ms and less than 5s.
     70               loop 5times
     71               hmi -> acu : set regulations (API011 opcode: 5)
     72               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++</b>
     73               ... 100 milliseconds later ...
     74               hmi -> acu : request regulations (API011 opcode: 4)
     75               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets = 0</b>
     76               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests++ (1,2,3,4,5)</b>
     77               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     78               end
     79               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests >= </b> \n  <b> MAX_NUM_OF_CONSECUTIVE_REQUESTS </b>
     80               hmi -> acu : <b>request status (API011 opcode: 3) </b>
     81               acu -> hmi : <b>publish status (API011 opcode: 3, feedback) </b>
     82               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 0</b>
     83               ... 100 milliseconds later ...
     84               hmi -> acu : request regulations (API011 opcode: 4)
     85               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
     86          
     87           else <b> ABNORMAL SITUATION! SHALL BE AVOIDED </b> \n HMI sets regulations continuously. \n HMI sets regulations with period less than 100ms.
     88               loop 5 times
     89               hmi -> acu : set regulations (API011 opcode: 5)
     90               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++ (1)</b>
     91               hmi -> acu : set regulations (API011 opcode: 5)
     92               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++ (2)</b>
     93               hmi -> acu : set regulations (API011 opcode: 5)
     94               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++ (3)</b>
     95               hmi -> acu : set regulations (API011 opcode: 5)
     96               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++ (4)</b>
     97               hmi -> acu : set regulations (API011 opcode: 5)
     98               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets++ (5)</b>
     99               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets >= </b> \n  <b> MAX_NUM_OF_CONSECUTIVE_REQUESTS </b>
    100               hmi -> acu : request regulations (API011 opcode: 4)
    101               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Sets = 0</b>
    102               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests++ (1,2,3,4,5)</b>
    103               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
    104               end
    105               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests >= </b> \n  <b> MAX_NUM_OF_CONSECUTIVE_REQUESTS </b>
    106               hmi -> acu : <b>request status (API011 opcode: 3) </b>
    107               acu -> hmi : <b>publish status (API011 opcode: 3, feedback) </b>
    108               hmi -> hmi : <b>API011_Num_Of_Consecutive_Regulations_Requests = 0</b>
    109               ... 100 milliseconds later ...
    110               hmi -> acu : request regulations (API011 opcode: 4)
    111               acu -> hmi : publish regulations (API011 opcode: 4, feedback)
    112           end
    113           @enduml
