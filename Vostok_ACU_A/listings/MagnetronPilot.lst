    149          /**
    150           *  @brief      It Initializes the module MagnetronPilot and its variables
    151           */
    152          void MagnetronPilot__Initialize(void)
    153          {
    154              Magnetron_Pilot_Allocation = 0;
    155              Pilot_Index = 0;
    156              memset(Magnetron_Pilot_Data, 0, sizeof(Magnetron_Pilot_Data));
    157          
    158              MagnetronPilotMainsSampler__Initialize();
    159              MagnetronPilotRelaySync__Initialize();
    160          }
    161          
    162          //---------------------------------------------------------------------------------------------------------------------
    163          /**
    164           *  @brief      Allocate pilot instance for magnetron.
    165           *
    166           *  @return     uint8 result - Allocation result.
    167           *  @retval     0-254 - Pilot allocation instance.
    168           *  @retval     0xFF - Allocation failed.
    169           */
    170          uint8 MagnetronPilot__Allocate(void)
    171          {
    172              uint8 result = 0xFF;
    173          
    174              if (Magnetron_Pilot_Allocation < HBL_PILOT_NUM_MAGNETRON)
    175              {
    176                  result = Magnetron_Pilot_Allocation;
    177                  Magnetron_Pilot_Allocation++;
    178              }
    179          
    180              return (result);
    181          }
    182          
    183          //---------------------------------------------------------------------------------------------------------------------
    184          /**
    185           *  @brief      Initialize magnetron pilot instance.
    186           *
    187           *  @param      HBL_LOAD_TYPE *load - Pointer to associated magnetron load instance.
    188           *
    189           *  @return     PASS_FAIL_TYPE result - Result of magnetron pilot instance initialization.
    190           *  @retval     PASS - Instance initialization succeeded.
    191           *  @retval     FAIL - Instance initialization failed.
    192           */
    193          PASS_FAIL_TYPE MagnetronPilot__InitializeInstance(HBL_LOAD_TYPE *load)
    194          {
    195              PASS_FAIL_TYPE result = FAIL;
    196          
    197              if (load->Pilot_Data_Index < Magnetron_Pilot_Allocation)
    198              {
    199                  Pilot_Index = load->Pilot_Data_Index;
    200                  Magnetron_Pilot_Data[Pilot_Index].Load = load;
    201                  Magnetron_Pilot_Data[Pilot_Index].Parameters = (void *)load->Parameter_Ptr.Data;
    202          
    203                  Magnetron_Pilot_Data[Pilot_Index].Pilot_Enable = FALSE;
    204          
    205                  //! Pilot parameter version validation
    206                  if(Magnetron_Pilot_Data[Pilot_Index].Parameters->Structure_Version == MAGNETRON_PILOT_PARAMETER_STRUCTURE_VERSION)
    207                  {
    208                      //! Pilot parameter length validation
    209                      if (load->Parameter_Ptr.Length >= 6)
    210                      {
    211                          HBL_GENERIC_INPUT_ENUM_TYPE door_id = Hbl__GetGIIDByIndex(Magnetron_Pilot_Data[Pilot_Index].Parameters->Door_GI_Index);
    212          
    213                          if (door_id == HBL_GI_DOOR_1 || door_id == HBL_GI_DOOR_2)
    214                          {
    215                              //! Initialize Mains Sampler
    216                              MagnetronPilotMainsSampler__InitializeInstance(Pilot_Index,
    217                                                                             Magnetron_Pilot_Data[Pilot_Index].Parameters->AC_Mains_Same_Phase,
    218                                                                             Magnetron_Pilot_Data[Pilot_Index].Parameters->Mains_Feedback_Pin);
    219          
    220                              //! Initialize Relay Sync
    221                              MagnetronPilotRelaySync__InitializeInstance(Pilot_Index,
    222                                                                          Magnetron_Pilot_Data[Pilot_Index].Parameters->MW_Feedback_Pin,
    223                                                                          Magnetron_Pilot_Data[Pilot_Index].Parameters->MW_FB_Active_High,
    224                                                                          Magnetron_Pilot_Data[Pilot_Index].Load->Pin_Ptr[0],
    225                                                                          Magnetron_Pilot_Data[Pilot_Index].Parameters->Turbo_Enable,
    226                                                                          Magnetron_Pilot_Data[Pilot_Index].Load->Pin_Ptr[1],
    227                                                                          Magnetron_Pilot_Data[Pilot_Index].Parameters->Turbo_On_Off_Delay,
    228                                                                          Magnetron_Pilot_Data[Pilot_Index].Parameters->Door_GI_Index);
    229          
    230                              //! Enable Pilot
    231                              Magnetron_Pilot_Data[Pilot_Index].Pilot_Enable = TRUE;
    232          
    233                              //! Initialize Magnetron Pilot state machine
    234                              MagnetronPilotInitialize();
    235          
    236                              result = PASS;
    237                          }
    238                          else
    239                          {
    240                              LOG_ADD_EXCEPTION(DOOR_GI_IS_NOT_CONFIGURED_CORRECTLY, door_id);
    241                          }
    242                      }
    243                      else
    244                      {
    245                          LOG_ADD_EXCEPTION(INVALID_PILOT_PARAMETER_LENGTH, Pilot_Index);
    246                      }
    247                  }
    248                  else
    249                  {
    250                      LOG_ADD_EXCEPTION(INVALID_PILOT_PARAMETER_VERSION, Pilot_Index);
    251                  }
    252              }
    253          
    254              return (result);
    255          }
