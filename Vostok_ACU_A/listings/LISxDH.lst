   1090          //---------------------------------------------------------------------------------------------------------------------
   1091          /**
   1092           * Wait for the read process to complete on the I2C bus and then capture the temperature data.
   1093           */
   1094          static void WaitForTempData(void)
   1095          {
   1096              // Check if the temperature data has been received.
   1097          #if (SPI_ENABLED == 1)
   1098              if (Spi__GetStatus((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, SPI_STATUS_STATE) == (uint16)SPI_STATE_IDLE)    // Bus is ready when there are 0 bytes to be processed (read or write)
   1099              {
   1100                  Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high now that transmission is complete
   1101          #else
   1102              if (I2c__GetStatus((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, I2C_STATUS_STATE) == I2C_STATE_IDLE)
   1103              {
   1104          #endif
   1105                  // Read the temperature data that was received from the I2C module.
   1106                  ACCEL_READ_TEMPERATURE_TYPE data;
   1107          #if (SPI_ENABLED == 1)
   1108                  (void)Spi__Read((SPI_ENUM_DEF)LISxDH.SF_Param_Ptr->Port, (void*)&data, sizeof(ACCEL_CMD_READ_TEMPERATURE));
   1109          #else
   1110                  if (I2c__Read((I2C_ENUM_TYPE)LISxDH.SF_Param_Ptr->Port, (void*)&data, sizeof(data)) == TRUE)
   1111          #endif
   1112                  {
   1113                      // Only need to use the data from the MSB register
   1114                      // Data size is 10 bits, but at 8 bit resolution 1 digit = 1 degree C so the data is divided by 4 (2^10 bits/ 2^8 bits) to get it into units of Celsius
   1115                      LISxDH.Temperature_Delta = (sint8)(data.Temp_MSB);
   1116          
   1117                      LISxDH.Failure_Counter = 0;     // Reset failure counter
   1118          
   1119                      EventReadComplete();
   1120                  }
   1121              }
   1122          
   1123              if (LISxDH.Timer > (uint16)I2C_TIMEOUT_READY)
   1124              {
   1125                  #if (ACCEL_COMM_TEST == ENABLED)
   1126                      LISxDH.Failure_Indicator_Timer = ACCEL_FAILURE_INDICATOR_TIME;
   1127                      LISxDH.Failure_Indicator_Counter++;
   1128                  #endif
   1129                  LOG_ADD_EXCEPTION(ACCEL_NOT_RESPONDING, 1);
   1130                  LISxDH.Failure_Counter++;
   1131                  if (LISxDH.Failure_Counter >= LISXDH_MAX_FAILURES)
   1132                  {
   1133                      LISxDH.Failure_Counter = 0;
   1134                      ACCELEROMETER_NOT_RESPONDING();
   1135                  }
   1136                  EventTimeout();
   1137              }
   1138          }
