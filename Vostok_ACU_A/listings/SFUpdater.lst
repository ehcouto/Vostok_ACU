    391                                      #ifdef SFUPDATER_ENABLE_UNALIGNED_MEMORY_HANDLING
    392                                          if(SFUpdater_Flash_Buffer_Write_Index > 0)
    393                                          {
    394                                              uint16 bytes_to_fill = FLASH_ALIGNMENT - SFUpdater_Flash_Buffer_Write_Index;
    395                                              memset(&SFUpdater_Flash_Buffer[SFUpdater_Flash_Buffer_Write_Index], SFUPDATER_FLASH_DEFAULT_VALUE, bytes_to_fill);
    396                                              (void) Flash__Write(SFUpdater_Displacement_Address, SFUpdater_Flash_Buffer, FLASH_ALIGNMENT);
