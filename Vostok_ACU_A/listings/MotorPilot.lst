    101          //---------------------------------------------------------------------------------------------------------------------
    102          /**
    103           *  @brief      Initialize motor pilot instance.
    104           *
    105           *  @param      HBL_LOAD_TYPE *load - Pointer to associated motor load instance.
    106           *
    107           *  @return     PASS_FAIL_TYPE result - Result of motor pilot instance initialization.
    108           *  @retval     PASS - Instance initialization succeeded.
    109           *  @retval     FAIL - Instance initialization failed.
    110           */
    111          PASS_FAIL_TYPE MotorPilot__InitializeInstance(HBL_LOAD_TYPE *load)
    112          {
    113              PASS_FAIL_TYPE result;
    114          
    115              result = FAIL;
    116          
    117              if (load != NULL)
    118              {
    119                  if (load->Pilot_Data_Index < Motor_Pilot_Allocation)
    120                  {
    121                      result = PASS;
    122                  }
    123              }
    124          
    125              return (result);
    126          }
    127          
    128          //---------------------------------------------------------------------------------------------------------------------
    129          /**
    130            *  @brief     Set motor pilot instance request.
    131           *
    132           *  @param      HBL_LOAD_TYPE *load - Pointer to associated motor load instance.
    133           *
    134           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    135           *
    136           *  @return     PASS_FAIL_TYPE result - Result of motor pilot request.
    137           *  @retval     PASS - Instance request succeeded.
    138           *  @retval     FAIL - Instance request failed.
    139          */
    140          PASS_FAIL_TYPE MotorPilot__Request(HBL_LOAD_TYPE *load, void *data)
    141          {
    142              PASS_FAIL_TYPE result = FAIL;
    143              if ((load != NULL) && (data != NULL))
    144              {
    145                  if (load->Pilot_Data_Index < Motor_Pilot_Allocation)
    146                  {
    147                      MOTOR_REQ_TYPE* source_buffer = data;
    148                      if (source_buffer->Size > MOTOR_PILOT_MAX_BYTE_REQ_NUM)
    149                      {
    150                          LOG_ADD_EXCEPTION(MOTOR_COMMAND_TOO_BIG, (MOTOR_PILOT_MAX_BYTE_REQ_NUM << 8) | source_buffer->Size);
    151                      }
    152                      else if (source_buffer->Size == 0)
    153                      {
    154                          uint8 cmd[] =
    155                          {
    156                              2,                                          // Number of bytes in the command
    157                              API039_ACTIVITY_STOP                        // Requested motor activity
    158                          };
    159                          memcpy(&Motor_Pilot_Data[load->Pilot_Data_Index].Requested, cmd, sizeof(cmd));
    160                          result = PASS;
    161                      }
    162                      else
    163                      {
    164                          // Copy the highest priority request (so far) into the request buffer.
    165                          memcpy(&Motor_Pilot_Data[load->Pilot_Data_Index].Requested, source_buffer, source_buffer->Size);
    166                          result = PASS;
    167                      }
    168                  }
    169              }
    170          
    171              return (result);
    172          }
    173          
    174          //---------------------------------------------------------------------------------------------------------------------
    175          /**
    176           *  @brief      Process motor pilot instance.
    177           *
    178           *  @param      HBL_LOAD_TYPE *load - Pointer to motor load instance.
    179           *
    180           *  @return     PASS_FAIL_TYPE result - Result of motor pilot instance process.
    181           *  @retval     PASS - Instance process succeeded.
    182           *  @retval     FAIL - Instance process failed.
    183           */
    184          PASS_FAIL_TYPE MotorPilot__Process(HBL_LOAD_TYPE *load)
    185          {
    186              PASS_FAIL_TYPE result;
    187              MOTOR_REQ_TYPE* current;
    188              MOTOR_REQ_TYPE* request;
    189          
    190              result = FAIL;
    191          
    192              if (load != NULL)
    193              {
    194                  if (load->Pilot_Data_Index < Motor_Pilot_Allocation)
    195                  {
    196                      // Look for a change in the requested control of the motor.
    197                      current = &Motor_Pilot_Data[load->Pilot_Data_Index].Processed;
    198                      request = &Motor_Pilot_Data[load->Pilot_Data_Index].Requested;
    199                      if ((request->ReqActivity != API039_ACTIVITY_NO_CHANGE) &&
    200                          ((current->Size != request->Size) ||
    201                           (memcmp(current, request, current->Size))))
    202                      {
    203          //                API039MotionCtrl__SetMotorActivity(request->ReqActivity, request->Data, request->Size - sizeof(request->Size) - sizeof(request->ReqActivity));
    204                          memcpy(current, request, request->Size);
    205                      }
    206          
    207                      result = PASS;
    208                  }
    209              }
    210          
    211              return (result);
    212          }
