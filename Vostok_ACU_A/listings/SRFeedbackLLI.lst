     97          /**
     98           * @brief      It initialises the module SRFeedbackLLI and its variables
     99           */
    100          void SRFeedbackLLI__Initialize(void)
    101          {
    102              SRData__UpdateByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation, 0);
    103              SRData__UpdateByte(&SRZeroCross_Index, &N_SRZeroCross_Index, HBL_INDEX_INVALID);
    104              SRData__Fill(SRFeedbackLLI_Data, N_SRFeedbackLLI_Data, 0, sizeof(SRFeedbackLLI_Data));
    105          
    106              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    107                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRFEEDBACK_LLI);
    108              #endif
    109          }
