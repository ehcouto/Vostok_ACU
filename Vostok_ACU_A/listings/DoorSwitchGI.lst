    114          
    115          sint32 DoorSwitchGI__GetConverted(HBL_GI_TYPE * generic_input,void * lli_data)
    116          {
    117              uint16 data_in;
    118              sint32 retval;
    119              uint8 index;
    120              HBL_IO_DEVICE_DATA_CONVERT_TABLE_HEADER *table_header;
    121              SETTINGFILE_LOADER_TYPE io_device_data;
    122              CONVERT_TABLE_TYPE convert_table;
    123          
    124              retval = 0;
    125          
    126              data_in = (uint16)(*((uint8 *)lli_data));
    127          
    128              index = generic_input->GI_Param_Offset;
    129              if (generic_input->GI_Param_Offset != 0XFF)
    130              {
    131                  if (SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, index, &io_device_data) == PASS)
    132                  {
    133                      table_header = (HBL_IO_DEVICE_DATA_CONVERT_TABLE_HEADER *)(io_device_data.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    134          
    135                      convert_table.input_table_1        = (void *)(&io_device_data.Data[2]);
    136                      convert_table.input_type           = DATATYPE_UINT8;
    137                      convert_table.output_type          = DATATYPE_UINT8;
    138                      convert_table.search_method        = CONVERT_EXACT_MATCH;
    139                      convert_table.table_size           = table_header->Point_Number;
    140          
    141                      //Input Data Type
    142                      if (table_header->S1 == 1)
    143                      {
    144                          convert_table.input_type       = DATATYPE_UINT16;
    145                          convert_table.output_table     = (void *)((&io_device_data.Data[2]) + (table_header->Point_Number << 1));
    146                      }
    147                      else
    148                      {
    149                          convert_table.output_table     = (void *)((&io_device_data.Data[2]) + table_header->Point_Number);
    150                      }
    151          
    152                      //Output Data Type
    153                      if (table_header->S2 == 1)
    154                      {
    155                          convert_table.output_type = DATATYPE_UINT16;
    156                      }
    157          
    158                      if (table_header->Interpolation == 1)
    159                      {
    160                          convert_table.search_method        = CONVERT_INTERPOLATION_1D;
    161                      }
    162          
    163                      retval = (sint32)Convert__Process(data_in, &convert_table);
    164                  }
    165              }
    166              else
    167              {
    168                  retval = (sint32)data_in;
    169          
    170              }
    171          
    172              return (retval);
    173          }
