   1000          static void AccelReadTemp(void)
   1001          {
   1002          #if (SPI_ENABLED == 1)
   1003              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
   1004              (void)Spi__Write((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, (void*)ACCEL_CMD_READ_TEMPERATURE, sizeof(ACCEL_CMD_READ_TEMPERATURE));
