    280          //-------------------------------------- Private Functions ------------------------------------------------------------
    281          //=====================================================================================================================
    282          
    283          #ifdef DEBUG_APIS_LIST
    284          /**
    285           * Call the function to be executed based on the parameters
    286           * @param element_list: it is the array containing the values of the input parameters to pass to the function
    287           * @param function_position:index of the function inside the list
    288           * @param node_id: the value of the node requesting the function execution
    289           * @param return_value_function: flag informing if the function has a return value or not
    290           * @return REVEAL_RECIPE_STATUS_TYPE that expresses the result of the parsing.
    291           */
    292          
    293          static REVEAL_RECIPE_STATUS_TYPE ExecuteFunction(sint32 element_list[],uint8 function_position,uint8 node_id,BOOL_TYPE return_value_function)
    294          {
    295              #define INPUT_PARAMETERS element_list[0],element_list[1],element_list[2],element_list[3],element_list[4],element_list[5],element_list[6]
    296              REVEAL_RECIPE_STATUS_TYPE retval;
    297              retval = NVO_RS_READY;
    298          
    299              if (return_value_function == FALSE)
    300              {
    301                  /*Execute the function with no return value*/
    302                  ((DEBUG_FUNCTION_HANDLER_TYPE)DEBUG_FUNCTIONS_LIST[function_position].Pointer)(INPUT_PARAMETERS);
    303          
    304                  /*Publish the feedback with only the function index information*/
    305                  Reveal__QueueMessageU8(API004DEBUG_NUM,API004_FBK_CONFIRM_EXECUTION,node_id,FALSE,FALSE,function_position);
    306              }
    307              else
    308              {
    309                  sint32 return_value;
    310                  uint8 return_value_data_type;
    311                  REVEAL_COMMAND_TYPE* rev_feedback = Reveal__NewFeedback(API004DEBUG_NUM, API004_FBK_CONFIRM_EXECUTION, node_id, sizeof(function_position)+sizeof(return_value));
    312                  /*Execute the function with a return value*/
    313                  return_value = ((DEBUG_FUNCTION_WITH_RETURN_HANDLER_TYPE)DEBUG_FUNCTIONS_LIST[function_position].Pointer)(INPUT_PARAMETERS);
    314                  return_value_data_type = (uint8)(DEBUG_FUNCTIONS_LIST[function_position].Signature & RETURN_VALUE_POSITION_MASK);
    315                  /*Publish the feedback with the return value information*/
    316                  if( (Reveal__AddDataU8(rev_feedback, function_position)== FAIL) ||
    317                      (Reveal__AddDataU32(rev_feedback, return_value)== FAIL) ||
    318                      (Reveal__AddDataU8(rev_feedback, return_value_data_type)== FAIL) ||
    319                      (Reveal__QueueCommand(rev_feedback)== FALSE)
    320                      )
    321                  {
    322                      retval = NVO_RS_BUSY;
    323                  }
    324              }
    325          
    326              return(retval);
    327          }
    328          
    329          /**
    330           * Publish on the Bus the information about the functions present in the List
    331           * @param function_id: index of the function inside the list
    332           * @param str: ASCII characters label describing the function name
    333           * @param sign: Signature Information of the function
    334           * @param mmp_enabled: flag used in case of multiple packets; 1 means another packet has to be sent, 0 means that is the last packet
    335           * @param node_id: the node to address the information
    336           * @return TRUE if data to publish is consistent, FALSE if not
    337           */
    338          static BOOL_TYPE PrintOnReveal(uint8 function_id,char* str,uint32 sign,BOOL_TYPE mmp_enabled,uint8 node_id)
    339          {
    340              uint8 message_size;
    341              BOOL_TYPE result;
    342          
    343              message_size = 0;
    344              result = FALSE;
    345          
    346              message_size = strlen(str);
    347              if (message_size > LABEL_MAX_LENGTH)
    348              {
    349                  message_size = LABEL_MAX_LENGTH;
    350              }
    351          
    352              if(message_size > 0)
    353              {
    354                  REVEAL_COMMAND_TYPE* rev_feedback = Reveal__NewFeedback(API004DEBUG_NUM, API004_FBK_FUNCTIONS_INFO, node_id, sizeof(function_id)+sizeof(sign)+message_size+1);
    355                  if(mmp_enabled == TRUE)  /*if Multi Message Packet is requested, the MMP bit is set*/
    356                  {
    357                      rev_feedback->opcode |= REVEAL_MMP_BIT;
    358                  }
    359          
    360                  result = (BOOL_TYPE)((Reveal__AddDataU8(rev_feedback, function_id)== PASS) &&
    361                                       (Reveal__AddDataU32(rev_feedback, sign)== PASS) &&
    362                                       (Reveal__AddDataU8Buffer(rev_feedback, (uint8*)str, message_size)== PASS) &&
    363                                       (Reveal__AddDataU8(rev_feedback, NULL_CHAR)== PASS) &&
    364                                       (Reveal__QueueCommand(rev_feedback)== TRUE));
    365          
    366              }
    367              return result;
    368          }
    369          #endif// #ifdef DEBUG_APIS_LIST
    370          #endif//#if (API004DEBUG_FEATURE == ENABLED)

