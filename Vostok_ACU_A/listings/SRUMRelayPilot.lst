      1          /**
      2           *  @file       SRUMRelayPilot.c
      3           *
      4           *  @brief      Pilot for Universal Motor driven with Triac + Relays
      5           *
      6           *  @defgroup   CLASS_B
      7           *
      8           *  @details    This module implements all feature to use a Triac + 2 Relay + Tap field relay circuit to drive an
      9           *              Universal Motor
     10           *
     11           *              Optional parameters:
     12           *              - SRUMRELAYPILOT_FORCE_OC - Set to ENABLED to use Output Compare to drive triac gate when ZC_HANDLER_TIMING_US != 0
     13           *              - SRUMRELAYPILOT_FALLBACK_SF_PARAMS - Macro to define fallback SF Params should be set if Parameter_Ptr is NULL
     14           *                  If not set, InitializeInstance will return FAIL
     15           *
     16           *              Function macros to define in SRUMRelayPilot_prv.h
     17           *              - PASS_FAIL_TYPE SRUMRELAYPILOT__CONTROL_INITIALIZE(HBL_LOAD_TYPE* load);
     18           *              Initialize the motor control module; returns PASS if process completed, FAIL if there were errors
     19           *
     20           *              - PASS_FAIL_TYPE SRUMRELAYPILOT__CONTROL_HANDLER(HBL_LOAD_TYPE* load, SRUMRELAYPILOT_CONTROL_PARAM_TYPE *param_ptr, SRUMRELAYPILOT_CONTROL_STATUS_TYPE *status_ptr);
     21           *              Motor control handler; it gets data from param_ptr and returns status in status_ptr variables.
     22           *              PASS if handler works properly; FAIL if there are errors (failures are not included on FAIL condition!)
     23           *
     24           *              - uint8 SRUMRELAYPILOT__GET_CSTM_TACHO_INDEX(HBL_LOAD_TYPE* load);              (Optional)
     25           *              Provides LLI index for tacho signal if no Setting file parameters are available
     26           *
     27           *              - SRUMRELAYPILOT_FALLBACK_SF_PARAMS                                             (Optional)
     28           *              Contains default Setting file parameters when no parameters are set; if not defined, initialization fails
     29           *
     30           *              - BOOL_TYPE SRUMRELAYPILOT__ISCONSISTENCYOK_ADDITIONAL_CHECK()                  (Optional)
     31           *              Adds an additional consistency check to be satisfied - e.g. ZeroCross signal is present
     32           *
     33           *              - BOOL_TYPE SRUMRELAYPILOT__ISSTOPCONDITION_ADDITIONAL_CHECK()
     34           *              Adds an additional condition to force motor stop - e.g. ZeroCross signal is lost
     35           *
     36           *  @section    Applicable_Documents
     37           *					List here all the applicable documents if needed. <tr>	
     38           *
     39           *  @copyright  Copyright 2019. Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     40           */
