    405          
    406          //---------------------------------------------------------------------------------------------------------------------
    407          /**
    408           *  @brief      Asynchronous process for DoorLockEMPilot.
    409           *
    410           *	@detail     Asynchronous process handles status transition and consistency check for door lock status
    411           *
    412           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    413           *
    414           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot asynch execution.
    415           *  @retval     PASS - Execution succeeded.
    416           *  @retval     FAIL - Execution failed.
    417           */
    418          PASS_FAIL_TYPE DoorLockEMPilot__AsynchProcess(HBL_LOAD_TYPE * load )
    419          {
    420              DOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    421              DOORLOCKEMPILOT_DATA_TYPE *ptr;
    422              PASS_FAIL_TYPE retval;
    423              BOOL_TYPE pin_val;
    424              uint8 index;
    425              HBL_CONSISTENCY_TYPE lock_feedback;
    426              HBL_LOAD_STATUS_TYPE target_status;
    427          
    428              retval = FAIL;
    429              pin_val = FALSE;
    430              index = load->Pilot_Data_Index;
    431          
    432              if (index < DoorLockEMPilot_Allocation)
    433              {
    434                  param_ptr = (DOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    435                  ptr = &DoorLockEMPilot_Data[index];
    436          
    437                  target_status.Load.Cur_Reg = ptr->Processed;
    438                  // Prevent use of TRN table when DoorLock status is OFF;
    439                  // during INITIALIZE consider Processed target like it has been already reached
    440                  if ((ptr->Processed != 0) && (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE))
    441                  {
    442                      target_status.Load.Status = ptr->PilotStatus.Load.Status;
    443                  }
    444                  else
    445                  {
    446                      target_status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    447                  }
    448                  lock_feedback.Byte = Hbl__GetOwnLoadConsistency(load, target_status.Byte);
    449                  retval = PASS;
    450          
    451                  switch (ptr->Status)
    452                  {
    453                      case DOORLOCKEM_STATUS_DOOR_LOCKING:
    454                          if ((lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK)
    455                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_OFF))
    456                          {
    457                              ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKED;
    458                              ptr->Retries = 0;
    459                          }
    460                          else if ((ptr->Retries == 0) &&
    461          				    (ptr->Retries_Counter >= (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS)))
    462                          {
    463                              ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKING_FAILED;
    464                          }
    465                          break;
    466          
    467                      case DOORLOCKEM_STATUS_DOOR_UNLOCKING:
    468                          if ((   (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    469                                  (lock_feedback.Consistency.Value == HBL_CONSISTENCY_DISCONNECTED))
    470                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON)
    471                          && (lock_feedback.Consistency.Table != HBL_CONSISTENCY_TABLE_ON_ALTERNATE))
    472                          {
    473                              ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKED;
    474                              ptr->Retries = 0;
    475                          }
    476                          else if ((ptr->Retries == 0) &&
    477          				    (ptr->Retries_Counter >= (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS)))
    478                          {
    479                              ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED;
    480                          }
    481                          break;
    482          
    483                      case DOORLOCKEM_STATUS_DOOR_LOCKED:
    484                      case DOORLOCKEM_STATUS_DOOR_UNLOCKED:
    485                      case DOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    486                      case DOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    487                          break;
    488          
    489                      default:
    490                          // Consistency detects door is locked/unlocked properly, according to acutal set point
    491                          if ((ptr->Requested == ptr->Processed) &&
    492                              (   (lock_feedback.Consistency.Value == HBL_CONSISTENCY_OK) ||
    493                                  (lock_feedback.Consistency.Value == HBL_CONSISTENCY_DISCONNECTED)) )
    494                          {
    495                              uint16 duration = param_ptr->Num_Pulses;
    496          
    497                              if (duration == 0)
    498                              {
    499                                  duration = SRDOORLOCKEM_DEFAULT_PULSES;
    500                              }
    501                              duration *= ptr->Period;
    502          
    503                              if (lock_feedback.Consistency.Table == HBL_CONSISTENCY_TABLE_OFF)
    504                              {
    505                                  // Door already unlocked
    506                                  ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKED;
    507                                  if(ptr->Retries_Counter < duration)
    508                                  {
    509                                      ptr->Retries_Counter = duration;
    510                                  }
    511                              else
    512                              {
    513                                  // Door already locked
    514                                  ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKED;
    515                                  if(ptr->Retries_Counter < duration)
    516                                  {
    517                                      ptr->Retries_Counter = duration;
    518                                  }
    519                              }
    520                          }
    521                          else
    522                          {
    523                              ptr->Status = DOORLOCKEM_STATUS_INIT;
    524                              // Wait for Time between pulses
    525                              if (ptr->Retries_Counter >= (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS))
    526                              {
    527                                  if (ptr->Processed == OFF)
    528                                  {
    529                                      // Door is assumed to be locked
    530                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKED;
    531                                      ptr->Processed = ON;
    532                                  }
    533                                  else
    534                                  {
    535                                      // Door is assumed to be unlocked
    536                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKED;
    537                                      ptr->Processed = OFF;
    538                                  }
    539                              }
    540                          }
    541                          break;
    542          
    543                  }
    544          
    545                  switch (ptr->Status)
    546                  {
    547                      case DOORLOCKEM_STATUS_DOOR_LOCKED:
    548                      case DOORLOCKEM_STATUS_DOOR_UNLOCKED:
    549                          ptr->PilotStatus.Load.Status = ((pin_val == TRUE) ? HBL_LOAD_STATUS_TARGET_ALT_TABLE : HBL_LOAD_STATUS_TARGET_COMPLETED);
    550                          ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    551                          break;
    552          
    553                      case DOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    554                      case DOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    555                          ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_FAILURE;
    556                          ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    557                          break;
    558          
    559                      default:
    560                          if (ptr->PilotStatus.Load.Status != HBL_LOAD_STATUS_INITIALIZE)
    561                          {
    562                              ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    563                          }
    564                  }
    565              }
    566          
    567              return (retval);
    568          }
    569          
    570          //---------------------------------------------------------------------------------------------------------------------
    571          /**
    572           *  @brief      One millisecond process for DoorLockEMPilot.
    573           *
    574           *	@detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    575           *
    576           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    577           *
    578           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot 1ms execution.
    579           *  @retval     PASS - Execution succeeded.
    580           *  @retval     FAIL - Execution failed.
    581           */
    582          PASS_FAIL_TYPE DoorLockEMPilot__Handler1ms(HBL_LOAD_TYPE * load )
    583          {
    584              DOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    585              DOORLOCKEMPILOT_DATA_TYPE *ptr;
    586              PASS_FAIL_TYPE retval;
    587              BOOL_TYPE pin_val;
    588              BOOL_TYPE pin_fbk_val;
    589              uint8 virtual_pin;
    590              uint8 index;
    591          
    592              retval = FAIL;
    593              pin_val = FALSE;
    594              pin_fbk_val = FALSE;
    595              index = load->Pilot_Data_Index;
    596          
    597              if (index < DoorLockEMPilot_Allocation)
    598              {
    599                  param_ptr = (DOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    600                  ptr = &DoorLockEMPilot_Data[index];
    601                  retval = PASS;
    602          
    603                  if (ptr->Fbk_Pin < VirtualPin__GetNumOf())
    604                  {
    605                      pin_fbk_val = Gpio__PinRead(VIRTUALPIN_TABLE[ptr->Fbk_Pin].port, VIRTUALPIN_TABLE[ptr->Fbk_Pin].pin);
    606                  }
    607          
    608                  if (pin_fbk_val != ptr->Fbk_Last_Pin_Value)
    609                  {
    610                      if (pin_fbk_val == TRUE)
    611                      {
    612                          if ((ptr->Fbk_Counter >= DOORLOCKEM_MIN_PERIOD_MS) && 
    613          				    (ptr->Fbk_Counter <= DOORLOCKEM_MAX_PERIOD_MS))
    614                          {
    615                              uint16 new_period = (ptr->Period + ptr->Fbk_Counter + 1) >> 1;
    616                              sint8 tmp_offset = (ptr->Fbk_Counter - (2 * ptr->Fbk_Last_Counter)) / 4;
    617                              if (tmp_offset < 0)
    618                              {
    619                                  tmp_offset += (ptr->Period / 2);
    620                              }
    621                              ptr->Period = new_period;
    622                              ptr->Cycle_Counter = tmp_offset;
    623                          }
    624                          ptr->Fbk_Counter = 0;
    625                      }
    626                      else
    627                      {
    628                          ptr->Fbk_Last_Counter = ptr->Fbk_Counter;
    629                      }
    630          
    631                      ptr->Fbk_Last_Pin_Value = pin_fbk_val;
    632                  }
    633                  if (ptr->Cycle_Counter >= ptr->Period)
    634                  {
    635                      ptr->Cycle_Counter = 0;
    636                  }
    637                  if (ptr->Retries_Counter < (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS))
    638                  {
    639                      ptr->Retries_Counter += 1;
    640                  }
    641          
    642                  if (ptr->Status != DOORLOCKEM_STATUS_INIT)
    643                  {
    644                      uint16 pulse_duration;
    645                      BOOL_TYPE force_pin = (BOOL_TYPE) ptr->Keep_Triac_On;
    646                      uint8 num_pulses = param_ptr->Num_Pulses;
    647                      if (num_pulses == 0)
    648                      {
    649                          num_pulses = DOORLOCKEM_DEFAULT_PULSES;
    650                      }
    651          
    652                      if ((ptr->Cycle_Counter == 0) ||
    653                          (ptr->Cycle_Counter == (ptr->Period/2)))
    654                      {
    655                          if ((ptr->Retries > 0) &&
    656                              (ptr->Retries_Counter >= (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS)))
    657                          {
    658                              ptr->Retries_Counter = 0;
    659                              ptr->Retries--;
    660                          }
    661                          else if (ptr->Process_Triac_On)
    662                          {
    663                              force_pin = TRUE;
    664                          }
    665                      }
    666          
    667                      if (!ptr->Process_Triac_On)
    668                      {
    669                          force_pin = FALSE;
    670                      }
    671                      ptr->Keep_Triac_On = force_pin;
    672          
    673                      pulse_duration = num_pulses * ptr->Period;
    674                      pulse_duration /= 2;
    675                      // Pulse duration is reduced by 1/4 period to ensure triac can switch OFF
    676                      pulse_duration -= (ptr->Period/4);
    677          
    678                      if ((force_pin == TRUE) ||
    679                          (ptr->Retries_Counter < pulse_duration))
    680                      {
    681                          pin_val = TRUE;
    682                      }
    683                  }
    684          
    685                  virtual_pin = (*load->Pin_Ptr);
    686                  pin_val ^= (BOOL_TYPE) ~load->Hi_Low_Activation_Bitmap;
    687                  pin_val &= (BOOL_TYPE) 0x01;
    688                  Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, pin_val);
    689          		
    690                  ptr->Cycle_Counter++;
    691                  if (ptr->Fbk_Counter < DOORLOCKEM_FBK_TIMEOUT)
    692                  {
    693          		    ptr->Fbk_Counter++;
    694            		}
    695              }
    696          
    697              return (retval);
    698          }
