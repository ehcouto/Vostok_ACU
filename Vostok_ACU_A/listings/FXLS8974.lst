   1357          
   1358          //---------------------------------------------------------------------------------------------------------------------
   1359          /**
   1360           *  State machine guard function to determine if self test feature is enabled
   1361           * @return
   1362           */
   1363          static BOOL_TYPE SelfTestEnabled(void)
   1364          {
   1365              BOOL_TYPE is_self_test_enabled = FALSE;
   1366          
   1367              if ((Fxls8974.Mode_Processed == FXLS8974_MODE_ST_POSITIVE_X) ||
   1368                  (Fxls8974.Mode_Processed == FXLS8974_MODE_ST_POSITIVE_Y) ||
   1369                  (Fxls8974.Mode_Processed == FXLS8974_MODE_ST_POSITIVE_Z) ||
   1370                  (Fxls8974.Mode_Processed == FXLS8974_MODE_ST_NEGATIVE_X) ||
   1371                  (Fxls8974.Mode_Processed == FXLS8974_MODE_ST_NEGATIVE_Y) ||
   1372                  (Fxls8974.Mode_Processed == FXLS8974_MODE_ST_NEGATIVE_Z))
   1373              {
   1374                  is_self_test_enabled = TRUE;
   1375              }
   1376          
   1377              return(is_self_test_enabled);
   1378          }
