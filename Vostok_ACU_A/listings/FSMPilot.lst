     31          // -- Private Constant Declarations --
     32          #define FSMPILOT_STATEMACHINE_TIMING_INTERVAL	10	//Interval in MS
     33          
     34          //! State machine values
     35          typedef enum
     36          {
     37              FSMPILOT_SM_IDLE = 0,
     38              FSMPILOT_SM_INIT,
     39              FSMPILOT_SM_SET_POINT_MONITORING,
     40              FSMPILOT_SM_T3,
     41              FSMPILOT_SM_T2
     42          } FSMPILOT_STATE_MACHINE_VAL_TYPE;
     43          
     44          //! Speed sign
     45          typedef sint8 FSMPILOT_SPEED_SIGN_TYPE;
     46          
     47          //! Target velocity
     48          typedef sint8 FSMPILOT_VELOCITY_TYPE;
     49          
     50          //! T2
     51          typedef uint8 FSMPILOT_T2_TYPE;
     52          
     53          //! T3
     54          typedef uint16 FSMPILOT_T3_TYPE;
     55          
     56          //! State machine manager
     57          PACKED typedef struct
     58          {
     59              FSMPILOT_VELOCITY_TYPE   		Processed; 				 		//!< Processed Speed value
     60              FSMPILOT_VELOCITY_TYPE   		Requested; 				  		//!< Requested Speed value
     61              FSMPILOT_VELOCITY_TYPE   		Current_Velocity; 		  		//!< Current Speed value
     62              FSMPILOT_T3_TYPE                T3_Cnt;                   		//!< T3 counter
     63              FSMPILOT_T2_TYPE                T2_Cnt;                   		//!< T2 counter
     64              uint8							Sense_Of_Rotation_Pin_Value;	//!< Target value for sor pin
     65              uint8							Power_Enable_Pin_1_Value;		//!< Target value for power enable pin 1
     66              uint8							Power_Enable_Pin_2_Value;		//!< Target value for power enable pin 2
     67              uint8							Monitoring_Flag;		  		//!< Indicating if the state machine is in monitoring state (0)
     68              FSMPILOT_STATE_MACHINE_VAL_TYPE State;      			  		//!< State machine value
     69          } FSMPILOT_DATA_TYPE;
     70          
     71          //! Struct to cast the parameters for the Fixed Speed Motor.
     72          PACKED typedef struct
     73          {
     74          	uint8 T2_Val;
     75          	uint8 T3_Val;
     76          } FSMPILOT_PARAMETERS_TYPE;
     77          
     78          //! Struct to cast the io pilot pins for the Fixed Speed Motor.
     79          PACKED typedef struct
     80          {
     81          	uint8 Sense_Of_Rotation_Pin;
     82          	uint8 Power_Enable_Pin_1;
     83          	uint8 Power_Enable_Pin_2;
     84          } FSMPILOT_PIN_MAP_TYPE;
