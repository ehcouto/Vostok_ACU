   \              0x00000000   
     74          {
     75              // Cross category Op Codes 0 - 5. Common and required for all projects.
     76              NULL_PROCESS_INITIALZE,                  //!< OpCode:  0 SetState
     77              NULL_PROCESS_INITIALZE,                  //!< OpCode:  1 SetVariable
     78              Maintain__Initialize,                    //!< OpCode:  2 Maintain
