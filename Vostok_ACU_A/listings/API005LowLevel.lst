    993              Reveal__AddDataU8(ptr,HblHmi__GetLLIIDByIndex(item_index));
    994              Reveal__AddDataU8(ptr,HblHmi__GetLLIPositionByIndex(item_index));
    995              Reveal__AddDataU8(ptr, data_size);
    996              Reveal__AddDataU8Buffer(ptr, HblHmi__GetLLIDataByIndex(item_index), data_size);
    997          }
