     29          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     30          
     31          //! The name of this module for use by the Log module.
     32          #define MODULE_NAME MODULE_I2CPRESSURESENSOR
     33          
     34          //! A list of log message IDs that are generated by this module.
     35          typedef enum MODULE_EXTRACTIONSIS_LOG_MESSAGE_ID_ENUM
     36          {
     37              ERROR_COMMUNICATION  = 1,
     38              ERROR_DATA_STUCK,
     39          }MODULE_I2CPRESSURESENSOR_LOG_MESSAGE_ID_TYPE;
     40          
     41          //! Hold initial value of the filter
     42          #define PRESSURE_SENSOR_INITIAL_FILTER_VALUE     0
     43          
     44          //! Hold the default alpha value
     45          #define PRESSURE_SENSOR_DEFAULT_ALPHA    32
     46          
     47          //! Hold the number of counts to fault
     48          #define I2C_PRESSURE_FAULT_COUNTER  8
     49          
     50          //! Holds the value if pressure sensor is stabilizing
     51          static const sint32 STABILIZING_PRESSURE = I2CPRESSURESENSOR_STABILIZING;
     52          
     53          //! Holds the value if there is an active I2C communication failure
     54          static const sint32 FAILURE_PRESSURE = I2CPRESSURESENSOR_I2C_FAILURE;
     55          
     56          typedef enum
     57          {
     58              I2C_PRESSURE_SENSOR_NOT_DEFINED = 0,
     59              I2C_PRESSURE_SENSOR_REQUEST,
     60              I2C_PRESSURE_SENSOR_READ
     61          }I2C_PRESSURE_SENSOR_STATE_TYPE;
     62          
     63          
     64          //! Manufacturer definition - this enum needs to reflect the one defined in the Pressure Sensor GI (PressureSensorGI.c)
     65          typedef enum
     66          {
     67              I2C_MANUF_NOT_DEFINED = 0,
     68              I2C_MANUF_ITM = 0x28,
     69              I2C_MANUF_PANASONIC = 0x27,
     70          } I2C_PRESSURE_MANUFACTURER_TYPE;
     71          
     72          
     73          PACKED typedef struct
     74          {
     75              uint16 Unused;
     76              uint8  Device_Type;
     77              uint8  Inverted_Alpha;
     78              uint16 Intital_Time;
     79          } I2C_PRESSURE_SENSOR_PARAM_TYPE;
     80          
     81          typedef struct
     82          {
     83              I2C_PRESSURE_SENSOR_STATE_TYPE State;
     84              IIR_FILTER_MEASURE_TYPE Filter;
     85              MILLIS_TIMER_TYPE Timer_Index;
     86              uint16 Pressure;
     87              uint8 Communication_Error_Counter;
     88              uint8 Buffer[4];
     89          }I2C_PRESSURE_SENSOR_DATA_TYPE;
     90          
     91          
     92          static I2C_PRESSURE_SENSOR_DATA_TYPE I2c_Pressure[HBL_LLI_NUM_I2C_PRESSURE_SENSOR];
     93          static uint8 I2CPressure_Sensor_LLI_Allocation;
     94          
     95          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     96          
     97          
     98          //=====================================================================================================================
     99          //-------------------------------------- Public Functions -------------------------------------------------------------
    100          //=====================================================================================================================
    101          //---------------------------------------------------------------------------------------------------------------------
    102          /**
    103           * @brief   It Initializes the module I2CPressureSensor LLI and its variables
    104           */
    105          void I2CPressureSensorLLI__Initialize(void)
    106          {
    107              uint8 index;
    108          
    109              for (index = 0; index < HBL_LLI_NUM_I2C_PRESSURE_SENSOR; index++)
    110              {
    111                  memset(&I2c_Pressure[index],0,sizeof(I2c_Pressure[0]));
    112              }
    113          
    114              I2CPressure_Sensor_LLI_Allocation = 0;
    115          }
    116          
    117          //---------------------------------------------------------------------------------------------------------------------
    118          /**
    119           * @brief   Determines the destination (index) of the data for the LLI.
    120           * @return  Index to a local buffer where the data will reside.
    121           */
    122          uint8 I2CPressureSensorLLI__Allocate(void)
    123          {
    124              uint8 retval;
    125              retval = 0xFF;
    126              if (I2CPressure_Sensor_LLI_Allocation < HBL_LLI_NUM_I2C_PRESSURE_SENSOR)
    127              {
    128                  retval = I2CPressure_Sensor_LLI_Allocation;
    129                  Millis__Reset(&I2c_Pressure[I2CPressure_Sensor_LLI_Allocation].Timer_Index);
    130                  I2CPressure_Sensor_LLI_Allocation++;
    131              }
    132              return (retval);
    133          }
    134          
    135          //---------------------------------------------------------------------------------------------------------------------
    136          /**
    137           * @brief   Initialize an instance of the LLI by extracting parameter data and initializing variables.
    138           * @param   input: data related to the instance of the LLI
    139           * @param   PASS if the initialization was successful, else FAIL
    140           */
    141          PASS_FAIL_TYPE I2CPressureSensorLLI__InitializeInstance(HBL_LLI_TYPE * input)
    142          {
    143              PASS_FAIL_TYPE retval;
    144              I2C_PRESSURE_SENSOR_PARAM_TYPE *param_ptr;
    145          
    146              param_ptr = (I2C_PRESSURE_SENSOR_PARAM_TYPE *)(void *)(input->Parameter_Ptr.Data);
    147          
    148              // Read parameter from virtual pin table
    149              const VIRTUALPIN_TYPE* pin_ptr = &(VIRTUALPIN_TABLE[input->Pin_Ptr[0]]);
    150          
    151              // If device is properly configured
    152          
    153              if(I2c__Initialize((I2C_ENUM_TYPE)pin_ptr->device, (I2C_SPEED_TYPE)pin_ptr->param1, I2C_ADDR_7BITS, (pin_ptr->param0) << 1) == TRUE)
    154              {
    155                  I2c_Pressure[input->Data_Index].State = I2C_PRESSURE_SENSOR_REQUEST;
    156                  I2c_Pressure[input->Data_Index].Filter.Inverted_Alpha = param_ptr->Inverted_Alpha;
    157          
    158                  //Start timer here
    159                  Millis__Start(&I2c_Pressure[I2CPressure_Sensor_LLI_Allocation].Timer_Index);
    160          
    161                  //Initialize filter
    162                  Filter__Initialize((void *)&(I2c_Pressure[input->Data_Index].Filter), PRESSURE_SENSOR_INITIAL_FILTER_VALUE, FILTER_IIR);
    163          
    164                  retval = PASS;
    165              }
    166              else
    167              {
    168                  Fault__ConditionDetected(FAULT_ID_PRESSURE_SENSOR); // Fault detected
    169          
    170                  retval = FAIL;
    171              }
    172          
    173              return (retval);
    174          }
    175          
    176          //---------------------------------------------------------------------------------------------------------------------
    177          /**
    178           * @brief   Retrieves the current value of the LLI
    179           * @param   input: data related to the instance of the LLI
    180           * @return  The current value of the LLI
    181           */
    182          void * I2CPressureSensorLLI__Get(HBL_LLI_TYPE * input)
    183          {
    184          	void* ptr = NULL;
    185          	I2C_PRESSURE_SENSOR_PARAM_TYPE *param_ptr;
    186          
    187          	param_ptr = (I2C_PRESSURE_SENSOR_PARAM_TYPE *)(void *)(input->Parameter_Ptr.Data);
    188          
    189          	if (input->Data_Index < I2CPressure_Sensor_LLI_Allocation)
    190          	{
    191          		if (Millis__ReachedTarget(&I2c_Pressure[input->Data_Index].Timer_Index, param_ptr->Intital_Time) == FALSE)
    192          		{
    193          			ptr = ((void *)&STABILIZING_PRESSURE);
    194          		}
    195          		else
    196          		{
    197          			if (I2c_Pressure[input->Data_Index].Communication_Error_Counter >= I2C_PRESSURE_FAULT_COUNTER)
    198          			{
    199          				// Return unique pressure value if there is an I2c communication failure
    200          				ptr = (void *)&FAILURE_PRESSURE;
    201          			}
    202          			else // all good
    203          			{
    204          				ptr = ((void *)&I2c_Pressure[input->Data_Index].Filter.Filtered_Value);
    205          			}
    206          		}
    207          	}
    208          
    209              return ptr;
    210          }
    211          
    212          //---------------------------------------------------------------------------------------------------------------------
    213          /**
    214           * @brief   Asynchronous processing of a the LLI
    215           * @param   input: data related to the instance of the LLI
    216           * @return  PASS if the LLI was successfully processed, else FAIL
    217           */
    218          BOOL_TYPE I2CPressureSensorLLI__AsynchProcess(HBL_LLI_TYPE * input)
    219          {
    220              BOOL_TYPE retval;
    221              I2C_PRESSURE_SENSOR_DATA_TYPE *ptr;
    222          
    223              retval = FALSE;
    224          
    225              if (input->Data_Index < I2CPressure_Sensor_LLI_Allocation)
    226              {
    227                  ptr = &I2c_Pressure[input->Data_Index];
    228          
    229                  const VIRTUALPIN_TYPE* pin_ptr = &(VIRTUALPIN_TABLE[input->Pin_Ptr[0]]);
    230          
    231                  switch(I2c_Pressure[input->Data_Index].State)
    232                  {
    233          
    234                      case I2C_PRESSURE_SENSOR_REQUEST:
    235          
    236                      	// Request the reading to the device
    237                      	retval = I2c__RequestRead((I2C_ENUM_TYPE)pin_ptr->device, 2);
    238          
    239                          ptr->State = I2C_PRESSURE_SENSOR_READ;
    240                          break;
    241          
    242          
    243                      case I2C_PRESSURE_SENSOR_READ:
    244          
    245                          if (I2c__GetStatus((I2C_ENUM_TYPE)pin_ptr->device,I2C_STATUS_STATE) == I2C_STATE_IDLE)// Check if bus is free
    246                          {
    247                              // Copy the I2c Rx buffer to the I2c_Pressure_Buffer
    248                          	retval = I2c__Read((I2C_ENUM_TYPE)pin_ptr->device, ptr->Buffer, sizeof(ptr->Buffer));	// Copy the I2c Rx buffer to the I2c_Pressure_Buffer
    249          
    250                              // Merge the pressure data bytes
    251                              ptr->Pressure  = ((uint16)ptr->Buffer[0]) << 8 | ptr->Buffer[1];
    252                              ptr->Pressure &= 0x3FFF;    // Mask off 2 status bits
    253          
    254                              // Update Filter
    255                              Filter__Update((void *)&(ptr->Filter), (FILTER_DATA_TYPE)(ptr->Pressure), FILTER_IIR);
    256          
    257                              ptr->Communication_Error_Counter = 0;
    258          
    259                              Fault__ConditionRemoved(FAULT_ID_PRESSURE_SENSOR);
    260          
    261                              ptr->State = I2C_PRESSURE_SENSOR_REQUEST;
    262                          }
    263                          else
    264                          {
    265                              // Note: There's no action if the Communication_Error_Counter is greater then I2C_PRESSURE_FAULT_COUNTER
    266                              if (ptr->Communication_Error_Counter == I2C_PRESSURE_FAULT_COUNTER)
    267                              {
    268                                  ptr->Communication_Error_Counter++; // increment commum. error counter
    269          
    270                                  LOG_ADD_EXCEPTION(ERROR_COMMUNICATION, 0); // publish exception
    271          
    272                                  Fault__ConditionDetected(FAULT_ID_PRESSURE_SENSOR); // fault detected
    273                              }
    274                              else if (ptr->Communication_Error_Counter < I2C_PRESSURE_FAULT_COUNTER)
    275                              {
    276                                  ptr->Communication_Error_Counter++; // increment commum. error counter
    277                              }
    278                              else    //(ptr->Communication_Error_Counter > I2C_PRESSURE_FAULT_COUNTER)
    279                              {
    280                                  I2c__Clear((I2C_ENUM_TYPE)pin_ptr->device);
    281                                  I2c__ResetBus((I2C_ENUM_TYPE)pin_ptr->device);
    282                                  ptr->State = I2C_PRESSURE_SENSOR_REQUEST;
    283                              }
    284                          }
    285                          break;
    286          
    287                      default:
    288                          // Left blank intentionally
    289                          break;
    290                  }
    291              }
    292          
    293              return (retval);
    294          }
    295          
