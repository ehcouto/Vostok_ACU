     73          //! ID for this module in the Log module.
     74          #define MODULE_NAME MODULE_MODIFIER
     75          
     76          //! A value that indicates that the modified_value is invalid or inactive.
     77          //! The value is also used to set the initial value for the min/max overall operations.
     78          #define MODIFY_VALUE_IS_OUT_OF_BOUNDS 1E39
