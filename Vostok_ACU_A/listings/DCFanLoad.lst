     63          /**
     64           *  @brief      It Initializes the module DCFanLoad and its variables
     65           *
     66           */
     67          void DCFanLoad__Initialize(void)
     68          {
     69              DCFanLoad_Allocation = 0;
     70              memset(DCFanLoad_Data,0,sizeof(DCFanLoad_Data));
     71          }
     72          
     73          //---------------------------------------------------------------------------------------------------------------------
     74          /**
     75           * @brief -
     76           * @return
     77           */
     78          uint8 DCFanLoad__Allocate(void)
     79          {
     80              uint8 retval;
     81              retval = 0xFF;
     82              if (DCFanLoad_Allocation < HBL_LOAD_NUM_DCFAN)
     83              {
     84                  retval = DCFanLoad_Allocation;
     85                  DCFanLoad_Allocation++;
     86          
     87              }
     88              return (retval);
     89          }
     90          
     91          //---------------------------------------------------------------------------------------------------------------------
     92          /**
     93           * @brief -
     94           *
     95           * @param load
     96           * @return
     97           */
     98          PASS_FAIL_TYPE DCFanLoad__InitializeInstance(HBL_LOAD_TYPE * load)
     99          {
    100              PASS_FAIL_TYPE ret_val = FAIL;
    101          
    102              if ( load->Load_Data_Index < DCFanLoad_Allocation )
    103              {
    104                  DCFanLoad_Data[load->Load_Data_Index].Processed_Speed  = 0;
    105                  DCFanLoad_Data[load->Load_Data_Index].Requested_Speed  = 0;
    106                  DCFanLoad_Data[load->Load_Data_Index].Accepted_Request = 0;
    107          
    108                  //Reset the timer
    109                  Millis__Reset(&DCFanLoad_Data[load->Load_Data_Index].Timer_Handle);
    110          
    111                  ret_val = PASS;
    112              }
    113              return ( ret_val );
    114          }
    115          
    116          //---------------------------------------------------------------------------------------------------------------------
    117          /**
    118           * @brief -
    119           *
    120           * @param load
    121           * @param data
    122           * @return
    123           */
    124          PASS_FAIL_TYPE DCFanLoad__Request(HBL_LOAD_TYPE * load,void * data)
    125          {
    126              if (load->Load_Data_Index < DCFanLoad_Allocation)
    127              {
    128                  DCFanLoad_Data[load->Load_Data_Index].Requested_Speed = *((uint8 *)data);
    129                  return (PASS);
    130              }
    131              else
    132              {
    133                  return (FAIL);
    134              }
    135          }
    136          
    137          //---------------------------------------------------------------------------------------------------------------------
    138          /**
    139           * @brief -
    140           *
    141           * @param load
    142           * @param pilot
    143           * @return
    144           */
    145          PASS_FAIL_TYPE DCFanLoad__Process(HBL_LOAD_TYPE * load, HBL_PILOT_HANDLER_HOOK_TYPE * pilot)
    146          {
    147              PASS_FAIL_TYPE retval;
    148          
    149              retval = FAIL;
    150          
    151              if (load->Load_Data_Index < DCFanLoad_Allocation)
    152              {
    153              	if(DCFanLoad_Data[load->Load_Data_Index].Accepted_Request != DCFanLoad_Data[load->Load_Data_Index].Requested_Speed)
    154              	{
    155              		DCFanLoad_Data[load->Load_Data_Index].Accepted_Request = DCFanLoad_Data[load->Load_Data_Index].Requested_Speed;
    156              	}
    157              	retval = PASS;
    158              }
    159          
    160              return(retval);
    161          }
    162          
    163          //---------------------------------------------------------------------------------------------------------------------
    164          /**
    165           * Getter for the Requested speed.
    166           * @param load compressor from which to get the requested speed.
    167           * @return NULL in case of failure. Otherwise the pointer to the requested speed. Cast it using *((COMPRESSORBASIC_SPEED_TYPE *)ptr) to get the value.
    168           */
    169          void * DCFanLoad__GetRequested(HBL_LOAD_TYPE * load)
    170          {
    171              if (load->Load_Data_Index < DCFanLoad_Allocation)
    172              {
    173                  return (&DCFanLoad_Data[load->Load_Data_Index].Requested_Speed);
    174              }
    175              else
    176              {
    177                  return (NULL);
    178              }
    179          }
    180          
    181          
    182          //---------------------------------------------------------------------------------------------------------------------
    183          /**
    184           * @brief -
    185           *
    186           * @param load
    187           * @param pilot
    188           */
    189          void * DCFanLoad__GetProcessed(HBL_LOAD_TYPE * load, HBL_PILOT_HANDLER_HOOK_TYPE * pilot)
    190          {
    191              if (load->Load_Data_Index < DCFanLoad_Allocation)
    192              {
    193                  return (pilot->GetProcessed(load));
    194              }
    195              else
    196              {
    197                  return (NULL);
    198              }
    199          }
    200          
    201          //---------------------------------------------------------------------------------------------------------------------
    202          /**
    203           * @brief -
    204           * @param load
    205           * @param pilot
    206           * @return
    207           */
    208          PASS_FAIL_TYPE DCFanLoad__AsyncProcess(HBL_LOAD_TYPE * load, HBL_PILOT_HANDLER_HOOK_TYPE * pilot)
    209          {
    210              DCFANLOAD_PARAMETERS_TYPE *parameters = (DCFANLOAD_PARAMETERS_TYPE *)(void*)load->Load_Parameter_Ptr.Data;
    211          
    212              if (load->Load_Data_Index < DCFanLoad_Allocation)
    213              {
    214                  switch (DCFanLoad_Data[load->Load_Data_Index].State)
    215                  {
    216                      default:
    217                      case DCFANLOAD_STATE_OFF:
    218                          DCFanLoad_Data[load->Load_Data_Index].Processed_Speed = 0;
    219          
    220                          if (DCFanLoad_Data[load->Load_Data_Index].Accepted_Request > 0)
    221                          {
    222                              DCFanLoad_Data[load->Load_Data_Index].State           = DCFANLOAD_STATE_RAMPING_UP;
    223          
    224                              Millis__Start(&DCFanLoad_Data[load->Load_Data_Index].Timer_Handle);
    225                              if(parameters->Startup_Speed == 0)
    226                              {
    227                              	DCFanLoad_Data[load->Load_Data_Index].Processed_Speed = DCFanLoad_Data[load->Load_Data_Index].Accepted_Request;
    228                              }
    229                              else
    230                              {
    231                              	DCFanLoad_Data[load->Load_Data_Index].Processed_Speed = parameters->Startup_Speed;
    232                              }
    233                          }
    234                          break;
    235                      case DCFANLOAD_STATE_RAMPING_UP:
    236                          if ( DCFanLoad_Data[load->Load_Data_Index].Accepted_Request == 0 )
    237                          {
    238                              // the request is zero, goto to state off
    239                              DCFanLoad_Data[load->Load_Data_Index].State = DCFANLOAD_STATE_OFF;
    240                          }
    241                          else if ( Millis__ReachedTarget(&DCFanLoad_Data[load->Load_Data_Index].Timer_Handle , ENDIANU16_STON(parameters->Startup_Time)) != FALSE )
    242                          {
    243                              DCFanLoad_Data[load->Load_Data_Index].Processed_Speed = DCFanLoad_Data[load->Load_Data_Index].Accepted_Request;
    244                              DCFanLoad_Data[load->Load_Data_Index].State = DCFANLOAD_STATE_ON;
    245                          }
    246                          break;
    247                      case DCFANLOAD_STATE_ON:
    248                          if ( DCFanLoad_Data[load->Load_Data_Index].Accepted_Request == 0 )
    249                          {
    250                              // the request is zero, goto to state off
    251                              DCFanLoad_Data[load->Load_Data_Index].State = DCFANLOAD_STATE_OFF;
    252                          }
    253                          else
    254                          {
    255                              DCFanLoad_Data[load->Load_Data_Index].Processed_Speed = DCFanLoad_Data[load->Load_Data_Index].Accepted_Request;
    256                          }
    257                          break;
    258                  }
    259          
    260                  if(pilot->Request != NULL)
    261                  {
    262                  	pilot->Request(load,&(DCFanLoad_Data[load->Load_Data_Index].Processed_Speed));
    263                  }
    264          		if(pilot->Process != NULL)
    265          		{
    266          			pilot->Process(load);
    267          		}
    268          		if(pilot->AsynchProcess != NULL)
    269          		{
    270          			pilot->AsynchProcess(load);
    271          		}
    272          
    273                  return (PASS);
    274              }
    275              else
    276              {
    277                  return (FAIL);
    278              }
    279          }
    280          /**
    281           * Returns the status of what is on the Pilot if the pilot has the GetStatus function implemented.
    282           * Otherwise returns the Processed_Speed.
    283           * @param load
    284           * @param pilot
    285           * @return uint8 with the Processed_Speed or the status of the Pilot if the Pilot is having the GetStatus implemented.
    286           */
    287          void * DCFanLoad__GetStatus	(HBL_LOAD_TYPE * load, HBL_PILOT_HANDLER_HOOK_TYPE * pilot)
    288          {
    289          	if((load->Load_Data_Index >= DCFanLoad_Allocation) ||
    290          	   (pilot->GetStatus == NULL))
    291          	{
    292          		return (&DCFanLoad_Data[load->Load_Data_Index].Processed_Speed);
    293          	}
    294          	else
    295          	{
    296          		return (pilot->GetStatus(load));
    297          	}
    298          }
    299          #endif
