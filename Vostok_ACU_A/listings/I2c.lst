    649                          I2C_3.CR1 |= I2C_CR1_PE | I2C_CR1_TXIE | I2C_CR1_RXIE | I2C_CR1_NACKIE | I2C_CR1_ERRIE;                       //I2c1 device is enabled
    650                      }
    651                  #endif
