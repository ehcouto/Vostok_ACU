    277          //---------------------------------------------------------------------------------------------------------------------
    278          /**
    279           * @brief This method parses feedbacks to the API003Disc sent to a broadcast or exclusively to this node.
    280           * @param buffer contains the Wide package that contains the message
    281           */

   \                                 In section .text, align 2, keep-with-next
    282          void API003Disc__FeedbackParser(REVEAL_MSG_TYPE * buffer)
    283          {
    284              switch ((API003DISC_OPCODES_TYPE)buffer->op_code)
    285              {
    286          #if (API003_FIREWALL_FEATURE == ENABLED)
    287                  case API003_OP_PUB_REVEAL_NODES:
    288                      if (buffer->payload == 2)
    289                      {
    290                          API03_Firewall_Password[buffer->node_id] = Utilities__ConvertArrayTo16bits(buffer->payload);
    291                          API003DISC__RECEIVED_REVEAL_NODES(buffer->node_id,Utilities__ConvertArrayTo16bits(buffer->payload))
    292                      }
    293                      break;
    294          #endif
    295                  case API003_OP_PUB_INFO:
    296                      API003DISC__RECEIVED_API_INFO(buffer->node_id,buffer->payload[0],Utilities__ConvertArrayTo16bits(&buffer->payload[1]),Utilities__ConvertArrayTo16bits(&buffer->payload[3]),buffer->payload[5]);
    297                      break;
    298                  case API003_OP_PUB_APIS:
    299                      API003DISC__RECEIVED_APIS(buffer->node_id,&buffer->payload[0],buffer->size-2);
    300                      break;
    301                  case API003_OP_PUB_INSTANCES:
    302                      API003DISC__RECEIVED_API_INSTANCE_INFO(buffer->node_id,buffer->payload[0],buffer->payload[1],Utilities__ConvertArrayTo16bits(&buffer->payload[2]),Utilities__ConvertArrayTo16bits(&buffer->payload[4]));
    303                      break;
    304                  default:
    305                      break;
    306              }
    307          }
   \                     API003Disc__FeedbackParser: (+1)
   \   00000000   0x4770             BX       LR               ;; return
    308          
