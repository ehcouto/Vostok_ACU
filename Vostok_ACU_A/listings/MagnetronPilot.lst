    283          //---------------------------------------------------------------------------------------------------------------------
    284          /**
    285           *  @brief      Process magnetron pilot instance.
    286           *
    287           *  @param      HBL_LOAD_TYPE *load - Pointer to magnetron load instance.
    288           *
    289           *  @return     PASS_FAIL_TYPE result - Result of magnetron pilot instance process.
    290           *  @retval     PASS - Instance process succeeded.
    291           *  @retval     FAIL - Instance process failed.
    292           */
    293          PASS_FAIL_TYPE MagnetronPilot__Process(HBL_LOAD_TYPE *load)
    294          {
    295              PASS_FAIL_TYPE result = FAIL;
    296          
    297              if (load->Pilot_Data_Index < Magnetron_Pilot_Allocation)
    298              {
    299                  Pilot_Index = load->Pilot_Data_Index;
    300          
    301                  if (Magnetron_Pilot_Data[Pilot_Index].Pilot_Enable == TRUE)
    302                  {
    303                      if (Magnetron_Pilot_Data[Pilot_Index].Processed != Magnetron_Pilot_Data[Pilot_Index].Requested)
    304                      {
    305                          if (Magnetron_Pilot_Data[Pilot_Index].Requested > MAGNETRON_PILOT_REQUEST_TURBO)
    306                          {
    307                              LOG_ADD_EXCEPTION(INVALID_REQUEST_VALUE, Pilot_Index);
    308                          }
    309                          else
    310                          {
    311                              if(Magnetron_Pilot_Data[Pilot_Index].Parameters->Turbo_Enable == TRUE)
    312                              {
    313                                  if(Magnetron_Pilot_Data[Pilot_Index].Requested == MAGNETRON_PILOT_REQUEST_TURBO && Magnetron_Pilot_Data[Pilot_Index].State == STATE_MAGNETRON_PILOT_ON)
    314                                  {
    315                                      LOG_ADD_EXCEPTION(NOT_ALLOW_TO_CHANGE_STATE_FROM_ON_TO_TURBO, Pilot_Index);
    316                                  }
    317                                  else
    318                                  {
    319                                      Magnetron_Pilot_Data[Pilot_Index].Processed = Magnetron_Pilot_Data[Pilot_Index].Requested;
    320                                  }
    321                              }
    322                              else
    323                              {
    324                                  if(Magnetron_Pilot_Data[Pilot_Index].Requested == MAGNETRON_PILOT_REQUEST_TURBO)
    325                                  {
    326                                      LOG_ADD_EXCEPTION(REQUEST_REJECT_DUE_TO_TURBO_FEATURE_DISABLE, Pilot_Index);
    327                                  }
    328                                  else
    329                                  {
    330                                      Magnetron_Pilot_Data[Pilot_Index].Processed = Magnetron_Pilot_Data[Pilot_Index].Requested;
    331                                  }
    332                              }
    333                          }
    334                      }
    335          
    336                      MagnetronPilotExecute();
    337          
    338                      result = PASS;
    339                  }
    340              }
    341          
    342              return (result);
    343          }
