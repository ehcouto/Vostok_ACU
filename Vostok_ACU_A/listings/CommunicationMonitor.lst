     12              @startuml{CommunicationMonitor State Machine.jpg}
     13                  title CommunicationMonitor State Machine
     14          
     15                  'use state = CommunicationMonitor_Data.State[CommunicationMonitor_Data.Data_Index]
     16          
     17                  [*] --> FAULT_MONITORING
     18          
     19                  FAULT_MONITORING : do /\t CheckRevealNodeStatus() \n RemoveFault()
     20                  FAULT_MONITORING --> FAULT_RECOVERING  : evFaultDetected
     21                  FAULT_MONITORING --> DISABLED  : evMonitoringDisabled
     22          
     23                  FAULT_RECOVERING : do /\t CheckRevealNodeStatus() \n ReportFault()
     24                  FAULT_RECOVERING --> FAULT_MONITORING  : evFaultRecovered
     25                  FAULT_RECOVERING --> DISABLED  : evMonitoringDisabled
     26          
     27                  DISABLED --> FAULT_MONITORING      : evMonitoringEnabled
     28          
     29          
     30              @enduml
