     75          /**
     76           *
     77           */
     78          void ZCTriacPilot__Initialize(void)
     79          {
     80              ZCTriacPilot_Allocation         = 0;
     81              memset(ZCTriacPilot_Data,0,sizeof(ZCTriacPilot_Data));
     82          }
     83          
