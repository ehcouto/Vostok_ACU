    172          //---------------------------------------------------------------------------------------------------------------------
    173          /**
    174           * @brief   Asynchronous processing of the LLI (5ms)
    175           * @param   input: data related to the instance of the LLI
    176           * @return  PASS if the LLI was successfully processed, else FAIL
    177           */
    178          BOOL_TYPE AccelerometerLLI__AsynchProcess(HBL_LLI_TYPE * input)
    179          {
    180              BOOL_TYPE retval = FALSE;
    181          
    182              if (input->Data_Index < AccelerometerLLI.Allocation)
    183              {
    184                  switch (AccelerometerLLI.Self_Test_State)
    185                  {
    186                      default:
    187                      case 0:
    188                          // do nothing
    189                          break;
    190                      case 1:
    191                          if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    192                          {
    193                              if (LISxDH__GetStatus() == ACCELEROMETER_DISABLED)
    194                              {
    195                                  AccelBaseline__RunSelfTest();
    196                                  AccelerometerLLI.Self_Test_State++;
    197                                  AccelBaseline__Background5ms();
    198                              }
    199                          }
    200                          else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    201                          {
    202                              if (FXLS8974__GetStatus() == ACCELEROMETER_DISABLED)
    203                              {
    204                                  SelfTestFXLS8974__Start();
    205                                  AccelerometerLLI.Self_Test_State++;
    206                                  SelfTestFXLS8974__Execute();
    207                              }
    208                          }
    209                          break;
    210                      case 2:
    211                          if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    212                          {
    213                              if (AccelBaseline__GetStatus() == ACCEL_IDLE)
    214                              {
    215                                  AccelerometerLLI_Public.Self_Test_Errors = AccelBaseline__GetSelfTestErrors();
    216                                  AccelerometerLLI__Enable();
    217                                  AccelerometerLLI.Self_Test_State = 0;
    218                                  AccelerometerLLI_Public.Self_Test_Completed = TRUE;
    219                              }
    220                              else
    221                              {
    222                                  AccelBaseline__Background5ms();
    223                              }
    224                          }
    225                          else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    226                          {
    227                              if (SelfTestFXLS8974__IsActive() == FALSE)
    228                              {
    229                                  AccelerometerLLI_Public.Self_Test_Errors = SelfTestFXLS8974__GetSelfTestErrors();
    230                                  AccelerometerLLI__Enable();
    231                                  AccelerometerLLI.Self_Test_State = 0;
    232                                  AccelerometerLLI_Public.Self_Test_Completed = TRUE;
    233                              }
    234                              else
    235                              {
    236                                  SelfTestFXLS8974__Execute();
    237                              }
    238                          }
    239                          break;
    240                  }
    241          
    242                  retval = TRUE;
    243              }
    244          
    245              return (retval);
    246          }
