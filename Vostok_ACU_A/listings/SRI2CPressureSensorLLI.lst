    366          //=====================================================================================================================
    367          //-------------------------------------- Private Functions ------------------------------------------------------------
    368          //=====================================================================================================================
    369          //---------------------------------------------------------------------------------------------------------------------
    370          /**
    371           * Initialize the filter data structure.
    372           * @param filter_struct = The structure used by the filter.
    373           * @param initial_value = The initial value that the filter should be set to.
    374           * @param filter_type = The type of filter that is being initialized.
    375           */
    376          void InitIirFilter(void* filter_struct, FILTER_DATA_TYPE initial_value)
    377          {
    378              IIR_FILTER_MEASURE_TYPE* iir_filter;
    379              uint16 i;
    380          
    381              // Convert the inverted alpha to the number of bits that will be shifted.
    382              iir_filter = (IIR_FILTER_MEASURE_TYPE*)filter_struct;
    383          
    384              for (i = IIRFILTER_MAX_COEFFICIENT_BIT; i > 0U; i--)
    385              {
    386                  if (BIT_TEST(iir_filter->Inverted_Alpha, i))
    387                  {
    388                      break;  // Exit the loop
    389                  }
    390              }
    391              iir_filter->Inverted_Alpha = i;
    392          
    393              // Setup the Accumulator value.
    394              iir_filter->Accumulator = initial_value << iir_filter->Inverted_Alpha;
    395          
    396              iir_filter->Filtered_Value = initial_value;
    397          }
    398          
    399          
    400          //---------------------------------------------------------------------------------------------------------------------
    401          /**
    402           * Update the filter variables based on a new sampled value.
    403           * @param filter_struct = The structure used by the filter.
    404           * @param new_sample_value = The new sampled value that should be considered by the filter.
    405           * @param filter_type = The type of filter that is being updated.
    406           */
    407          void UpdateIirFilter(void* filter_struct, FILTER_DATA_TYPE new_sample_value)
    408          {
    409              IIR_FILTER_MEASURE_TYPE* iir_filter;
    410              FILTER_DATA_TYPE value;
    411          
    412              iir_filter = ((IIR_FILTER_MEASURE_TYPE*)filter_struct);
    413              iir_filter->Accumulator += new_sample_value - iir_filter->Filtered_Value;
    414              value = iir_filter->Accumulator;
    415          
    416              if (iir_filter->Inverted_Alpha > 1U)
    417              {
    418                  value >>= iir_filter->Inverted_Alpha - 1;
    419              }
    420              if (iir_filter->Inverted_Alpha > 0U)
    421              {
    422                  value += 1;
    423                  value >>= 1;
    424              }
    425              iir_filter->Filtered_Value = value;
    426          }
    427          
    428          #endif // (HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR > 0)


 

 


