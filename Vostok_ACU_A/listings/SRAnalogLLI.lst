    327          //---------------------------------------------------------------------------------------------------------------------
    328          /**
    329           * @brief	Process function to read on ZC Peak angle (90, 270)
    330           * @param input		pointer to HBL_LLI_TYPE structure instance
    331           * @param peak_polarity		TRUE for 90, FALSE for 270
    332           * @return	TRUE if a new sample is ready, FALSE otherwise
    333           */
    334          BOOL_TYPE SRAnalogLLI__PeakProcess(HBL_LLI_TYPE * input, BOOL_TYPE peak_polarity)
    335          {
    336              BOOL_TYPE retval = FALSE;
    337          
    338          	if ((SRData__CheckByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation) == SRDATA_OK) &&
    339          			(input->Data_Index < SRAnalogLLI_Allocation))
    340          	{
    341          	    SRANALOGLLI_PARAM_TYPE *param_ptr = (SRANALOGLLI_PARAM_TYPE *) (input->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    342          	    BOOL_TYPE acflag = FALSE;
    343          
    344                  if ((param_ptr != NULL) &&
    345          			(param_ptr->Config.Ac_Line != 0))
    346                  {
    347                      acflag = TRUE;
    348                  }
    349          
    350                  if (acflag == peak_polarity)
    351                  {
    352                      retval = AnalogInputDoRead(input, SRANALOGLLI_SINGLE_READ, FALSE);
    353                  }
    354              }
    355          	else
    356          	{
    357          		SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, input->LLI_Handler_Index, input->Data_Index);
    358          	}
    359              return (retval);
    360          }
    361          
    362          //---------------------------------------------------------------------------------------------------------------------
    363          /**
    364           * @brief   Process function to read on ZC Peak angle (90, 270)
    365           * @param input     pointer to HBL_LLI_TYPE structure instance
    366           * @param peak_polarity     TRUE for 90, FALSE for 270
    367           * @return  TRUE if a new sample is ready, FALSE otherwise
    368           */
    369          BOOL_TYPE SRAnalogLLI__PeakToPeakProcess(HBL_LLI_TYPE * input, BOOL_TYPE peak_polarity)
    370          {
    371              BOOL_TYPE retval = FALSE;
    372          
    373              if ((SRData__CheckByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation) == SRDATA_OK) &&
    374                      (input->Data_Index < SRAnalogLLI_Allocation))
    375              {
    376                  SRANALOGLLI_READ_TYPE read_type = (peak_polarity == TRUE) ? SRANALOGLLI_HI_PEAK_READ : SRANALOGLLI_LO_PEAK_READ;
    377                  retval = AnalogInputDoRead(input, read_type, FALSE);
    378              }
    379              else
    380              {
    381                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, input->LLI_Handler_Index, input->Data_Index);
    382              }
    383          
    384              return (retval);
    385          }
    386          
