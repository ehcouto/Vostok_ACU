     99          //---------------------------------------------------------------------------------------------------------------------
    100          /**
    101           *  @brief      It Initializes the module DigitalLowLevel and its variables
    102           *
    103           */
    104          PASS_FAIL_TYPE ConductivityLLI__InitializeInstance(HBL_LLI_TYPE * input)
    105          {
    106              uint8 virtual_pin;
    107          
    108              if (input->Data_Index < HBL_LLI_NUM_CONDUCTIVITY)
    109              {
    110                  virtual_pin = input->Pin_Ptr[0];
    111          
    112                  ConductivityLLI_Timer_Parameter[input->Data_Index].Timer      = (TIMER_TYPE)VIRTUALPIN_TABLE[virtual_pin].device;
    113                  ConductivityLLI_Timer_Parameter[input->Data_Index].Channel    = (TIMER_CHANNEL_TYPE)VIRTUALPIN_TABLE[virtual_pin].param0;
    114                  ConductivityLLI_Timer_Parameter[input->Data_Index].Mode       = TIMER_MODE_INPUT_CAPTURE;
    115                  ConductivityLLI_Timer_Parameter[input->Data_Index].Port       = VIRTUALPIN_TABLE[virtual_pin].port;
    116                  ConductivityLLI_Timer_Parameter[input->Data_Index].Pin        = VIRTUALPIN_TABLE[virtual_pin].pin;
    117                  ConductivityLLI_Timer_Parameter[input->Data_Index].Pin_ReMap  = VIRTUALPIN_TABLE[virtual_pin].pin_remap;
    118                  ConductivityLLI_Timer_Parameter[input->Data_Index].Polarity   = TIMER_POLARITY_ACTIVE_HIGH;
    119          
    120                  Timer__Config(&ConductivityLLI_Timer_Parameter[input->Data_Index]);
    121                  Timer__CaptureStart(&ConductivityLLI_Timer_Parameter[input->Data_Index], TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    122          
    123                  return (PASS);
    124              }
    125              else
    126              {
    127                  return (FAIL);
    128              }
    129          
    130          
    131          }
    132          
