    335          //---------------------------------------------------------------------------------------------------------------------
    336          /**
    337           * @brief   Handler for periodic SRI2CPressureSensorLLI Data Verification.
    338           */
    339          void SRI2CPressureSensorLLI__Handler(void)
    340          {
    341              MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    342              BOOL_TYPE retval;
    343              uint8 index;
    344          
    345              MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    346              retval = (BOOL_TYPE) (SR_CHECK_BYTE(Sr_I2CPressure_Sensor_LLI_Allocation) == SRDATA_OK);
    347              MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    348          
    349              for (index = 0; index < HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR; index++)
    350              {
    351                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    352                  retval &= (BOOL_TYPE) (Crc8(0xFF, (uint8 *) &Sr_I2c_Pressure_Data[index], sizeof(I2C_PRESSURE_SENSOR_DATA_TYPE)) == SRI2CPressureSensorLLI_Crc[index]); //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    353                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    354                  if (retval == FALSE)
    355                  {
    356                      SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0, index);
    357                      break;
    358                  }
    359              }
    360          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    361              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRI2C_PRESSURE_SENSOR_LLI_CHECKS);
    362          #endif
    363          
    364          }
