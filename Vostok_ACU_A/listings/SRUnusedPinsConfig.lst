    230          //=====================================================================================================================
    231          //-------------------------------------- Private Functions ------------------------------------------------------------
    232          //=====================================================================================================================
    233          //---------------------------------------------------------------------------------------------------------------------
    234          /**
    235           * Update the output pin based on the requested value and change configuration
    236           * @param unused_pins_table_index = SR_UNUSED_PINS_TABLE Table index
    237           * @return None
    238           */
    239          static void DoUnusedPinsUpdate( uint8 unused_pins_table_index )
    240          {
    241              // Validate Virtual Pin Index is within VIRTUALPIN_TABLE limits.
    242              SR_UNUSED_PINS_PARAM_TYPE *cur_param_ptr =
    243                          (SR_UNUSED_PINS_PARAM_TYPE *)&SR_UNUSED_PINS_TABLE[ unused_pins_table_index ];
    244              if(cur_param_ptr->Virtual_Pin_Index < VirtualPin__GetNumOf())
    245              {
    246                  VIRTUALPIN_TYPE *pin_ptr = (void *) &VIRTUALPIN_TABLE[cur_param_ptr->Virtual_Pin_Index];
    247          
    248                  // Check an entry where Port is not set
    249                  if(pin_ptr->port != PORT_NULL)
    250                  {
    251                      // Set Pin value if an Output Type is set
    252                      if((cur_param_ptr->Gpio_Type == OUTPUT_PUSHPULL) ||
    253                          (cur_param_ptr->Gpio_Type == OUTPUT_OPEN_DRAIN) ||
    254                          (cur_param_ptr->Gpio_Type == SPECIAL_FUNCTION_PUSH_PULL) ||
    255                          (cur_param_ptr->Gpio_Type == SPECIAL_FUNCTION_OPEN_DRAIN))
    256                      {
    257                          Gpio__PinWrite(pin_ptr->port, pin_ptr->pin, (BOOL_TYPE)cur_param_ptr->Is_High);
    258                      }
    259                      // Configure Pin
    260                      Gpio__PinConfig(pin_ptr->port, pin_ptr->pin, (GPIO_PIN_MODE_TYPE)cur_param_ptr->Gpio_Type);
    261                  }
    262              }
    263          }
    264          
    265          
    266          /**
    267           * Update the output pin based on the requested value and change configuration
    268           * This method doesn't validate previous pin configuration or data.
    269           * It mainly used in Initialization Method or first time pin configuration.
    270           * @param None
    271           * @return None
    272           */
    273          static void ConfigUnusedPins( void )
    274          {
    275              uint8 table_index;
    276          
    277              // Check configuration and status of each pin entry  in SR_UNUSED_PINS_TABLE
    278              for( table_index = 0; table_index < NUMBER_OF_UNUSED_PINS_TO_CONFIG ; table_index++  )
    279              {
    280                  // Update the pins.
    281                  DoUnusedPinsUpdate( table_index );
    282              }
    283          }
    284          
    285          #endif  // #if (SR_UNUSED_PINS_CONFIG_FEATURE == ENABLED)


 

 


