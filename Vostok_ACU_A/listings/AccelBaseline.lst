    479          
    480          //---------------------------------------------------------------------------------------------------------------------
    481          /**
    482           * Capture accelerometer points to calculate the baseline measurement.
    483           */
    484          static void AverageMeasure(void)
    485          {
    486              sint16 vector[3];
    487              while ((Accel_Baseline.Samples <= Accel_Baseline.Sf->Average_Samples) &&
    488                     (LISxDH__Read(vector)))
    489              {
    490                  // Add the new accelerometer XYZ point to the running sum of raw points.
    491                  for (uint8 axis = 0; axis < 3U; axis++)
    492                  {
    493                      Accel_Baseline.Sum[axis] += vector[axis];
    494                  }
    495                  Accel_Baseline.Samples++;
    496              }
    497          
    498              // Check if there is enough data for an average measurement.
    499              if (Accel_Baseline.Samples >= Accel_Baseline.Sf->Average_Samples)
    500              {
    501                  // Calculate and save the average measurement data
    502                  for (uint8 axis = 0; axis < 3U; axis++)
    503                  {
    504                      // Skip the axes whose baseline is already updated.
    505                      if (BIT_TEST(Accel_Baseline.Axis_Baseline_Updated, axis) == 0)
    506                      {
    507                          vector[axis] = Accel_Baseline.Sum[axis] / Accel_Baseline.Samples;
    508                          Accel_Baseline.Point[Accel_Baseline.Average_Index][axis] = vector[axis];
    509                      }
    510                  }
    511          
    512                  // Increment counters to indicate that there is a new average measurement.
    513                  uint8 count = Accel_Baseline.Sf->Baseline_Average_Count;
    514                  Accel_Baseline.Average_Count++;
    515                  Accel_Baseline.Average_Index++;
    516                  if (Accel_Baseline.Average_Index >= count)
    517                  {
    518                      Accel_Baseline.Average_Index = 0;
    519                  }
    520          
    521                  // Determine if there are enough average measurements to calculate a baseline.
    522                  if (Accel_Baseline.Average_Count >= count)
    523                  {
    524                      // Check if the average variation is low enough to update the baselines.
    525                      for (uint8 axis = 0; axis < 3U; axis++)
    526                      {
    527                          // Skip the axes whose baseline is already updated.
    528                          if (BIT_TEST(Accel_Baseline.Axis_Baseline_Updated, axis) == 0)
    529                          {
    530                              // Calculate the min and max for the last 'count' measurements.
    531                              sint16 min = SHRT_MAX;
    532                              sint16 max = SHRT_MIN;
    533                              for (uint8 index = 0; index < count; index++)
    534                              {
    535                                  if (min > Accel_Baseline.Point[index][axis])
    536                                  {
    537                                      min = Accel_Baseline.Point[index][axis];
    538                                  }
    539                                  if (max < Accel_Baseline.Point[index][axis])
    540                                  {
    541                                      max = Accel_Baseline.Point[index][axis];
    542                                  }
    543                              }
    544          
    545                              // Check if the min/max range is within a small enough range.
    546                              if ((max - min) < Accel_Baseline.Sf->Baseline_Range_Threshold)
    547                              {
    548                                  sint32 sum = 0;
    549                                  for (uint8 index = 0; index < count; index++)
    550                                  {
    551                                      sum += Accel_Baseline.Point[index][axis];
    552                                  }
    553                                  vector[axis] = sum / count;
    554          
    555                                  // Validate the proposed baseline measurement value.
    556                                  min = Accel_Baseline.Sf->Baseline_Minimum[axis];
    557                                  max = Accel_Baseline.Sf->Baseline_Maximum[axis];
    558                                  if ((min <= vector[axis]) && (vector[axis] <= max))
    559                                  {
    560                                      Accel_Baseline.Baseline[axis] = vector[axis];
    561                                      BIT_SET(Accel_Baseline.Axis_Baseline_Updated, axis);
    562                                  }
    563                              }
    564                          }
    565                      }
    566          
    567                      // Check if all baselines have been updated.
    568                      if (Accel_Baseline.Axis_Baseline_Updated == ALL_AXES_UPDATED)
    569                      {
    570                          Accel_Baseline.Baseline_Errors = 0;
    571                          EventPassed();
    572                      }
    573                      // Check if the baseline measurement attempt failed.
    574                      else if (Accel_Baseline.Average_Count >= (count + Accel_Baseline.Sf->Baseline_Max_Retries))
    575                      {
    576                          EventFailed();
    577                      }
    578                      else
    579                      {
    580                          // Need more average measurements for a baseline with a lower noise threshold.
    581                          EventNextAverage();
    582                      }
    583                  }                                           // End baseline measurement calculation attempt.
    584                  else
    585                  {
    586                      // Need more average measurements to ensure a stable signal.
    587                      EventNextAverage();
    588                  }
    589              }                                               // End new average measurement.
    590          }
