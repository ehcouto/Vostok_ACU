   1272           * Process information received from MCU about FF
   1273           * @param motor = The motor ID related to the FF received
   1274           * @param failures = bitmap of FF
   1275           */
   1276          static void API221ApplReceivedStatus (API221_CLIENT_MOTOR_INDEX_TYPE motor, uint32 status)
   1277          {
   1278          	HBL_PILOT_ENUM_TYPE drain_pump_pilot_type = Hbl__GetPilotIDByIndex(Hbl__GetLoadIndexByLoadID(HBL_LOAD_DRAIN_PUMP));
   1279          	if (drain_pump_pilot_type == HBL_PILOT_EXTERNAL_MOTOR)
   1280          	{
   1281          		This_Pc->PC_Status[motor] = status;
   1282          		This_Pc->PC_PendingStatus[motor] = TRUE;
   1283          	}
   1284          	else
   1285          	{
   1286          		Pump_Control[COMPARTMENT_DEFAULT][1].PC_Status[motor] = status;
   1287          		Pump_Control[COMPARTMENT_DEFAULT][1].PC_PendingStatus[motor] = TRUE;
   1288          
   1289          		Pump_Control[COMPARTMENT_DEFAULT][0].PC_Status[motor] = status;
   1290          		Pump_Control[COMPARTMENT_DEFAULT][0].PC_PendingStatus[motor] = TRUE;
   1291          	}
   1292          }
