    167          // -- Private Structure Type Declarations --
    168          
    169          //! The setting file data structure used to define a single time entry.
    170          //! There are three versions of the data structure:
    171          //!     2-byte: Uses the Simple structure and has no modifiers
    172          //!     4-byte: Uses the Full structure and either has no modifier or uses an 8-bit modifier
    173          //!     6-byte: Uses the Full structure and uses a 16-bit modifier
    174          typedef PACKED struct SF_TIME_ENTRY_STRUCT
    175          {
    176              uint8 First_Statement       : 7;
    177              uint8 Format                : 1;                // 0 = Simple, 1 = Full
    178              union TIME_ESTIMATE_UNION
    179              {
    180                  struct TIME_ENTRY_SIMPLE_STRUCT
    181                  {
    182                      uint8 Value                 : 6;
    183                      uint8 Scale                 : 2;
    184                  } Simple;
    185                  PACKED struct TIME_ENTRY_FULL_STRUCT
    186                  {
    187                      uint8 Modifier_Byte;
    188                      uint16 Seconds;
    189                      uint16 Modifier_Word;
    190                  } Full;
    191              } Type;
    192          } SF_TIME_ENTRY_TYPE;
    193          
    194          //! The data structure used to remember the first time entry of a cycle prediction.
    195          //! There is a first time entry associated with both the main cycle and any active sub-cycle.
    196          //! If the cycle has started running, then the first time entry is the time entry that was most
    197          //! recently executed (not skipped).
    198          typedef struct FIRST_TIME_ENTRY_DATA_STRUCT
    199          {
    200              //! A pointer to the setting file time entry data for the first time entry.
    201              SF_TIME_ENTRY_TYPE* First_Time_Entry;
    202          
    203              //! A counter that counts time since the first time entry.
    204              //! Units are based on #ESTIMATOR_CALLS_PER_SECOND.
    205              sint32 Calls_Since_Time_Entry;
    206          
    207              //! The cycle that contains the phase with the first time entry.
    208              uint8 Cycle;
    209          
    210              //! The phase with the first time entry.
    211              uint8 Phase;
    212          } FIRST_TIME_ENTRY_DATA_TYPE;
    213          
    214          //! A structure with the volatile variables used by this module.
    215          typedef struct ESTIMATOR_DATA_STRUCT
    216          {
    217              //! A pointer to the time entry of the phase that is actively being estimated.
    218              SF_TIME_ENTRY_TYPE* Sf_Time_Entry;
    219          
    220              //! The number of predicted statements in single cycle. If this value is too large
    221              //! (> #MAX_STATEMENTS_PER_CYCLE), then the cycle is assumed to have an infinite
    222              //! prediction loop.
    223              uint16 Statements_In_Cycle;
    224          
    225              //! Definition of process lo statement sizes. Bit 'n' represents process 'n'.
    226              //! Bit value of 0 = Process 'n' uses an 8-bit lo statement.
    227              //! Bit value of 1 = Process 'n' uses a 16-bit lo statement.
    228              uint16 Lo_Statement_Length_Map;
    229          
    230              //! A copy of Wip_Seconds. This variable should be removed to save RAM.
    231              uint16 Seconds_After_Time_Entry[APPLIANCE_MAX_COMPARTMENTS];
    232          
    233              //! The remaining number of statements to predict in a single call to the
    234              //! Estimator__Background() function. If this value reaches zero, then the estimation is
    235              //! paused and resumed on the next call to the Estimator__Background() function.
    236              uint16 Statement_Countdown;
    237          
    238              //! The number of seconds estimated for the execution of the current cycle being predicted.
    239              //! This value does not include the first time entry. (WIP = work in progress)
    240              uint16 Wip_Seconds;
    241          
    242              //! The run time data for the cycle that will be resumed after the current sub-cycle ends.
    243              RUN_TIME_DATA_TYPE Return_Data;
    244          
    245              //! The run time data of the cycle that is currently running and should be estimated.
    246              RUN_TIME_DATA_TYPE Running_Data;
    247          
    248              //! The phase data (from Selector) for the cycle and phase that is currently being predicted.
    249              PHASE_DATA_TYPE Phase_Data;
    250          
    251              //! Determined state of each compartment's estimation.
    252              //! This value is the result of the most recent estimation in a compartment.
    253              ESTIMATOR_COMPARTMENT_STATE_TYPE State[APPLIANCE_MAX_COMPARTMENTS];
    254          
    255              //! A working copy (WIP = work in progress) of the compartment's estimation state.
    256              //! This value is the state of the current estimation.
    257              ESTIMATOR_COMPARTMENT_STATE_TYPE Wip_State;
    258          
    259              //! The running cycle the last time that an estimate was started.
    260              //! Estimations are only calculated when this value is the same for two consecutive calls.
    261              uint8 Last_Estimated_Cycle[APPLIANCE_MAX_COMPARTMENTS];
    262          
    263              //! The running phase the last time that an estimate was started.
    264              //! Estimations are only calculated when this value is the same for two consecutive calls.
    265              uint8 Last_Estimated_Phase[APPLIANCE_MAX_COMPARTMENTS];
    266          
    267              //! The compartment that is currently being estimated.
    268              //! Used as an index into the arrays of APPLIANCE_MAX_COMPARTMENTS elements.
    269              uint8 Compartment                   : 4;
    270          
    271              //! TRUE when remaining times must be calculated quickly for all compartments.
    272              //! This condition occurs when at least one compartment is in the programming state.
    273              uint8 Do_Fast_Estimates             : 1;
    274          
    275              //! TRUE while actively estimating a compartment's remaining time.
    276              //! This value is used to track estimations across multiple calls.
    277              uint8 Is_Estimating                 : 1;
    278          
    279              //! TRUE if the displacement for the modifier is the size of a word, else FALSE.
    280              //! If one modifier displacement is a word, all of them will be words.
    281              uint8 Is_Modifier_Displacement_Word : 1;
    282          
    283              //! TRUE when a phase with a time is first encountered during the prediction.
    284              //! FALSE as soon as the time for the phase is consumed.
    285              //! Ensures that the time for a phase is never counted more than once.
    286              uint8 Phase_Time_Counted            : 1;
    287          
    288              #if (ESTIMATOR_TRACE == ENABLED)
    289                  //! Trace debugging data with predicted phase times.
    290                  //! Times[n] = predicted seconds for phase n.
    291                  uint16 Times[ESTIMATOR_MAX_PHASES];
    292          
    293                  //! Index into the Statements[] array of statements.
    294                  uint16 Statement_Index;
    295          
    296                  //! The cycle associated with the last estimated statement.
    297                  //! Used to determine when a change in cycle is predicted.
    298                  uint8 Cycle_Of_Last_Statement;
    299          
    300                  //! Trace debugging data with the predicted statement execution sequence.
    301                  //! Each entry consists of two bytes:
    302                  //!     Cycle initialization or change represented by {0xCC, cycle_number}.
    303                  //!     Statement execution represented by {phase_number, statement_number}.
    304                  uint8 Statements[ESTIMATOR_MAX_STATEMENT_BYTES];
    305          
    306                  //! Index into the Times[] array of times.
    307                  uint8 Time_Index;
    308              #endif
    309          } ESTIMATOR_DATA_TYPE;
    310          
    311          //! A structure with the non-volatile variables used by this module.
    312          typedef struct ESTIMATOR_NV_DATA_STRUCT
    313          {
    314              //! The number of seconds that the module predicts will be repeated after a sub-cycle ends.
    315              //! If this number is negative, then the prediction is to skip a number of seconds.
    316              sint16 Repeat_Seconds[APPLIANCE_MAX_COMPARTMENTS];
    317          
    318              //! Seconds elapsed after the last phase with a time entry and before the start of the current phase.
    319              uint16 Seconds_Elapsed_Before_Phase[APPLIANCE_MAX_COMPARTMENTS];
    320          
    321              //! The recent time entries for the selected or running cycles in all the compartments.
    322              //! The cycle can be a normal user cycle or a sub-cycle.
    323              FIRST_TIME_ENTRY_DATA_TYPE Running[APPLIANCE_MAX_COMPARTMENTS];
    324          
    325              //! The recent time entries for the main cycles that will resume after their respective
    326              //! sub-cycle finish running. This value is only used when the 'Running' field refers to a
    327              //! time entry for a sub-cycle.
    328              FIRST_TIME_ENTRY_DATA_TYPE Return[APPLIANCE_MAX_COMPARTMENTS];
    329          } ESTIMATOR_NV_DATA_TYPE;
