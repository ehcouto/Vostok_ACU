    103          //---------------------------------------------------------------------------------------------------------------------
    104          /**
    105           *  @brief      Allocate pilot instance for DoorlockWaxPilot.
    106           *
    107           *  @return     uint8 result - Allocation result.
    108           *  @retval     0-254 - Pilot allocation instance.
    109           *  @retval     0xFF - Allocation failed.
    110           */
    111          uint8 DoorLockWaxPilot__Allocate(void)
    112          {
    113              uint8 retval = 0xFF;
    114          
    115          	if (DoorLockWaxPilot_Allocation < HBL_PILOT_NUM_DOORLOCKWAX)
    116          	{
    117          		retval = DoorLockWaxPilot_Allocation;
    118          		DoorLockWaxPilot_Allocation++;
    119          	}
    120              return(retval);
    121          }
    122          
    123          //---------------------------------------------------------------------------------------------------------------------
    124          /**
    125           *  @brief      Initialize DoorLockWaxPilot instance.
    126           *
    127           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
    128           *
    129           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot instance initialization.
    130           *  @retval     PASS - Instance initialization succeeded.
    131           *  @retval     FAIL - Instance initialization failed.
    132           */
    133          PASS_FAIL_TYPE DoorLockWaxPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    134          {
    135              PASS_FAIL_TYPE retval = FAIL;
    136              uint8 index = load->Pilot_Data_Index;
    137              DOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    138              DOORLOCKWAXPILOT_DATA_TYPE *ptr;
    139              uint8 *ptr_pin_table;
    140              uint8 fbk_index;
    141              uint8 virtual_pin;
    142          
    143          
    144              if (index < DoorLockWaxPilot_Allocation)
    145              {
    146              	ptr = (DOORLOCKWAXPILOT_DATA_TYPE *) &DoorLockWaxPilot_Data[index];  //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    147              	param_ptr = (DOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    148          
    149              	ptr->Status = DOORLOCKWAX_STATUS_INIT;
    150              	ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_INITIALIZE;
    151              	ptr->Counter = param_ptr->Filter_Time;
    152              	ptr->Fbk_Timeout_Counter = param_ptr->Filter_Time * DOORLOCKWAX_TIMING_REF;
    153              	ptr->Fbk_Period = DOORLOCKWAX_INITIAL_PERIOD;
    154              	ptr->Debounce = DOORLOCKWAX_MAX_DEBOUNCE;
    155          
    156              	// Check if a Feedback/SRFeedback LLI is configured for pin synchronization
    157              	fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_FEEDBACK);
    158              	if (fbk_index >= Hbl__GetNumLLI())
    159              	{
    160                      fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_SRFEEDBACK);
    161              	}
    162              	ptr_pin_table = Hbl__GetLLIPinTabPtr(fbk_index);
    163          
    164              	if (ptr_pin_table == NULL)
    165              	{
    166              		virtual_pin = VirtualPin__GetNumOf();
    167              	}
    168              	else
    169              	{
    170              		virtual_pin = ptr_pin_table[0];
    171              	}
    172              	ptr->Fbk_Pin = virtual_pin;
    173          
    174              	virtual_pin = load->Pin_Ptr[0];
    175          		if ((virtual_pin < VirtualPin__GetNumOf()) &&
    176          			(VIRTUALPIN_TABLE[virtual_pin].port != 0xFF))
    177          		{
    178          			uint8 pin_val = ~load->Hi_Low_Activation_Bitmap;
    179          			pin_val &= 0x01;
    180                  	Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) pin_val);
    181          			Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    182          			retval = PASS;
    183          		}
    184              }
    185              return(retval);
    186          }
