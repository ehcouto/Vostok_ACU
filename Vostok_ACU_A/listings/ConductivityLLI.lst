    140          void * ConductivityLLI__Get(HBL_LLI_TYPE * input)
    141          {
    142              if (input->Data_Index < HBL_LLI_NUM_CONDUCTIVITY)
    143              {
    144                  return ((void *)&ConductivityLLI_Data[input->Data_Index]);
    145              }
    146              else
    147              {
    148                  return (NULL);
    149              }
    150          }
