     53          //! The name of this module for use by the Log module.
     54          #define MODULE_NAME MODULE_STABILITY_CONTROL
     55          
     56          //! A list of log message IDs that are generated by this module.
     57          typedef enum MODULE_STABILITY_CONTROL_LOG_MESSAGE_ID_ENUM
     58          {
     59          	ERROR_LOADING_PARAMETERS       = 1,
     60          } MODULE_STABILITY_CONTROL_LOG_MESSAGE_ID_TYPE;
     61          
     62          //! Time that instability condition must be detected continuously before reacting to Instability (macro to convert the setting file value to 100 ms units)
     63          #define INSTABILITY_DETECTION_TIME_100MS 		(Common_Parameters_Ptr->Instability_Detection_Time_x2 * (uint16)5)
     64          //! Time that no water condition must be detected continuously before reacting to No Water (macro to convert the setting file value to 100 ms units)
     65          #define NO_WATER_DETECTION_TIME_100MS 			(Common_Parameters_Ptr->No_Water_Detection_Time_x2 * (uint16)5)
     66          //! Time that no water condition must be detected to declare Very Low Water condition (macro to convert the setting file value to 100 ms units)
     67          #define VERY_LOW_WATER_DETECTION_TIME_100MS 	(Common_Parameters_Ptr->Very_Low_Water_Detection_Time_x2 * (uint16)5)
     68          //! If water is detected as present for this amount of time continuously, reset the timer monitoring for "Very Low Water" (macro to convert the setting file value to 100 ms units)
     69          #define WATER_PRESENT_TIME_100MS 				(Common_Parameters_Ptr->Water_Present_Time_x2 * (uint16)5)
     70          
     71          //! Value used to indicate that there is no limit in the number of subcycle executions
     72          #define INVALID_MAX_SUBCYCLE_CALLS			255
     73          
     74          //! Multiplier to get the actual speed from the setting file speed reduction minimum speed parameter
     75          #define SETTING_FILE_SPEED_MULTIPLIER			25
     76          
     77          //! Setting file parameters structure for a single instance of the stability Control Task
     78          typedef PACKED struct STABILITY_CONTROL_INSTANCE_PARAMS_STRUCT
     79          {
     80          	uint8 Reaction_To_Very_Low_Water		:4; //! The reaction to trigger if Very Low Water is detected
     81          	uint8 Reaction_To_Instability			:4; //! The reaction to trigger if Instability is detected
     82          
     83          	uint8 Reaction_To_Air_Lock				:4; //! The reaction to trigger if Air Lock is detected
     84          	uint8 Reaction_To_No_Water				:4; //! The reaction to trigger if No Water is detected
     85          
     86          	uint8 Reaction_After_Max_Phase_Repeats	:4; //! The reaction to trigger when one of the other events has caused the phase to repeat the maximum number of times
     87          	uint8 Reaction_To_Plugged_Filter		:4; //! The reaction to trigger if Plugged Filter is detected
     88          
     89          	uint8 Phase_Where_To_Restart;			//! The phase of the current cycle where to jump if a Restart Phase reaction is triggered
     90          	uint8 Phase_Where_To_Skip;				//! The phase of the current cycle where to jump if a Skip Phase reaction is triggered.
     91          
     92          	uint8 Loop_Detection_Secondary_Reaction	:4; //! The reaction to trigger when Loop Detection secondary reaction is requested
     93          	uint8 Loop_Detection_Primary_Reaction	:4; //! The reaction to trigger when Loop Detection primary reaction is requested
     94          
     95          	uint8 Reaction_After_Max_Speed_Reduct	:4; //! The reaction to trigger when Loop Detection secondary reaction is requested
     96          	uint8 Unused0							:4; //! Unused
     97          
     98          	uint8 Unused;							//! Just for alignment
     99          } STABILITY_CONTROL_INSTANCE_PARAMS_TYPE;
    100          
