     43          /**
     44           * Operation: tells us what to do with the variable and Values.
     45           */
     46          typedef enum SETVARIABLE_OPERATION_ENUM
     47          {
     48          	SV_OPERATION_SET            = 0,
     49          	SV_OPERATION_ADD_SET        = 1,
     50          	SV_OPERATION_SUB_SET        = 2,
     51              SV_OPERATION_MULTIPLY_SET   = 3,
     52              SV_OPERATION_DIVIDE_SET     = 4
     53          }SETVARIABLE_OPERATION_TYPE;
     54          
     55          /**
     56           * It performs a simple value attribution Variable = Operand or simple math like adding or subtracting.
     57           */
     58          typedef struct SETVARIABLE_DEFAULT_STRUCT
     59          {
     60          	//! First word
     61          	SETVARIABLE_OPERATION_TYPE Operation	:4;
     62          	uint8 Size_Of_This_Struct				:4;	//! This is here to calculate the number of loops needed to process all the data on the displacement. If it is zero, we use sizeof instead.
     63          
     64          	uint8 unused_0;
     65          	//! Second word
     66          	ACU_VARIABLE_ID_TYPE Variable_Index;		//! Index to the Variable on the Variable module (Look at Variable_prm.h and Variable_prv.h)
     67          	uint8 Variable_Offset;						//! Offset to access a Variable on the Variable Module. If Variable is an Array, the offset is the index of the Variable inside the Array. If it is a regulation, it is the position on the Regulation Array.
     68          	//! Third word.
     69          	union
     70          	{
     71          		sint16 Sint16;
     72          		uint16 Uint16;
     73          	}Operand;
     74          
     75          	//! Fourth Word
     76              uint8 Modifier_Index;
     77              uint8 unused_1;
     78          
     79          }SETVARIABLE_DEFAULT_TYPE;
     80          /**
     81           * It performs Variable++ or Variable--
     82           */
     83          typedef struct SETVARIABLE_INC_DEC_STRUCT
     84          {
     85              ACU_VARIABLE_ID_TYPE Variable_Index;		//! Index to the Variable on the Variable module (Look at Variable_prm.h and Variable_prv.h)
     86          	uint8 Variable_Offset;
     87          }SETVARIABLE_INC_DEC_TYPE;
     88          /**
     89           * It performs bit operations on the variable.
