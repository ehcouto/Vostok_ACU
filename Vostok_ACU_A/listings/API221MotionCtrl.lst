   1647          
   1648          //=====================================================================================================================
   1649          //  --- Public Functions (Server Only) --------------------------------------------------------------------------------
   1650          //=====================================================================================================================
   1651          
   1652          
   1653          #if (API221_SERVER_FEATURE == ENABLED)
   1654          //---------------------------------------------------------------------------------------------------------------------
   1655          /**
   1656           * Publish a motor event on the communications bus.
   1657           * @param server_motor = The server-based motor index.
   1658           * @param event = The specific event value to publish.
   1659           * @return TRUE if the request was sent. Otherwise, FALSE.
   1660           */
   1661          BOOL_TYPE API221MotionCtrl__PostEvent(uint8 server_motor, API221_MOTOR_EVENT_TYPE event)
   1662          {
   1663              #if (API221_CLIENT_FEATURE == ENABLED)
   1664                  return PostEvent(WIN_NODE, server_motor, event);
   1665              #else
   1666                  if ((server_motor < API221_SERVER_MOTOR_COUNT) && (event < API221_EVENT_COUNT))
   1667                  {
   1668                      REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM, API221_FBK_PUBLISH_EVENT, REVEAL_BROADCAST_NODE, 2);
   1669                      return (BOOL_TYPE)((Reveal__AddDataU8(msg, server_motor) == PASS) &&
   1670                                         (Reveal__AddDataU8(msg, event) == PASS) &&
   1671                                         (Reveal__QueueCommand(msg) == TRUE));
   1672                  }
   1673                  return FALSE;
   1674              #endif
   1675          }
   1676          #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1677          
   1678          
   1679          //=====================================================================================================================
   1680          //  --- Private Functions (Client) ------------------------------------------------------------------------------------
   1681          //=====================================================================================================================
   1682          
   1683          #if (API221_CLIENT_FEATURE == ENABLED)
   1684          //---------------------------------------------------------------------------------------------------------------------
   1685          /**
   1686           * Convert the motor ID communicated on API221 to a client-side motor index.
   1687           * @param server_motor = The server-side motor index.
   1688           * @return The client-side motor index or an out-of-range value if there is no corresponding motor index.
   1689           */
   1690          static API221_CLIENT_MOTOR_INDEX_TYPE ConvertServerMotorIndexToClientMotorIndex(uint8 node, uint8 server_motor)
   1691          {
   1692              for (API221_CLIENT_MOTOR_INDEX_TYPE client_motor = (API221_CLIENT_MOTOR_INDEX_TYPE)0;
   1693                   client_motor < API221_SYSTEM_MOTOR_COUNT;
   1694                   client_motor++)
   1695              {
   1696                  if ((API221_MOTOR_IDS[client_motor].Communication_Node == node) &&
   1697                      (API221_MOTOR_IDS[client_motor].Motor_Index == server_motor))
   1698                  {
   1699                      return client_motor;
   1700                  }
   1701              }
   1702              return (API221_CLIENT_MOTOR_INDEX_TYPE)API221_SYSTEM_MOTOR_COUNT;
   1703          }
   1704          
   1705          //---------------------------------------------------------------------------------------------------------------------
   1706          /**
   1707           * Post a motor event to the API221 client.
   1708           * @param communication_node = The node that generated the event.
   1709           * @param server_motor = The motor on the API221 server that generated the event.
   1710           * @param event = The generated event.
   1711           * @return TRUE if the event was posted.
   1712           */
   1713          static BOOL_TYPE PostEvent(uint8 communication_node, uint8 server_motor, API221_MOTOR_EVENT_TYPE event)
   1714          {
   1715              API221_CLIENT_MOTOR_INDEX_TYPE client_motor = ConvertServerMotorIndexToClientMotorIndex(communication_node, server_motor);
   1716              if ((client_motor < API221_SYSTEM_MOTOR_COUNT) &&
   1717                  (event < API221_EVENT_COUNT))
   1718              {
   1719                  uint8 motor_event = BUILD_MOTOR_EVENT(client_motor, event);
   1720                  Callback__Notify(&Api221_Callback, motor_event);
   1721                  return TRUE;
   1722              }
   1723              return FALSE;
   1724          }
   1725          
   1726          //---------------------------------------------------------------------------------------------------------------------
   1727          /**
   1728           * Update the request for periodic publication of analog data channels.
   1729           * All these parameters are guaranteed to be in range since they are controlled within this module.
   1730           * @param add = TRUE to add channels; FALSE to remove channels.
   1731           * @param client_motor = The value used to uniquely identify the system device on the client.
   1732           * @param channels = The analog input channels to remove from the request for periodic data.
   1733           *                   Each bit represents an analog data channel.
   1734           * @return TRUE if the request was sent. Otherwise, FALSE.
   1735           */
   1736          static BOOL_TYPE RequestPeriodicDataChannels(BOOL_TYPE add, API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint32 channels)
   1737          {
   1738              BOOL_TYPE result = FALSE;
   1739              uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1740              uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1741              #if (API221_SERVER_FEATURE == ENABLED)
   1742                  if (motor_node == WIN_NODE)
   1743                  {
   1744                      #ifdef API221_READ_ANALOG_DATA
   1745                          UpdatePeriodicDataChannels(add, server_motor, channels);
   1746                          result = TRUE;
   1747                      #endif
   1748                  }
   1749                  else
   1750              #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   1751              {
   1752                  API221MOTIONCTRL_OPCODE_TYPE op_code = (API221MOTIONCTRL_OPCODE_TYPE)
   1753                          (add ? (uint8)API221_CMD_ADD_PERIODIC_DATA_CHANNELS : (uint8)API221_CMD_REMOVE_PERIODIC_DATA_CHANNELS);
   1754                  REVEAL_COMMAND_TYPE* cmd = Reveal__NewCommand(API221MOTIONCTRL_NUM, op_code, motor_node, 5);
   1755                  result = (BOOL_TYPE)((Reveal__AddDataU8(cmd, server_motor) == PASS) &&
   1756                                       (Reveal__AddDataU32(cmd, channels) == PASS) &&
   1757                                       (Reveal__QueueCommand(cmd) == TRUE));
   1758              }
   1759              return result;
   1760          }
   1761          
   1762          #if (KEEP_RUNNING_TIMER > 0)
   1763          //---------------------------------------------------------------------------------------------------------------------
   1764          /**
   1765           * Send API221_CMD_KEEP_RUNNING to any server motors that are running to keep them from timing out.
   1766           */
   1767          static void SendKeepRunningMessages(void)
   1768          {
   1769              for (API221_CLIENT_MOTOR_INDEX_TYPE client_motor = (API221_CLIENT_MOTOR_INDEX_TYPE)0;
   1770                   client_motor < API221_SYSTEM_MOTOR_COUNT;
   1771                   client_motor++)
   1772              {
   1773                  uint16 timer = Api221.Keep_Running_Timer[client_motor];
   1774                  if (timer == 0)
   1775                  {
   1776                      // Motor is not running -- do nothing.
   1777                  }
   1778                  else if (timer == 1)
   1779                  {
   1780                      uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1781                    #if (API221_SERVER_FEATURE == ENABLED)
   1782                      if (motor_node != WIN_NODE)
   1783                    #endif
   1784                      {
   1785                          uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1786                          BOOL_TYPE result = Reveal__QueueMessageU8(API221MOTIONCTRL_NUM, API221_CMD_KEEP_RUNNING, motor_node, TRUE, FALSE, server_motor);
   1787                          if (result == TRUE)
   1788                          {
   1789                              Api221.Keep_Running_Timer[client_motor] = KEEP_RUNNING_TIMER;
   1790                          }
   1791                      }
   1792                  }
   1793                  else
   1794                  {
   1795                      Api221.Keep_Running_Timer[client_motor] = timer - 1;
   1796                  }
   1797              }
   1798          }
   1799          #endif      // #if (KEEP_RUNNING_TIMER > 0)
   1800          
   1801          //---------------------------------------------------------------------------------------------------------------------
   1802          /**
   1803           * Send a standard command to the specified motor or motor-controlled device.
   1804           * All standard commands contain arrays of uint16 values stored in little-endian format that must
   1805           * be converted to big-endian format in the Reveal message.
   1806           * @param client_motor = The value used to uniquely identify the system device on the client.
   1807           * @param op_code = The Reveal OpCode that identifies the type of standard command.
   1808           * @param params = A pointer to the uint16 parameters that should be placed on the Reveal payload.
   1809           * @param size = The number of bytes to copy from the params[] array.
   1810           * @return TRUE if the request was sent. Otherwise, FALSE.
   1811           */
   1812          static BOOL_TYPE SendStandardCommand(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, API221MOTIONCTRL_OPCODE_TYPE op_code, uint16* params, uint8 num_of_params)
   1813          {
   1814              BOOL_TYPE result = FALSE;
   1815              uint8 motor_node = API221_MOTOR_IDS[client_motor].Communication_Node;
   1816              uint8 size = 2 * num_of_params + 1;
   1817              REVEAL_COMMAND_TYPE* cmd = Reveal__NewCommand(API221MOTIONCTRL_NUM, op_code, motor_node, size);
   1818              uint8 server_motor = API221_MOTOR_IDS[client_motor].Motor_Index;
   1819              if (Reveal__AddDataU8(cmd, server_motor) == PASS)
   1820              {
   1821                  result = TRUE;
   1822                  for (uint8 param_index = 0; param_index < num_of_params; param_index++)
   1823                  {
   1824                      if (Reveal__AddDataU16(cmd, params[param_index]) == FAIL)
   1825                      {
   1826                          result = FALSE;
   1827                          break;                              // Break out of for() loop.
   1828                      }
   1829                  }
   1830                  if (result == TRUE)
   1831                  {
   1832                      result = Reveal__QueueCommand(cmd);
   1833                      #if (KEEP_RUNNING_TIMER > 0)
   1834                          if (result == TRUE)
   1835                          {
   1836                              if (op_code == API221_CMD_STOP)
   1837                              {
   1838                                  Api221.Keep_Running_Timer[client_motor] = 0;
   1839                              }
   1840                              else
   1841                              {
   1842                                  Api221.Keep_Running_Timer[client_motor] = KEEP_RUNNING_TIMER;
   1843                              }
   1844                          }
   1845                      #endif
   1846                  }
   1847              }
   1848              return result;
   1849          }
   1850          
   1851          
   1852          #if (API221_STORED_ANALOG_INPUTS > 0)
   1853          //---------------------------------------------------------------------------------------------------------------------
   1854          /**
   1855           * Insert an analog input value into the array of all analog input values, Api221.Data[].
   1856           * Replace any previously stored analog input value with the same analog input ID.
   1857           * Maintain the array order so that the analog input values are sorted from newest to oldest.
   1858           * Drop the oldest analog input value if it does not fit in the array.
   1859           * Api221.Data[0] will contain the inserted analog input value when done.
   1860           * @param data = The structure that holds the motor index, channel index, and analog input value.
   1861           */
   1862          static void StoreAnalogInput(API221_CLIENT_MOTOR_INDEX_TYPE client_motor, uint8 channel, sint32 value)
   1863          {
   1864              // Look for the presence of the analog input ID in the existing stored data array.
   1865              uint8 num_of_analog_inputs_to_shift = API221_STORED_ANALOG_INPUTS - 1;
   1866              uint8 new_sequence_number = 0;                  // Assume this is the first occurrence in the stored data.
   1867          
   1868              // The last analog input must be checked to avoid unnecessarily losing the sequence number.
   1869              for (uint8 i = 0; i < API221_STORED_ANALOG_INPUTS; i++)
   1870              {
   1871                  API221_STORED_DATA_TYPE* stored = &Api221.Data[i];
   1872          
   1873                  if ((stored->Channel == channel) && (stored->Motor == client_motor))
   1874                  {
   1875                      num_of_analog_inputs_to_shift = i;
   1876                      if (stored->Sequence < UCHAR_MAX - 1)
   1877                      {
   1878                          new_sequence_number = stored->Sequence + 1;
   1879                      }
   1880                      else
   1881                      {
   1882                          new_sequence_number = 1;
   1883                      }
   1884                      break;                                  // Break out of the for() loop.
   1885                  }
   1886              }
   1887          
   1888              // Shift the array elements.
   1889              //      This will remove any previously stored copy of the analog input, and...
   1890              //      it will make space for the new analog input at the start of the array.
   1891              if (num_of_analog_inputs_to_shift > 0)
   1892              {
   1893                  memmove(&Api221.Data[1], &Api221.Data[0],
   1894                          num_of_analog_inputs_to_shift * sizeof(API221_STORED_DATA_TYPE));
   1895              }
   1896          
   1897              // Store the new analog input at the start of the array.
   1898              Api221.Data[0].Value = value;
   1899              Api221.Data[0].Motor = client_motor;
   1900              Api221.Data[0].Channel = channel;
   1901              Api221.Data[0].Sequence = new_sequence_number;
   1902          }
   1903          #endif      // #if (API221_STORED_ANALOG_INPUTS > 0)
   1904          #endif      // #if (API221_CLIENT_FEATURE == ENABLED)
   1905          
   1906          
   1907          //=====================================================================================================================
   1908          //  --- Private Functions (Server) ------------------------------------------------------------------------------------
   1909          //=====================================================================================================================
   1910          
   1911          
   1912          #if (API221_SERVER_FEATURE == ENABLED)
   1913          #if (TIMEOUT_TO_STOP > 0)
   1914          //---------------------------------------------------------------------------------------------------------------------
   1915          /**
   1916           * Implement Auto-Stop feature on the server.
   1917           * Automatically stop the motor if timeout occurs before expected messages from the client.
   1918           * @param server_motor = The server-based motor index.
   1919           */
   1920          static void AutoStopCheck(uint8 server_motor)
   1921          {
   1922              uint8 timeout = Api221.Stop_Timeout[server_motor];
   1923              if (timeout == 0)
   1924              {
   1925                  // Do nothing.
   1926              }
   1927              else if (timeout == 1)
   1928              {
   1929                  if (API221_DEVICE_STOP(server_motor, API221_DEFAULT_DECELERATION) == TRUE)
   1930                  {
   1931                      LOG_ADD_EVENT(MOTOR_STOPPED_DUE_TO_TIMEOUT, server_motor);
   1932                      Api221.Stop_Timeout[server_motor] = 0;
   1933                  }
   1934                  else
   1935                  {
   1936                      LOG_ADD_EXCEPTION(MOTOR_REJECTED_STOP_FROM_TIMEOUT, server_motor);
   1937                  }
   1938              }
   1939              else
   1940              {
   1941                  Api221.Stop_Timeout[server_motor] = timeout - 1;
   1942              }
   1943          }
   1944          #endif      // #if (TIMEOUT_TO_STOP > 0)
   1945          
   1946          //---------------------------------------------------------------------------------------------------------------------
   1947          /**
   1948           * Check the motor status and react to changes.
   1949           * @param server_motor = The server-side motor index which is associated with the status.
   1950           */
   1951          static void CheckForMotorStatusChangeEvents(uint8 server_motor)
   1952          {
   1953              uint8 prev_status = Api221.Status_Flags[server_motor];
   1954              uint8 next_status = API221_READ_MOTOR_STATUS(server_motor);
   1955              if (prev_status != next_status)
   1956              {
   1957                  // Save the new status.
   1958                  Api221.Status_Flags[server_motor] = next_status;
   1959          
   1960                  // Determine if any error occurred.
   1961                  if ((BIT_TEST(prev_status, API221_STS_ANY_ERROR_FOUND) == 0) &&
   1962                      (BIT_TEST(next_status, API221_STS_ANY_ERROR_FOUND) == 1))
   1963                  {
   1964                      API221MotionCtrl__PostEvent(server_motor, API221_EVENT_ERROR);
   1965                  }
   1966          
   1967                  // Look for events derived from previous and current status.
   1968                  //      Setup a key with the following bits:
   1969                  //          bit 3 = Had previously reached target
   1970                  //          bit 2 = Was previously stopped
   1971                  //          bit 1 = Has currently reached target
   1972                  //          bit 0 = Is currently stopped
   1973                  uint8 key = ((prev_status << 1) & 0x0C) + ((next_status >> 1) & 0x03);
   1974                  //      Use the key to look up the event in a table.
   1975                  API221_MOTOR_EVENT_TYPE event = KEY_TO_EVENT[key];
   1976                  if (event != API221_EVENT_NONE)
   1977                  {
   1978                      API221MotionCtrl__PostEvent(server_motor, event);
   1979                  }
   1980              }
   1981          }
   1982          
   1983          //---------------------------------------------------------------------------------------------------------------------
   1984          /**
   1985           * Publish the status for a specific motor controlled by the server.
   1986           * @param requesting_node = The node that requested the motor status.
   1987           * @param server_motor = The server-side motor index whose status should be published.
   1988           * @return TRUE if the request was sent. Otherwise FALSE.
   1989           */
   1990          static BOOL_TYPE PublishMotorStatus(uint8 requesting_node, uint8 server_motor)
   1991          {
   1992              REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM, API221_FBK_PUBLISH_MOTOR_STATUS, requesting_node, 2);
   1993              return (BOOL_TYPE)((Reveal__AddDataU8(msg, server_motor) == PASS) &&
   1994                                 (Reveal__AddDataU8(msg, Api221.Status_Flags[server_motor]) == PASS) &&
   1995                                 (Reveal__QueueCommand(msg) == TRUE));
   1996          }
   1997          
   1998          #ifdef API221_READ_ANALOG_DATA
   1999          //---------------------------------------------------------------------------------------------------------------------
   2000          /**
   2001           * Publish periodic data if it was requested and it is time to publish it.
   2002           */
   2003          static void CheckIfTimeToPublishPeriodicData(void)
   2004          {
   2005              if (Api221.Publication_Period > 0)
   2006              {
   2007                  if (Api221.Publication_Counter > 0)
   2008                  {
   2009                      Api221.Publication_Counter--;
   2010                  }
   2011                  if ((Api221.Publication_Counter == 0) &&
   2012                      (Api221.Requested != 0))
   2013                  {
   2014                      if (GeneratePeriodicData() == TRUE)
   2015                      {
   2016                          // Setup the counter for the next publication.
   2017                          Api221.Publication_Counter = Api221.Publication_Period;
   2018                      }
   2019                      else
   2020                      {
   2021                          LOG_ADD_EXCEPTION(PERIODIC_PUBLICATION_FAILED, Api221.Num_Of_Requested_Analog_Inputs);
   2022                      }
   2023                  }
   2024              }
   2025          }
   2026          
   2027          //---------------------------------------------------------------------------------------------------------------------
   2028          /**
   2029           * Generate all the requested analog inputs.
   2030           * The API221 Client/Server will save the results in a local array.
   2031           * The API221 Server Only will publish the results on Reveal
   2032           * @return TRUE if a message with the analog inputs was sent to Reveal; otherwise FALSE.
   2033           */
   2034          static BOOL_TYPE GeneratePeriodicData(void)
   2035          {
   2036              #if (API221_CLIENT_FEATURE == ENABLED)
   2037                  // Iterate through all the server_motors and their associated analog inputs.
   2038                  for (uint8 server_motor = 0; server_motor < API221_SERVER_MOTOR_COUNT; server_motor++)
   2039                  {
   2040                      uint32 requested = Api221.Requested[server_motor];
   2041                      if (requested > 0)
   2042                      {
   2043                          API221_CLIENT_MOTOR_INDEX_TYPE client_motor = ConvertServerMotorIndexToClientMotorIndex(WIN_NODE, server_motor);
   2044                          for (uint8 channel = 0; requested > 0; channel++)
   2045                          {
   2046                              if (BIT_TEST(requested, channel) != 0)
   2047                              {
   2048                                  // Analog input 'channel' is requested for 'server_motor'.
   2049                                  BIT_CLR(requested, channel);
   2050                                  sint32 value = API221_READ_ANALOG_DATA(server_motor, channel);
   2051                                  StoreAnalogInput(client_motor, channel, value);
   2052                              }
   2053                          }
   2054                      }
   2055                  }
   2056                  return TRUE;
   2057              #else
   2058                  // Create a feedback message.
   2059                  uint8 payload_size = Api221.Num_Of_Requested_Analog_Inputs * SIZE_OF_ANALOG_DATA_PAYLOAD;
   2060                  REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM, API221_FBK_PUBLISH_PERIODIC_DATA, Api221.Requesting_Node, payload_size);
   2061                  if (msg == NULL)
   2062                  {
   2063                      return FALSE;                               // Could not get a Reveal feedback message.
   2064                  }
   2065          
   2066                  // Iterate through all the server_motors and their associated analog inputs.
   2067                  for (uint8 server_motor = 0; server_motor < API221_SERVER_MOTOR_COUNT; server_motor++)
   2068                  {
   2069                      uint32 requested = Api221.Requested[server_motor];
   2070                      for (uint8 channel = 0; requested > 0; channel++)
   2071                      {
   2072                          if (BIT_TEST(requested, channel) != 0)
   2073                          {
   2074                              // Analog input 'channel' is requested for 'server_motor'.
   2075                              BIT_CLR(requested, channel);
   2076                              if (RevealAddAnalogInput(msg, server_motor, channel) == FAIL)
   2077                              {
   2078                                  return FALSE;                   // Failed to add the analog input to the payload.
   2079                              }
   2080                          }
   2081                      }
   2082                  }
   2083                  return (BOOL_TYPE)(Reveal__QueueCommand(msg) == TRUE);
   2084              #endif
   2085          }
   2086          
   2087          //---------------------------------------------------------------------------------------------------------------------
   2088          /**
   2089           * Publish a single analog input value.
   2090           * @param requesting_node = The node that requested the analog input value.
   2091           * @param server_motor = The server-side motor index whose analog data should be published.
   2092           * @param channel = The analog input ID.
   2093           * @return TRUE if the request was sent. Otherwise, FALSE.
   2094           */
   2095          static BOOL_TYPE PublishAnalogData(uint8 requesting_node, uint8 server_motor, uint8 channel)
   2096          {
   2097              REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM, API221_FBK_PUBLISH_ANALOG_DATA, requesting_node, SIZE_OF_ANALOG_DATA_PAYLOAD);
   2098              return (BOOL_TYPE)((RevealAddAnalogInput(msg, server_motor, channel) == PASS) &&
   2099                                 (Reveal__QueueCommand(msg) == TRUE));
   2100          }
   2101          
   2102          //---------------------------------------------------------------------------------------------------------------------
   2103          /**
   2104           * Publish information about the current status of the periodic publication feature.
   2105           * @param requesting_node = The node to which the periodic data should be sent.
   2106           * @return TRUE if the packet was sent successfully. Otherwise FALSE.
   2107           */
   2108          static BOOL_TYPE PublishPeriodicDataStatus(uint8 requesting_node)
   2109          {
   2110              REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM,
   2111                                                             API221_FBK_PUBLISH_PERIODIC_DATA_STATUS,
   2112                                                             requesting_node,
   2113                                                             sizeof(uint16) + API221_SERVER_MOTOR_COUNT * sizeof(uint32));
   2114              PASS_FAIL_TYPE pass = Reveal__AddDataU16(msg, API221_MS_PER_CALL_TO_BACKGROUND * Api221.Publication_Period);
   2115              for (uint8 server_motor = 0; (pass == PASS) && (server_motor < API221_SERVER_MOTOR_COUNT); server_motor++)
   2116              {
   2117                  pass = Reveal__AddDataU32(msg, Api221.Requested[server_motor]);
   2118              }
   2119          
   2120              if (pass == PASS)
   2121              {
   2122                  return (BOOL_TYPE)Reveal__QueueCommand(msg);
   2123              }
   2124              else
   2125              {
   2126                  return FALSE;
   2127              }
   2128          }
   2129          
   2130          //---------------------------------------------------------------------------------------------------------------------
   2131          /**
   2132           * Add a single analog input to a Reveal packet that is under construction.
   2133           * @param msg = Pointer to the REVEAL_COMMAND_TYPE that holds the message being built.
   2134           * @param server_motor = The server-side motor index.
   2135           * @param channel = The analog input ID.
   2136           * @return PASS if the analog input data was successful added to the Reveal message; otherwise FAIL.
   2137           */
   2138          static PASS_FAIL_TYPE RevealAddAnalogInput(REVEAL_COMMAND_TYPE* msg, uint8 server_motor, uint8 channel)
   2139          {
   2140              sint32 value = API221_READ_ANALOG_DATA(server_motor, channel);
   2141              return (PASS_FAIL_TYPE)((Reveal__AddDataU8(msg, server_motor) == PASS) &&
   2142                                      (Reveal__AddDataU8(msg, channel) == PASS) &&
   2143                                      (Reveal__AddDataU8Buffer(msg, (uint8*)(void*)&value, sizeof(value)) == PASS));
   2144          }
   2145          
   2146          //---------------------------------------------------------------------------------------------------------------------
   2147          /**
   2148           * Set the publication period for all periodic data published by this communication node.
   2149           * @param milliseconds = The requested number of milliseconds between periodically published data.
   2150           * @return TRUE if the requested period is supported; otherwise FALSE.
   2151           */
   2152          static BOOL_TYPE SetPublicationPeriod(uint8 node, uint16 milliseconds)
   2153          {
   2154              if ((milliseconds == 0) || (milliseconds >= MINIMUM_PUBLICATION_MILLISECONDS))
   2155              {
   2156                  // Verify that the requested millisecond publication rate can be supported.
   2157                  uint16 calls_to_background = milliseconds / API221_MS_PER_CALL_TO_BACKGROUND;
   2158                  if ((milliseconds % API221_MS_PER_CALL_TO_BACKGROUND == 0) &&
   2159                      (calls_to_background <= UCHAR_MAX))
   2160                  {
   2161                      if (Api221.Publication_Period != (uint8)calls_to_background)
   2162                      {
   2163                          Api221.Publication_Period = (uint8)calls_to_background;
   2164                      }
   2165                      Api221.Requesting_Node = node;
   2166                      return TRUE;
   2167                  }
   2168              }
   2169              return FALSE;
   2170          }
   2171          
   2172          //---------------------------------------------------------------------------------------------------------------------
   2173          /**
   2174           * Add or remove analog data channels from the list of periodically published data.
   2175           * @param add = TRUE to add channels; FALSE to remove channels.
   2176           * @param server_motor = The server-side motor index.
   2177           * @param channels = A mask of the analog data channels to add or remove.
   2178           *                   Bit 'n' of this value represents an analog data channel #n.
   2179           */
   2180          static void UpdatePeriodicDataChannels(BOOL_TYPE add, uint8 server_motor, uint32 channels)
   2181          {
   2182              if (add == TRUE)
   2183              {
   2184                  Api221.Requested[server_motor] |= channels;
   2185              }
   2186              else
   2187              {
   2188                  Api221.Requested[server_motor] &= ~channels;
   2189              }
   2190              Api221.Num_Of_Requested_Analog_Inputs = Utilities__CountOneBitsInArray((uint8*)(Api221.Requested), sizeof(Api221.Requested));   //lint !e928 Suppress Info: cast from pointer to pointer [MISRA 2004 rule 11.4]
   2191          }
   2192          #endif      // #ifdef API221_READ_ANALOG_DATA
   2193          
   2194          #ifdef API221_READ_FAILURE_FLAGS
   2195          //---------------------------------------------------------------------------------------------------------------------
   2196          /**
   2197           * Publish event if any failure flags have been removed through the motor interface.
   2198           * @param server_motor = The server-side motor index which is associated with the failure flags.
   2199           */
   2200          static void CheckForRemovedFailureFlags(uint8 server_motor)
   2201          {
   2202              uint32 next_failure_flags = API221_READ_FAILURE_FLAGS(server_motor);
   2203              uint32 prev_failure_flags = Api221.Failure_Flags[server_motor];
   2204          
   2205              // Save the new failure flags.
   2206              Api221.Failure_Flags[server_motor] = next_failure_flags;
   2207          
   2208              // Check if a failure has been removed (any bit changed from 1 to 0)
   2209              if ((prev_failure_flags & (prev_failure_flags ^ next_failure_flags)) != 0)
   2210              {
   2211                  API221MotionCtrl__PostEvent(server_motor, API221_EVENT_REMOVED_ERROR);
   2212              }
   2213          }
   2214          
   2215          //---------------------------------------------------------------------------------------------------------------------
   2216          /**
   2217           * Publish all the failure flags.
   2218           * @param requesting_node = The node that requested the failure flags.
   2219           * @param server_motor = The server-side motor index which is associated with the failure flags.
   2220           * @return NVO_RS_READY if the message was successfully sent; otherwise NVO_RS_REJECTED.
   2221           */
   2222          static REVEAL_RECIPE_STATUS_TYPE PublishFailureFlags(uint8 requesting_node, uint8 server_motor)
   2223          {
   2224              REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API221MOTIONCTRL_NUM, API221_FBK_PUBLISH_FAILURE_FLAGS, requesting_node, 5);
   2225              if ((Reveal__AddDataU8(msg, server_motor) == PASS) &&
   2226                  (Reveal__AddDataU32(msg, Api221.Failure_Flags[server_motor]) == PASS) &&
   2227                  (Reveal__QueueCommand(msg) == TRUE))
   2228              {
   2229                  return NVO_RS_READY;
   2230              }
   2231              else
   2232              {
   2233                  return NVO_RS_REJECTED;
   2234              }
   2235          }
   2236          #endif      // #ifdef API221_READ_FAILURE_FLAGS
   2237          #endif      // #if (API221_SERVER_FEATURE == ENABLED)
   2238          
   2239          #endif      // #if ((API221_CLIENT_FEATURE == ENABLED) || (API221_SERVER_FEATURE == ENABLED))


 

 


