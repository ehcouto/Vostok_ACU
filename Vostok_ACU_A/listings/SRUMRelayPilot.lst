    270          //---------------------------------------------------------------------------------------------------------------------
    271          /**
    272           *  @brief      Set SRUMRelayPilot instance request.
    273           *
    274           *  @param      load - Pointer to associated DoorLockEMPilot instance.
    275           *  @param      data - Pointer to request data. Pass argument as uint8 *.
    276           *
    277           *  @return     PASS_FAIL_TYPE result - Result of SRUMRelayPilot request.
    278           *  @retval     PASS - Instance request succeeded.
    279           *  @retval     FAIL - Instance request failed.
    280           */
    281          PASS_FAIL_TYPE  SRUMRelayPilot__Request(HBL_LOAD_TYPE *load, void *data)
    282          {
    283              PASS_FAIL_TYPE result = FAIL;
    284          
    285              if ((SRDATA_OK == SRData__CheckByte(&SRUMRelayPilot_Allocation, &N_SRUMRelayPilot_Allocation)) &&
    286                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    287              {
    288                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    289                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    290                  if ((SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr,(void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE))) &&
    291                      (data_ptr->State != SRUMRELAYPILOT_INITALIZE))
    292                  {
    293                      SRData__UpdateArray((void *) &data_ptr->Requested, (void *) &n_data_ptr->Requested,
    294                          (void *)data, sizeof(SRUMRELAYPILOT_PARAM_TYPE));
    295                      result = PASS;
    296                  }
    297              }
    298          
    299              return (result);
    300          }
