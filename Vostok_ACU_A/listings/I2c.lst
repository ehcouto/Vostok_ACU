    524                          Gpio__PinConfig(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT, INPUT_FLOAT);
    525          
    526          
    527                          //Read the SDA status
    528                          aux = Gpio__PinRead(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT);
    529          
    530                          count = 0;
    531          
    532                          //If the SDA is hold by the slave then it must be released by mimicking the I2c clock
    533                          //reading SDA status
