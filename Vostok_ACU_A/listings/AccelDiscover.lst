    229          /**
    230           * Initialize the microcontroller peripherals used by the module
    231           */
    232          static void AccelHwInit(void)
    233          {
    234          #if (SPI_ENABLED == 1)
    235          
    236              Spi__Initialize((SPI_ENUM_DEF)AccelDiscover.Port);
    237          
    238              if (AccelDiscover.Device_Index == 0U)    // NXP
    239              {
    240                  Spi__SetConfiguration((SPI_ENUM_DEF)AccelDiscover.Port, SPI_POLARITY_SCK_IDLE_0, SPI_EDGE_FIRST, SPI_ODER_MSB_FIRST);
    241              }
    242              else    // ST
    243              {
    244                  Spi__SetConfiguration((SPI_ENUM_DEF)AccelDiscover.Port, SPI_POLARITY_SCK_IDLE_1, SPI_EDGE_SECOND, SPI_ODER_MSB_FIRST);
    245              }
    246          
    247              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, TRUE);           // Pull chip select high (reset CS)
    248          #else
    249              // Setup the I2C peripheral.
    250              // NOTE: The I2C module includes the I2C R/W bit as part of the address.
    251              I2c__Initialize((I2C_ENUM_TYPE)AccelDiscover.Port, (I2C_SPEED_TYPE)I2C_400KHZ, I2C_ADDR_7BITS, (AccelDiscover.Address << 1));
    252          #endif
    253          }
    254          
    255          
    256          //---------------------------------------------------------------------------------------------------------------------
    257          /**
    258           * Send a command to the accelerometer to read the WHO_AM_I register that identifies the device
    259           */
    260          static void AccelReadIdentity(void)
    261          {
    262          #if (SPI_ENABLED == 1)
    263              uint8 buffer[3];
    264              buffer[0] = ACCEL_IDENTIFY_REGISTERS[AccelDiscover.Device_Index];
    265              buffer[1] = 0xFF;                                     // Unused byte to read the byte of register data from the accelerometer
    266              buffer[2] = 0xFF;                                     // Unused byte to read the byte of register data from the accelerometer
    267              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
    268          
    269              uint8 num_write_bytes = 2;   // Default value satisfies LISxDH accelerometer
    270              if (AccelDiscover.Device_Index == 0U)    // NXP
    271              {
    272                  num_write_bytes = 3;
    273              }
    274              (void)Spi__Write((SPI_ENUM_DEF)AccelDiscover.Port, buffer, num_write_bytes);
    275          #else
    276              uint8 buffer[1];
    277              buffer[0] = ACCEL_IDENTIFY_REGISTERS[AccelDiscover.Device_Index];
    278          
    279              I2c__WriteThenRead((I2C_ENUM_TYPE)AccelDiscover.Port, buffer, 1, 1);
    280          #endif
    281          }
