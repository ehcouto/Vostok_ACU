    180          /**
    181           *    @brief    It initializes a specific I2C module i.e. I2c1 or I2c2
    182           *
    183           *    @details  This method first reset I2C module to ensure there is no activity on the I2C bus prior to its initialization,
    184           *              then it enables the particular I2C module and configures it with user defined speed, also defines which type
    185           *              of addressing scheme is used i.e. 7-bit or 10-bit addressing
    186           *    @param    i2c       : I2C module i.e. I2c1 or I2c2 device
    187           *    @param    speed     : defines the i2c bus speed
    188           *    @param    addr_type : defines the slave addressing scheme types used 7-bits or 10-bits
    189           *    @param    i2c_Addr  : defines the slave address used during I2C communication
    190           *    @return   BOOL_TYPE
    191           *      @retval   TRUE (1) : It means I2C module is successfully initialized
    192           *      @retval   FALSE(0) : It means I2C module initialization is unsuccessful
    193           *
    194           *    @image html I2c__Initialize.jpg
    195           */

   \                                 In section .text, align 2, keep-with-next
    196          BOOL_TYPE I2c__Initialize(I2C_ENUM_TYPE i2c,I2C_SPEED_TYPE speed, I2C_ADRESS_TYPE addr_type, uint8 i2c_addr)
    197          {
    198              #if ((I2C1_FEATURE == ENABLED) || (I2C2_FEATURE == ENABLED) || (I2C3_FEATURE == ENABLED))
    199          
    200                  BOOL_TYPE response;
    201                  uint32 apb_clock;
    202                  uint8 prescaler;
    203                  uint8 scll;
    204                  uint8 sclh;
    205                  uint32 sdadel_scl_del;
    206          
    207                  response = FALSE;
    208                  prescaler = 0;
    209          
    210                  I2c__ResetBus(i2c);                                     //I2C bus is reset i.e. SCL is made low-high & SDA is checked for high
    211          
    212                  apb_clock = Micro__GetClock()->SYSCLK_Frequency;        //Peripheral clock is supplied by ABP module
    213          
    214                  //Clock configuration
    215                  switch (speed)
    216                  {
    217                      case I2C_50KHZ:
    218                          prescaler = apb_clock / I2C_BASE_FREQUENCY_AT_50KHZ_100KHZ_SPEED;
    219          
    220                          scll = (apb_clock/prescaler)/I2C_SCLL_FREQUENCY_AT_50KHZ;
    221                          sclh = (apb_clock/prescaler)/I2C_SCLH_FREQUENCY_AT_50KHZ;
    222                          sdadel_scl_del = (I2C_SDADEL_AT_50_100KHZ | I2C_SCLDEL_AT_50_100KHZ);
    223                          break;
    224          
    225                      case I2C_400KHZ:
    226                          prescaler = apb_clock / I2C_BASE_FREQUENCY_AT_400KHZ_SPEED;
    227          
    228                          scll = (apb_clock/prescaler)/I2C_SCLL_FREQUENCY_AT_400KHZ;
    229                          sclh = (apb_clock/prescaler)/I2C_SCLH_FREQUENCY_AT_400KHZ;
    230                          sdadel_scl_del = (I2C_SDADEL_AT_400KHZ | I2C_SCLDEL_AT_400KHZ);
    231                          break;
    232          
    233                      case I2C_100KHZ:
    234                      default:
    235                          prescaler = apb_clock / I2C_BASE_FREQUENCY_AT_50KHZ_100KHZ_SPEED;
    236          
    237                          scll = (apb_clock/prescaler)/I2C_SCLL_FREQUENCY_AT_100KHZ;
    238                          sclh = (apb_clock/prescaler)/I2C_SCLH_FREQUENCY_AT_100KHZ;
    239                          sdadel_scl_del = (I2C_SDADEL_AT_50_100KHZ | I2C_SCLDEL_AT_50_100KHZ);
    240                          break;
    241                  }
    242          
    243                  prescaler--;
    244                  scll--;
    245                  sclh--;
    246          
    247                  #if (I2C1_FEATURE == ENABLED)
    248                      if (i2c == I2C1)
    249                      {
    250                          I2c1_Ack_Error = I2C_ERROR_NONE;
    251          
    252                          //System clock (SYSCLK) selected as I2c1 clock
    253                          RCC.CCIPR &= ~RCC_CCIPR_I2C1SEL;
    254                          RCC.CCIPR |= LL_RCC_I2C1_CLKSOURCE_SYSCLK;
    255          
    256                          //Enable the clock for I2c1 module
    257                          RCC.APBENR1 |= RCC_APBENR1_I2C1EN;
    258          
    259                          //Reset the I2c1
    260                          RCC.APBRSTR1 |= RCC_APBENR1_I2C1EN;
    261                          RCC.APBRSTR1 &= (uint32)(~RCC_APBENR1_I2C1EN);
    262          
    263                          I2c__Disable(i2c);                                      //I2C module is disabled
    264          
    265                          GPIO__PIN_COFIG_AF(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT, I2C_1_SDA__AF);
    266                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT);
    267          
    268                          GPIO__PIN_COFIG_AF(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, I2C_1_SCL__AF);
    269                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT);
    270          
    271                          I2C_1.TIMINGR = (((prescaler & 0xf) << 28) | sdadel_scl_del | ((sclh & 0xff) << 8) | (scll & 0xff));
    272          
    273                          //Configure the Digital filter
    274                          I2C_1.CR1 |= (uint32)((I2C1_DIGITAL_NOISE_FILTER << 8) & I2C_CR1_DFN);
    275          
    276                          #if (I2C1_SLAVE_FEATURE == DISABLED)
    277                              //Configure the Device address
    278                              I2C_1.CR2 |= (uint32)i2c_addr;
    279                          #else
    280                              //Slave Byte Control
    281                              I2C_1.CR1 |= I2C_CR1_SBC;
    282          
    283                              I2C_1.OAR1 = (i2c_addr & 0xFE) | I2C_OAR1_OA1EN;
    284                          #endif
    285          
    286                          //Set the interrupt
    287                          Micro__NVICEnableIRQ (I2C1_IRQ_CHANNEL, I2C1_INTERRUPT_PREEMPTION_PRIORITY);
    288          
    289                          response = TRUE;
    290                      }
    291                  #endif
    292          
    293                  #if (I2C2_FEATURE == ENABLED)
    294                      if (i2c == I2C2)
    295                      {
    296                          I2c2_Ack_Error = I2C_ERROR_NONE;
    297          
    298                          //System clock (SYSCLK) selected as I2c1 clock
    299                          RCC.CCIPR &= ~RCC_CCIPR_I2C2SEL;
    300                          RCC.CCIPR |= LL_RCC_I2C2_CLKSOURCE_SYSCLK;
    301          
    302                          //Enable the clock for I2c1 module
    303                          RCC.APBENR1 |= RCC_APBENR1_I2C2EN;
    304          
    305                          //Reset the I2c1
    306                          RCC.APBRSTR1 |= RCC_APBENR1_I2C2EN;
    307                          RCC.APBRSTR1 &= (uint32)(~RCC_APBENR1_I2C2EN);
    308          
    309                          I2c__Disable(i2c);                                      //I2C module is disabled
    310          
    311                          GPIO__PIN_COFIG_AF(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT, I2C_2_SDA__AF);
    312                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_2_SDA_PORT, I2C_2_SDA_PORTBIT);
    313          
    314                          GPIO__PIN_COFIG_AF(I2C_2_SCL_PORT, I2C_2_SCL_PORTBIT, I2C_2_SCL__AF);
    315                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_2_SCL_PORT, I2C_2_SCL_PORTBIT);
    316          
    317                          I2C_2.TIMINGR = (((prescaler & 0xf) << 28) | sdadel_scl_del | ((sclh & 0xff) << 8) | (scll & 0xff));
    318          
    319                          //Configure the Digital filter
    320                          I2C_2.CR1 |= (uint32)((I2C2_DIGITAL_NOISE_FILTER << 8) & I2C_CR1_DFN);
    321          
    322                          //Configure the Device address
    323                          I2C_2.CR2 |= (uint32)i2c_addr;
    324          
    325                          //Set the interrupt
    326                          Micro__NVICEnableIRQ (I2C2_3_IRQ_CHANNEL, I2C2_3_INTERRUPT_PREEMPTION_PRIORITY);
    327          
    328                          response = TRUE;
    329                      }
    330                  #endif
    331          
    332                  #if (I2C3_FEATURE == ENABLED)
    333                      if (i2c == I2C3)
    334                      {
    335                          I2c3_Ack_Error = I2C_ERROR_NONE;
    336          
    337                          //Enable the clock for I2c1 module
    338                          RCC.APBENR1 |= RCC_APBENR1_I2C3EN;
    339          
    340                          //Reset the I2c1
    341                          RCC.APBRSTR1 |= RCC_APBENR1_I2C3EN;
    342                          RCC.APBRSTR1 &= (uint32)(~RCC_APBENR1_I2C3EN);
    343          
    344                          I2c__Disable(i2c);                                      //I2C module is disabled
    345          
    346                          GPIO__PIN_COFIG_AF(I2C_3_SDA_PORT, I2C_3_SDA_PORTBIT, I2C_3_SDA__AF);
    347                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_3_SDA_PORT, I2C_3_SDA_PORTBIT);
    348          
    349                          GPIO__PIN_COFIG_AF(I2C_3_SCL_PORT, I2C_3_SCL_PORTBIT, I2C_3_SCL__AF);
    350                          GPIO__PIN_COFIG_SF_OPENDRAIN(I2C_3_SCL_PORT, I2C_3_SCL_PORTBIT);
    351          
    352                          I2C_3.TIMINGR = (((prescaler & 0xf) << 28) | sdadel_scl_del | ((sclh & 0xff) << 8) | (scll & 0xff));
    353          
    354                          //Configure the Digital filter
    355                          I2C_3.CR1 |= (uint32)((I2C3_DIGITAL_NOISE_FILTER << 8) & I2C_CR1_DFN);
    356          
    357                          //Configure the Device address
    358                          I2C_3.CR2 |= (uint32)i2c_addr;
    359          
    360                          //Set the interrupt
    361                          Micro__NVICEnableIRQ (I2C2_3_IRQ_CHANNEL, I2C2_3_INTERRUPT_PREEMPTION_PRIORITY);
    362          
    363                          response = TRUE;
    364                      }
    365                  #endif
    366          
    367                  I2c__Enable(i2c);
    368          
    369                  return (response);
    370          
    371              #else
    372                  return (FALSE);
   \                     I2c__Initialize: (+1)
   \   00000000   0x2000             MOVS     R0,#+0
   \   00000002   0x4770             BX       LR               ;; return
    373              #endif
    374          }
