    656          //----------------------------------------------------------------------------------------------------------
    657          /**
    658           * @brief   This API is been called from the API007Data__CommandParser()
    659           *          Process the request for claim size by the client
    660           *
    661           * @details Enabled only for Server side
    662           *          Sends the feedback message depending on weather the claim is accepted or rejected
    663           *
    664           * @param client_node_id - Client Node ID
    665           * @param size  - Claim Size
    666           */
    667          void API007NVData__ProcessClaimSize(uint8 client_node_id, uint16 size)
    668          {
    669          	#if(API007NVDATA_SERVER_FEATURE == ENABLED)
    670          		BOOL_TYPE claim_successfull = FALSE;
    671          		uint16 existing_client_size = 0;
    672          		uint16 re_index = 0;
    673          		uint16 last_client = 0;
    674          		BOOL_TYPE needs_remap_cdt = FALSE;
    675          
    676          		for (uint8 index = 0; index < API007NVDATA_SERVER_NUM_CLIENTS_SUPPORT; index++)
    677          		{
    678          			if (API007NVData_CDTable[index].Node_ID != EMPTY_NODE_ID)
    679          			{
    680          				if (API007NVData_CDTable[index].Node_ID == client_node_id)
    681          				{
    682          					//found the node
    683          					//check the size requested matches what CDT already has or else forcedly corrupt the crc
    684          					if (((API007NVData_CDTable[index].End_Index + 1) - API007NVData_CDTable[index].Start_Index) == size)
    685          					{
    686          						claim_successfull = TRUE;
    687          					}
    688          					else
    689          					{
    690          						//Find the last client registered
    691          						for(re_index = index+1; re_index < API007NVDATA_SERVER_NUM_CLIENTS_SUPPORT; re_index++)
    692          						{
    693          							//find the last client registered in the CDT Table
    694          							if (API007NVData_CDTable[re_index].Node_ID == EMPTY_NODE_ID)
    695          							{
    696          								break;
    697          							}
    698          						}
    699          
    700          						last_client = re_index;
    701          						re_index--;
    702          
    703          
    704          						//First make sure we have enough space for claimed size
    705          						existing_client_size = (API007NVData_CDTable[index].End_Index + 1) - API007NVData_CDTable[index].Start_Index;
    706          
    707          						//if claim is more then the existing then we need to make sure we have enough space
    708          						if (existing_client_size < size)
    709          						{
    710          							//Does new size fits in the memory
    711          							if ((API007NVDATA_SERVER_DATA_TRUE_SIZE - (API007NVData_CDTable[re_index].End_Index + 1) + existing_client_size) >= size)
    712          							{
    713          								needs_remap_cdt = TRUE;
    714          							}
    715          						}
    716          						else
    717          						{
    718          							//If the new claim is smaller then the existing then we just need remap of CDT Table
    719          							needs_remap_cdt = TRUE;
    720          						}
    721          
    722          						if (needs_remap_cdt == TRUE)
    723          						{
    724          							claim_successfull = TRUE;
    725          
    726          							API007NVData_CDTable[index].End_Index = API007NVData_CDTable[index].Start_Index + size - 1;	//-1 as end address is inclusive type
    727          
    728          							for (re_index = (index+1); re_index < last_client; re_index++)
    729          							{
    730          								existing_client_size = (API007NVData_CDTable[re_index].End_Index + 1) - API007NVData_CDTable[re_index].Start_Index;
    731          
    732          								API007NVData_CDTable[re_index].Start_Index = API007NVData_CDTable[(re_index-1)].End_Index + 1;
    733          								API007NVData_CDTable[re_index].End_Index = API007NVData_CDTable[re_index].Start_Index + existing_client_size - 1;	//-1 as end address is inclusive type
    734          							}
    735          						}
    736          						else
    737          						{
    738          
    739          						}
    740          
    741          						break;	//After Remap CDT break
    742          					}
    743          
    744          					break;	//If the claim matches to the CDT then break
    745          				}
    746          			}
    747          			else
    748          			{
    749          				//Node Not registered yet...register it
    750          				//check is enough space available to allocate
    751          				uint16 last_client_end_index = 0;
    752          				if (index != 0)
    753          				{
    754          					last_client_end_index = API007NVData_CDTable[(index-1)].End_Index;
    755          				}
    756          
    757          				if ((API007NVDATA_SERVER_DATA_TRUE_SIZE - last_client_end_index) > size)
    758          				{
    759          					API007NVData_CDTable[index].Node_ID 	= client_node_id;
    760          					API007NVData_CDTable[index].Start_Index = last_client_end_index + 1;
    761          					API007NVData_CDTable[index].End_Index 	= API007NVData_CDTable[index].Start_Index + size - 1;
    762          
    763          					claim_successfull = TRUE;
    764          				}
    765          
    766                          break; //Break after registering into the CDT Table
    767          			}
    768          		}
    769          
    770          
    771          
    772          		if (claim_successfull == FALSE)
    773          		{
    774          			size = 0;
    775          		}
    776          
    777          		API007Data__NVDataFbkClaimSize(client_node_id, size);
    778          
    779          
    780          	#endif
    781          }
