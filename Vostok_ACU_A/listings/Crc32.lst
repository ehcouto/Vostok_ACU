     35          /**
     36           * @brief This method calculates a CRC32bits for 1 byte each time
     37           * @param crc Previews CRC value
     38           * @param data Data to be processed in this Crc interaction
     39           * @return CRC product of this process
     40           */

   \                                 In section .text, align 4, keep-with-next
     41          uint32 Crc32__ProcessByte( uint32 crc, uint8 data )
     42          {
   \                     Crc32__ProcessByte: (+1)
   \   00000000   0xB430             PUSH     {R4,R5}
     43              // calculate it
     44              crc = ( crc >> 4 ) ^ CRC32_TABLE[ (uint8)( crc & 0x0000000FU ) ^ ( data & 0x0FU ) ];
   \   00000002   0x220F             MOVS     R2,#+15
   \   00000004   0x....             ADR.N    R3,CRC32_TABLE
   \   00000006   0x0904             LSRS     R4,R0,#+4
   \   00000008   0x0015             MOVS     R5,R2
   \   0000000A   0x4005             ANDS     R5,R5,R0
   \   0000000C   0x0010             MOVS     R0,R2
   \   0000000E   0x4008             ANDS     R0,R0,R1
   \   00000010   0x4068             EORS     R0,R0,R5
   \   00000012   0x0080             LSLS     R0,R0,#+2
   \   00000014   0x5818             LDR      R0,[R3, R0]
   \   00000016   0x4060             EORS     R0,R0,R4
     45              crc = ( crc >> 4 ) ^ CRC32_TABLE[ (uint8)( crc & 0x0000000FU ) ^ ( data >> 4 ) ];
     46          
     47              // return the new value
     48              return( crc );
   \   00000018   0x0904             LSRS     R4,R0,#+4
   \   0000001A   0x4002             ANDS     R2,R2,R0
   \   0000001C   0x1108             ASRS     R0,R1,#+4
   \   0000001E   0x4050             EORS     R0,R0,R2
   \   00000020   0x0080             LSLS     R0,R0,#+2
   \   00000022   0x5818             LDR      R0,[R3, R0]
   \   00000024   0x4060             EORS     R0,R0,R4
   \   00000026   0xBC30             POP      {R4,R5}
   \   00000028   0x4770             BX       LR               ;; return
     49          }
