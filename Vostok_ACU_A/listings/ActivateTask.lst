     43          // There must be exactly TASK_COUNT tasks defined in the TASK_LIST[] array.
     44          #define TASK_COUNT ELEMENTS_IN_ARRAY(TASK_LIST)
     45          
     46          // The number of compartments multiplied by the number of tasks must not exceed 255.
     47          CT_ASSERT(APPLIANCE_MAX_COMPARTMENTS * TASK_COUNT < 256);
