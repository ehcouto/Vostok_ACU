     98          
     99          //=====================================================================================================================
    100          //-------------------------------------- Public Functions -------------------------------------------------------------
    101          //=====================================================================================================================
    102          
    103          //---------------------------------------------------------------------------------------------------------------------
    104          /**
    105           *  @brief	Initializes the module MultiInputLLI and its variables
    106           */
    107          void MultiInputLLI__Initialize(void)
    108          {
    109              MultiInputLLI_Allocation = 0;
    110              memset(&MultiInputLLI_Config, 0, sizeof(MultiInputLLI_Config));
    111              memset(&MultiInputLLI_Data, 0, sizeof(MultiInputLLI_Data));
    112          }
    113          
    114          //---------------------------------------------------------------------------------------------------------------------
    115          /**
    116           * @brief   Determines the destination (index) of the data for the LLI.
    117           * @return  Index to a local buffer where the data will reside.
    118           */
    119          uint8 MultiInputLLI__Allocate(void)
    120          {
    121              uint8 retval;
    122              retval = 0xFF;
    123          
    124              if (MultiInputLLI_Allocation < HBL_LLI_NUM_MULTIINPUT)
    125              {
    126                  retval = MultiInputLLI_Allocation;
    127                  MultiInputLLI_Allocation++;
    128              }
    129          
    130              return (retval);
    131          }
    132          
    133          //---------------------------------------------------------------------------------------------------------------------
    134          /**
    135           * @brief   Initialize an instance of the MultiInput LLI by extracting parameter data and initializing variables.
    136           * @param   input: data related to the instance of the LLI
    137           * @param   status: see definition of HBL_LLI_STATUS
    138           */
    139          PASS_FAIL_TYPE MultiInputLLI__InitializeInstance(HBL_LLI_TYPE * input)
    140          {
    141              PASS_FAIL_TYPE retval;
    142              MULTIINPUTLLI_PARAMETERS_TYPE * parameters;
    143              uint8 index;
    144              uint8 handler_index;
    145          
    146              retval = FAIL;
    147          
    148              if (input->Data_Index < MultiInputLLI_Allocation)
    149              {
    150              	// Adding 2 to skip the header for MultiInputLLI, as the parameters would have to apply to all the involved LLIs
    151                  parameters = (MULTIINPUTLLI_PARAMETERS_TYPE *)(input->Parameter_Ptr.Data + 2);        //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    152          
    153                  if (input->LLI_ID == HBL_LLI_MULTIINPUT_2)
    154                  {
    155                      MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs = 2;
    156                  }
    157                  else if (input->LLI_ID == HBL_LLI_MULTIINPUT_3)
    158                  {
    159                      MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs = 3;
    160                  }
    161                  else if (input->LLI_ID == HBL_LLI_MULTIINPUT_4)
    162                  {
    163                      MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs = 4;
    164                  }
    165          
    166                  for (index = 0; index < MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs; index++)
    167                  {
    168                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_Handler_Index = HBL_INDEX_INVALID;
    169                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Data_Index = HBL_INDEX_INVALID;
    170          
    171                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID = parameters[index].LLI_ID;
    172                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Pin_Ptr = &(input->Pin_Ptr[index]);
    173          
    174                      if (parameters[index].LLI_Params_Offset != 0xFF)   // Check for LLI with no parameters
    175                      {
    176                      	//NOTE: A board that is both an ACU and HMI cannot support the MultiInputLLI if it uses an LLI with parameters
    177          #if (SYSTEM_ACU_HANDLING == ENABLED || SYSTEM_ACU_EXPANSION_HANDLING == ENABLED)
    178                          SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, parameters[index].LLI_Params_Offset, &MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Parameter_Ptr);
    179          #elif (SYSTEM_HMI_HANDLING == ENABLED || SYSTEM_HMI_EXPANSION_HANDLING == ENABLED)
    180                          SettingFile__BasicLoader(SF_PTR_UI_IO_DEVICE, parameters[index].LLI_Params_Offset, &MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Parameter_Ptr);
    181          #endif
    182                      }
    183                      else
    184                      {
    185                          MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Parameter_Ptr.Data = NULL;
    186                          MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Parameter_Ptr.Length = 0;
    187                      }
    188          
    189                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_Mux = 0;            // Mux not allowed for MultiInput LLI
    190                      MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_Position = 0x7F;    // Don't care about LLI position for MultiInput LLI
    191          
    192                      retval = PASS;
    193          
    194                      for (handler_index = 0; handler_index < MULTIINPUT_NUM_REGISTERED_INPUTS; handler_index++)
    195                      {
    196                          if (MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID == MULTIINPUT_LLI_HANDLERS[handler_index].LLI_ID)
    197                          {
    198                              MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_Handler_Index = handler_index;
    199                              MultiInputLLI_Config[input->Data_Index].LLI_Data[index].Data_Index = MULTIINPUT_LLI_HANDLERS[handler_index].Allocate();
    200                              retval &= MULTIINPUT_LLI_HANDLERS[handler_index].InitializeInstance(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index]);
    201                              break;
    202                          }
    203                      }
    204                  }
    205              }
    206          
    207              return (retval);
    208          }
    209          
    210          //---------------------------------------------------------------------------------------------------------------------
    211          /**
    212           * @brief   Retrieves the current value of each input assigned to a MultiInput LLI based on the input type.
    213           * @param   input: data related to the instance of the LLI
    214           * @param   status: see definition of HBL_LLI_STATUS
    215           * @return  The current value of each input assigned to a MultiInput LLI based on the input type.
    216           */
    217          void * MultiInputLLI__Get(HBL_LLI_TYPE * input)
    218          {
    219              uint8 handler_index;
    220              uint8 index;
    221              BOOL_TYPE * digital_lli_data_ptr;
    222              uint16 * analog_lli_data_ptr;
    223              uint8 * feedback_lli_data_ptr;
    224          
    225              if (input->Data_Index < MultiInputLLI_Allocation)
    226              {
    227                  // Iterate through all the inputs of the Multi Input LLI to get the data for each input
    228                  for (index = 0; index < MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs; index++)
    229                  {
    230                      // Iterate through all the registered Multi Input LLI handlers
    231                      for (handler_index = 0; handler_index < MULTIINPUT_NUM_REGISTERED_INPUTS; handler_index++)
    232                      {
    233                          // Look for a match on the LLI ID for the individual input of the Multi Input LLI
    234                          if (MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID == MULTIINPUT_LLI_HANDLERS[handler_index].LLI_ID)
    235                          {
    236                              if (MULTIINPUT_LLI_HANDLERS[handler_index].Get != NULL)
    237                              {
    238                                  // Set the data for the individual input of the Multi Input LLI based on the LLI ID
    239                                  // This must be handled this way because the LLI Get() functions return a void pointer and each LLI has a different data size
    240                                  switch (MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID)
    241                                  {
    242                                      case HBL_LLI_DIGITAL:
    243                                          digital_lli_data_ptr = MULTIINPUT_LLI_HANDLERS[handler_index].Get(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index]);
    244                                          MultiInputLLI_Data[input->Data_Index][index] = (uint16)(digital_lli_data_ptr[0]);
    245                                          break;
    246                                      case HBL_LLI_ANALOG:
    247                                          analog_lli_data_ptr = MULTIINPUT_LLI_HANDLERS[handler_index].Get(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index]);
    248                                          MultiInputLLI_Data[input->Data_Index][index] = (uint16)(analog_lli_data_ptr[0]);
    249                                          break;
    250                                      case HBL_LLI_FEEDBACK:
    251                                          feedback_lli_data_ptr = MULTIINPUT_LLI_HANDLERS[handler_index].Get(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index]);
    252                                          MultiInputLLI_Data[input->Data_Index][index] = (uint16)(feedback_lli_data_ptr[0]);
    253                                          break;
    254                                      default:
    255                                          break;
    256                                  }
    257                              }
    258                              break;
    259                          }
    260                      }
    261                  }
    262                  return ((void *)&MultiInputLLI_Data[input->Data_Index]);
    263              }
    264              else
    265              {
    266                  return (NULL);
    267              }
    268          }
    269          
    270          //---------------------------------------------------------------------------------------------------------------------
    271          /**
    272           * @brief   Asynchronous processing of a MultiInput LLI.
    273           * @param   input: data related to the instance of the LLI
    274           * @param   status: see definition of HBL_LLI_STATUS
    275           * @return  PASS if the LLI was successfully processed, else FAIL.
    276           */
    277          BOOL_TYPE MultiInputLLI__AsynchProcess(HBL_LLI_TYPE * input)
    278          {
    279              BOOL_TYPE retval;
    280              uint8 handler_index;
    281              uint8 index;
    282          
    283              retval = FALSE;
    284          
    285              if (input->Data_Index < MultiInputLLI_Allocation)
    286              {
    287                  for (index = 0; index < MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs; index++)
    288                  {
    289                      for (handler_index = 0; handler_index < MULTIINPUT_NUM_REGISTERED_INPUTS; handler_index++)
    290                      {
    291                          if (MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID == MULTIINPUT_LLI_HANDLERS[handler_index].LLI_ID)
    292                          {
    293                              if (MULTIINPUT_LLI_HANDLERS[handler_index].AsynchProcess != NULL)
    294                              {
    295                                  retval |= MULTIINPUT_LLI_HANDLERS[handler_index].AsynchProcess(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index]);
    296                              }
    297                              break;
    298                          }
    299                      }
    300                  }
    301              }
    302          
    303              return (retval);
    304          }
    305          
    306          //---------------------------------------------------------------------------------------------------------------------
    307          /**
    308           * @brief   Peak processing of a MultiInput LLI.
    309           * @param   input: data related to the instance of the LLI
    310           * @param   status: see definition of HBL_LLI_STATUS
    311           * @param   peak_polarity:
    312           * @return  PASS if the LLI was successfully processed, else FAIL.
    313           */
    314          BOOL_TYPE MultiInputLLI__PeakProcess(HBL_LLI_TYPE * input, BOOL_TYPE peak_polarity)
    315          {
    316              BOOL_TYPE retval;
    317              uint8 handler_index;
    318              uint8 index;
    319          
    320              retval = FALSE;
    321          
    322              if (input->Data_Index < MultiInputLLI_Allocation)
    323              {
    324                  for (index = 0; index < MultiInputLLI_Config[input->Data_Index].Num_Of_Inputs; index++)
    325                  {
    326                      for (handler_index = 0; handler_index < MULTIINPUT_NUM_REGISTERED_INPUTS; handler_index++)
    327                      {
    328                          if (MultiInputLLI_Config[input->Data_Index].LLI_Data[index].LLI_ID == MULTIINPUT_LLI_HANDLERS[handler_index].LLI_ID)
    329                          {
    330                              if (MULTIINPUT_LLI_HANDLERS[handler_index].PeakProcess != NULL)
    331                              {
    332                                  retval |= MULTIINPUT_LLI_HANDLERS[handler_index].PeakProcess(&MultiInputLLI_Config[input->Data_Index].LLI_Data[index], peak_polarity);
    333                              }
    334                              break;
    335                          }
    336                      }
    337                  }
    338              }
    339          
    340              return (retval);
    341          }
