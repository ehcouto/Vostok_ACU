    298              	RECEIVED_WRITE_NVDATA_FBK_PASS,
    299              	RECEIVED_WRITE_NVDATA_FBK_FAILED,
    300              	RECEIVED_ERROR,
    301              }API007NVDATA_SERVER_FBK;
