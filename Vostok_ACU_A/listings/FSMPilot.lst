    190          PASS_FAIL_TYPE FSMPilot__Process(HBL_LOAD_TYPE * load)
    191          {
    192              if (load->Pilot_Data_Index < HBL_PILOT_NUM_FSM)
    193              {
    194              	FSMPilot_Data[load->Pilot_Data_Index].Processed = FSMPilot_Data[load->Pilot_Data_Index].Requested;
    195              }
    196              return (PASS);
    197          }
