    277                  //! Buffer required for interactions with SpiMgr module. (Not used by this module.)
    278                  uint8 Rx_Buffer[API010_STREAM_BUFFER_SIZE];
    279              #endif
    280          
    281              //! The selected extraction method actively being used by API010.
