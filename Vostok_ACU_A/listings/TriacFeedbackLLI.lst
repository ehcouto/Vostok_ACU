      1          /**
      2           *  @file       TriacFeedbackLLI.c
      3           *
      4           *  @brief      Module for TriacFeedbackLLI reading - detects a Nominal/Double grid frequency or a Digital level
      5           *
      6           *  @details    This module track an input and decode it as level (Low or High) or frequency (grid frequency or its double).
      7           *
      8           *              In order to detect a frequency two event must be measured without additional spurious event.
      9           *              After this, the module is capable of rejecting an arbitrary number of spurious event.
     10           *
     11           *              The read of the level at the end of this time window is performed via a simple read.
     12           *
     13           *              Macros available to configure the module:
     14           *
     15           *               TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY:
     16           *                  (Default 45) Minimum mains frequency allowed
     17           *
     18           *               TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY:
     19           *                  (Default 65) Maximum mains frequency allowed
     20           *
     21           *
     22           *  @copyright  Copyright 2019 Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     23           */
     24          //---------------------------------------------------------------------------------------------------------------------
     25          //---------------------------------------------------------------------------------------------------------------------
     26          
     27          
     28          //-------------------------------------- Include Files ----------------------------------------------------------------
     29          #include "TriacFeedbackLLI.h"
     30          
     31          #if (HBL_LLI_NUM_TRIACFEEDBACK > 0)
     32          #include "Gpio.h"
     33          #include "Micro.h"
     34          #include "VirtualPin.h"
     35          #include <string.h>
     36          
     37          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     38          
     39          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     40          #define DEFAULT_NUM_SAMPLES                 16
     41          #define MIN_NUM_SAMPLES                     8
     42          #define SAMPLES_NOISE_THRESHOLD             2
     43          
     44          // Minimum frequency allowed
     45          #ifndef TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY
     46              #ifdef SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY
     47                  #define TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY SRTRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY
     48              #else
     49                  #define TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY   45
     50              #endif
     51          #endif
     52          
     53          // Maximum frequency allowed
     54          #ifndef TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY
     55              #ifdef SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY
     56                  #define TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY SRTRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY
     57              #else
     58                  #define TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY   65
     59              #endif
     60          #endif
     61          
     62          #define TIME_MSEC_IN_ONE_SEC                (1000)
     63          
     64          #define MINIMUM_DURATION_ALLOWED            (TIME_MSEC_IN_ONE_SEC / TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY)
     65          #define MAXIMUM_DURATION_ALLOWED            ((TIME_MSEC_IN_ONE_SEC / TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY) + 1)
     66          
     67          #define MINIMUM_HALF_DURATION_ALLOWED       ((TIME_MSEC_IN_ONE_SEC / (2 * TRIACFEEDBACKLLI_ALLOWED_MAX_FREQUENCY)))
     68          #define MAXIMUM_HALF_DURATION_ALLOWED       ((TIME_MSEC_IN_ONE_SEC / (2 * TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY)) + 1)
     69          
     70          #define LAST_FREQUENCY_EVENT_TIMEOUT        ((3 * TIME_MSEC_IN_ONE_SEC) / (2 * TRIACFEEDBACKLLI_ALLOWED_MIN_FREQUENCY))
     71          
     72          typedef struct
     73          {
     74              uint8 N_Read:3;
     75              uint8 Unused_0:5;
     76              uint8 Unused_1:5;
     77              uint8 Pull_Up:1;
     78              uint8 Unused_2:1;
     79              uint8 Inverted:1;
     80          } TRIACFEEDBACKLLI_PARAM_TYPE;
     81          
     82          typedef struct
     83          {
     84              // Buffer of Gpio samples collected
     85              uint16 Pin_Buffer;
     86              // Sampling Sequence counter - updated on each 1ms sample
     87              uint8 Sampling_Counter;
     88              // last Sampling Sequence counter reference of the last Asynch iteration
     89              uint8 Async_Sampling_Reference;
     90              // Frequency detection in progress
     91              BOOL_TYPE Is_Detecting_Frequency;
     92              // Double frequency detection in progress
     93              BOOL_TYPE Is_Detecting_Double_Frequency;
     94              // Sampling Sequence counter reference of the last frequency event detected
     95              uint8 Last_Frequency_Event_Reference;
     96              // Time (in ms) between last two frequency events detected
     97              uint8 Time_Between_Frequency_Events;
     98              // Counter of High / Low pin level event detected: it increments on a new High value event, decrements on a new Low value event
     99              sint8 Level_Counter;
    100              // Counter of valid Frequency event detected: it increments when valid Frequency events have been detected
    101              uint8 Frequency_Counter;
    102              // Counter of Double Frequency event detected: it increments if a valid double frequency event happened
    103              uint8 Double_Frequency_Counter;
    104              // Current Feedback LLI value (0, 1, 2, 3)
    105              TRIAC_FEEDBACK_LLI_OUTPUT_TYPE Value;
    106          } TRIACFEEDBACKLLI_DATA_TYPE;
    107          
    108          static TRIACFEEDBACKLLI_DATA_TYPE TriacFeedbackLLI_Data[HBL_LLI_NUM_TRIACFEEDBACK];
    109          static uint8 TriacFeedbackLLI_Allocation;
    110          
    111          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
    112          static void UpdateLastFrequencyTimingEvents(TRIACFEEDBACKLLI_DATA_TYPE *data_ptr, uint8 new_frequency_reference);
