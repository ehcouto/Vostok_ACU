     32          /**
     33           *  @brief      Determine a filtered value based on an input value.
     34           *  @details    The floating-point equation for an IIR filter is:
     35           *              <pre>
     36           *                  V = (alpha * new_value) + ((1 - alpha) * V)
     37           *                  alpha is in the range (0..1]
     38           *              </pre>
     39           *              The equation can be rewritten as:
     40           *              <pre>
     41           *                  V = (alpha * new_value) + V - (alpha * V)
     42           *                  V = V + (alpha * (new_value - V))
     43           *              </pre>
     44           *
     45           *              This function assumes that alpha is a power of 2 (i.e. 1/2, 1/4, 1/8, etc).
     46           *              Therefore, alpha can be fully described by the power of 2 or the number of bits
     47           *              involved.  Refer to the alpha_bits parameter for details.
     48           *
     49           *              This function uses fixed-point calculations.  To do this without rounding errors,
     50           *              the stored value must have more precision than the value used in the application.
     51           *              The fixed-point equation looks like this:
     52           *              <pre>
     53           *                  V = Stored Value
     54           *                  V = V + (new_value - (V >> alpha_bits))
     55           *
     56           *                  va = Value used by the application
     57           *                  va = Round(V >> alpha_bits)
     58           *              </pre>
     59           *
     60           *  @param      iir_value = A value that stores the current filtered value with additional precision.
     61           *                      The additional precision required depends on the alpha_bits.
     62           *  @param      new_value = An input to the filter system with normal precision.
     63           *  @param      alpha_bits = Exponent of alpha.  alpha = 2 ^ (-alpha_bits).
     64           *
     65           *              Sum of new_value resolution and alpha_bits must not be higher than 16 bits
     66           *
     67           *  @return     Returns the updated filtered value after rounding.
     68           */

   \                                 In section .text, align 2, keep-with-next
     69          ADDR_SIZE_IIRFILTER uint16 IIRFilter(uint16 *iir_value, uint16 new_value, uint8 alpha_bits)
     70          {
     71              *iir_value += new_value - (((*iir_value >> (alpha_bits - 1)) + 1) >> 1);
   \                     IIRFilter: (+1)
   \   00000000   0x8803             LDRH     R3,[R0, #+0]
   \   00000002   0x1E52             SUBS     R2,R2,#+1
   \   00000004   0x1859             ADDS     R1,R3,R1
   \   00000006   0x4113             ASRS     R3,R3,R2
   \   00000008   0x1C5B             ADDS     R3,R3,#+1
   \   0000000A   0x105B             ASRS     R3,R3,#+1
   \   0000000C   0x1AC9             SUBS     R1,R1,R3
   \   0000000E   0x8001             STRH     R1,[R0, #+0]
     72          
     73              return (((*iir_value >> (alpha_bits - 1)) + 1) >> 1);
   \   00000010   0x8800             LDRH     R0,[R0, #+0]
   \   00000012   0x4110             ASRS     R0,R0,R2
   \   00000014   0x1C40             ADDS     R0,R0,#+1
   \   00000016   0x1040             ASRS     R0,R0,#+1
   \   00000018   0xB280             UXTH     R0,R0
   \   0000001A   0x4770             BX       LR               ;; return
     74          }
