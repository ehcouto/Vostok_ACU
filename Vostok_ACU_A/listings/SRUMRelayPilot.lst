    151          //---------------------------------------------------------------------------------------------------------------------
    152          /**
    153           * @brief   Checks if there is free space and reserve a new instance
    154           * @return  index of SRUMRelayPilot instance, HBL_INDEX_INVALID if all HBL_PILOT_NUM_SRUMRELAY are already allocated
    155           */
    156          uint8 SRUMRelayPilot__Allocate(void)
    157          {
    158              uint8 retval = HBL_INDEX_INVALID;
    159          
    160              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    161                  (SRUMRelayPilot_Allocation < HBL_PILOT_NUM_SRUMRELAY))
    162              {
    163                  retval = SRUMRelayPilot_Allocation;
    164                  SRData__UpdateByte((void *)&SRUMRelayPilot_Allocation, (void *)&N_SRUMRelayPilot_Allocation, SRUMRelayPilot_Allocation+1);
    165              }
    166          
    167              return (retval);
    168          
    169          }
    170          
    171          //---------------------------------------------------------------------------------------------------------------------
    172          /**
    173           * @brief      Initializes a new instance of SRUMRelayPilot
    174           * @param      load     pointer to HBL_LOAD_TYPE structure reserved for that instance
    175           * @retval     PASS      if instance initialization succeeded
    176           * @retval     FAIL      if there were errors
    177           */
    178          PASS_FAIL_TYPE  SRUMRelayPilot__InitializeInstance(HBL_LOAD_TYPE *load)
    179          {
    180              PASS_FAIL_TYPE ret_val = FAIL;
    181          
    182              if((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    183                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    184              {
    185                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    186                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    187                  HBL_LOAD_STATUS_TYPE load_value;
    188                  uint8 *pin_ptr = load->Pin_Ptr;
    189                  uint8 hi_lo_bitmap = load->Hi_Low_Activation_Bitmap;
    190                  uint8 pin_value = 0;
    191                  ret_val = PASS;
    192          
    193                  if (SRDATA_OK != SRData__CheckArrayNonBlocking(data_ptr, n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE)))
    194                  {
    195                      ret_val = FAIL;
    196                  }
    197          
    198          
    199                  if (load->Pin_Ptr == NULL)
    200                  {
    201                      ret_val = FAIL;
    202                  }
    203          
    204                  #ifndef SRUMRELAYPILOT_FALLBACK_SF_PARAMS
    205                      if (load->Parameter_Ptr.Data == NULL)
    206                      {
    207                          ret_val = FAIL;
    208                      }
    209                  #endif
    210                  SRData__UpdateByte((void *) &data_ptr->State, (void *) &n_data_ptr->State, SRUMRELAYPILOT_INITALIZE);
    211                  load_value = data_ptr->Status.Load;
    212                  load_value.Load.Status = HBL_LOAD_STATUS_INITIALIZE;
    213                  SRData__UpdateByte(&data_ptr->Status.Load.Byte, &n_data_ptr->Status.Load.Byte, load_value.Byte);
    214                  SRData__UpdateByte(&data_ptr->ZeroCross_Sequence, &n_data_ptr->ZeroCross_Sequence, 0);
    215          
    216                  // Initialize Motor Control
    217                  ret_val &= SRUMRELAYPILOT__CONTROL_INITIALIZE(load);
    218                  // Check Triac pin, Cw Pin, Ccw_Pin, Tap Field pin
    219                  ret_val &= (PASS_FAIL_TYPE) (pin_ptr[0] < VirtualPin__GetNumOf());
    220                  ret_val &= (PASS_FAIL_TYPE) (pin_ptr[1] < VirtualPin__GetNumOf());
    221                  ret_val &= (PASS_FAIL_TYPE) (pin_ptr[2] < VirtualPin__GetNumOf());
    222                  ret_val &= (PASS_FAIL_TYPE) (pin_ptr[3] < VirtualPin__GetNumOf());
    223          
    224                  if (ret_val == PASS)
    225                  {
    226                      VIRTUALPIN_TYPE *virtual_pin_ptr = (void *) &VIRTUALPIN_TABLE[pin_ptr[0]];
    227          
    228                      // Configure Triac
    229                      #if (ZC_HANDLER_TIMING_US > 0) && (ZC_NUM_GPIO_REQUESTS > 0) && (SRUMRELAYPILOT_FORCE_OC == DISABLED)
    230                      SRData__UpdateByte((void *) &data_ptr->Triac_Id, (void *) &n_data_ptr->Triac_Id,
    231                              ZeroCross__RegisterGpioActivity(virtual_pin_ptr->port, virtual_pin_ptr->pin));
    232                          ret_val &= (data_ptr->Triac_Id != ZEROCROSS_ID_INVALID);
    233                      #else
    234                          // Output Compare
    235                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Port, (void *) &n_data_ptr->OC_Timer_Config.Port, virtual_pin_ptr->port);
    236                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Pin, (void *) &n_data_ptr->OC_Timer_Config.Pin, virtual_pin_ptr->pin);
    237                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Polarity, (void *) &n_data_ptr->OC_Timer_Config.Polarity,
    238                              (hi_lo_bitmap & 0x01) ? TIMER_POLARITY_ACTIVE_HIGH : TIMER_POLARITY_ACTIVE_LOW);
    239                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Timer, (void *) &n_data_ptr->OC_Timer_Config.Timer, virtual_pin_ptr->device);
    240                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Channel, (void *) &n_data_ptr->OC_Timer_Config.Channel, virtual_pin_ptr->param0);
    241                          SRData__UpdateByte((void *) &data_ptr->OC_Timer_Config.Mode, (void *) &n_data_ptr->OC_Timer_Config.Mode, TIMER_MODE_DISABLE);
    242                          ret_val = Timer__Config(&data_ptr->OC_Timer_Config);
    243                      #endif
    244          
    245                          // Configure Pins
    246                          UpdatePin(pin_ptr[0], pin_value, hi_lo_bitmap & 0x01);
    247                          UpdatePin(pin_ptr[1], pin_value, (hi_lo_bitmap >> 1) & 0x01);
    248                          UpdatePin(pin_ptr[2], pin_value, (hi_lo_bitmap >> 2) & 0x01);
    249                          UpdatePin(pin_ptr[3], pin_value, (hi_lo_bitmap >> 3) & 0x01);
    250          
    251                          // Check pin configuration
    252                          ret_val &= CheckPin(pin_ptr[0], pin_value, hi_lo_bitmap & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT);
    253                          ret_val &= CheckPin(pin_ptr[1], pin_value, (hi_lo_bitmap >> 1) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT);
    254                          ret_val &= CheckPin(pin_ptr[2], pin_value, (hi_lo_bitmap >> 2) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT);
    255                          ret_val &= CheckPin(pin_ptr[3], pin_value, (hi_lo_bitmap >> 3) & 0x01, SRUMRELAYPILOT_TRIAC_DEBOUNCE_CNT);
    256          
    257                          SRData__UpdateByte((void *) &data_ptr->State, (void *) &n_data_ptr->State, SRUMRELAYPILOT_IDLE);
    258                  }
    259                  else
    260                  {
    261                      load_value = data_ptr->Status.Load;
    262                      load_value.Load.Status = HBL_LOAD_STATUS_FAILURE;
    263                      SRData__UpdateByte((void *) &data_ptr->Status.Load.Byte, (void *) &n_data_ptr->Status.Load.Byte, load_value.Byte);
    264                  }
    265              }
    266          
    267              return(ret_val);
    268          }
