    801          //----------------------------------------------------------------------------------------------------------------------
    802          /**
    803           * Convert the server-side function id to a index of server function ID configuration table.
    804           * @param server_function_id = The server-side function id that identifies the remote function.
    805           * @return Index of server function ID configuration table
    806           */
    807          static uint8 ConvertServerFunctionIdToIndex(uint8 server_function_id)
    808          {
    809              uint8 ret_value = (uint8)API013_NUM_OF_SERVER_FUNCTIONS;
    810          
    811              for (uint8 index = 0; index < API013_NUM_OF_SERVER_FUNCTIONS; index++)
    812              {
    813                  if ((API013_SERVER_FUNCTION_ID_TYPE)API013_SERVER_FUNCTIONS[index].Server_Function_Id == (API013_SERVER_FUNCTION_ID_TYPE)server_function_id)
    814                  {
    815                      ret_value = index;
    816                  }
    817              }
    818              return ret_value;
    819          }
    820          //---------------------------------------------------------------------------------------------------------------------
    821          /**
    822           * Send a feedback message with all the data from all the remote functions active on this server.
    823           */
    824          static void PublishAllRemoteFunctionData(void)
    825          {
    826              REMOTE_FUNCTION_DATA_TYPE data_elements[API013_MAX_PUBLISHED_DATA];
    827          
    828              // Determine the size of the payload required for all the data elements.
    829              ACTIVE_TYPE active = INACTIVE;
    830              uint8 total = 0;
    831              for (uint8 index = 0; index < API013_NUM_OF_SERVER_FUNCTIONS; index++)
    832              {
    833                  if (Utilities__GetBitInArray(Api013.Functions_Active, index) == (uint8)ACTIVE)
    834                  {
    835                      active = ACTIVE;
    836                      total += RemoteFunctionGetData(index, &data_elements[total]);
    837                  }
    838                  else if (active != INACTIVE)
    839                  {
    840                      // Support sequentially linked remote function indices where additional remote functions only provide additional data.
    841                      if ((API013_SERVER_FUNCTIONS[index].Background_Function == REMOTE_FUNCTION_BACKGROUND_NULL) &&
    842                          (API013_SERVER_FUNCTIONS[index].Do_Control_Function == REMOTE_FUNCTION_DO_CONTROL_NULL) &&
    843                          (API013_SERVER_FUNCTIONS[index].Get_Status_Function == REMOTE_FUNCTION_GET_STATUS_NULL))
    844                      {
    845                          total += RemoteFunctionGetData(index, &data_elements[total]);
    846                      }
    847                      else
    848                      {
    849                          active = INACTIVE;
    850                      }
    851                  }
    852              }
    853          
    854              if ((0U < total) && (total <= API013_MAX_DATA_CHANNELS_PER_FUNCTION))
    855              {
    856                  (void)PublishPreparedData(data_elements, total);
    857              }
    858          }
    859          
    860          
    861          //---------------------------------------------------------------------------------------------------------------------
    862          /**
    863           * Publish a set of data elements to Reveal.
    864           * @param data_elements = The data that must be published.
    865           * @param count = The number of data elements in the 'data_elements' array.
    866           */
    867          static BOOL_TYPE PublishPreparedData(REMOTE_FUNCTION_DATA_TYPE* data_elements, uint8 count)
    868          {
    869              BOOL_TYPE ret_value = FALSE;
    870          
    871              // Get a pointer to the feedback message.
    872              uint8 payload_size = (uint8)(count * sizeof(REMOTE_FUNCTION_DATA_TYPE));
    873          
    874              REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API013RMTFCN_NUM, (uint8)API013_FBK_PUBLISH_FUNCTION_DATA, Api013.Data_Receiver_Node, payload_size);
    875              if (msg != NULL)
    876              {
    877                  ret_value = (BOOL_TYPE)(((PASS == Reveal__AddDataU8Buffer(msg, (uint8*)data_elements, payload_size)) &&
    878                                           (FALSE != Reveal__QueueCommand(msg))));
    879              }
    880              return ret_value;
    881          }
    882          
    883          
    884          //---------------------------------------------------------------------------------------------------------------------
    885          /**
    886           * Publish the status of a specified remote function.
    887           * @param server_function_id = The server-side function ID that identifies the remote function.
    888           * @param status = Pointer to the function status data.
    889           * @param size = Number of bytes in the function status data.
    890           * @return TRUE if the message was sent; otherwise FALSE.
    891           */
    892          static BOOL_TYPE PublishRemoteFunctionStatus(uint8 destination, uint8 server_function_id, uint8* status, uint8 size)
    893          {
    894              uint8 index;
    895              BOOL_TYPE ret_value = FALSE;
    896              index = ConvertServerFunctionIdToIndex(server_function_id);
    897              if (API013_NUM_OF_SERVER_FUNCTIONS > index)
    898              {
    899                  REVEAL_COMMAND_TYPE* msg = Reveal__NewFeedback(API013RMTFCN_NUM, (uint8)API013_FBK_PUBLISH_FUNCTION_STATUS, destination, (uint8)(size + 2U));
    900                  ret_value = (BOOL_TYPE)(((PASS  == Reveal__AddDataU8(msg, (uint8)API013_SERVER_FUNCTIONS[index].Server_Function_Id)) &&
    901                                                    (PASS  == Reveal__AddDataU8(msg, Utilities__GetBitInArray(Api013.Functions_Active, index))) &&
    902                                                    (PASS  == Reveal__AddDataU8Buffer(msg, status, size)) &&
    903                                                    (FALSE != Reveal__QueueCommand(msg))));
    904              }
    905          
    906              return ret_value;
    907          }
    908          
