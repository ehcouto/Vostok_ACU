    194          /**
    195           *  @brief      Provides current SRTriacFeedbackLLI value
    196           * @param   input     pointer to HBL_LLI_TYPE structure reserved for that instance
    197           * @return  Pointer to LLI Data structure (Public_Data.Output) or NULL if input points to an invalid item
    198           */
    199          void * SRTriacFeedbackLLI__Get(HBL_LLI_TYPE * input)
    200          {
    201              void *dataptr = NULL;
    202          
    203              (void)SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    204              if (input->Data_Index < SRTriacFeedbackLLI_Allocation)
    205              {
    206                  (void) SRData__CheckByte((void *) &SRTriacFeedbackLLI_Data[input->Data_Index].Value, (void *) &N_SRTriacFeedbackLLI_Data[input->Data_Index].Value);
    207                  dataptr = &SRTriacFeedbackLLI_Data[input->Data_Index].Value;
    208              }
    209              return(dataptr);
    210          }
