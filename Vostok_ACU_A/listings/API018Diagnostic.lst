     65          // -- Private Enumerated Constant Declarations --
     66          
     67          //! All the API018 command and feedback OpCodes.
     68          typedef enum API018DIAGNOSTIC_OPCODE_ENUM
     69          {
     70              API018_CMD_REQUEST_STATISITCS_VERSION   = 1,    //!< Request the Statistics version numbers.
     71              API018_FBK_PUBLISH_STATISTICS_VERSION   = 1,    //!< Publish the Statistics version numbers.
     72              API018_CMD_GENERATE_FAULT               = 2,    //!< Generate a fault.
     73              API018_CMD_CLEAR_SAVED_FAULTS           = 3,    //!< Clear all fault information.
     74              API018_CMD_REMOVE_FAULT                 = 4,    //!< Remove an active fault.
     75              API018_CMD_REQUEST_FAULT_CODES          = 5,    //!< Request fault codes for all recorded faults.
     76              API018_FBK_PUBLISH_FAULT_CODES          = 5,    //!< Publish fault codes for all recorded faults.
     77              API018_CMD_REQUEST_STATISTICS           = 6,    //!< Request statistics data.
     78              API018_FBK_PUBLISH_STATISTICS           = 6,    //!< Publish statistics data.
     79              API018_CMD_REQUEST_COMMON_LIFETIME_DATA = 7,    //!< Request cycle data.
     80              API018_FBK_PUBLISH_COMMON_LIFETIME_DATA = 7,    //!< Publish cycle data.
     81          
     82              API018_CMD_REQUEST_DIAGNOSTIC_CONFIG    = 30,   //!< Request diagnostic configuration information.
     83              API018_FBK_PUBLISH_DIAGNOSTIC_CONFIG    = 30    //!< Publish diagnostic configuration information.
     84          } API018DIAGNOSTIC_OPCODE_TYPE;
     85          
     86          //! Enumerated list of the sections of the Statistics data.
     87          //! The order of these sections must match the order of the sections in the Statistics structure.
     88          typedef enum API018_SECTION_ENUM
     89          {
     90              API018_INACTIVE                     = 0,
     91              API018_SECTION_HEADER               = 0,
     92          
     93              API018_SECTION_FIRST                = 1,
     94          
     95              API018_SECTION_LIFETIME             = 1,
     96              API018_SECTION_CYCLES               = 2,
     97              API018_SECTION_FAULTS               = 3,
     98              API018_SECTION_PRE_FAULTS           = 4,
     99              API018_SECTION_LAST_CYCLES          = 5,
    100              API018_SECTION_FAULTS_BLACK_BOX     = 6,
    101              API018_SECTION_PRE_FAULTS_BLACK_BOX = 7,
    102          
    103              API018_SECTION_LAST                 = 7,
    104          
    105              API018_SECTION_NONE_REMAINING       = 0x20,
    106          
    107              API018_SECTION_ALL                  = 0x40,     //!< Request for all statistics sections.
    108          } API018_SECTION_TYPE;
