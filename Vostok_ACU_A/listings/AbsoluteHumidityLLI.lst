    738          //----------------------------------------------------------------------------------------------
    739          /**
    740           *  @brief      It filter the duty value and return filtered PWM value.
    741           *
    742                  Humidity signal filter. Filters 14-bit signal from PWM Data Buffer.
    743          
    744                  1:st degree butterworth lowpass canonical IIR-filter,
    745                  with Fc = 0.1*Fn.  (Fc= Frequency cutoff, Fn = nyquist)
    746          
    747                  Filter parameters:
    748                  a1=1
    749                  a2=-0.7265
    750                  b1=0.1367
    751                  b2=0.1367
    752          
    753                  a2-b2 normalized to (1(decimal)=256) gives: -a2=186
    754                                                              b1=b2=35.
    755          
    756                  All calculations is 32-bit. No truncation except for last division with 256.
    757          
    758                  Canonical structure:
    759          
    760                  x(n) >--------------------------
    761                                  | b2            | b1
    762                                  |      _        |
    763                                  + --->|T| ----> + --------------> y(n)
    764                                  |      -             |
    765                                  | -a2                |
    766                                  <--------------------
    767          
    768                  y(n) = b1*x(n) + b2*x(n-1) - a2*y(n-1)
    769           */
    770          static uint16 AbsoluteHumidityFilter(uint16 sample)
    771          {
    772              uint32 newSample, tempValue;
    773          
    774              // Conver duty (0~10000) to 14 bit pwm (0~16383)
    775              tempValue = (uint32)sample*(uint32)16383;
    776              tempValue /= 10000;
    777              sample = (uint16)tempValue;
    778          
    779              // Calculate new filter output value
    780              newSample = (uint32)sample*(uint32)ABSOLUTE_HUMIDITY_FILTER_B1;    // newSample = 256*b1*x(n)
    781              tempValue = newSample;
    782              newSample += (uint32)(Absolute_Humidity_LLI_Data[LLI_Index].Filter_Delay); // newSample += 256*b2*x(n-1) + 256*(-a2)*y(n-1) => 256y(n)
    783          
    784              // calculate new filter delay tap value
    785              Absolute_Humidity_LLI_Data[LLI_Index].Filter_Delay = tempValue; // Filter_Delay = 256*b2*x(n)
    786              Absolute_Humidity_LLI_Data[LLI_Index].Filter_Delay += ((((uint32)(newSample))*(uint32)ABSOLUTE_HUMIDITY_FILTER_A2_MINUS) >> 8); // Filter_Delay += 256*(-a2) * 256*y(n) / 256 => 256*b2*x(n) + 256*(-a2)*y(n)
    787          
    788              // Return new filtered value
    789              return((uint16)(newSample >>= 8)); // newSample/256 => y(n)
    790          }
