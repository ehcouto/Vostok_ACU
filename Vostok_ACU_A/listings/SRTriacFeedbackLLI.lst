    133          //---------------------------------------------------------------------------------------------------------------------
    134          /**
    135           * @brief   Checks if there is free space and reserve a new instance
    136           * @return  index of SRTriacFeedbackLLI instance, 0xFF if all HBL_LLI_NUM_SRTRIACFEEDBACK are already allocated
    137           */
    138          uint8 SRTriacFeedbackLLI__Allocate(void)
    139          {
    140              uint8 retval = HBL_ALLOCATION_INVALID;
    141          
    142              (void) SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    143              if(SRTriacFeedbackLLI_Allocation < (uint8) HBL_LLI_NUM_SRTRIACFEEDBACK)
    144              {
    145                  retval = SRTriacFeedbackLLI_Allocation;
    146                  SRData__UpdateByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation, SRTriacFeedbackLLI_Allocation + 1U);
    147              }
    148              return (retval);
    149          }
    150          
    151          //---------------------------------------------------------------------------------------------------------------------
    152          /**
    153           * @brief      Initializes a new instance of SRTriacFeedbackLLI
    154           * @param   input     pointer to HBL_LLI_TYPE structure reserved for that instance
    155           * @return  PASS if initialize succeed, FAIL if there were any error
    156           */
    157          PASS_FAIL_TYPE SRTriacFeedbackLLI__InitializeInstance(HBL_LLI_TYPE * input)
    158          {
    159              PASS_FAIL_TYPE ret_status = FAIL;
    160          
    161              (void) SRData__CheckByte(&SRTriacFeedbackLLI_Allocation, &N_SRTriacFeedbackLLI_Allocation);
    162          
    163              if(input->Data_Index < SRTriacFeedbackLLI_Allocation)
    164              {
    165                  SRTRIACFEEDBACKLLI_DATA_TYPE *data = &SRTriacFeedbackLLI_Data[input->Data_Index];
    166                  SRTRIACFEEDBACKLLI_DATA_TYPE *n_data = &N_SRTriacFeedbackLLI_Data[input->Data_Index];
    167                  SRTRIACFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *)input->Parameter_Ptr.Data;
    168                  GPIO_PIN_MODE_TYPE type = INPUT_FLOAT;
    169                  uint8 virtual_pin = input->Pin_Ptr[0];
    170          
    171                  (void) SRData__CheckArray(data, n_data, sizeof(SRTRIACFEEDBACKLLI_DATA_TYPE));
    172          
    173                  if((feedback_param != NULL) &&
    174                      ((uint8) feedback_param->Pull_Up != 0U))
    175                  {
    176                      type = INPUT_PULLUP;
    177                  }
    178          
    179                  if(virtual_pin < VirtualPin__GetNumOf())
    180                  {
    181                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, type);
    182                      SRData__UpdateByte((void *) &data->Value,(void *) &n_data->Value, SRTRIAC_UNKNOWN_UNKNOWN_VALUE);
    183                      if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, type, FALSE))
    184                      {
    185                          ret_status = PASS;
    186                      }
    187                  }
    188              }
    189          
    190              return(ret_status);
    191          }
