     22                  SetupEepromRead --> ReadEeprom : evProceed
     23                  SetupEepromRead -> [*] : evFail
     24          
     25                  ReadEeprom : entry / StartTimer()\n\t RequestEepromRead()
     26                  ReadEeprom : do / DoEepromRead()
     27                  ReadEeprom --> ReadEeprom : evReadNextSection
     28                  ReadEeprom --> SetupEepromRead : evFail
     29                  ReadEeprom --> SetupTrimValueWrite : evReadComplete
     30          
     31                  SetupTrimValueWrite : do / ConfigureI2CForRam()
     32                  SetupTrimValueWrite --> WriteTrimValue : evProceed
     33                  SetupTrimValueWrite --> SetupTrimValueWrite : evFail
     34          
     35                  WriteTrimValue : entry / StartTimer()\n\t WriteOscillatorTrim()
     36                  WriteTrimValue : do / WaitForI2cIdle()
     37                  WriteTrimValue --> ReadTrimValue : evWriteComplete
     38                  WriteTrimValue --> SetupTrimValueWrite : evFail
     39          
     40                  ReadTrimValue : entry / StartTimer()\n\t RequestOscTrimRead()
     41                  ReadTrimValue : do / DoOscTrimRead()
     42                  ReadTrimValue --> SetupConfigValueWrite : evReadComplete
     43                  ReadTrimValue --> SetupTrimValueWrite : evFail
     44          
     45                  SetupConfigValueWrite : do / ConfigureI2CForRam()
     46                  SetupConfigValueWrite --> WriteConfigValue : evProceed
     47                  SetupConfigValueWrite --> SetupConfigValueWrite : evFail
     48          
     49                  WriteConfigValue : entry / StartTimer()\n\t WriteConfiguration()
     50                  WriteConfigValue : do / WaitForI2cIdle()
     51                  WriteConfigValue --> ReadConfigValue : evWriteComplete
     52                  WriteConfigValue --> SetupConfigValueWrite : evFail
     53          
     54                  ReadConfigValue : entry / StartTimer()\n\t RequestStatusRead()
     55                  ReadConfigValue : do / DoConfigRead()
     56                  ReadConfigValue --> WaitForNextStep : evReadComplete
     57                  ReadConfigValue --> SetupConfigValueWrite : evFail
     58          
     59                  WaitForNextStep : do / WaitForNextStep()
     60                  WaitForNextStep --> StartStep : evStart
     61          
     62                  StartStep : entry / StartAcquisition()
     63                  StartStep : do / WaitForI2cIdle()
     64                  StartStep --> ReadStatus : evWriteComplete
     65                  StartStep --> SetupTrimValueWrite : evFail
     66          
