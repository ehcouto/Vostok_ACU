     93          static SRDOORLOCKWAXPILOT_DATA_TYPE SRDoorLockWaxPilot_Data[HBL_PILOT_NUM_SRDOORLOCKWAX];
     94          
     95          static uint8 N_SRDoorLockWaxPilot_Allocation;
     96          static SRDOORLOCKWAXPILOT_DATA_TYPE N_SRDoorLockWaxPilot_Data[HBL_PILOT_NUM_SRDOORLOCKWAX];
