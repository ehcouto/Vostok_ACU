    817          //---------------------------------------------------------------------------------------------------------------------
    818          /**
    819           * @brief       Get all the digital inputs. It parses the command from Reveal, builds up the
    820           *              buffer and sends it back to the communication buffer.
    821           * @param       buffer a point to the incoming Reveal buffer
    822           * @return      TRUE: The variable was successfully changed.
    823           *              FALSE: The variable could not be changed.
    824           */
    825          uint8 Get_Error(REVEAL_MSG_TYPE *buffer)
    826          {
    827              uint8 ret_val;
    828              MOTOR_ENUM_TYPE motor_index;
    829              uint8 param_value;
    830          
    831              ret_val = FALSE;                                // By default, the feedback is always false.
    832          
    833              if(buffer->sdu_length == 4)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
    834              {
    835                  // Recover the data from the Reveal buffer
    836                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
    837                  param_value = (uint8)buffer->payload[1];
    838          
    839                  // Check the sanity of the motor index
    840                  if(motor_index < API220_NR_OF_CONNECTED_MOTORS  &&  param_value == 0)
    841                  {
    842                      // Invoke the publishing method with the required feedback
    843                      Publish_Error(motor_index, Mci_Digital_Error[motor_index]);
    844          
    845                      ret_val = TRUE;                         // Command is accepted
    846                  }else if(motor_index < API220_NR_OF_CONNECTED_MOTORS  &&  param_value == 255)
    847                  {
    848                  	// Clear error holder
    849                  	 Mci__ClearError(motor_index);
    850                      // Update the error
    851                  	 Mci_Digital_Error[motor_index] = Mci__GetErrorList(motor_index);
    852                  	 // Invoke the publishing method with the required feedback
    853                  	 Publish_Error(motor_index, Mci_Digital_Error[motor_index]);
    854                  	 ret_val = TRUE;                         // Command is accepted
    855                  }
    856              }
    857          
    858              return(ret_val);
    859          }
    860          #endif
