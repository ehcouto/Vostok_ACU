     48          /**
     49           * @brief -     Allocates the Non maskable interrupt table for RX210 micro
     50           * @details -   This table is allocated at the 0xFFFFFF80 location
     51           *              __root forces to populate the table in the output file
     52           */
     53          #pragma location = "Non_Maskable_Jump_interrupt_table"

   \                                 In section Non_Maskable_Jump_interrupt_table, align 4, root
     54          __root const intvec_elem NON_MASKABLE_JUMP_INTERRUPT_TABLE[] =
   \                     NON_MASKABLE_JUMP_INTERRUPT_TABLE:
   \   00000000   0x........         DC32 SFE(CSTACK), MicroJumptoResetHandler
   \              0x........   
     55          {
     56          { .__ptr = __sfe( "CSTACK" ) },
     57              MicroJumptoResetHandler,                    //1 Initial Program Counter
     58          };
     59          
     60          
     61          
     62          #pragma optimize=low

   \                                 In section .text, align 4, keep-with-next, root
     63          __root static void MicroJumptoResetHandler(void)
     64          {
   \                     MicroJumptoResetHandler: (+1)
   \   00000000   0xB580             PUSH     {R7,LR}
     65              ((intfunc)*(((uint32 *)&__ICFEDIT_INTERRUPT_TABLE_start__ + RESET_HANDLER_INDEX)))();
   \   00000002   0x4802             LDR      R0,??MicroJumptoResetHandler_0
   \   00000004   0x6840             LDR      R0,[R0, #+4]
   \   00000006   0x4780             BLX      R0
     66          }
   \   00000008   0xBD01             POP      {R0,PC}          ;; return
   \   0000000A   0xBF00             Nop      
   \                     ??MicroJumptoResetHandler_0:
   \   0000000C   0x........         DC32     __ICFEDIT_INTERRUPT_TABLE_start__
     67          
     68          #endif
