     71          //=====================================================================================================================
     72          //  --- Public Functions ----------------------------------------------------------------------------------------------
     73          //=====================================================================================================================
     74          
     75          
     76          //---------------------------------------------------------------------------------------------------------------------
     77          /**
     78           * Initialize all instances of this Pilot type.
     79           *  - Initialize static RAM used by the module.
     80           *  - Initialize any corrupted NVData used by the module.
     81           */
     82          void SRDigitalOutputPilot__Initialize(void)
     83          {
     84              SR_FILL(Digital_Output, 0, sizeof(Digital_Output));
     85          
     86              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
     87                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRDIGITALOUTPUT_PILOT);
     88              #endif
     89          }
     90          
     91          
     92          //---------------------------------------------------------------------------------------------------------------------
     93          /**
     94           * Reserve memory for this pilot instance.
     95           * @return The index of the allocated Pilot.
     96           *         Return 0xFF if there is no space allocated for another Pilot of this type.
     97           */
     98          uint8 SRDigitalOutputPilot__Allocate(void)
     99          {
    100              uint8 pilot_index = 0xFF;
    101              SR_CHECK_BYTE(Digital_Output.Allocation);
    102              if (Digital_Output.Allocation < HBL_PILOT_NUM_SRDIGITALOUTPUT)
    103              {
    104                  pilot_index = Digital_Output.Allocation;
    105                  SR_SET_BYTE(Digital_Output.Allocation, Digital_Output.Allocation + 1);
    106              }
    107              return pilot_index;
    108          }
    109          
    110          
    111          //---------------------------------------------------------------------------------------------------------------------
    112          /**
    113           * Initialize this pilot instance.
    114           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    115           * @return PASS if the Pilot instance is successfully initialized; otherwise FAIL.
    116           */
    117          PASS_FAIL_TYPE SRDigitalOutputPilot__InitializeInstance(HBL_LOAD_TYPE* load)
    118          {
    119              PASS_FAIL_TYPE result = FAIL;
    120              if (load != NULL)
    121              {
    122                  SR_CHECK_BYTE(Digital_Output.Allocation);
    123                  uint8 virtual_pin = load->Pin_Ptr[0];
    124                  if ((load->Pilot_Data_Index < Digital_Output.Allocation) &&
    125                      (virtual_pin < VirtualPin__GetNumOf()) &&
    126                      (VIRTUALPIN_TABLE[virtual_pin].port != PORT_NULL))
    127                  {
    128                      const VIRTUALPIN_TYPE* vp = &VIRTUALPIN_TABLE[virtual_pin];
    129                      GPIO_PORT_TYPE port = vp->port;
    130                      uint8 pin = vp->pin;
    131                      if (Gpio__Validate(port, pin) == PASS)
    132                      {
    133                          DoPinUpdate(load, port, pin);
    134                          Gpio__PinConfig(port, pin, vp->pin_config);
    135                          result = PASS;
    136                      }
    137                  }
    138              }
    139              return result;
    140          }
    141          
    142          
    143          //---------------------------------------------------------------------------------------------------------------------
    144          /**
    145           * Verify that the RAM used by this module is not corrupted.
    146           * Report a sequence step to SRTaskSequence.
    147           */
    148          void SRDigitalOutputPilot__CheckDataIntegrity(void)
    149          {
    150              SR_CHECK_BYTE(Digital_Output.Allocation);
    151              SR_CHECK_ARRAY(Digital_Output.Data);
    152          
    153              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    154                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRDIGITALOUTPUTPILOT_CHECKS);
    155              #endif
    156          }
    157          
    158          
    159          //---------------------------------------------------------------------------------------------------------------------
    160          /**
    161           * Update the requested state of the output controlled by this pilot instance.
    162           * This function must not set the output.
    163           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    164           * @param data = A pointer to memory that contains the new requested pilot state.
    165           * @return PASS if the requested pilot state is successfully saved; otherwise FAIL.
    166           */
    167          PASS_FAIL_TYPE SRDigitalOutputPilot__Request(HBL_LOAD_TYPE* load, void* data)
    168          {
    169              PASS_FAIL_TYPE result = FAIL;
    170              if (load != NULL)
    171              {
    172                  uint8 pilot_index = load->Pilot_Data_Index;
    173                  SR_CHECK_BYTE(Digital_Output.Allocation);
    174                  if (pilot_index < Digital_Output.Allocation)
    175                  {
    176                      SR_SET_BYTE(Digital_Output.Data[pilot_index].Requested, *((uint8*)data));
    177                      result = PASS;
    178                  }
    179              }
    180              return result;
    181          }
    182          
    183          
    184          //---------------------------------------------------------------------------------------------------------------------
    185          /**
    186           * Update the output controlled by this pilot instance based on previous requests.
    187           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    188           * @return PASS if the controlled output is successfully updated; otherwise FAIL.
    189           */
    190          PASS_FAIL_TYPE SRDigitalOutputPilot__Process(HBL_LOAD_TYPE* load)
    191          {
    192              PASS_FAIL_TYPE result = FAIL;
    193              if (load != NULL)
    194              {
    195                  uint8 pilot_index = load->Pilot_Data_Index;
    196                  SR_CHECK_BYTE(Digital_Output.Allocation);
    197                  if (pilot_index < Digital_Output.Allocation)
    198                  {
    199                      SR_CHECK_BYTE(Digital_Output.Data[pilot_index].Requested);
    200                      SR_SET_BYTE(Digital_Output.Data[pilot_index].Processed, Digital_Output.Data[pilot_index].Requested);
    201                      result = PASS;
    202                  }
    203              }
    204              return result;
    205          }
    206          
    207          
    208          //---------------------------------------------------------------------------------------------------------------------
    209          /**
    210           * Get the requested state of the output controlled by this pilot instance.
    211           * This function does not necessarily return the current state of the output.
    212           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    213           * @return A pointer to data that describes the requested state of the output.
    214           */
    215          void* SRDigitalOutputPilot__GetRequested(HBL_LOAD_TYPE* load)
    216          {
    217              void* requested = NULL;
    218              if (load != NULL)
    219              {
    220                  uint8 pilot_index = load->Pilot_Data_Index;
    221                  SR_CHECK_BYTE(Digital_Output.Allocation);
    222                  if (pilot_index < Digital_Output.Allocation)
    223                  {
    224                      SR_CHECK_BYTE(Digital_Output.Data[pilot_index].Requested);
    225                      requested = &Digital_Output.Data[pilot_index].Requested;
    226                  }
    227              }
    228              return requested;
    229          }
    230          
    231          
    232          //---------------------------------------------------------------------------------------------------------------------
    233          /**
    234           * Get the state of the output controlled by this pilot instance.
    235           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    236           * @return A pointer to data that describes the state of the output.
    237           */
    238          void* SRDigitalOutputPilot__GetProcessed(HBL_LOAD_TYPE* load)
    239          {
    240              void* processed = NULL;
    241              if (load != NULL)
    242              {
    243                  uint8 pilot_index = load->Pilot_Data_Index;
    244                  SR_CHECK_BYTE(Digital_Output.Allocation);
    245                  if (pilot_index < Digital_Output.Allocation)
    246                  {
    247                      SR_CHECK_BYTE(Digital_Output.Data[pilot_index].Processed);
    248                      processed = &Digital_Output.Data[pilot_index].Processed;
    249                  }
    250              }
    251              return processed;
    252          }
    253          
    254          
    255          //------------------------------------------------------------------------------------------------
    256          /**
    257           * Handle behaviors that must be implemented periodically by this pilot instance.
    258           * This function is called every 5ms.
    259           * @param load = A pointer to the HBL_LOAD_TYPE structure with load and pilot instance information.
    260           * @return PASS or FAIL.
    261           */
    262          PASS_FAIL_TYPE SRDigitalOutputPilot__AsynchProcess(HBL_LOAD_TYPE* load)
    263          {
    264              PASS_FAIL_TYPE result = FAIL;
    265              if (load != NULL)
    266              {
    267                  uint8 pilot_index = load->Pilot_Data_Index;
    268                  SR_CHECK_BYTE(Digital_Output.Allocation);
    269                  if (pilot_index < Digital_Output.Allocation)
    270                  {
    271                      // Determine the port/pin information.
    272                      uint8 virtual_pin = load->Pin_Ptr[0];
    273                      const VIRTUALPIN_TYPE* vp = &VIRTUALPIN_TABLE[virtual_pin];
    274                      GPIO_PORT_TYPE port = vp->port;
    275                      uint8 pin = vp->pin;
    276          
    277                      // Check the current configuration of the pin.
    278                      SR_CHECK_BYTE(Digital_Output.Data[pilot_index].Last_Pin_Value);
    279                      if (Gpio__CheckConfig(port, pin, vp->pin_config,
    280                                            (BOOL_TYPE)(Digital_Output.Data[pilot_index].Last_Pin_Value)) == TRUE)
    281                      {
    282                          DoPinUpdate(load, port, pin);
    283                          result = PASS;
    284                      }
    285                      else
    286                      {
    287                          SRException__Queue(SREXCEPTION_GPIO_CONFIGURATION_CORRUPTION, load->Load_Id, vp->pin_config);
    288                      }
    289                  }
    290              }
    291              return result;
    292          }
