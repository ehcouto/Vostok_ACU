    601          /**
    602           * @brief   Monitor unbalanced after entering regulating state for 2s, if PWM is out of range or PWM continue
    603           *          increasing or decreasing by 10, trigger balancing event; Otherwise, trigger balanced event.
    604           *
    605           */
    606          static void MonitorUnbalanced(void)
    607          {
    608              Absolute_Humidity_LLI_Data[LLI_Index].Delay_Counter++;
    609               if(Absolute_Humidity_LLI_Data[LLI_Index].Delay_Counter > ABSOLUTE_HUMIDITY_REGULATING_DELAY)
    610               {
    611                   if((AbsoluteHumidityPWMGetDuty() < ABSOLUTE_HUMIDITY_PWM_LOW_DUTY) || (AbsoluteHumidityPWMGetDuty() > ABSOLUTE_HUMIDITY_PWM_HI_DUTY))
    612                   {
    613                       if(Absolute_Humidity_LLI_Data[LLI_Index].Error_Counter >= ABSOLUTE_HUMIDITY_ERROR_DELAY)
    614                       {
    615                           Absolute_Humidity_LLI_Data[LLI_Index].Error_Counter = ABSOLUTE_HUMIDITY_ERROR_DELAY;
    616                           if(Absolute_Humidity_LLI_Data[LLI_Index].Error_Status == FALSE)
    617                           {
    618                               Absolute_Humidity_LLI_Data[LLI_Index].Error_Status = TRUE;
    619                               LOG_ADD_EXCEPTION(HUMIDITY_SENSOR_ERROR_PRESENT_IN_UNBALANCED, LLI_Index);
    620                           }
    621                       }
    622                       else
    623                       {
    624                           Absolute_Humidity_LLI_Data[LLI_Index].Error_Counter++;
    625                       }
    626                   }
    627                   else
    628                   {
    629                       if(Absolute_Humidity_LLI_Data[LLI_Index].Error_Status == TRUE)
    630                       {
    631                           Absolute_Humidity_LLI_Data[LLI_Index].Error_Status = FALSE;
    632                           LOG_ADD_EXCEPTION(HUMIDITY_SENSOR_ERROR_CANCEL, LLI_Index);
    633                       }
    634                       Absolute_Humidity_LLI_Data[LLI_Index].Error_Counter = 0;
    635                   }
    636          
    637                   if(((Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter < -10) || (Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter > 10)) || (Absolute_Humidity_LLI_Data[LLI_Index].Error_Status == TRUE))
    638                   {
    639                       EventBalancing();
    640                   }
    641                   else
    642                   {
    643                       EventBalanced();
    644                   }
    645               }
    646          }
