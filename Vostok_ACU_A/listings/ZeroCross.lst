   1714          /**
   1715           * @brief  Initialize the GPIO request service
   1716           *
   1717           */
   1718          static void GpioRequestInitialize(void)
   1719          {
   1720              for(uint8 gpio_index = 0U; gpio_index < ((uint8) ZEROCROSS_GPIO_REQUEST_NUMBER); gpio_index++)
   1721              {
   1722                  ZeroCross_Gpio_Pin_Configuration[gpio_index].Gpio_Id = ZEROCROSS_ID_INVALID;
   1723                  ZeroCross_Gpio_Pin_Configuration[gpio_index].Port = PORT_NULL;
   1724                  ZeroCross_Gpio_Pin_Configuration[gpio_index].Pin = 0U;
   1725          
   1726                  ZeroCross_Gpio_Requests[gpio_index].Gpio_Id = ZEROCROSS_ID_INVALID;
   1727                  ZeroCross_Gpio_Requests[gpio_index].Active_Degree = 0U;
   1728                  ZeroCross_Gpio_Requests[gpio_index].Deactive_Degree = 0U;
   1729                  ZeroCross_Gpio_Requests[gpio_index].Active_value = FALSE;
   1730          
   1731                  ZeroCross_Gpio_Processing[gpio_index].Gpio_Id = ZEROCROSS_ID_INVALID;
   1732                  ZeroCross_Gpio_Processing[gpio_index].Active_Degree = 0U;
   1733                  ZeroCross_Gpio_Processing[gpio_index].Deactive_Degree = 0U;
   1734                  ZeroCross_Gpio_Processing[gpio_index].Active_value = FALSE;
   1735              }
   1736          }
