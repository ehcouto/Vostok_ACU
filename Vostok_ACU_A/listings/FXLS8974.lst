   1041          
   1042          //---------------------------------------------------------------------------------------------------------------------
   1043          /**
   1044           *  State machine function to configure the SLF_TEST_CONFIG_2 register. All other register settings are handled
   1045           *  in the ACCEL_CMD_SELF_TEST_ENABLE table.
   1046           */
   1047          static void ConfigSelfTest(void)
   1048          {
   1049              uint8 command[3];
   1050          
   1051          #if (SPI_ENABLED == 1)
   1052              Gpio__PinWrite(SPI_CS_PORT, SPI_CS_PIN, FALSE);       // Pull chip select low during transmission
   1053          
   1054              // Need to add the register address to the data for SPI as there is no argument in Spi__Write that automatically appends this
   1055              command[0] = ACCEL_REG_SELF_TEST_CFG_2;
   1056              command[1] = 0xFF;  // Dummy byte required after the register address
   1057              command[2] = 0x08;  // Self Test measurement phase decimation factor for 256 samples over 80ms at 12.5 ODR
   1058              (void)Spi__Write((SPI_ENUM_DEF)Fxls8974.SF_Param_Ptr->Port, (void*)command, sizeof(command));
   1059          #else
   1060              command[0] = 0x08;  // Self Test measurement phase decimation factor for 256 samples over 80ms at 12.5 ODR
   1061              I2c__Write((I2C_ENUM_TYPE)Fxls8974.SF_Param_Ptr->Port, ACCEL_REG_SELF_TEST_CFG_2, (void*)command, 1);
   1062          #endif
   1063          }
   1064          
