      1          /**
      2           *  @file		HeaterShadowing.c
      3           *
      4           *  @brief		A task that implements the Heater Shadowing Detection algorithm
      5           *
      6           *  @details	The configuration of loads inside the dishwasher can cause some "dry spots" in the heater when washing
      7           *  			using certain spray arms. If heater is turned on for some time with one or multiple dry spots, it can
      8           *  			dramatically increase its temperature to levels that could shorten the heater life. The objective of this
      9           *  			algorithm is to detect when the heater has a dry spot by monitoring the heater current sensor.
     10           *
     11             @startuml{HeaterShadowing State Machine.jpg}
     12                  title Heater Shadowing State Machine
     13          
     14          		[*] --> INITIALIZE
     15          
     16          		INITIALIZE : entry / InitializeEntry()
     17          		INITIALIZE --> HOLD : evStartHeaterShadowingAlgorithm
     18                  INITIALIZE -r-> [*] : evHeaterShadowingNotActive \n/ SetAlgorithmNotActive()
     19          
     20          		HOLD: entry / HoldEntry()
     21          		HOLD: do / HoldDo()
     22          		HOLD --> HOLD : eventCycleResume
     23          		HOLD --> HEATER_OFF : eventHoldTimeExpired \n[!HeaterIsOn()]
     24          		HOLD --> UNKNOWN_POSITION : eventHoldTimeExpired \n[HeaterIsOn() && (!DiverterInLSAOrMSA())]
     25          		HOLD --> WAITING_DELAY : eventHoldTimeExpired \n[HeaterIsOn() && DiverterInLSAOrMSA()]
     26          
     27          		HEATER_OFF : entry / HeaterOffEntry()
     28          		HEATER_OFF : do / HeaterOffDo()
     29          		HEATER_OFF --> HOLD : eventCycleResume
     30          		HEATER_OFF --> UNKNOWN_POSITION : evHeaterOn \n[!DiverterInLSAOrMSA()]
     31          		HEATER_OFF --> WAITING_DELAY : evHeaterOn \n[DiverterInLSAOrMSA()]
     32          
     33          		UNKNOWN_POSITION : entry / UnknownPositionEntry()
     34          		UNKNOWN_POSITION : do / UnknownPositionDo()
     35          		UNKNOWN_POSITION --> HOLD : eventCycleResume
     36          		UNKNOWN_POSITION --> HEATER_OFF : evHeaterOff
     37          		UNKNOWN_POSITION --> WAITING_DELAY : evDiverterPositionChanged
     38          
     39          		WAITING_DELAY : entry / WaitingDelayEntry()
     40          		WAITING_DELAY : do / WaitingDelayDo()
     41          		WAITING_DELAY --> HOLD : eventCycleResume
     42          		WAITING_DELAY --> HEATER_OFF : evHeaterOff
     43          		WAITING_DELAY --> UNKNOWN_POSITION : evDiverterPositionUnknown
     44          		WAITING_DELAY --> WAITING_DELAY : evDiverterPositionChanged
     45          		WAITING_DELAY --> CHECK_DELTA : evDelayExpired \n/ SaveCurrentBaseline()
     46          
     47          		CHECK_DELTA : entry / CheckDeltaEntry()
     48          		CHECK_DELTA : do / CheckDeltaDo()
     49          		CHECK_DELTA --> HOLD : eventCycleResume
     50          		CHECK_DELTA --> HEATER_OFF : evHeaterOff
     51          		CHECK_DELTA --> UNKNOWN_POSITION : evDiverterPositionUnknown
     52          		CHECK_DELTA --> WAITING_DELAY : evDiverterPositionChanged
     53          		CHECK_DELTA --> TIMEOUT : evTimeoutExpired
     54          
     55          		TIMEOUT : entry / TimeoutEntry()
     56          		TIMEOUT : do / TimeoutDo()
     57          		TIMEOUT --> HOLD : eventCycleResume
     58          		TIMEOUT --> HEATER_OFF : evHeaterOff
     59          		TIMEOUT --> UNKNOWN_POSITION : evDiverterPositionUnknown
     60          		TIMEOUT --> WAITING_DELAY : evDiverterPositionChanged
     61          
