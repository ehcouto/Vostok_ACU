    382          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
    383          /**
    384           * @brief  Configures the specified port-pin into the Alternate function.
    385           */
    386          #define GPIO__PIN_COFIG_AF(PORT, PORTBIT, AF)       {(*(volatile GPIO_DEF *)GPIO_PORT_LIST[PORT]).AFR[PORTBIT >> 0x03] = (*(volatile GPIO_DEF *)GPIO_PORT_LIST[PORT]).AFR[PORTBIT >> 0x03] | ((uint32)(AF) << ((uint32)((uint32)PORTBIT & (uint32)0x07) << 2));}
    387          
    388          //=====================================================================================================================
    389          //-------------------------------------- Public Functions -------------------------------------------------------------
    390          //=====================================================================================================================
    391          //---------------------------------------------------------------------------------------------------------------------
    392          //---------------------------------------------------------------------------------------------------------------------
    393          /**
    394           *    @brief    This method initializes a specific SPI module by reading the Spi Configuration parameters
    395           *              defined in the Spi_prm.h file.
    396           *    @details  Before using Spi module this method should be called to initialize specific Spi module.
    397           *              To make use of this API the following configuration macros must be defined in the Spi_prm.h file-
    398           *              "#define SPI_x_PRESCALER"\n
    399           *              "#define SPI_x_LSBFIRST"\n
    400           *              "#define SPI_x_POL"\n
    401           *              "#define SPI_x_CPHA_EDGE"
    402           *    @param    spi : specific SPI module
    403           *    @image    html    Spi__Initialize.jpg
    404           */

   \                                 In section .text, align 2, keep-with-next
    405          void Spi__Initialize(SPI_ENUM_DEF spi)
    406          {
    407              #if ((SPI_1_FEATURE == ENABLED) || (SPI_2_FEATURE == ENABLED) || (SPI_3_FEATURE == ENABLED))
    408          
    409                  //Initialize the DMA
    410                  Dma__EngineInitialize();
    411          
    412                  //Clear the buffers
    413                  Spi__Clear(spi);
    414          
    415                  #if (SPI_1_FEATURE == ENABLED)
    416                      if (spi == SPI1)
    417                      {
    418                          //Enable the clock for Spi1 module
    419                          RCC.APBENR2 |= RCC_APBENR2_SPI1EN;
    420          
    421                          //Reset the Spi1
    422                          RCC.APBRSTR2 |= RCC_APBRSTR2_SPI1RST;
    423                          RCC.APBRSTR2 &= (uint32)(~RCC_APBRSTR2_SPI1RST);
    424          
    425                          #if (SPI_1_TX_ONLY == DISABLED)
    426                              // 8bits data format
    427                              // RXNE event is generated if the FIFO level is greater than or equal to 1/4 (8-bit)
    428                              SPI_1.CR2 = SPI_CR2_DS_0 | SPI_CR2_DS_1 | SPI_CR2_DS_2 | SPI_CR2_FRXTH;
    429          
    430                              // 2-line unidirectional data mode selected
    431                              // CRC Disable
    432                              // Spi1 Baud rate, Polarity, Edge, DataFrame Format, Full Duplex, Software slave management
    433                              // Master Mode Enable, Spi Enabled.
    434                              SPI_1.CR1 = SPI_1_CR1_BR | SPI_1_CR1_CPOL | SPI_1_CR1_CPHA | SPI_1_CR1_LSBFIRST | SPI_CR1_SSM | SPI_CR1_SSI | SPI_CR1_MSTR;
    435          
    436                          #else
    437                              // 8bits data format
    438                              SPI_1.CR2 = SPI_CR2_DS_0 | SPI_CR2_DS_1 | SPI_CR2_DS_2;
    439          
    440                              // 1-line bidirectional data mode selected
    441                              // Transmit only mode enabled
    442                              // CRC Disable
    443                              // Spi1 Baud rate, Polarity, Edge, DataFrame Format, Software slave management
    444                              // Master Mode Enable, Spi Enabled.
    445                              SPI_1.CR1 = SPI_1_CR1_BR | SPI_1_CR1_CPOL | SPI_1_CR1_CPHA | SPI_1_CR1_LSBFIRST | SPI_CR1_SSM | SPI_CR1_SSI | SPI_CR1_MSTR | SPI_CR1_BIDIMODE | SPI_CR1_BIDIOE;
    446                          #endif
    447          
    448                          #if (SPI_1_TX_ONLY == DISABLED)
    449                              SPI_1.CR2 |= SPI_CR2_LDMARX;
    450                          #endif
    451                          SPI_1.CR2 |= SPI_CR2_LDMATX;
    452                      }
    453                  #endif
    454          
    455                  #if (SPI_2_FEATURE == ENABLED)
    456                      if (spi == SPI2)
    457                      {
    458                          //Enable the clock for Spi1 module
    459                          RCC.APBENR1 |= RCC_APBENR1_SPI2EN;
    460          
    461                          //Reset the Spi1
    462                          RCC.APBRSTR1 |= RCC_APBRSTR1_SPI2RST;
    463                          RCC.APBRSTR1 &= (uint32)(~RCC_APBRSTR1_SPI2RST);
    464          
    465                          #if (SPI_2_TX_ONLY == DISABLED)
    466                              // 8bits data format
    467                              // RXNE event is generated if the FIFO level is greater than or equal to 1/4 (8-bit)
    468                              SPI_2.CR2 = SPI_CR2_DS_0 | SPI_CR2_DS_1 | SPI_CR2_DS_2 | SPI_CR2_FRXTH;
    469          
    470                              // 2-line unidirectional data mode selected
    471                              // CRC Disable
    472                              // Spi1 Baud rate, Polarity, Edge, DataFrame Format, Full Duplex, Software slave management
    473                              // Master Mode Enable, Spi Enabled.
