     30          // -- Private Structure Type Declarations --
     31          
     32          //! Volatile data required for each instance of the pilot.
     33          typedef struct SR_DIGITAL_OUTPUT_PILOT_INSTANCE_STRUCT
     34          {
     35              //! The value requested for the digital output.
     36              uint8 Requested;
     37          
     38              //! The value accepted and processed for the digital output.
     39              uint8 Processed;
     40          
     41              //! The most recently written value to the digital output pin.
     42              uint8 Last_Pin_Value;
     43          } SR_DIGITAL_OUTPUT_PILOT_INSTANCE_TYPE;
     44          
     45          //! Volatile data required for the pilot module.
     46          typedef struct SR_DIGITAL_OUTPUT_PILOT_DATA_STRUCT
     47          {
     48              SR_DIGITAL_OUTPUT_PILOT_INSTANCE_TYPE Data[HBL_PILOT_NUM_SRDIGITALOUTPUT];
     49              //! Tracks the number of digital output pilot allocations.
     50              uint8 Allocation;
     51          } SR_DIGITAL_OUTPUT_PILOT_DATA_TYPE;
     52          
     53          
     54          //  --- Private Definitions -------------------------------------------------------------------------------------------
     55          
     56          
     57          // -- Private Variable Definitions --
     58          
     59          //! All the volatile data used by this module.
     60          static SR_DIGITAL_OUTPUT_PILOT_DATA_TYPE Digital_Output;
     61          
     62          //! An inverted copy of the volatile data used by this module for data integrity purposes.
     63          static SR_DIGITAL_OUTPUT_PILOT_DATA_TYPE N_Digital_Output;
     64          
     65          
