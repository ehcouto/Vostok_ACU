   1359                              }
   1360                          }
   1361                          else
   1362                          {
   1363                              //Clear the index to accommodate the new read
   1364                              I2c1_RxPointer = 0;
   1365          
   1366                              I2C_1.CR1 |= I2C_CR1_RXIE | I2C_CR1_NACKIE;
   1367          
   1368                              //Write transfer, Slave enters receiver mode
   1369                              I2C_1.CR2 |= I2C1_BUFFER_IN_SIZE << I2C_CR2_NBYTES_POS;
   1370                          }
   1371          
   1372                          //Clear the error to accommodate the new errors
   1373                          I2C_1.ICR = (I2C_ICR_ADDRCF);
   1374                      }
   1375                      //I2c1_Slave_TxSize
   1376          
   1377                      if ((I2C_1.ISR & I2C_ISR_RXNE) != FALSE)
   1378                      {
   1379                          I2c1_Buffer_In[I2c1_RxPointer] = I2C_1.RXDR;
