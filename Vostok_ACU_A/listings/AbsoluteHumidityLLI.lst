    487          //---------------------------------------------------------------------------------------------------------------------
    488          /**
    489           * @brief   Initialize the counters when state is changed.
    490           */
    491          static void CounterInitialize(void)
    492          {
    493              Absolute_Humidity_LLI_Data[LLI_Index].Delay_Counter = 0;
    494              Absolute_Humidity_LLI_Data[LLI_Index].Direction_Counter = 0;
    495          }
