    303          /**
    304           *  @brief      Process SRUMRelayPilot instance.
    305           *
    306           *  @param      load - Pointer to SRUMRelayPilot instance.
    307           *
    308           *  @return     PASS_FAIL_TYPE result - Result of SRUMRelayPilot instance process.
    309           *  @retval     PASS - Instance process succeeded.
    310           *  @retval     FAIL - Instance process failed.
    311           */
    312          PASS_FAIL_TYPE  SRUMRelayPilot__Process(HBL_LOAD_TYPE *load)
    313          {
    314              PASS_FAIL_TYPE result = FAIL;
    315          
    316              if ((SRDATA_OK == SRData__CheckByte((void *)&SRUMRelayPilot_Allocation,(void *)&N_SRUMRelayPilot_Allocation)) &&
    317                  (load->Pilot_Data_Index < SRUMRelayPilot_Allocation))
    318              {
    319                  SRUMRELAYPILOT_DATA_TYPE *data_ptr = &SRUMRelayPilot_Data[load->Pilot_Data_Index];
    320                  SRUMRELAYPILOT_DATA_TYPE *n_data_ptr = &N_SRUMRelayPilot_Data[load->Pilot_Data_Index];
    321                  if ((SRDATA_OK == SRData__CheckArrayNonBlocking((void *)data_ptr,(void *)n_data_ptr, sizeof(SRUMRELAYPILOT_DATA_TYPE))) &&
    322                      (SRUMRelayPilot_Data[load->Pilot_Data_Index].State != SRUMRELAYPILOT_INITALIZE))
    323                  {
    324                      SRData__UpdateArray((void *) &data_ptr->Processed, (void *) &n_data_ptr->Processed,
    325                          (void *) &data_ptr->Requested, sizeof(SRUMRELAYPILOT_PARAM_TYPE));
    326                      result = PASS;
    327                  }
    328              }
    329          
    330              return (result);
    331          }
