    318          /**
    319           *
    320           * @param data_rate Output data rate based on LISxDH data sheet for output data rate (ODR) configuration
    321           */
    322          static void SetOutputDataRate(uint8 data_rate)
    323          {
    324              if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    325              {
    326                  switch(data_rate)
    327                  {
    328                      case 0:
    329                      case 1:
    330                          AccelerometerLLI_Public.Output_Data_Rate = data_rate;
    331                          break;
    332                      case 2:
    333                          AccelerometerLLI_Public.Output_Data_Rate = 10;
    334                          break;
    335                      case 3:
    336                          AccelerometerLLI_Public.Output_Data_Rate = 25;
    337                          break;
    338                      case 4:
    339                          AccelerometerLLI_Public.Output_Data_Rate = 50;
    340                          break;
    341                      case 5:
    342                          AccelerometerLLI_Public.Output_Data_Rate = 100;
    343                          break;
    344                      case 6:
    345                          AccelerometerLLI_Public.Output_Data_Rate = 200;
    346                          break;
    347                      case 7:
    348                          AccelerometerLLI_Public.Output_Data_Rate = 400;
    349                          break;
    350                      case 8:
    351                          AccelerometerLLI_Public.Output_Data_Rate = 1620;
    352                          break;
    353                      case 9:
    354                          AccelerometerLLI_Public.Output_Data_Rate = 1344;
    355                          break;
    356                      default:
    357                          AccelerometerLLI_Public.Output_Data_Rate = 0;   // Unknown data rate
    358                          break;
    359                  }
    360              }
    361              else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    362              {
    363                  switch(data_rate)
    364                  {
    365                      case 0:
    366                          AccelerometerLLI_Public.Output_Data_Rate = 0;
    367                          break;
    368                      case 1:
    369                          AccelerometerLLI_Public.Output_Data_Rate = 1;  // TODO: Rate is actually 1.5Hz
    370                          break;
    371                      case 2:
    372                          AccelerometerLLI_Public.Output_Data_Rate = 12; // TODO: Rate is actually 12.5Hz
    373                          break;
    374                      case 3:
    375                          AccelerometerLLI_Public.Output_Data_Rate = 25;
    376                          break;
    377                      case 4:
    378                          AccelerometerLLI_Public.Output_Data_Rate = 50;
    379                          break;
    380                      case 5:
    381                          AccelerometerLLI_Public.Output_Data_Rate = 100;
    382                          break;
    383                      case 6:
    384                          AccelerometerLLI_Public.Output_Data_Rate = 200;
    385                          break;
    386                      case 7:
    387                          AccelerometerLLI_Public.Output_Data_Rate = 400;
    388                          break;
    389                      case 8:
    390                          AccelerometerLLI_Public.Output_Data_Rate = 1600;
    391                          break;
    392                      case 9:
    393          //                AccelerometerLLI_Public.Output_Data_Rate = 3200;
    394                          // TODO: Update setting file to use "8" for 1600Hz (3200Hz was too fast)
    395                          AccelerometerLLI_Public.Output_Data_Rate = 1600;
    396                          break;
    397                      default:
    398                          AccelerometerLLI_Public.Output_Data_Rate = 0;   // Unknown data rate
    399                          break;
    400                  }
    401              }
    402          }
