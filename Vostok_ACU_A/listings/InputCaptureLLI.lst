     98          //---------------------------------------------------------------------------------------------------------------------
     99          /**
    100           * @brief      It Initializes the module DigitalLowLevel and its variables
    101           */
    102          void InputCaptureLLI__Initialize(void)
    103          {
    104              memset(&InputCaptureLLI_Data,0,sizeof(InputCaptureLLI_Data));
    105              InputCaptureLLI_Allocation = 0;
    106          }
    107          
    108          //---------------------------------------------------------------------------------------------------------------------
    109          /**
    110           * @brief
    111           * @return
    112           */
    113          uint8 InputCaptureLLI__Allocate(void)
    114          {
    115              uint8 retval;
    116          
    117              retval = 0xFF;
    118          
    119              if (InputCaptureLLI_Allocation < HBL_LLI_NUM_INPUTCAPTURE)
    120              {
    121                  retval = InputCaptureLLI_Allocation;
    122                  InputCaptureLLI_Allocation++;
    123          
    124              }
    125              return (retval);
    126          }
    127          
    128          //---------------------------------------------------------------------------------------------------------------------
    129          /**
    130           *  @brief      It Initializes the module DigitalLowLevel and its variables
    131           *
    132           */
    133          PASS_FAIL_TYPE InputCaptureLLI__InitializeInstance(HBL_LLI_TYPE * input)
    134          {
    135              PASS_FAIL_TYPE ret_status = FAIL;
    136          
    137              if (input->Data_Index < InputCaptureLLI_Allocation)
    138              {
    139                  MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    140                  uint8 delta_expanded;
    141                  INPUTCAPTURE_DATA_TYPE *data = (INPUTCAPTURE_DATA_TYPE *)&InputCaptureLLI_Data[input->Data_Index]; //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    142                  INPUTCAPTURELLI_PARAMETERS_TYPE *parameters = (INPUTCAPTURELLI_PARAMETERS_TYPE *)input->Parameter_Ptr.Data; //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    143                  uint8 virtual_pin = input->Pin_Ptr[0];
    144          
    145                  delta_expanded = 1 << parameters->Delta;
    146                  // If Delta is set to 1, fallback to N.Reads - backward compatibility
    147                  if (delta_expanded <= 1)
    148                  {
    149                      delta_expanded = 1 << parameters->N_Read;
    150                  }
    151          
    152                  data->Continue_mode = TRUE;
    153                  data->Filter_Initialized = FALSE;
    154          
    155                  //Initialize the filters
    156                  data->Private_Period.Inverted_Alpha = delta_expanded;
    157                  data->Private_Duty.Inverted_Alpha   = delta_expanded;
    158          
    159                  data->Timer_Parameter.Timer       =   (TIMER_TYPE)VIRTUALPIN_TABLE[virtual_pin].device;
    160                  data->Timer_Parameter.Channel     =   (TIMER_CHANNEL_TYPE)VIRTUALPIN_TABLE[virtual_pin].param0;
    161                  data->Timer_Parameter.Mode        =   TIMER_MODE_INPUT_CAPTURE;
    162                  data->Timer_Parameter.Port        =   VIRTUALPIN_TABLE[virtual_pin].port;
    163                  data->Timer_Parameter.Pin         =   VIRTUALPIN_TABLE[virtual_pin].pin;
    164                  data->Timer_Parameter.Pin_ReMap   =   VIRTUALPIN_TABLE[virtual_pin].pin_remap;
    165                  data->Timer_Parameter.Polarity    =   TIMER_POLARITY_ACTIVE_HIGH;
    166          
    167                  //Configure Continuous reading
    168                  MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    169                  ret_status =  Timer__Config(&data->Timer_Parameter);
    170                  ret_status |= Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    171                  MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    172          
    173                  //Init the timeout and start it
    174                  Millis__Reset(&data->Timer_Timeout);
    175                  Millis__Start(&data->Timer_Timeout);
    176          
    177                  //Init the sampling for discrete mode
    178                  Millis__Reset(&data->Timer_Sampling);
    179              }
    180          
    181              return (ret_status);
    182          }
    183          
    184          //---------------------------------------------------------------------------------------------------------------------
    185          /**
    186           *
    187           * @param   input
    188           * @return  pointer to the INPUTCAPTURE_PUBLIC_TYPE for the specified input
    189           * @return  NULL passed input was invalid
    190           */
    191          void * InputCaptureLLI__Get(HBL_LLI_TYPE * input)
    192          {
    193              if (input->Data_Index < InputCaptureLLI_Allocation)
    194              {
    195                  return ((void *)&InputCaptureLLI_Data[input->Data_Index]);
    196              }
    197              else
    198              {
    199                  return (NULL);
    200              }
    201          }
    202          
    203          //---------------------------------------------------------------------------------------------------------------------
    204          /**
    205           * @details - Controls the Discrete Sampling mode and Timeout
    206           * @param input
    207           * @param status
    208           * @return
    209           */
    210          BOOL_TYPE InputCaptureLLI__AsynchProcess(HBL_LLI_TYPE * input)
    211          {
    212              BOOL_TYPE ret_val;
    213          
    214              ret_val = FALSE;
    215          
    216              INPUTCAPTURELLI_PARAMETERS_TYPE *parameters;
    217              INPUTCAPTURE_DATA_TYPE *data;
    218          
    219              if (input->Data_Index < InputCaptureLLI_Allocation)
    220              {
    221                  MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    222                  data = (INPUTCAPTURE_DATA_TYPE *)&InputCaptureLLI_Data[input->Data_Index]; //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    223                  parameters = (INPUTCAPTURELLI_PARAMETERS_TYPE *)(input->Parameter_Ptr.Data);        //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    224          
    225                  //Enable Sampling only if Auto or Continuous reading is set
    226                  if ((data->Continue_mode == FALSE) &&
    227                      (data->Timer_Parameter.Mode == TIMER_MODE_DISABLE))
    228                  {
    229                      if (Millis__ReachedTarget(&data->Timer_Sampling, parameters->Sampling_Time * 5) == TRUE)
    230                      {
    231                          Millis__Start(&data->Timer_Sampling);
    232                          // Enable timer as Input Capture
    233                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    234                          data->Timer_Parameter.Mode = TIMER_MODE_INPUT_CAPTURE;
    235                          Timer__Config(&data->Timer_Parameter);
    236                          Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    237                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    238                      }
    239                  }
    240          
    241                  //Re-Initialize the InputCapture peripheral if their is no signal received in the timeout period
    242                  if (Millis__ReachedTarget(&data->Timer_Timeout, parameters->Time_Out * 5) == TRUE)
    243                  {
    244                      // Disable timer
    245                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    246                      InputCaptureLLI_Data[input->Data_Index].Timer_Parameter.Mode = TIMER_MODE_DISABLE;
    247                      Timer__Config(&InputCaptureLLI_Data[input->Data_Index].Timer_Parameter);
    248                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    249                      // Reset filter
    250                      data->Filter_Initialized = FALSE;
    251                      data->Continue_mode = TRUE;
    252                      //Restart reading of samples
    253                      data->Private_Valid_Sample_Count                    = 0;
    254                      data->Private_Invalid_Sample_Count                  = 0;
    255                      data->Private_Current_Count                         = 0;
    256                      //Refresh the Timeout timer
    257                      Millis__Start(&data->Timer_Timeout);
    258                      //Refresh sampling time
    259                      Millis__Start(&data->Timer_Sampling);
    260                      // Initialize the Timer module and start sampling
    261                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    262                      InputCaptureLLI_Data[input->Data_Index].Timer_Parameter.Mode = TIMER_MODE_INPUT_CAPTURE;
    263                      Timer__Config(&InputCaptureLLI_Data[input->Data_Index].Timer_Parameter);
    264                      Timer__CaptureStart(&InputCaptureLLI_Data[input->Data_Index].Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    265                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    266                  }
    267          
    268                  ret_val = TRUE;
    269              }
    270          
    271              return(ret_val);
    272          }
    273          
    274          //---------------------------------------------------------------------------------------------------------------------
    275          /**
    276           *
    277           * @param input
    278           * @return
    279           */
    280          BOOL_TYPE InputCaptureLLI__ICProcess(HBL_LLI_TYPE * input)
    281          {
    282              INPUTCAPTURELLI_PARAMETERS_TYPE *parameters;
    283              INPUTCAPTURE_DATA_TYPE *data;
    284              BOOL_TYPE retval;
    285              uint32 captured_duration;
    286              uint16 captured_duty;
    287              uint8 n_read_expanded;
    288          
    289          
    290              retval = FALSE;
    291          
    292              if (input->Data_Index < InputCaptureLLI_Allocation)
    293              {
    294                  MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    295                  data = (INPUTCAPTURE_DATA_TYPE *)&InputCaptureLLI_Data[input->Data_Index]; //lint !e929 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    296                  parameters = (INPUTCAPTURELLI_PARAMETERS_TYPE *)input->Parameter_Ptr.Data; //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    297          
    298                  //Read the current captured duration and duty
    299                  captured_duration = Timer__GetCaptureDuration(&data->Timer_Parameter);
    300                  captured_duty = Timer__GetCaptureDuty(&data->Timer_Parameter);
    301          
    302                  //Refresh the Timeout timer
    303                  Millis__Start(&data->Timer_Timeout);
    304          
    305                  //Disable the Timer Input Capture if the Sampling Read is set
    306                  if (data->Continue_mode == FALSE)
    307                  {
    308                      //Discrete Sampling Mode
    309                      //Switch to Discrete sampling as Current captured duration is too small to do in continuous sampling
    310                      //Disable the Timer and let control the sampling from the InputCaptureLLI__AsynchProcess()
    311                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    312                      data->Timer_Parameter.Mode = TIMER_MODE_DISABLE;
    313                      Timer__Config(&data->Timer_Parameter);
    314                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    315          
    316                  }
    317          
    318                  /*SSS latch_check to changing mode*/
    319                  if (((captured_duration) < (INPUTCAPTURELLI_AUTO_FEATURE_DOWN_PERIOD_HYS)) && (data->Continue_mode)) /*(f > MAX_FREQUENCY*)*/
    320                  {
    321                      Millis__Start(&data->Timer_Sampling);
    322                      //Change the mode and stop InputCapture
    323                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    324                      data->Continue_mode = FALSE;
    325                      data->Timer_Parameter.Mode = TIMER_MODE_DISABLE;
    326                      Timer__Config(&data->Timer_Parameter);
    327                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    328                  }
    329                  else if(((captured_duration) > (INPUTCAPTURELLI_AUTO_FEATURE_UP_PERIOD_HYS))&& !(data->Continue_mode))/*((f > MAX_FREQUENCY-HYSTERESIS*))*/
    330                  {
    331                      //Change the mode and restart InputCapture
    332                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    333                      data->Continue_mode = TRUE;
    334                      data->Timer_Parameter.Mode = TIMER_MODE_INPUT_CAPTURE;
    335                      Timer__Config(&data->Timer_Parameter);
    336                      Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    337                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    338                  }
    339                  else
    340                  {
    341                      /*all ok*/
    342                  }
    343          
    344                  //Expand the number of reads
    345                  n_read_expanded = 1 << parameters->N_Read;
    346          
    347                  data->Private_Current_Count++;
    348          
    349                  //validate the Cycle Period
    350                  if ((captured_duration >= (ENDIANU16_STON(parameters->Minimum_Period) << 3)) &&
    351                      (captured_duration <= (ENDIANU16_STON(parameters->Maximum_Period) << 3)))
    352                  {
    353                      //validate the captured_duty
    354                      if ((captured_duty >= ENDIANU16_STON(parameters->Minimum_Duty)) &&
    355                          (captured_duty <= ENDIANU16_STON(parameters->Maximum_Duty)))
    356                      {
    357                          data->Private_Valid_Sample_Count++;
    358          
    359                          //scale the period based on the base
    360                          captured_duration = captured_duration / parameters->Base_Period;
    361                          if (data->Filter_Initialized == TRUE)
    362                          {
    363                              Filter__Update((void *)(&(data->Private_Period)), (FILTER_DATA_TYPE)captured_duration, FILTER_IIR);
    364                              Filter__Update((void *)(&(data->Private_Duty)), (FILTER_DATA_TYPE)captured_duty, FILTER_IIR);
    365                          }
    366                          else
    367                          {
    368                              Filter__Initialize((void *)(&(data->Private_Period)), (FILTER_DATA_TYPE) captured_duration, FILTER_IIR);
    369                              Filter__Initialize((void *)(&(data->Private_Duty)), (FILTER_DATA_TYPE) captured_duty , FILTER_IIR);
    370                              data->Filter_Initialized = TRUE;
    371                          }
    372                      }
    373                      else
    374                      {
    375                          data->Private_Invalid_Sample_Count++;
    376                      }
    377                  }
    378                  else
    379                  {
    380                      data->Private_Invalid_Sample_Count++;
    381                  }
    382          
    383                  //Check if there are too many invalid samples
    384                  if(data->Private_Invalid_Sample_Count == MAX_INVALID_SAMPLE_COUNT)
    385                  {
    386                      //Force Timer_Timeout to DONE state
    387                      Millis__Start(&data->Timer_Timeout);
    388                      Millis__SetElapsed(&data->Timer_Timeout, parameters->Time_Out * 5);
    389                  }
    390          
    391                  //if its the new sampling
    392                  if(data->Private_Valid_Sample_Count >= n_read_expanded)
    393                  {
    394                      //Copy previous sampling data
    395                      data->Public_Data.Period                    = data->Private_Period.Filtered_Value;
    396                      data->Public_Data.Duty                      = data->Private_Duty.Filtered_Value;
    397                      data->Public_Data.Valid_Sample_Count        = data->Private_Valid_Sample_Count;
    398                      data->Public_Data.InValid_Sample_Count      = data->Private_Invalid_Sample_Count;
    399          
    400                      //new readings available
    401                      data->Public_Data.Sequence_Count++;
    402          
    403                      if (data->Public_Data.Sequence_Count == 0)
    404                      {
    405                          data->Public_Data.Sequence_Count++;
    406                      }
    407          
    408                      //Prepare for reading new sampling
    409                      data->Private_Valid_Sample_Count                    = 0;
    410                      data->Private_Invalid_Sample_Count                  = 0;
    411                      data->Private_Current_Count                         = 0;
    412          
    413                      //Data ready after the filter
    414                      retval = TRUE;
    415                  }
    416              }
    417          
    418              return (retval);
    419          }
