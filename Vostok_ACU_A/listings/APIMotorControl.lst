    708          //---------------------------------------------------------------------------------------------------------------------
    709          /*
    710           * @brief       Request to stop the motor by invoking the Mci stop command.
    711           * @param       buffer - a pointer to the received Reveal buffer.
    712           * @return      Returns whether Mci has accepted or not the command; TRUE = accepted; FALSE = denied
    713           */
    714          volatile unsigned short stop_motor_counter;
    715          volatile unsigned short stop_motor_counter1;
    716          uint8 Stop_Motor(REVEAL_MSG_TYPE *buffer)
    717          {
    718          #ifdef API220_ENABLE_MCI_CALLS
    719          
    720              uint8 ret_val;
    721              MOTOR_ENUM_TYPE motor_index;
    722              sint16 target_accel;
    723              #ifndef ENABLE_API220_CALLBACKS
    724                  MCI_CMD_RESPONSE_TYPE feedback;
    725                  REVEAL_COMMAND_TYPE *command;
    726              #endif
    727          
    728              ret_val = FALSE;                                // Default answer is FALSE
    729          
    730              stop_motor_counter++;
    731          
    732              if(buffer->sdu_length == 5)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
    733              {
    734                  //custom code
    735                  API220_MCI_STOP_CALLBACK();
    736          
    737                  stop_motor_counter1++;
    738          
    739                  // Build up the data from the Reveal buffer
    740                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
    741                  target_accel = ((sint16)(buffer->payload[1])<<8) + buffer->payload[2];
    742          
    743                  // Set the last commands to internal variables.
    744                  Last_Speed_Target[motor_index] = 0;
    745                  Last_Ramp_Target[motor_index] = target_accel;
    746          
    747                  #ifdef ENABLE_API220_CALLBACKS
    748          
    749                      // Invoke Mci stop
    750                      Mci__Stop(motor_index, target_accel);
    751          
    752                  #else
    753          
    754                      // Invoke Mci stop and read its feedback
    755                      feedback = Mci__Stop(motor_index, target_accel);
    756          
    757                      command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_STOP, REVEAL_BROADCAST_NODE, 4);
    758                      if(command != NULL)
    759                      {
    760                          // Build and enqueue the Reveal buffer with the required feedback
    761                          Reveal__AddDataU8(command, motor_index);
    762                          Reveal__AddDataU16(command, target_accel);
    763                          Reveal__AddDataU8(command, (uint8)feedback);
    764          
    765                          ret_val = Reveal__QueueCommand(command);
    766                      }
    767                  #endif
    768              }
    769              return(ret_val);
    770          
    771          #else
    772          
    773              return(FALSE);
    774          
    775          #endif
    776          }
