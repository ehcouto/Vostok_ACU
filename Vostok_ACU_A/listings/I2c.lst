    452          /**
    453           *    @brief    It is used to reset I2C bus
    454           *
    455           *    @details  This method performs the I2C bus reset operation in two cases such as prior to I2C module initialization
    456           *              and in case any bus error occurs during I2C bus communication
    457           *    @param    i2c : I2C modules i.e. I2c1 or I2c2 device
    458           *    @return   BOOL_TYPE
    459           *      @retval   TRUE (1) : It indicates I2C bus is reset operation is successful
    460           *      @retval   FALSE(0) : It indicates I2C bus is reset operation is unsuccessful
    461           *    @image html I2c__ResetBus.jpg
    462           */

   \                                 In section .text, align 2, keep-with-next
    463          BOOL_TYPE I2c__ResetBus(I2C_ENUM_TYPE i2c)
    464          {
    465              #if ((I2C1_FEATURE == ENABLED) || (I2C2_FEATURE == ENABLED) || (I2C3_FEATURE == ENABLED))
    466                  BOOL_TYPE response;
    467                  uint8 count;
    468                  uint8 aux;
    469          
    470                  response = FALSE;
    471          
    472                  #if (I2C1_FEATURE == ENABLED)
    473                      if (i2c == I2C1)
    474                      {
    475                          Gpio__PinWrite(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, TRUE);
    476          
    477                          //Configure the SDA as INPUT mode and SCL into OOUTPUT mode
    478                          Gpio__PinConfig(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, OUTPUT_OPEN_DRAIN);
    479                          Gpio__PinConfig(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT, INPUT_FLOAT);
    480          
    481                          //Read the SDA status
    482                          aux = Gpio__PinRead(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT);
    483          
    484                          count = 0;
    485          
    486                          //If the SDA is hold by the slave then it must be released by mimicking the I2c clock
    487                          //reading SDA status
    488                          while((aux == FALSE) &&
    489                                (count < 10))
    490                          {
    491                              //Send a clock pulse to the slave to release the SDA line
    492                              Gpio__PinWrite(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, FALSE);
    493                              Micro__DelayNumNops(10);
    494                              Gpio__PinWrite(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, TRUE);
    495                              Micro__DelayNumNops(10);
    496          
    497                              //read the status of the SDA line
    498                              aux = Gpio__PinRead(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT);
    499                              count++;
    500                          }
    501          
    502                          response = (BOOL_TYPE)aux;
    503          
    504                          I2c1_Ack_Error = I2C_ERROR_NONE;
    505          
    506                          if (aux == FALSE)
    507                          {
    508                              //If the SDA line is still read as low then log the BUS_LOCK error
    509                              I2c1_Ack_Error = I2C_ERROR_BUS_LOCKED;
    510                          }
    511          
    512                          Gpio__PinConfig(I2C_1_SCL_PORT, I2C_1_SCL_PORTBIT, SPECIAL_FUNCTION_OPEN_DRAIN);   //Configure SCL line for I2C1
    513                          Gpio__PinConfig(I2C_1_SDA_PORT, I2C_1_SDA_PORTBIT, SPECIAL_FUNCTION_OPEN_DRAIN);   //Configure SDA line for I2C1
    514                      }
    515                  #endif
    516          
    517                  #if (I2C2_FEATURE == ENABLED)
