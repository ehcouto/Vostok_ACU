    104          typedef enum MODULE_MODIFIER_LOG_MESSAGE_ID_ENUM
    105          {
    106              CANNOT_LOAD_PARAMETERS = 1,
    107              INVALID_OVERALL_OPERATION,
    108              INVALID_DTV_OPTION,
    109              CONVERT_STATUS_FAILED,
    110              MISSING_TABLE_DATA,
    111              NO_32BIT_TABLE_SUPPORT_AVAILABLE,
    112              CANNOT_GET_VARIABLE_VALUE,
    113              INVALID_ACTION,
    114              DATATYPE_NOT_SUPPORTED
    115          } MODULE_MODIFIER_LOG_MESSAGE_ID_TYPE;
