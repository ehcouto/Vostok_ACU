    430          
    431                  //Enable the clock for Power control module
    432                  RCC.APBENR1 |= RCC_APBENR1_PWREN;
    433          
    434                  SYSCFG.CFGR2 &= ~SYSCFG_CFGR2_PVDL;
    435          
    436                  //Enable the voltage detector
    437                  PWR.CR2 |= PWR_CR2_PVDE | (MICRO_LOW_VOLTAGE_LEVEL << PWR_CR2_PVDFT_POS) | (MICRO_LOW_VOLTAGE_LEVEL << PWR_CR2_PVDRT_POS);
    438          
    439                  // Connect the Alternate function device to the bus
    440                  RCC.APBENR2 |= RCC_APBENR2_SYSCFGEN;
    441          
    442                  //Enable the External mask register for External Line 16
    443                  EXTI.IMR1 |= EXTI_IMR1_IM16;
    444          
    445                  //Configure the interrupt for rise time
    446                  EXTI.RTSR1 |= EXTI_RTSR1_RT16;
    447          
    448                  Micro__NVICEnableIRQ(PVD_IRQ_CHANNEL, PVD_PREEMPTION_PRIORITY);
    449              #endif
    450          }
