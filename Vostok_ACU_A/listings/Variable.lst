    500          //=====================================================================================================================
    501          //-------------------------------------- Getters and Setters using KVP Ids---------------------------------------------
    502          //=====================================================================================================================
    503          #if(VARIABLES_HAVE_KVP_ID == ENABLED)
    504          	/**
    505          	 * Getter to the content of the variable. Access it using Kvp_ID.
    506          	 * @param kvp_id	32 bits ID for the variable.
    507          	 * @param value		value of the variable. if the return of the function is TRUE this value was retrieved properly.
    508          	 * @return	TRUE means the value is valid: it was possible to retrieve it. FALSE means you should NOT use the value.
    509          	 */
    510          	BOOL_TYPE Variable__GetValuebyKVP(uint32 kvp_id, sint32 *value)
    511          	{
    512          		VARIABLE_ID_TYPE index;
    513          		uint8 offset;
    514          
    515          		if(GetVariablePositionByKVP(kvp_id, &index, &offset) == TRUE)
    516          		{
    517          			return Variable__GetValue(index, offset, value);
    518          		}
    519          		return FALSE;
    520          	}
    521          	/**
    522          	 * Getter to the DATATYPE of the variable referenced by the KVP_ID
    523          	 * @param kvp_id 32 bits ID for the variable.
    524          	 * @return TRUE means it was possible to retrieve the DATATYPE_TYPE for the given index and offset. FALSE means no valid return.
    525          	 */
    526          	DATATYPE_TYPE Variable__GetTypeByKVP(uint32 kvp_id)
    527          	{
    528          		VARIABLE_ID_TYPE index;
    529          		uint8 offset;
    530          
    531          		if(GetVariablePositionByKVP(kvp_id, &index, &offset) == TRUE)
    532          		{
    533          			return Variable__GetTypeByIndex(index);
    534          		}
    535          		return DATATYPE_INVALID;
    536          	}
    537          	/**
    538          	 * Setter to the value of the variable referenced by the given KVP_ID.
    539          	 * @param operation one of the possible operations to be performed on a variable.
    540          	 * @param kvp_id 32 bits ID for the variable.
    541          	 * @param value 32 bits value you want to set. For Increment/Decrement operations the value is not used. you can pass any constant.
    542          	 * @return TRUE if the requested operation was performed. FALSE means it was not possible and reason will be on the Log.
    543          	 */
    544          	BOOL_TYPE Variable__SetValueByKVP(VARIABLE_SET_OPERATION_TYPE operation, uint32 kvp_id, sint32 value)
    545          	{
    546          		VARIABLE_ID_TYPE index;
    547          		uint8 offset;
    548          
    549          		if(GetVariablePositionByKVP(kvp_id, &index, &offset) == TRUE)
    550          		{
    551          			return Variable__SetValue(operation, index, offset, value);
    552          		}
    553          		return FALSE;
    554          	}
    555          	/**
    556          		 * It receives the index for the variable and returns the related KVP.
    557          		 * @param variable_index as per the constants defined on this module.
    558          		 * @return The KVP Index for the variable or FFFFFFFF if the variable is not found.
    559          		 */
    560          		uint32 Variable__GetKVPByIndex(VARIABLE_ID_TYPE variable_index)
    561          		{
    562          			uint32 kvp_id;
    563          			uint8 key;
    564          
    565          			kvp_id = 0xFFFFFFFF;
    566          			for(key = 0; key < ELEMENTS_IN_ARRAY(Kvp_To_Variable_Table); key++)
    567          			{
    568          				if(variable_index == Kvp_To_Variable_Table[key].Variable_Index)
    569          				{
    570          					kvp_id = Kvp_To_Variable_Table[key].Kvp_Id;
    571          					key = ELEMENTS_IN_ARRAY(Kvp_To_Variable_Table);
    572          				}
    573          			}
    574          			return kvp_id;
    575          		}
    576          	/**
    577          	 * Function that returns the Index and Offset of the variable on the ACU_DATA_HOLDER array.
    578          	 * It receives the KVP ID and if it is present on the KVP_TO_VARIABLE_TRANSLATION_TABLE, we return the index and offset to that variable.
    579          	 * @param kvp_id	unique uint32 index for the variable. It is used for connectivity.
    580          	 * @param *index	it will be loaded with the Index for the Variable only if the function returns TRUE this is a valid Index.
    581          	 * @param *offset	it will be loaded with the Offset for the Variable only if the function returns TRUE this is a valid Offset.
    582          	 * @return TRUE if we were able to retrieve the information.
    583          	 */
    584          	static BOOL_TYPE GetVariablePositionByKVP(uint32 kvp_id, VARIABLE_ID_TYPE *index, uint8 *offset)
    585          	{
    586          		BOOL_TYPE ret;
    587          		uint8 key;
    588          
    589          		ret = FALSE;
    590          		// If we are receiving valid addresses to load with the info, we proceed.
    591          		if((index == NULL) || (offset == NULL))
    592          		{
    593          			LOG_ADD_EXCEPTION(NULL_POINTERS_ON_KVP, kvp_id);
    594          		}
    595          		else
    596          		{
    597          			for(key = 0; key < ELEMENTS_IN_ARRAY(Kvp_To_Variable_Table); key++)
    598          			{
    599          				if(kvp_id == Kvp_To_Variable_Table[key].Kvp_Id)
    600          				{
    601          					if(Kvp_To_Variable_Table[key].Variable_Index < VARIABLE_MAX_NUMBER_OF_ACU_VARIABLES)
    602          					{
    603          						ret = TRUE;
    604          						*index  = Kvp_To_Variable_Table[key].Variable_Index;
    605          						*offset = Kvp_To_Variable_Table[key].Offset;
    606          					}
    607          				}
    608          			}
    609          		}
    610          		return ret;
    611          	}
    612          #endif
