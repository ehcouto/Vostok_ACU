    209          //---------------------------------------------------------------------------------------------------------------------
    210          /**
    211           * @brief	Checks if there is free space and reserve a new instance
    212           * @return	index of AbsoluteHumidityLLI instance, 0xFF if all HBL_LLI_NUM_ABSOLUTEHUMIDITY are already allocated
    213           */
    214          uint8 AbsoluteHumidityLLI__Allocate(void)
    215          {
    216              uint8 retval = HBL_ALLOCATION_INVALID;
    217          
    218              if(Absolute_Humidity_LLI_Allocation < HBL_LLI_NUM_ABSOLUTEHUMIDITY)
    219              {
    220                  retval = Absolute_Humidity_LLI_Allocation;
    221                  Absolute_Humidity_LLI_Allocation++;
    222              }
    223              return (retval);
    224          }
    225          
    226          //---------------------------------------------------------------------------------------------------------------------
    227          /**
    228           * @brief Initializes a new instance of AbsoluteHumidityLLI
    229           * @param input		pointer to HBL_LLI_TYPE structure reserved for that instance
    230           * @param status
    231           */
    232          PASS_FAIL_TYPE AbsoluteHumidityLLI__InitializeInstance(HBL_LLI_TYPE *input)
    233          {
    234              PASS_FAIL_TYPE retval = FAIL;
    235              uint8 table_index;
    236          
    237              if(input->Data_Index < Absolute_Humidity_LLI_Allocation)
    238              {
    239                  LLI_Index = input->Data_Index;
    240                  Absolute_Humidity_LLI_Data[LLI_Index].LLI = input;
    241          
    242                  //! Initialize AH enable pin
    243                  table_index = Absolute_Humidity_LLI_Data[LLI_Index].LLI->Pin_Ptr[ENABLE_PIN];
    244                  if(VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    245                  {
    246                      Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, FALSE);
    247                      Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    248          
    249                      //! Initialize AH feedback pin
    250                      table_index = Absolute_Humidity_LLI_Data[LLI_Index].LLI->Pin_Ptr[FEEDBACK_PIN];
    251                      if(VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    252                      {
    253                          Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    254          
    255                          //! Initialize AH pwm pin
    256                          table_index = Absolute_Humidity_LLI_Data[LLI_Index].LLI->Pin_Ptr[PWM_PIN];
    257                          if(VIRTUALPIN_TABLE[table_index].port != PORT_NULL)
    258                          {
    259                              Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, FALSE);
    260                              Gpio__PinConfig(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, VIRTUALPIN_TABLE[table_index].pin_config);
    261          
    262                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Timer         = (TIMER_TYPE)VIRTUALPIN_TABLE[table_index].device;
    263                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Channel       = (TIMER_CHANNEL_TYPE)VIRTUALPIN_TABLE[table_index].param0;
    264                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Mode          = TIMER_MODE_PWM;
    265                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Port          = VIRTUALPIN_TABLE[table_index].port;
    266                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Pin           = VIRTUALPIN_TABLE[table_index].pin;
    267                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Pin_ReMap     = VIRTUALPIN_TABLE[table_index].pin_remap;
    268                              Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter.Polarity      = TIMER_POLARITY_ACTIVE_HIGH;
    269          
    270                              if(Timer__Config(&Absolute_Humidity_LLI_Data[LLI_Index].Timer_Parameter) == PASS)
    271                              {
    272                                  //! Initialize Absolute humidity LLI state machine
    273                                  AbsoluteHumidityLLIInitialize();
    274          
    275                                  //! Enable Absolute humidity LLI
    276                                  Absolute_Humidity_LLI_Data[LLI_Index].Enable = TRUE;
    277          
    278                                  retval = PASS;
    279                              }
    280                              else
    281                              {
    282                                  LOG_ADD_EXCEPTION(CONFIGURE_PWM_FAILED, LLI_Index);
    283                              }
    284                          }
    285                          else
    286                          {
    287                              LOG_ADD_EXCEPTION(CONFIGURE_FEEDBACK_PIN_FAILED, LLI_Index);
    288                          }
    289                      }
    290                      else
    291                      {
    292                          LOG_ADD_EXCEPTION(CONFIGURE_FEEDBACK_PIN_FAILED, LLI_Index);
    293                      }
    294                  }
    295                  else
    296                  {
    297                      LOG_ADD_EXCEPTION(CONFIGURE_ENABLE_PIN_FAILED, LLI_Index);
    298                  }
    299              }
    300          
    301              return (retval);
    302          }
