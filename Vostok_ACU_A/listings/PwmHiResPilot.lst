     25          //! constant = 1s update time for the acceleration manager.
     26          #define PWM_HI_RES_UPDATE_TIME_MS					1000
     27          //! Constant to emulate the pwm.
     28          #define PWM_HI_RES_PILOT_EMULATED_BASE_FREQUENCY	1000		//!< in Hz
     29          /**
     30           * data structure from settings file.
     31           */
     32          typedef PACKED struct PWM_HI_RES_PARAMETER_STRUCT
     33          {
     34              //Base frequency.
     35              uint16 Base_Frequency;
     36              uint16 Speed_Min;
     37              uint16 Delta_Max;
     38              uint16 Delta_Min;
     39              //Is Frequency or duty?
     40              uint8  Is_Frequency_Driven	:1;
     41              uint8  Acceleration_Feature :1;
     42              uint8  Unused1				:6;
     43              //One empty byte here
     44              uint8 Unused2;
     45          } PWMHIRESPILOT_PARAMETER_TYPE;
     46          
     47          /**
     48           * This is the data definition. Depending on the SF we can drive
     49           * the output on frequency or High Resolution Duty Cycle (0-10000).
     50           */
     51          typedef PACKED struct
     52          {
     53              PWMHIRESPILOT_PARAMETER_TYPE *Parameters;
     54              TIMER_PARAMETER_TYPE Timer_Parameter;
     55              uint16 Timer_Counter;
     56              uint16 Number_Of_Steps;
     57              uint16 Number_Of_Steps_On;
     58              uint16 Steps_For_Emulation;
     59              uint16 Requested;
     60              uint16 Processed;
     61              uint16 Previous;
     62              PWMHIRESPILOT_STATUS_TYPE Pilot_Status;
     63          } PWMHIRESPILOT_DATA_TYPE;
