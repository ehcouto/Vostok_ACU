    826          				((BIT_TEST(This_Pc->PC_Status[MOTOR_1],API221_STS_MOTOR_RUNNING) != 0U) && (BIT_TEST(This_Pc->PC_Status[MOTOR_1],API221_STS_REACHED_TARGET) == 0U)))
