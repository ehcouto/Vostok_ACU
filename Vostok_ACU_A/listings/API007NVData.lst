    107           	@startuml(API007NVData.png)
    108          	 hide footbox
    109               autonumber
    110          
    111          	participant API007NVData_Client
    112          	participant API007Data_Client
    113          	participant API007Data_Server
    114          	participant API007NVData_Server
    115          
    116          
    117          							==  Info Update ==
    118          	API007NVData_Client -> API007Data_Client : API007Data__NVDataCmdClaimSizeRequest(uint16 size)
    119          
    120          	API007Data_Client -> API007Data_Server : CMD, OPCODE - API007_OP_REQ_CLAIM_NVDATA(0x13),\nDATA[0-1] - size
    121          
    122          	API007Data_Server -> API007NVData_Server : API007NVData__ProcessClaimSize(uint8 client_node_id, uint16 size)
    123          	API007NVData_Server ->API007Data_Server : API007Data__NVDataFbkClaimSize(uint8 client_node_id, uint16 size)
    124          	API007Data_Server --> API007Data_Client : FBK, OPCODE - API007_OP_REQ_CLAIM_NVDATA(0x13),\nDATA[0-1] - size
    125          	API007Data_Client -> API007NVData_Client : API007NVData__ReceivedClaimSize(uint16 size)
    126          
    127          
    128          							==  Read ==
    129          	API007NVData_Client -> API007Data_Client : API007Data__NVDataCmdReadRequest(uint16 index, uint16 size)
    130          
    131          	API007Data_Client -> API007Data_Server : CMD, OPCODE - API007_OP_REQ_READ_NVDATA(0x14),\nDATA[0-1] - index\nDATA[2-3] - size
    132          
    133          	API007Data_Server -> API007NVData_Server : API007NVData__ProcessReadCmd(uint8 client_node_id, uint16 index, uint16 size)
    134          	API007NVData_Server ->API007Data_Server : API007Data__NVDataFbkReadData(uint8 client_node_id, uint16 index, uint16 size, uint8 *read_data_ptr)
    135          	API007Data_Server --> API007Data_Client : FBK, OPCODE - API007_OP_REQ_READ_NVDATA(0x14),\nDATA[0-1] - index\nDATA[2...] - Read Data
    136          	API007Data_Client -> API007NVData_Client : API007NVData__ReceivedRead(uint16 index ,uint16 size, uint8 * data_ptr)
    137          
    138          
    139          							==  Write ==
    140          	API007NVData_Client -> API007Data_Client : API007Data__NVDataCmdWriteRequest(uint16 index, uint16 size, uint8 *write_data_ptr)
    141          
    142          	API007Data_Client -> API007Data_Server : CMD, OPCODE - API007_OP_REQ_WRITE_NVDATA(0x15),\nDATA[0-1] - index\nDATA[2...] - Write Data
    143          
    144          	API007Data_Server -> API007NVData_Server : API007NVData__ProcessWriteCmd(uint8 client_node_id, uint16 index ,uint16 size, uint8 * data_ptr)
    145          	API007NVData_Server ->API007Data_Server : API007Data__NVDataFbkWriteData(uint8 client_node_id, uint16 index)
    146          	API007Data_Server --> API007Data_Client : FBK, OPCODE - API007_OP_REQ_WRITE_NVDATA(0x15),\nDATA[0-1] - index(currently pointing after the write cmd)
    147          	API007Data_Client -> API007NVData_Client : API007NVData__ReceivedWrite(uint16 index)
    148          
    149          
    150          
    151          	@enduml
