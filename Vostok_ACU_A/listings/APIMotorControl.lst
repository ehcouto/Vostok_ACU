   1000          #ifndef API220_FVT_ONLY
   1001          //---------------------------------------------------------------------------------------------------------------------
   1002          /**
   1003           * @brief       Set digital data in the Mci. The data comes from Reveal, is parsed within this method. If there is a
   1004           *              free spot in the Reveal stack, then the Mci set digital command is performed
   1005           * @param       buffer a pointer to the incoming Reveal buffer
   1006           * @return      TRUE: The variable was successfully changed.
   1007           *              FALSE: The variable could not be changed.
   1008           */
   1009          uint8 Set_Digital(REVEAL_MSG_TYPE *buffer)
   1010          {
   1011              uint8 dig_feedback;
   1012              uint8 ret_val;
   1013              MOTOR_ENUM_TYPE motor_index;
   1014              MCI_DO_TYPE dig_index;
   1015              uint8 dig_data;
   1016              REVEAL_COMMAND_TYPE *command;
   1017          
   1018              ret_val = FALSE;                                // Default answer is false.
   1019          
   1020              if(buffer->sdu_length == 5)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
   1021              {
   1022                  command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_SET_DIGITAL, REVEAL_BROADCAST_NODE, 4);
   1023                  if(command != NULL)
   1024                  {
   1025                      // Recover the data from the serial communication.
   1026                      motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
   1027                      dig_index = (MCI_DO_TYPE)buffer->payload[1];
   1028                      dig_data = (MCI_DO_TYPE)buffer->payload[2];
   1029                      dig_data = GET_TRUE_FALSE(dig_data);
   1030          
   1031          #ifdef API220_ENABLE_MCI_CALLS
   1032                      // Invoke the Mci Command.
   1033                      dig_feedback = Mci__SetDigital(motor_index, dig_index, (T_BOOL)dig_data);
   1034          #else
   1035                      dig_feedback = FALSE;
   1036          #endif
   1037          
   1038                      // Build and enqueue the Reveal buffer with the required feedback
   1039                      Reveal__AddDataU8(command, motor_index);
   1040                      Reveal__AddDataU8(command, dig_index);
   1041                      Reveal__AddDataU8(command, dig_data);
   1042                      Reveal__AddDataU8(command, dig_feedback);
   1043          
   1044                      ret_val = Reveal__QueueCommand(command);
   1045                  }
   1046              }
   1047          
   1048              return(ret_val);
   1049          }
   1050          
   1051          
   1052          
   1053          //---------------------------------------------------------------------------------------------------------------------
   1054          /**
   1055           * @brief       Get analog data from Mci according to the incoming Reveal buffer.
   1056           * @param       buffer a pointer to the incoming Reveal buffer
   1057           * @return      TRUE data is read and has properly fedback the Reveal protocol
   1058           *              FALSE data wasn't read nor built in the Reveal stack
   1059           */
   1060          uint8 Get_Analog(REVEAL_MSG_TYPE *buffer)
   1061          {
   1062              uint8 ret_val;
   1063              MOTOR_ENUM_TYPE motor_index;
   1064              MCI_AI_TYPE analog_data_index;
   1065          
   1066              ret_val = FALSE;                                // Default answer is false.
   1067          
   1068              if(buffer->sdu_length == 4)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
   1069              {
   1070                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
   1071                  analog_data_index = (MCI_AI_TYPE)buffer->payload[1];
   1072          
   1073                  ret_val = Publish_Analog_Input(motor_index, analog_data_index);
   1074              }
   1075          
   1076              return(ret_val);
   1077          }
   1078          
   1079          
   1080          
   1081          
   1082          //---------------------------------------------------------------------------------------------------------------------
   1083          /**
   1084           * @brief       Publish on the Reveal bus the requested analog data.
   1085           * @param       motor_index is the requested motor index connected to the Mci API implementation.
   1086           * @param       analog_data_index indexes the requested analog data from the Mci API implementation
   1087           * @return      TRUE data was properly read and set in the Reveal buffer
   1088           *              FALSE data wasn't able to be read nor be built on the on the Reveal buffer
   1089           */
   1090          uint8 Publish_Analog_Input(MOTOR_ENUM_TYPE motor_index, MCI_AI_TYPE analog_data_index)
   1091          {
   1092              uint16 temp_u16;
   1093              uint8 ret_val;
   1094              sint32 analog_data;
   1095              REVEAL_COMMAND_TYPE *command;
   1096          
   1097              ret_val = FALSE;                            // By default, the feedback is FALSE.
   1098          
   1099              // Check and, if available, enqueue a new Reveal feedback.
   1100              command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_GET_ANALOG, REVEAL_BROADCAST_NODE, 6);
   1101              if(command != NULL)
   1102              {
   1103                  if(analog_data_index < MCI_AI_NR_OF_AI)
   1104                  {
   1105                   	// Invoke Mci with required analog data to be read
   1106                  	analog_data = (sint32)Mci__GetAnalog(motor_index, analog_data_index);
   1107          
   1108                  	// Build and enqueue the Reveal buffer with the required feedback
   1109                  	Reveal__AddDataU8(command, motor_index);
   1110                  	Reveal__AddDataU8(command, analog_data_index);
   1111                  	Reveal__AddDataU32(command, (uint32)analog_data);        
   1112                  }
   1113                  else
   1114                  {
   1115                      // Build and enqueue the Reveal buffer with the required feedback
   1116                      Reveal__AddDataU8(command, motor_index);
   1117                      Reveal__AddDataU8(command, analog_data_index);
   1118          
   1119                      temp_u16 = (uint16)(Mci__GetAnalog(MOTOR0, MCI_AI_SPEED_REFERENCE_RPM_S16)>>16);
   1120                      Reveal__AddDataU16(command, temp_u16);
   1121          
   1122                      temp_u16 = (uint16)(Mci__GetAnalog(MOTOR0, MCI_AI_ACTUAL_SPEED_S16)>>16);
   1123                      Reveal__AddDataU16(command, temp_u16);
   1124          
   1125                      temp_u16 = (uint16)Mci__GetAnalog(MOTOR0, MCI_AI_INTERNAL_MCI_STATE);
   1126                      Reveal__AddDataU8(command, (uint8)temp_u16);
   1127          
   1128                      temp_u16 = (uint16)(Mci__GetAnalog(MOTOR0, MCI_AI_BUS_VOLTAGE_S16)>>16);
   1129                      Reveal__AddDataU16(command, temp_u16);
   1130                  }
   1131          
   1132                  ret_val = Reveal__QueueCommand(command);
   1133              }
   1134          
   1135              return(ret_val);
   1136          }
   1137          
   1138          
   1139          
   1140          
   1141          //---------------------------------------------------------------------------------------------------------------------
   1142          /*
   1143           * @brief       Set analog data in the Mci.
   1144           * @param       buffer a pointer to the incoming Reveal buffer
   1145           * @return      TRUE: The variable was successfully changed.
   1146           *              FALSE: The variable could not be changed.
   1147           */
   1148          uint8 Set_Analog(REVEAL_MSG_TYPE *buffer)
   1149          {
   1150              uint8 ret_val;
   1151              uint8 feedback;
   1152              MOTOR_ENUM_TYPE motor_index;
   1153              MCI_AO_TYPE analog_data_index;
   1154              uint32 analog_data;
   1155              REVEAL_COMMAND_TYPE *command;
   1156          
   1157              ret_val = FALSE;                                // Default answer is FALSE
   1158          
   1159              if(buffer->sdu_length == 8)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
   1160              {
   1161                  // Check and, if available, enqueue a new Reveal feedback.
   1162                  command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_SET_ANALOG, REVEAL_BROADCAST_NODE, 7);
   1163                  if(command != NULL)
   1164                  {
   1165                      motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
   1166                      analog_data_index = (MCI_AO_TYPE)buffer->payload[1];
   1167                      analog_data =   (((uint32)buffer->payload[2])<<24) +
   1168                                      (((uint32)buffer->payload[3])<<16) +
   1169                                      (((uint32)buffer->payload[4])<<8)  +
   1170                                      (((uint32)buffer->payload[5]));
   1171          
   1172          #ifdef API220_ENABLE_MCI_CALLS
   1173                      // Invoke Mci to write the analog data
   1174                      feedback = Mci__SetAnalog(motor_index, analog_data_index, analog_data);
   1175          #else
   1176                      feedback = FALSE;
   1177          #endif
   1178          
   1179                      // Update last user analog write request
   1180                      Last_Analog_Output[motor_index][analog_data_index] = analog_data;
   1181          
   1182                      // Build and enqueue the Reveal buffer with the required feedback
   1183                      Reveal__AddDataU8(command, motor_index);
   1184                      Reveal__AddDataU8(command, analog_data_index);
   1185                      Reveal__AddDataU32(command, analog_data);
   1186                      Reveal__AddDataU8(command, feedback);
   1187          
   1188                      ret_val = Reveal__QueueCommand(command);
   1189                  }
   1190              }
   1191          
   1192              return(ret_val);
   1193          }
   1194          
   1195          
   1196          
   1197          
   1198          //---------------------------------------------------------------------------------------------------------------------
   1199          /*
   1200           * @brief       Parse the buffer that sets the parameters to periodically publish the analog data.
   1201           * @param       buffer a Reveal buffer to be parsed
   1202           * @return      TRUE the command accepted with all parameters correct. FALSE something was wrong in the requested data
   1203           */
   1204          uint8 Set_Data_Periodically_Publish(REVEAL_MSG_TYPE *buffer)
   1205          {
   1206              MOTOR_ENUM_TYPE motor_index;
   1207              MCI_AI_TYPE analog_data_index;
   1208              uint8 publish_rate;
   1209              uint8 ret_val;
   1210          
   1211              ret_val = FALSE;                                // Default answer is FALSE
   1212          
   1213              if(buffer->sdu_length == 5)                     // This command requests receiving this amount of bytes, include API and Opcode bytes.
   1214              {
   1215                  // Build the data from the buffer
   1216                  motor_index = (MOTOR_ENUM_TYPE)buffer->payload[0];
   1217                  analog_data_index = (MCI_AI_TYPE)buffer->payload[1];
   1218                  publish_rate = buffer->payload[2];
   1219          
   1220                  // Sanity check on the given parameters
   1221                  if( (motor_index < API220_NR_OF_CONNECTED_MOTORS) &&
   1222                      (analog_data_index < MCI_AI_NR_OF_AI)   )
   1223                  {
   1224                      // If the rate is different than zero, it means that something has to be published periodically
   1225                      if(publish_rate)
   1226                      {
   1227                          // Enable the periodic publishing according to the received bytes.
   1228                          Api220_Per_Analog_Data[motor_index][analog_data_index].Publish_Requested = TRUE;
   1229                          Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Threshold = (publish_rate * 40)/API220_NR_OF_CONNECTED_MOTORS;
   1230                          Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Counter = 0;
   1231                      }
   1232                      else // otherwise, it is requested to stop publishing
   1233                      {
   1234                          // Disable the periodic publishing.
   1235                          Api220_Per_Analog_Data[motor_index][analog_data_index].Publish_Requested = FALSE;
   1236                          Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Threshold = 0;
   1237                          Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Counter = 0;
   1238                      }
   1239          
   1240                      ret_val = TRUE;                         // command accepted.
   1241                  }
   1242          
   1243              }
   1244          
   1245              return(ret_val);
   1246          }
   1247          #endif
   1248          #if (MCI_FVT_TESTS == ENABLED)
   1249          
   1250          
   1251          
   1252          
   1253          //---------------------------------------------------------------------------------------------------------------------
   1254          /*
   1255           * @brief       Parse commands required by FVT mode.
   1256           * @details     Parse and communicates to FVT tests, start, stop, request and publish results.
   1257           * @param       buffer a Reveal buffer to be parsed
   1258           * @return      TRUE the command accepted with all parameters correct. FALSE something was wrong in the requested data
   1259           */
   1260          
   1261          
   1262          static uint8 Api220_Fvt_Mode(REVEAL_MSG_TYPE *buffer)
   1263          {
   1264              API220_FVT_COMMANDS_TYPE fvt_command;
   1265              uint8 feedback;
   1266              MOTOR_ENUM_TYPE motor_index;
   1267              REVEAL_COMMAND_TYPE *command;
   1268              uint8 ret_val;
   1269          
   1270              ret_val = FALSE;                                // Default answer is FALSE
   1271          
   1272              // parse incoming package
   1273              fvt_command = (API220_FVT_COMMANDS_TYPE)buffer->payload[0];
   1274              motor_index = (MOTOR_ENUM_TYPE)buffer->payload[1];
   1275          
   1276              switch(fvt_command)
   1277              {
   1278                  case API220_FVT_START:
   1279          
   1280                      //custom code
   1281                      API220_FVT_START_CALLBACK();
   1282          
   1283                      // Check and, if available, enqueue a new Reveal feedback.
   1284                      command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_FVT, REVEAL_BROADCAST_NODE, 6);
   1285                      if(command != NULL)
   1286                      {
   1287                          feedback = FVT_START(motor_index);
   1288          
   1289                          Api220_Fvt_Result_Published = FALSE;
   1290          
   1291                          Reveal__AddDataU8(command, fvt_command);
   1292                          Reveal__AddDataU8(command, motor_index);
   1293                          Reveal__AddDataU8(command, feedback);
   1294          
   1295                          ret_val = Reveal__QueueCommand(command);
   1296                      }
   1297                      break;
   1298          
   1299                  case API220_FVT_STOP:
   1300          
   1301                      //custom code
   1302                      API220_FVT_STOP_CALLBACK();
   1303          
   1304                      // Check and, if available, enqueue a new Reveal feedback.
   1305                      command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_FVT, REVEAL_BROADCAST_NODE, 6);
   1306                      if(command != NULL)
   1307                      {
   1308                          feedback = FVT_STOP(motor_index);
   1309          
   1310                          Reveal__AddDataU8(command, fvt_command);
   1311                          Reveal__AddDataU8(command, motor_index);
   1312                          Reveal__AddDataU8(command, feedback);
   1313          
   1314                          ret_val = Reveal__QueueCommand(command);
   1315                      }
   1316                      break;
   1317          
   1318                  case API220_FVT_REQUEST_RESULT:
   1319                      ret_val = Publish_Fvt_Result();
   1320                      break;
   1321          
   1322                  default:
   1323                      // Left blank intentionally
   1324                      break;
   1325              }
   1326          
   1327          
   1328          
   1329              return(ret_val);
   1330          }
   1331          
   1332          uint8 Publish_Fvt_Result(void)
   1333          {
   1334              REVEAL_COMMAND_TYPE *command;
   1335              MCI_FVT_TEST_RESULT_TYPE fvt_result;
   1336              MCL_FVT_PARAMS_TYPE *fvt_parameters;
   1337              MOTOR_ENUM_TYPE motor_index;
   1338              uint8 ret_val;
   1339          
   1340              ret_val = FALSE;
   1341          
   1342          #ifdef MCL_FVT_LEGACY
   1343              // Check and, if available, enqueue a new Reveal feedback.
   1344              command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_FVT, REVEAL_BROADCAST_NODE, 6);
   1345              if(command != NULL)
   1346              {
   1347                  MclFvt__GetResult(&fvt_result);
   1348                  fvt_parameters = MclFvt__GetParameters();
   1349                  motor_index = FVT_GET_MOTOR();
   1350          
   1351                  Reveal__AddDataU8(command, API220_FVT_REQUEST_RESULT);
   1352                  Reveal__AddDataU8(command, motor_index);
   1353          
   1354                  Reveal__AddDataU8(command, fvt_result.Error_List);
   1355          
   1356                  for(uint8 i=0; i< (fvt_parameters->ADC_Injection_Steps); i++)
   1357                  {
   1358                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_DC_Bus_Min));
   1359                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_A));
   1360                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_B));
   1361                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_C));
   1362                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_A));
   1363                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_B));
   1364                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_C));
   1365                  }
   1366          
   1367                  Reveal__AddDataU16(command, (uint16)(fvt_result.Surge_Test_Avg_DC_Bus_Volt_Open));
   1368                  Reveal__AddDataU16(command, (uint16)(fvt_result.Surge_Test_Avg_DC_Bus_Volt_Close));
   1369          
   1370                  Reveal__AddDataU8(command, fvt_result.OC_Test_Found[0]);
   1371          
   1372                  // first packet
   1373                  ret_val = Reveal__QueueCommand(command);
   1374              }
   1375          
   1376          #else
   1377          
   1378              // Check and, if available, enqueue a new Reveal feedback.
   1379              command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_FVT, REVEAL_BROADCAST_NODE, 6);
   1380              if(command != NULL)
   1381              {
   1382                  MclFvt__GetResult(&fvt_result);
   1383                  fvt_parameters = MclFvt__GetParameters();
   1384                  motor_index = FVT_GET_MOTOR();
   1385          
   1386                  Reveal__AddDataU8(command, API220_FVT_REQUEST_RESULT_FVT2_1);
   1387                  Reveal__AddDataU8(command, motor_index);
   1388                  Reveal__AddDataU8(command, fvt_result.Error_List);
   1389          
   1390          
   1391                  Reveal__AddDataU16(command, (uint16)(fvt_result.adc_idle.Sensors_Test_Avg_DC_Bus_Idle));
   1392                  Reveal__AddDataU16(command, (uint16)(fvt_result.adc_idle.Sensors_Test_Avg_Inverter_Temp));
   1393                  Reveal__AddDataU16(command, (uint16)(fvt_result.adc_idle.Sensors_Test_Avg_Micro_Temp));
   1394                  Reveal__AddDataU16(command, (uint16)(fvt_result.adc_idle.Sensors_Test_Avg_Delta_Temp));
   1395          
   1396          
   1397                  for(uint8 i=0; i<MCLFVT_INJECTION_POSITION_STEPS_MAX; i++)
   1398                  {
   1399                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_DC_Bus_Min));
   1400                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_DC_Bus_Max));
   1401                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_DC_Bus_Ripple));
   1402                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_A));
   1403                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_B));
   1404                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Phase_Volt_C));
   1405                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_A));
   1406                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_B));
   1407                      Reveal__AddDataU16(command, (uint16)(fvt_result.current_inj[i].Sensors_Test_Avg_Curr_C));
   1408                  }
   1409          
   1410                  // first packet
   1411                  ret_val = Reveal__QueueCommand(command);
   1412              }
   1413          
   1414          
   1415              command = Reveal__NewFeedback(API220_MOTOR_CONTROL_NUM, API220_OPCODE_MOTOR_CONTROL_FVT, REVEAL_BROADCAST_NODE, 6);
   1416          
   1417              if(command != NULL)
   1418              {
   1419                  Reveal__AddDataU8(command, API220_FVT_REQUEST_RESULT_FVT2_2);
   1420                  Reveal__AddDataU8(command, motor_index);
   1421          
   1422                  Reveal__AddDataU16(command, (uint16)(fvt_result.Surge_Test_Avg_DC_Bus_Volt_Open));
   1423                  Reveal__AddDataU16(command, (uint16)(fvt_result.Surge_Test_Avg_DC_Bus_Volt_Close));
   1424          
   1425                  for(uint8 i= 0; i<MCLFVT_OC_POSITION_STEPS_MAX; i++)
   1426                  {
   1427                      Reveal__AddDataU8(command, (uint8)(fvt_result.OC_Test_Found[i]));
   1428                  }
   1429                  // second packet
   1430                  ret_val = Reveal__QueueCommand(command);
   1431              }
   1432          #endif
   1433          
   1434              return(ret_val);
   1435          }
   1436          
   1437          #endif
   1438          #ifndef API220_FVT_ONLY
   1439          //---------------------------------------------------------------------------------------------------------------------
   1440          /*
   1441           * @brief       Handle the algorithms for periodic analog data publishing.
   1442           */
   1443          void Periodically_Publish_Analog(void)
   1444          {
   1445              static MOTOR_ENUM_TYPE motor_index;
   1446              uint8 analog_data_index;
   1447          
   1448              // Handle the connected motor amount, it shall sweep of number of the connected motors
   1449              motor_index++;
   1450              if(motor_index >= API220_NR_OF_CONNECTED_MOTORS)
   1451              {
   1452                  motor_index = MOTOR0;
   1453              }
   1454          
   1455              // Sweeps all the requested analog data for publishing
   1456              for(analog_data_index = 0; analog_data_index < (1+MCI_AI_NR_OF_AI); analog_data_index++)
   1457              {
   1458                  // Check if the data defined in the PUBLISH_ANALOG_DATA_TYPE is requested for periodic publishing
   1459                  if(Api220_Per_Analog_Data[motor_index][analog_data_index].Publish_Requested == TRUE)
   1460                  {
   1461                      // If the publishing time is not yet over, then
   1462                      if(Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Counter)
   1463                      {
   1464                          // count the time.
   1465                          Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Counter--;
   1466                      }
   1467                      else // otherwise
   1468                      {
   1469                          // attempt to build and stack the command on the wide, if it was stacked,
   1470                          if(Publish_Analog_Input(motor_index, (MCI_AI_TYPE)analog_data_index) == TRUE)
   1471                          {
   1472                              // then reload the time for publishing.
   1473                              Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Counter = Api220_Per_Analog_Data[motor_index][analog_data_index].Time_Threshold;
   1474                          }
   1475                      }
   1476                  }
   1477              }
   1478          }
   1479          
   1480          
   1481          
   1482          
   1483          //---------------------------------------------------------------------------------------------------------------------
   1484          /*
   1485           * @brief       Manual control of the inverter output
   1486           * @detail      The output can be manually controlled, this output might be the voltage vector or the current vector.
   1487           * @param       buffer - a pointer to the received Reveal buffer.
   1488           * @return      Returns whether Mci has accepted or not the command; TRUE = accepted; FALSE = denied
   1489           */
   1490          uint8 Manual_Control(REVEAL_MSG_TYPE *buffer)
