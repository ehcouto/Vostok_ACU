    720              // For negative force test: ACCEL_SELF_TEST_DISCARD_COUNT + ACCEL_SELF_TEST_SAMPLES
    721              #define ACCEL_SELF_TEST_TOTAL_SAMPLES (3.0 * (ACCEL_SELF_TEST_DISCARD_COUNT + ACCEL_SELF_TEST_SAMPLES))
    722              // Sample rate is based on LISXDH_MODE_ST_REF, LISXDH_MODE_ST_0, and LISXDH_MODE_ST_1.
    723              #define ACCEL_SELF_TEST_MILLISECONDS_PER_SAMPLE (1000.0 / 400.0)
