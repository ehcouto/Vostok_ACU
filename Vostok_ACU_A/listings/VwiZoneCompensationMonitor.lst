     97          /**
     98           * It initializes the Vwi Zone Compensation Monitor and its data.
     99           *
    100           * @return None
    101           *
    102           */
    103          void VwiZoneCompensationMonitor__Initialize(void)
    104          {
    105          	if (Micro__GetResetMode() == MICRO_RESET_MODE_COLD)
    106          	{
    107          		SETTINGFILE_LOADER_TYPE loader;
    108          		Vwi_Zone_Compensation_Common_Params = NULL;
    109          		if (SettingFile__BasicLoader(SF_PTR_ACU_ALGORITHM_PARAMETERS, DISPL_VWI_ZONE_COMPENSATION_COMMON, &loader) == PASS)
    110          		{
    111          			Vwi_Zone_Compensation_Common_Params = (const VWI_ZONE_COMPENSATION_COMMON_PARAMS_TYPE *)(void*)(loader.Data);
    112          
    113          			VwiZoneCompensationReadParams();
    114          
    115          			VWIZC_Diverter_Position = 0;
    116          			VWIZC_Current_Multiplier = 0;
    117          			VWIZC_Old_Current_Multiplier = 0;
    118          			VWIZC_Old_Diverter_Position_Is_Stable = FALSE;
    119          			VWIZC_Diverter_Position_Requested = NULL;
    120          			VWIZC_Last_Diverter_Position = 0;
    121          		}
    122          		else
    123          		{
    124          			VWIZC_Current_Multiplier = VWI_MULTIPLIER_DEFAULT;
    125          			VWIZC_Old_Current_Multiplier = 0;
    126          		}
    127          #if (VWI_CLIENT_FEATURE == ENABLED)
    128          		// When VWI is on an external server, the first API013 command sending is triggered by the condition
    129          		// (VWIZC_Refresh_Command_Counter = 0).
    130          		// Setting
    131          		// 		VWIZC_Old_Current_Multiplier = VWIZC_Current_Multiplier;
    132          		// prevent the API013 command from being sent multiple times before the first API013 status packet is received.
    133          		VWIZC_Old_Current_Multiplier = VWIZC_Current_Multiplier;
    134          
    135          		VWIZC_Refresh_Command_Counter = 0;
    136          		API013RemoteFunction__RegisterForEvents((API013_EVENT_HANDLER_TYPE)VwiZoneCompensation_API013ApplReceivedStatus);
    137          #endif // (VWI_CLIENT_FEATURE == ENABLED)
    138          	}
    139          }
    140          
    141          
    142          //----------------------------------------------------------------------------
    143          /**
    144           * It implements the execution of the Vwi Zone Compensation Monitor
    145           *
    146           * @return None
    147           *
    148           */
    149          void VwiZoneCompensationMonitor__Execution(void)
    150          {
    151          #if (VWI_CLIENT_FEATURE == ENABLED)
    152          	uint16 reveal_node_status;
    153          	uint8 *mcu_enable_state_ptr;
    154          #endif // (VWI_CLIENT_FEATURE == ENABLED)
    155          
    156          	if ((Vwi_Zone_Compensation_Common_Params != NULL) && (DishAuxVar__IsDrainPumpOn() == FALSE))
    157          	{
    158          		SETTINGFILE_LOADER_TYPE loader;
    159          		uint8 num_items;
    160          
    161          		if (Diverter_Position_Unknown() == FALSE)
    162          		{
    163          			if ((uint8)DishAuxVar__GetDiverterPosition().Is_Stable == (uint8)TRUE)
    164          			{
    165          				VWIZC_Diverter_Position = DishAuxVar__GetDiverterPosition().Position;
    166          
    167          				VWIZC_Last_Diverter_Position = VWIZC_Diverter_Position;
    168          
    169          				SystemTimers__NVResetTimer(&NV_Timer_Handle_Vwi_Moltiplier_Delay);
    170          			}
    171          			else if ((DishAuxVar__GetDiverterPosition().Is_Stable == FALSE) && ((uint8)VWIZC_Old_Diverter_Position_Is_Stable == (uint8)TRUE))
    172          			{
    173          				VWIZC_Diverter_Position_Requested = (uint8*)Hbl__GetRequestedLoad(Hbl__GetLoadIndexByLoadID(HBL_LOAD_DIVERTER));
    174          
    175          				if ((VWIZC_Diverter_Position_Requested != NULL) && (*VWIZC_Diverter_Position_Requested < (uint8)DIVERTER_POSITION_MAX))
    176          				{
    177          					if ((VWIZC_Multiplier_Pos[*VWIZC_Diverter_Position_Requested] > VWIZC_Multiplier_Pos[VWIZC_Diverter_Position]) &&
    178          							(VWIZC_Multiplier_Pos[*VWIZC_Diverter_Position_Requested] != (uint16)__UNSIGNED_SHORT_MAX__))
    179          					{
    180          						VWIZC_Diverter_Position = *VWIZC_Diverter_Position_Requested;
    181          						SystemTimers__NVResetTimer(&NV_Timer_Handle_Vwi_Moltiplier_Delay);
    182          					}
    183          					else
    184          					{
    185          						if (Vwi_Zone_Compensation_Common_Params->Multiplyer_Delay == (uint8)0)
    186          						{
    187          							VWIZC_Diverter_Position = *VWIZC_Diverter_Position_Requested;
    188          						}
    189          						else
    190          						{
    191          							(void)SystemTimers__NVSetTimerMS(&NV_Timer_Handle_Vwi_Moltiplier_Delay, Vwi_Zone_Compensation_Common_Params->Multiplyer_Delay*(uint32)100 ,SYSTEMTIMERS_TYPE_DOWN_COUNTER);
    192          						}
    193          					}
    194          				}
    195          			}
    196          
    197          			VWIZC_Old_Diverter_Position_Is_Stable = DishAuxVar__GetDiverterPosition().Is_Stable;
    198          
    199          			if (SystemTimers__NVCheckTimer(&NV_Timer_Handle_Vwi_Moltiplier_Delay) == SYSTEMTIMERS_STATE_DONE)
    200          			{
    201          				if (VWIZC_Diverter_Position_Requested != NULL)
    202          				{
    203          					VWIZC_Diverter_Position = *VWIZC_Diverter_Position_Requested;
    204          				}
    205          
    206          				SystemTimers__NVResetTimer(&NV_Timer_Handle_Vwi_Moltiplier_Delay);
    207          			}
    208          		}
    209          
    210          		if (SettingFile__BasicLoader(SF_PTR_ACU_ALGORITHM_PARAMETERS, DISPL_VWI_ZONE_COMPENSATION_MULTIPLIERS, &loader) == PASS)
    211          		{
    212          			num_items = (uint8)(loader.Length/sizeof(VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE));
    213          
    214          			if (VWIZC_Diverter_Position < num_items)
    215          			{
    216          				if (Diverter_Position_Unknown() == FALSE)
    217          				{
    218          					VWIZC_Current_Multiplier = VWIZC_Multiplier_Pos[VWIZC_Diverter_Position];
    219          				}
    220          				else
    221          				{
    222          					if ((uint8)Vwi_Zone_Compensation_Common_Params->Unknown_Position_Multiplier_Enable == (uint8)TRUE)
    223          					{
    224          						VWIZC_Current_Multiplier = Vwi_Zone_Compensation_Common_Params->Multiplier_Position_Unknown;
    225          					}
    226          					else
    227          					{
    228          						VWIZC_Current_Multiplier = VWIZC_Multiplier_Pos[VWIZC_Last_Diverter_Position];
    229          					}
    230          				}
    231          			}
    232          			else
    233          			{
    234          				VWIZC_Current_Multiplier = VWI_MULTIPLIER_DEFAULT;
    235          			}
    236          		}
    237          		else
    238          		{
    239          			VWIZC_Current_Multiplier = VWI_MULTIPLIER_DEFAULT;
    240          		}
    241          	}
    242          	else
    243          	{
    244          		VWIZC_Current_Multiplier = VWI_MULTIPLIER_DEFAULT;
    245          	}
    246          
    247          #if (VWI_CLIENT_FEATURE == ENABLED)
    248          	reveal_node_status = Reveal__GetNodestatus();
    249          
    250          	mcu_enable_state_ptr = (uint8 *)Hbl__GetProcessedLoad(Hbl__GetLoadIndexByLoadID(HBL_LOAD_MCU_ENABLE));
    251          
    252          	if (VWIZC_Refresh_Command_Counter > (uint8)0)
    253          	{
    254          		VWIZC_Refresh_Command_Counter --;
    255          	}
    256          
    257          	if ((BIT_TEST(reveal_node_status, WIN_MCU_ADDRESS) != (uint8)0) && ((mcu_enable_state_ptr == NULL) || (*mcu_enable_state_ptr != (uint8)OFF)))
    258          	{
    259          		// MCU is on and is communicating
    260          		if ((VWIZC_Current_Multiplier != VWIZC_Old_Current_Multiplier) || (VWIZC_Refresh_Command_Counter == (uint8)0))
    261          		{
    262          			// VWI Multiplier has changed or it's time to refresh its value, the command is sent
    263          			uint8 enable_params[2];
    264          
    265          			enable_params[0] = HIBYTE(VWIZC_Current_Multiplier);
    266          			enable_params[1] = LOBYTE(VWIZC_Current_Multiplier);
    267          
    268          			(void)API013RemoteFunction__SendControl (API013_CLIENT_FUNCTION_VWI_MULTIPLIER,  REMOTE_FUNCTION_COMMAND_ENABLE, enable_params, sizeof(enable_params));
    269          
    270          			// Reload the refresh counter
    271          			VWIZC_Refresh_Command_Counter = VWI_MULTIPLIER_REFRESH_PERIOD;
    272          		}
    273          	}
    274          
    275          #else
    276          	if (VWIZC_Current_Multiplier != VWIZC_Old_Current_Multiplier)
    277          	{
    278          		Vwi_SetInputSignalMultiplier(VWIZC_Current_Multiplier);
    279          
    280          		VWIZC_Old_Current_Multiplier = VWIZC_Current_Multiplier;
    281          	}
    282          #endif // (VWI_CLIENT_FEATURE == DISABLED)
    283          
    284          }
    285          
