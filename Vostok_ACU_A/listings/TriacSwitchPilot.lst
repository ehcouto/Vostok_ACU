     30          
     31          #define     TRIAC_SWITCH_OFF_DELAY_MS       5U
     32          
     33          typedef enum
     34          {
     35              TRIACSWITCH_OFF_STATE = 0,
     36              TRIACSWITCH_SYNC_STATE,
     37              TRIACSWITCH_ON_STATE,
     38              TRIACSWITCH_TURNING_OFF,
     39              TRIACSWITCH_END_STATE,
     40          }TRIACSWITCHPILOT_STATE_TYPE;
     41          
     42          
     43          typedef struct
     44          {
     45              uint8                           Requested;
     46              uint8                           Processed;
     47              uint16                          Timer_Counter;
     48              TRIACSWITCHPILOT_STATE_TYPE     State;
     49              TRIACSWITCHPILOT_STATUS_TYPE    Pilot_Status;
     50          } TRIACSWITCHPILOT_DATA_TYPE;
     51          
     52          static TRIACSWITCHPILOT_DATA_TYPE Triac_Switch_Data[HBL_PILOT_NUM_TRIACSWITCH];
     53          
     54          /* Current TriacSwitchPilot allocated */
     55          static uint8 Triac_Switch_Allocation;
     56          
