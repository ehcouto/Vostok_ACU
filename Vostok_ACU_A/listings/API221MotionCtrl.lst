    124              // Force TIMEOUT_TO_STOP to a default value if API221_MS_TIMEOUT_TO_STOP is undefined.
    125              //! Number of background function calls to wait before forcing a stop of the motor.
    126              #ifndef API221_MS_TIMEOUT_TO_STOP
    127                  #define TIMEOUT_TO_STOP                         (5000 / API221_MS_PER_CALL_TO_BACKGROUND)
    128              #elif (API221_MS_TIMEOUT_TO_STOP == 0)
    129                  #define TIMEOUT_TO_STOP                         (0)
    130              #elif (API221_MS_TIMEOUT_TO_STOP < 1000)
    131                  #define TIMEOUT_TO_STOP                         (1000 / API221_MS_PER_CALL_TO_BACKGROUND)
    132              #elif (API221_MS_TIMEOUT_TO_STOP > 15000)
    133                  #define TIMEOUT_TO_STOP                         (15000 / API221_MS_PER_CALL_TO_BACKGROUND)
    134              #else
    135                  #define TIMEOUT_TO_STOP                         (API221_MS_TIMEOUT_TO_STOP / API221_MS_PER_CALL_TO_BACKGROUND)
    136              #endif
    137              // Ensure that the auto-stop time is in the valid range.
    138              CT_ASSERT((TIMEOUT_TO_STOP >= 0) && (TIMEOUT_TO_STOP <= USHRT_MAX));
    139          #endif      // #if (API221_SERVER_FEATURE == ENABLED)
