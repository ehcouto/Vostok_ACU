   \                                 In section .text, align 2, keep-with-next
     79          void VwiMonitor__Initialize(void)
     80          {
     81          #if(VWI_CLIENT_FEATURE == ENABLED)
     82          
     83          	if (Micro__GetResetMode() == MICRO_RESET_MODE_COLD)
     84          	{
     85          		VwiMonitor_Callback_Active = FALSE;
