   1294          //---------------------------------------------------------------------------------------------------------------------
   1295          /**
   1296           * Handle events published through API221.
   1297           * This function is called by the communication thread.
   1298           * @param event = The event that was published through API221.
   1299           */
   1300          static void API221HandleMotorEvent(API221_EVENT_TYPE event)
   1301          {
   1302          	switch (event.Event)
   1303          	{
   1304          		 case API221_EVENT_STOPPED:
   1305          			 if (This_Pc->Pump_Control_State != STATE_PUMP_CONTROL_WAIT_STOPPED)
   1306          			 {
   1307          				 if ((PC_Subcycle_Name != CYCLE_NAME_WASH_MOTOR_FAULT) &&
   1308          				 	(PC_Subcycle_Name != CYCLE_NAME_DRAIN_MOTOR_FAULT))
   1309          				 {
   1310          					 LOG_ADD_EXCEPTION(ERROR_MCU_RESET, This_Pc->Pump_Control_State);
   1311          				 	 EventMcuReset();
   1312          				 }
   1313          			 }
   1314          			 else
   1315          			 {
   1316          				 EventRun();
   1317          			 }
   1318          			 break;
   1319          		 case API221_EVENT_REACHED_TARGET:
   1320          			 if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_0)
   1321          			 {
   1322          				 PumpControl__SetPreviousWashMotorSpeed(This_Pc->PC_Motor_Speed);
   1323          			 }
   1324          			 else if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_1)
   1325          			 {
   1326          				 PumpControl__SetPreviousDrainMotorSpeed(This_Pc->PC_Motor_Speed);
   1327          			 }
   1328          			 break;
   1329          		 case API221_EVENT_DEBLOCKING_READY:
   1330          		 	 if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_0)
   1331          			 {
   1332          		 		PC_Wash_Pump_Deblocking_Ready = TRUE;
   1333          			 }
   1334          			 else if (event.Motor == (API221_CLIENT_MOTOR_INDEX_TYPE)MOTOR_1)
   1335          			 {
   1336          		 		PC_Drain_Pump_Deblocking_Ready = TRUE;
   1337          			 }
   1338          		 	 break;
   1339          		 default:
   1340          			 // Ignore all other events
   1341          			 break;
   1342          	}
   1343          }
   1344          
   1345          static BOOL_TYPE Double_VSM_Pump_Cannot_Run(PROCESS_CONTROL_TYPE* process_control)
   1346          {
   1347          	HBL_PILOT_ENUM_TYPE drain_pump_pilot_type = Hbl__GetPilotIDByIndex(Hbl__GetLoadIndexByLoadID(HBL_LOAD_DRAIN_PUMP));
   1348          	BOOL_TYPE return_value = FALSE;
   1349          	if (drain_pump_pilot_type != HBL_PILOT_EXTERNAL_MOTOR)
   1350          	{
   1351          		return_value = FALSE;
   1352          	}
   1353          	else
   1354          	{
   1355          		if ((process_control->F1_F0_Flags != (uint8)DRAIN_PUMP_CONTROL_ACTIVATE) && ((uint8)PumpControl__GetVSMDrainIsRunning() == (uint8)TRUE))
   1356          		{
   1357          			return_value = TRUE;
   1358          		}
   1359          		else
   1360          		{
   1361          			return_value = FALSE;
   1362          		}
   1363          	}
   1364          
   1365          	return return_value;
   1366          }
