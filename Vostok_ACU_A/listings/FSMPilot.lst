     98          /**
     99           * @brief
    100           * @return
    101           */
    102          void FSMPilot__Initialize(void)
    103          {
    104              FSMPilot_Allocation = 0;
    105              memset (FSMPilot_Data , 0 , sizeof(FSMPilot_Data));
    106          
    107          }
    108          
    109          
    110          //---------------------------------------------------------------------------------------------------------------------
    111          /**
    112           * @brief
    113           * @return
    114           */
    115          uint8 FSMPilot__Allocate(void)
    116          {
    117              uint8 retval;
    118              retval = 0xFF;
    119              if (FSMPilot_Allocation < HBL_PILOT_NUM_FSM)
    120              {
    121                  retval = FSMPilot_Allocation;
    122                  FSMPilot_Allocation++;
    123          
    124              }
    125              return (retval);
    126          }
    127          
    128          
    129          //---------------------------------------------------------------------------------------------------------------------
    130          /**
    131           *
    132           * @param load
    133           */
    134          PASS_FAIL_TYPE FSMPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    135          {
    136          	FSMPILOT_DATA_TYPE *data;
    137          	PASS_FAIL_TYPE retval;
    138              uint8 virtual_pin;
    139              uint8 loop_index;
    140              retval = FAIL;
    141          
    142              if (load->Pilot_Data_Index < FSMPilot_Allocation)
    143              {
    144                  data = &FSMPilot_Data[load->Pilot_Data_Index];
    145                  data->State = FSMPILOT_SM_INIT; // set state machine val
    146          
    147                  for (loop_index = 0; loop_index < 3; loop_index++)
    148                  {
    149                  	virtual_pin = load->Pin_Ptr[loop_index];
    150          
    151                      if (VIRTUALPIN_TABLE[virtual_pin].port != 0xFF)
    152                      {
    153                          Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, VIRTUALPIN_TABLE[virtual_pin].pin_config);
    154                      }
    155                  }
    156          
    157                  retval = PASS;
    158              }
    159          
    160              return (retval);
    161          }
    162          
    163          
    164          //---------------------------------------------------------------------------------------------------------------------
    165          /**
    166           * @brief
    167           * @param load
    168           * @param data
    169           * @return
    170           */
    171          PASS_FAIL_TYPE FSMPilot__Request(HBL_LOAD_TYPE * load,void * data)
    172          {
    173              if (load->Pilot_Data_Index < FSMPilot_Allocation)
    174              {
    175              	FSMPilot_Data[load->Pilot_Data_Index].Requested = *(FSMPILOT_VELOCITY_TYPE *)data;
    176                  return (PASS);
    177              }
    178              else
    179              {
    180              	return (FAIL);
    181              }
    182          }
    183          
