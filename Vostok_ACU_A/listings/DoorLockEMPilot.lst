     89          /**
     90           *  @brief      It Initializes the module DoorLockEMPilot and its variables
     91           *
     92           */
     93          void DoorLockEMPilot__Initialize(void )
     94          {
     95              DoorLockEMPilot_Allocation = 0;
     96              memset(DoorLockEMPilot_Data, 0, sizeof(DoorLockEMPilot_Data));
     97          }
