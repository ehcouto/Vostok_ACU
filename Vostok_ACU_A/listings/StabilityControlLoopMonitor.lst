     42          //! A structure to hold non-volatile data for the Stability Control Loop monitor
     43          typedef struct STABILITY_CONTROL_LOOP_NV_DATA_STRUCT
     44          {
     45          	//! Timer 1 of the Stability Loop Control algorithm
     46          	uint16 Timer_1_Counter;
     47          
     48          	//! Timer 2 of the Stability Loop Control algorithm
     49          	uint16 Timer_2_Counter;
     50          
     51          	//! Incremented each time the heater is turned off due to VWI conditions
     52          	uint16 Relay_Counter;
     53          
     54          	//! Incremented each time the Primary Reaction is triggered
     55          	uint8 Primary_Reaction_Counter;
     56          
     57          	//! Incremented each time the Secondary Reaction is triggered
     58          	uint8 Secondary_Reaction_Counter;
     59          
     60          	//! If TRUE then the primary reaction is skipped and the secondary reaction is triggered
     61          	BOOL_TYPE Switch_To_Secondary_Reaction;
     62          } STABILITY_CONTROL_LOOP_NV_DATA_TYPE;
     63          
     64          //! A structure to hold volatile data for the Stability Control Loop monitor
     65          typedef struct STABILITY_CONTROL_LOOP_DATA_STRUCT
     66          {
     67          	//! Pointer to the setting file parameters for the Stability Control (they include Stability Control Loop parameters)
     68          	const STABILITY_CONTROL_COMMON_PARAMS_TYPE *Loop_Parameters_Ptr;
     69          
     70          	//! Timer 1 value (in seconds)
     71          	uint16 Timer_1;
     72          
     73          	//! Timer 2 value (in seconds)
     74          	uint16 Timer_2;
     75          
     76          	//! Status of Heater Allowed in the previous iteration
     77          	BOOL_TYPE VWI_Heater_Allowed_Prev;
     78          
     79          	//! The outcome of the Stability Control Loop (if it is requesting a reaction and which one)
     80          	STABILITY_CONTROL_LOOP_OUTCOME_TYPE Outcome;
     81          } STABILITY_CONTROL_LOOP_DATA_TYPE;
