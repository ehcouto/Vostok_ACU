    541                  {
    542                      case API018_FBK_PUBLISH_FAULT_CODES:
    543                          // 4 bytes repeated:
    544                          //      Fault Index (U8) 0 = Most recently recorded fault, 1 = Next most recently recorded fault, etc.
    545                          //      Fault Code (U8)
    546                          //      Fault Sub-Code (U8)
    547                          //      Engineering Code (U8)
    548                          Api018.Number_Of_Error_Codes = 0;
    549                          memset(Api018.Error_Codes, UCHAR_MAX, sizeof(Api018.Error_Codes));
    550                          for (uint8 i = 0; i < fbk->size; i += 4)
    551                          {
    552                              uint8 fault_index = i / 4;
    553                              if (fault_index < API018_MAX_STORED_FAULTS)
    554                              {
    555                                  API018_ERROR_CODE_TYPE* e = &Api018.Error_Codes[fault_index];
    556                                  e->F_Code = fbk->payload[i + 1];
    557                                  e->E_Code = fbk->payload[i + 2];
    558                                  e->Eng_Code = fbk->payload[i + 3];
    559                                  Api018.Number_Of_Error_Codes++;
    560                              }
    561                          }
    562                          HmiFaultMgr__ReceiveFaultData();
    563                          break;
    564          
    565                      case API018_FBK_PUBLISH_COMMON_LIFETIME_DATA:
    566                          //Seconds-payload bytes 0 to 3
    567                          //Cycles_Count-payload bytes 4 to 5
    568                          //Seconds_Running_Cycle-payload bytes 6 to 9(When STATISTICS_SAVED_CYCLES>0)
    569                          if (fbk->size >= 6)
    570                          {
    571                              Api018.Common_Lifetime_Data.Seconds=Utilities__ConvertArrayTo32bits(&fbk->payload[0]);
    572                              Api018.Common_Lifetime_Data.Cycle_Count=Utilities__ConvertArrayTo16bits(&fbk->payload[4]);
    573                              if (fbk->size >= 10)
    574                              {
    575                                  Api018.Common_Lifetime_Data.Seconds_Running_Cycles=Utilities__ConvertArrayTo32bits(&fbk->payload[6]);
    576                              }
    577                          }
    578                          break;
    579          
    580                      default:
    581                          break;
    582                  }
    583              #endif
