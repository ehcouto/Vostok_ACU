    122          /**
    123           *
    124           * @param generic_input
    125           * @param lli_data
    126           * @return
    127           */
    128          sint32  ProbeLpsGI__GetConverted(HBL_GI_TYPE * generic_input,void * lli_data)
    129          {
    130              uint16 data_in;
    131              sint32 retval;
    132              uint8 index;
    133              SETTINGFILE_LOADER_TYPE io_device_data;
    134          
    135              retval = 0;
    136          
    137              data_in = *((uint16 PACKED *)lli_data);
    138          
    139              index = generic_input->GI_Param_Offset;
    140          
    141              if (generic_input->GI_Param_Offset != 0XFF)
    142              {
    143                  if (SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE, index, &io_device_data) == PASS)
    144                  {
    145                      data_in = AnalizeZeroLev(data_in, &io_device_data);
    146          
    147                      retval = HblCommon__ConvertIODeviceData(data_in, (HBL_IO_DEVICE_DATA_CONVERT_TABLE_HEADER *)(io_device_data.Data + OFFSET_RANGE_TICKS_VALUE));  //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    148                  }
    149              }
    150              else
    151              {
    152                  retval = (sint32)data_in;
    153          
    154              }
    155          
    156              return (retval);
    157          }
    158          
    159          
    160          //=====================================================================================================================
    161          //-------------------------------------- Private Functions ------------------------------------------------------------
    162          //=====================================================================================================================
    163          
    164          static uint16 AnalizeZeroLev (uint16 data_inLocal, SETTINGFILE_LOADER_TYPE * io_device_data_local)
    165          {
    166              uint16 zeroLocal;
    167              sint16 retVal;
    168              sint32 CalPSensor_ZeroLevel;
    169          
    170          	Variable__GetValue(VARIABLE_LPS_CALIBRATION_ZERO, 0, (sint32 *)(&CalPSensor_ZeroLevel));
    171          
    172          	if ((CalPSensor_ZeroLevel >= (ENDIANU16_STON((*(uint16 *)(io_device_data_local->Data+2))))) && (CalPSensor_ZeroLevel <= (ENDIANU16_STON((*(uint16 *)(io_device_data_local->Data))))))
    173          	{
    174          		zeroLocal = CalPSensor_ZeroLevel;
    175          	}
    176          	else
    177          	{
    178          		zeroLocal = ENDIANU16_STON((*(uint16 *)(io_device_data_local->Data+4)));
    179          	}
    180          
    181          	retVal = data_inLocal - zeroLocal;
    182          
    183          	if (retVal<0)
    184          	{
    185          		retVal = 0;
    186          	}
    187          
    188          	return (retVal);
    189          }
