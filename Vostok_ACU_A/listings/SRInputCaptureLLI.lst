    121          //---------------------------------------------------------------------------------------------------------------------
    122          /**
    123           * @brief
    124           * @return
    125           */
    126          uint8 SRInputCaptureLLI__Allocate(void)
    127          {
    128              uint8 retval;
    129          
    130              retval = 0xFF;
    131          
    132              if (SRData__CheckByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation) == SRDATA_OK)
    133              {
    134                  if (SRInputCaptureLLI_Allocation < HBL_LLI_NUM_SRINPUTCAPTURE)
    135                  {
    136                      retval = SRInputCaptureLLI_Allocation;
    137                      SRData__UpdateByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation, SRInputCaptureLLI_Allocation+1);
    138                  }
    139              }
    140              else
    141              {
    142                  SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0, 0xFF);
    143              }
    144          
    145              return (retval);
    146          }
