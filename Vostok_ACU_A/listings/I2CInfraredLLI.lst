    850          
    851          //---------------------------------------------------------------------------------------------------------------------
    852          /**
    853           * Start the timer.
    854           * Elapsed time is available from the GetMilliseconds() function.
    855           */
    856          static void StartTimer(void)
    857          {
    858              I2c_Infrared_Lli.Start_Milliseconds = (uint16)Millis__GetFreeRunningCounter();
    859          }
    860          
    861          
    862          //---------------------------------------------------------------------------------------------------------------------
    863          /**
    864           * Wait for the I2C bus to become idle with a short timeout.
    865           * Timeout is based on the expected I2c access time.
    866           */
    867          static void WaitForI2cIdle(void)
    868          {
    869              if (IsI2cIdle() == TRUE)
    870              {
    871                  EventWriteComplete();
    872              }
    873              else if (GetMilliseconds() >= I2C_NOT_IDLE_MS_TIMEOUT)
    874              {
    875                  EventFail();
    876              }
    877          }
    878          
    879          
    880          //---------------------------------------------------------------------------------------------------------------------
    881          /**
    882           * Wait for time to start the next acquisition step.
    883           * The method used will run at the specified requested refresh rate or as fast as possible if the
    884           * requested refresh rate cannot be maintained.
    885           */
    886          static void WaitForNextStep(void)
    887          {
    888              uint16 elapsed = GetMilliseconds();
    889              uint16 step_ms = I2c_Infrared_Lli.Sf->Step_Period_Milliseconds;
    890              if (elapsed >= step_ms)
    891              {
    892                  if (elapsed < 2 * step_ms)
    893                  {
    894                      I2c_Infrared_Lli.Start_Milliseconds += step_ms;
    895                  }
    896                  else
    897                  {
    898                      // Accommodate unrecoverable slip.
    899                      StartTimer();
    900                  }
    901                  EventStart();
    902              }
    903          }
