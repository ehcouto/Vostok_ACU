    838          /**
    839           * Send the start command to start a new acquisition.
    840           */
    841          static void StartAcquisition(void)
    842          {
    843              uint8 data = MLX_CMD_START_STEP_HI_BYTE;
    844              if (I2c__Write(I2c_Infrared_Lli.Sf->I2c_Channel, MLX_CMD_START_STEP_LO_BYTE, &data, sizeof(data)) == FALSE)
    845              {
    846                  EventFail();
    847              }
    848          }
