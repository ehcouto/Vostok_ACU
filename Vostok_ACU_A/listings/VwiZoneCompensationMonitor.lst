    288          //-------------------------------------- Private Functions ------------------------------------------------------------
    289          //=====================================================================================================================
    290          BOOL_TYPE Diverter_Position_Unknown(void)
    291          {
    292          	BOOL_TYPE ret_value;
    293          	if 	(Fault__IsInFaultState(FAULT_ID_DIVERTER_CANNOT_FIND_POSITIONS) ||
    294          	    ((uint8)AlternateLoad__GetAlternateLoadSearchHome() == (uint8)TRUE))
    295          	{
    296          		ret_value = TRUE;
    297          	}
    298          	else
    299          	{
    300          		ret_value = FALSE;
    301          	}
    302          	return ret_value;
    303          }
    304          
    305          void VwiZoneCompensationReadParams(void)
    306          {
    307          	SETTINGFILE_LOADER_TYPE loader;
    308          	uint8 num_items;
    309          	const VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE *vwi_zone_compensation_multiplier_params_ptr;
    310          
    311          	memset(VWIZC_Multiplier_Pos,__UNSIGNED_CHAR_MAX__,sizeof(VWIZC_Multiplier_Pos));
    312          
    313          	if (SettingFile__BasicLoader(SF_PTR_ACU_ALGORITHM_PARAMETERS, DISPL_VWI_ZONE_COMPENSATION_MULTIPLIERS, &loader) == PASS)
    314          	{
    315          		num_items = (uint8)(loader.Length/sizeof(VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE));
    316          
    317          		for (uint8 pos = 0; pos < num_items; pos++)
    318          		{
    319          			vwi_zone_compensation_multiplier_params_ptr = (const VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE *)(void*)(loader.Data + (pos * sizeof(VWI_ZONE_COMPENSATION_MULTIPLIERS_PARAMS_TYPE)));
    320          			VWIZC_Multiplier_Pos[pos] = vwi_zone_compensation_multiplier_params_ptr->Multiplier_Pos;
    321          		}
    322          	}
    323          }
    324          
    325          
    326          #if (VWI_CLIENT_FEATURE == ENABLED) && (VWI_INTERNAL_COMMUNICATION == DISABLED) && (API013_CLIENT_FEATURE == ENABLED)
    327          static void VwiZoneCompensation_API013ApplReceivedStatus (uint8 client_function_index)
    328          {
    329          	const API013_FUNCTION_STATUS_TYPE* received_status;
    330          
    331          	received_status = API013RemoteFunction__GetReceivedStatus();
    332          
    333          	if (client_function_index == (uint8)API013_CLIENT_FUNCTION_VWI_MULTIPLIER)
    334          	{
    335          		if (received_status->Size >= sizeof(VWIZC_Old_Current_Multiplier))
    336          		{
    337          			VWIZC_Old_Current_Multiplier = Utilities__ConvertArrayTo16bits(received_status->Status);
    338          		}
    339          	}
    340          }
    341          #endif // (VWI_CLIENT_FEATURE == ENABLED)
    342          
    343          #endif // (VWI_THREE_PHASE_MOTOR_TYPE== ENABLED)


 

 


