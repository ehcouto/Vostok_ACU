     96          
     97          BOOL_TYPE DoorSwitchGI__AsynchProcess(HBL_GI_TYPE * generic_input,void * lli_data, uint8 lli_sequence)
     98          {
     99          	BOOL_TYPE retval;
    100          
    101          	retval = FALSE;
    102          
    103          	if(generic_input->Data_Index < DoorSwitchGI_Allocation)
    104          	{
    105          		if (DoorSwitchGI_LLI_Sequence[generic_input->Data_Index] != lli_sequence)
    106          		{
    107          			DoorSwitchGI_LLI_Sequence[generic_input->Data_Index] = lli_sequence;
    108          			retval = TRUE;
    109          		}
    110          	}
    111              return(retval);
    112          }
