    357          /**
    358           * Initialize the I2CInfraredLLI module's variables.
    359           */
    360          void I2CInfraredLLI__Initialize(void)
    361          {
    362              memset(&I2c_Infrared_Lli, 0, sizeof(I2c_Infrared_Lli));
    363          }
    364          
    365          
    366          //---------------------------------------------------------------------------------------------------------------------
    367          /**
    368           * Allocate memory out of the pre-allocated RAM for the next LLI of this type.
    369           * @return The index to the new LLIs allocated memory.
    370           *         Returns HBL_INDEX_INVALID if there is no more memory reserved.
    371           */
    372          uint8 I2CInfraredLLI__Allocate(void)
    373          {
    374              uint8 index = HBL_INDEX_INVALID;
    375              if (I2c_Infrared_Lli.Allocation < HBL_LLI_NUM_I2C_INFRARED_SENSOR)
    376              {
    377                  index = I2c_Infrared_Lli.Allocation;
    378                  I2c_Infrared_Lli.Allocation++;
    379              }
    380              return index;
    381          }
    382          
    383          
    384          //---------------------------------------------------------------------------------------------------------------------
    385          /**
    386           * Initialize an instance of the LLI by reading and updating HBL's data structure.
    387           * @param input = Pointer to the HBL data structure that references the LLI instance.
    388           * @return PASS if the initialization was successful; otherwise FAIL.
    389           */
    390          PASS_FAIL_TYPE I2CInfraredLLI__InitializeInstance(HBL_LLI_TYPE* input)
    391          {
    392              PASS_FAIL_TYPE result = FAIL;
    393              if (input != NULL)
    394              {
    395                  if ((input->Parameter_Ptr.Data != NULL) && (input->Parameter_Ptr.Length > 2))
    396                  {
    397                      I2c_Infrared_Lli.Sf = (SF_I2C_INFRARED_LLI_TYPE*)(void*)&input->Parameter_Ptr.Data[2];
    398                  }
    399                  else
    400                  {
    401                      I2c_Infrared_Lli.Sf = &I2C_INFRARED_LLI_HARD_CODED_CONFIG;
    402                  }
    403                  IrLliInitialize();
    404                  if (I2c_Infrared_Lli.State != STATE_IR_LLI_NONE)
    405                  {
    406                      I2c_Infrared_Lli.Sensor.Eeprom = &I2c_Infrared_Lli.Eeprom;
    407                      I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_INITIALIZING;
    408                      result = PASS;
    409                  }
    410              }
    411              return result;
    412          }
    413          
    414          
    415          //---------------------------------------------------------------------------------------------------------------------
    416          /**
    417           * Get the current data of the referenced LLI.
    418           * @param input = Pointer to the HBL data structure that references the LLI instance.
    419           * @return Pointer to the current data of the referenced LLI.
    420           */
    421          void* I2CInfraredLLI__Get(HBL_LLI_TYPE* input)
    422          {
    423              void* data = NULL;
    424              if ((input != NULL) &&
    425                  (input->Data_Index == 0))
    426              {
    427                  data = (void*)&I2c_Infrared_Lli.Sensor;
    428                  if (I2c_Infrared_Lli.Sensor.LLI_Status == I2C_IR_LLI_DATA_READY)
    429                  {
    430                      EventGIRead();
    431                  }
    432              }
    433              return data;
    434          }
    435          
    436          
    437          //---------------------------------------------------------------------------------------------------------------------
    438          /**
    439           * Background function for the referenced LLI.
    440           * Called every 5ms.
    441           * @param input = Pointer to the HBL data structure that references the LLI instance.
    442           * @return Returns TRUE if new data is available. Otherwise FALSE.
    443           */
    444          BOOL_TYPE I2CInfraredLLI__AsynchProcess(HBL_LLI_TYPE* input)
    445          {
    446              if (input->Data_Index < I2c_Infrared_Lli.Allocation)
    447              {
    448                  IrLliExecute();
    449                  switch (I2c_Infrared_Lli.State)
    450                  {
    451                      case STATE_IR_LLI_SETUP_EEPROM_READ:
    452                      case STATE_IR_LLI_READ_EEPROM:
    453                      case STATE_IR_LLI_SETUP_TRIM_VALUE_WRITE:
    454                      case STATE_IR_LLI_WRITE_TRIM_VALUE:
    455                      case STATE_IR_LLI_READ_TRIM_VALUE:
    456                      case STATE_IR_LLI_SETUP_CONFIG_VALUE_WRITE:
    457                      case STATE_IR_LLI_WRITE_CONFIG_VALUE:
    458                      case STATE_IR_LLI_READ_CONFIG_VALUE:
    459                          I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_INITIALIZING;
    460                          break;
    461          
    462                      case STATE_IR_LLI_WAIT_FOR_NEXT_STEP:
    463                          I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_WAITING_FOR_DATA;
    464                          break;
    465          
    466                      case STATE_IR_LLI_START_STEP:
    467                      case STATE_IR_LLI_READ_STATUS:
    468                      case STATE_IR_LLI_READ_PIXELS:
    469                          I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_ACQUIRING_DATA;
    470                          break;
    471          
    472                      case STATE_IR_LLI_DATA_READY:
    473                          I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_DATA_READY;
    474                          break;
    475          
    476                      default:
    477                          I2c_Infrared_Lli.Sensor.LLI_Status = I2C_IR_LLI_ERROR;
    478                          break;
    479                  }
    480              }
    481          
    482              BOOL_TYPE data_ready = I2c_Infrared_Lli.Data_Ready;
    483              I2c_Infrared_Lli.Data_Ready = FALSE;
    484              return data_ready;
    485          }
