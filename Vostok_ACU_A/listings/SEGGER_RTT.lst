    296          *
    297          *  Function description
    298          *    Initializes the control block an buffers.
    299          *    May only be called via INIT() to avoid overriding settings.
    300          *
    301          */
    302          #define INIT()  {                                                                                    \
    303                            volatile SEGGER_RTT_CB* pRTTCBInit;                                                \
    304                            pRTTCBInit = (volatile SEGGER_RTT_CB*)((char*)&_SEGGER_RTT + SEGGER_RTT_UNCACHED_OFF); \
    305                            do {                                                                               \
    306                              if (pRTTCBInit->acID[0] == '\0') {                                               \
    307                                _DoInit();                                                                     \
    308                              }                                                                                \
    309                            } while (0);                                                                       \
    310                          }
