    293          /**
    294           *  Method to start the execution of the self test for the accelerometer
    295           */
    296          void AccelerometerLLI__RunSelfTest(void)
    297          {
    298              AccelerometerLLI.Self_Test_State = 1;
    299              AccelerometerLLI_Public.Self_Test_Completed = FALSE;
    300              AccelerometerLLI__Disable(); // Must disable reading of the accelerometer done by this module
    301          }
