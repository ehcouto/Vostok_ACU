    255          
    256          //---------------------------------------------------------------------------------------------------------------------
    257          /**
    258           *  @brief      Stepper pilot control based on 1 millisecond call rate.
    259           *
    260           *  @param      HBL_LOAD_TYPE *load - Pointer to stepper load instance.
    261           *
    262           *  @return     PASS_FAIL_TYPE result - Result of stepper pilot handler.
    263           *  @retval     PASS - Instance handler succeeded.
    264           *  @retval     FAIL - Instance handler failed.
    265           */
    266          PASS_FAIL_TYPE StepperPilot__Handler1ms (HBL_LOAD_TYPE *load)
    267          {
    268              PASS_FAIL_TYPE result;
    269              STEPPER_PILOT_DATA_TYPE *data;
    270              uint8 sequence;
    271              uint8 mask;
    272              uint8 loop_index;
    273              uint8 table_index;
    274          
    275              result = PASS;
    276              data = &(Stepper_Pilot_Data[load->Load_Data_Index]);
    277          
    278              if (data->Pulse_Counter < data->Pulse_Width)
    279              {
    280                 data->Pulse_Counter++;
    281              }
    282              else
    283              {
    284                  data->Pulse_Counter = 1;
    285          
    286                  if (data->Stepper_Array_Index > data->Parameters.Number_Of_Sequences - 1)
    287                  {
    288                      if (data->Step != 0)
    289                      {
    290                          data->Step--;
    291                      }
    292          
    293                      if (data->Step != 0)
    294                      {
    295                          // Reset the array index and do another pass
    296                          data->Stepper_Array_Index = 0;
    297                      }
    298                      else
    299                      {
    300                          // Indicate request is complete and turn off all stepper outputs
    301                          data->Status = COMPLETE;
    302          
    303                          for (loop_index = 0; loop_index < 4;  loop_index++)
    304                          {
    305                              table_index = load->Pin_Ptr[loop_index];
    306                              Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, FALSE);
    307                          }
    308                      }
    309                  }
    310          
    311                  // If we are within the step array, do the next step
    312                  if (data->Stepper_Array_Index < data->Parameters.Number_Of_Sequences)
    313                  {
    314                      if (data->Processed.Direction == STEPPER_DIRECTION_FORWARD)
    315                      {
    316                          sequence = data->Parameters.Sequences[data->Stepper_Array_Index];
    317                      }
    318                      else
    319                      {
    320                          sequence = data->Parameters.Sequences[data->Parameters.Number_Of_Sequences - data->Stepper_Array_Index - 1];
    321                      }
    322          
    323                      mask = 0x08;
    324                      for (loop_index = 0; loop_index < 4; loop_index++)
    325                      {
    326                          table_index = load->Pin_Ptr[loop_index];
    327          
    328                          if (mask & sequence)
    329                          {
    330                              Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, TRUE);
    331                          }
    332                          else
    333                          {
    334                              Gpio__PinWrite(VIRTUALPIN_TABLE[table_index].port, VIRTUALPIN_TABLE[table_index].pin, FALSE);
    335                          }
    336          
    337                          mask >>= 1;
    338                      }
    339          
    340                      data->Stepper_Array_Index++;
    341                  }
    342              }
    343          
    344              return (result);
    345          }
    346          
    347          //---------------------------------------------------------------------------------------------------------------------
    348          /**
    349           *  @brief      Get stepper pilot instance status.
    350           *
    351           *  @param      HBL_LOAD_TYPE *load - Pointer to stepper load instance.
    352           *
    353           *  @return     void *status - pointer to status of pilot instance. Cast it using *((COMPLETE_TYPE *)ptr) to get value.
    354           *  @retval     COMPLETE - instance request is complete
    355           *  @retval     INCOMPLETE - instance request in process
    356           */
    357          void * StepperPilot__GetStatus(HBL_LOAD_TYPE *load)
    358          {
    359              void *status;
    360          
    361              status = &(Stepper_Pilot_Data[load->Pilot_Data_Index].Status);
    362          
    363              return (status);
    364          }
