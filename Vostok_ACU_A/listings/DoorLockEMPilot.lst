     29          
     30          #define DOORLOCKEM_DEFAULT_PULSES            (3)
     31          #define DOORLOCKEM_INITIAL_PERIOD           (18)
     32          #define DOORLOCKEM_TIME_SPACING_UNIT_MS     (100)
     33          #define DOORLOCKEM_FBK_TIMEOUT              (DOORLOCKEM_TIME_SPACING_UNIT_MS)
     34          
     35          #define ZC_ALLOWED_MIN_FREQUENCY            45
     36          #define ZC_ALLOWED_MAX_FREQUENCY            65
     37          
     38          // Minimum and maximum period from ZeroCross frequency boundaries set - Round to near
     39          #define DOORLOCKEM_MIN_PERIOD_MS		((2000+ZC_ALLOWED_MAX_FREQUENCY)/(ZC_ALLOWED_MAX_FREQUENCY*2))
     40          #define DOORLOCKEM_MAX_PERIOD_MS		((2000+ZC_ALLOWED_MIN_FREQUENCY)/(ZC_ALLOWED_MIN_FREQUENCY*2))
     41          
     42          typedef enum DOORLOCKEM_STATUS_ENUM
     43          {
     44              DOORLOCKEM_STATUS_INIT,
     45              DOORLOCKEM_STATUS_DOOR_UNLOCKED,
     46              DOORLOCKEM_STATUS_DOOR_LOCKING,
     47              DOORLOCKEM_STATUS_DOOR_LOCKING_FAILED,
     48              DOORLOCKEM_STATUS_DOOR_LOCKED,
     49              DOORLOCKEM_STATUS_DOOR_UNLOCKING,
     50              DOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED
     51          } DOORLOCKEM_STATUS_TYPE;
     52          
     53          PACKED typedef struct
     54          {
     55          uint16 Retries_Counter;
     56          uint8 Fbk_Counter;
     57          uint8 Fbk_Last_Counter;
     58          uint8 Period;
     59          uint8 Cycle_Counter;
     60          uint8 Fbk_Last_Pin_Value;
     61          uint8 Fbk_Pin;
     62          uint8 Requested;
     63          uint8 Processed;
     64          HBL_LOAD_STATUS_TYPE PilotStatus;
     65          DOORLOCKEM_STATUS_TYPE Status;
     66              uint8 Request_Triac_On;
     67              uint8 Process_Triac_On;
     68              uint8 Keep_Triac_On;
     69          uint8 Retries;
     70          } DOORLOCKEMPILOT_DATA_TYPE;
     71          
     72          typedef struct
     73          {
     74          uint8 Max_Retries :4;
     75          uint8 Num_Pulses :4;
     76          uint8 Time_Spacing;
     77          } DOORLOCKEMPILOT_PARAM_TYPE;
     78          
     79          static uint8 DoorLockEMPilot_Allocation;
     80          static DOORLOCKEMPILOT_DATA_TYPE DoorLockEMPilot_Data[HBL_PILOT_NUM_DOORLOCKEM];
