    189          /**
    190           *  @brief      Set DoorLockWaxPilot instance request.
    191           *
    192           *  @param      HBL_LOAD_TYPE *load - Pointer to associated DoorLockWaxPilot instance.
    193           *
    194           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    195           *
    196           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot request.
    197           *  @retval     PASS - Instance request succeeded.
    198           *  @retval     FAIL - Instance request failed.
    199           */
    200          PASS_FAIL_TYPE DoorLockWaxPilot__Request(HBL_LOAD_TYPE * load,void * data)
    201          {
    202          	PASS_FAIL_TYPE retval = FAIL;
    203          	uint8 index = load->Pilot_Data_Index;
    204          
    205              if (index < DoorLockWaxPilot_Allocation)
    206              {
    207              	DoorLockWaxPilot_Data[index].Requested = *((uint8 *) data);
    208              	retval = PASS;
    209              }
    210          
    211          	return(retval);
    212          }
    213          
    214          
    215          //---------------------------------------------------------------------------------------------------------------------
    216          /**
    217           *  @brief      Process DoorLockWaxPilot instance.
    218           *
    219           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockWaxPilot instance.
    220           *
    221           *  @return     PASS_FAIL_TYPE result - Result of DoorLockWaxPilot instance process.
    222           *  @retval     PASS - Instance process succeeded.
    223           *  @retval     FAIL - Instance process failed.
    224           */
    225          PASS_FAIL_TYPE DoorLockWaxPilot__Process(HBL_LOAD_TYPE * load)
    226          {
    227              DOORLOCKWAXPILOT_PARAM_TYPE *param_ptr;
    228          	DOORLOCKWAXPILOT_DATA_TYPE *ptr;
    229          	PASS_FAIL_TYPE retval = FAIL;
    230          	uint8 index = load->Pilot_Data_Index;
    231          
    232              if (index < DoorLockWaxPilot_Allocation)
    233              {
    234              	ptr = &DoorLockWaxPilot_Data[index];
    235          
    236              	if (ptr->Requested != ptr->Processed)
    237              	{
    238                  	param_ptr = (DOORLOCKWAXPILOT_PARAM_TYPE *) load->Parameter_Ptr.Data; //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    239          
    240              		if (ptr->Requested == 0)
    241              		{
    242              			switch (ptr->Status)
    243              			{
    244              			case DOORLOCKWAX_STATUS_DOOR_LOCKED:
    245              			case DOORLOCKWAX_STATUS_DOOR_LOCKING:
    246              				ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    247              				ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    248              		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_UNLOCKING;
    249              				ptr->Counter = ENDIANS16_STON(param_ptr->Unlock_Timeout);
    250              		    	ptr->Wait_Trigger = 1;
    251              				break;
    252          
    253              			default:
    254              		    	ptr->Status = DOORLOCKWAX_STATUS_INIT;
    255              				ptr->Counter = param_ptr->Filter_Time;
    256              				break;
    257              			}
    258              		}
    259              		else
    260          			{
    261          				switch (DoorLockWaxPilot_Data[index].Status)
    262          				{
    263          				case DOORLOCKWAX_STATUS_DOOR_UNLOCKED:
    264          				case DOORLOCKWAX_STATUS_DOOR_UNLOCKING:
    265          					ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    266          					ptr->PilotStatus.Load.Cur_Reg = ptr->Processed;
    267              		    	ptr->Status = DOORLOCKWAX_STATUS_DOOR_LOCKING;
    268              				ptr->Counter = ENDIANS16_STON(param_ptr->Unlock_Timeout);
    269              		    	ptr->Wait_Trigger = 1;
    270          					break;
    271          
    272          				default:
    273              		    	ptr->Status = DOORLOCKWAX_STATUS_INIT;
    274              				ptr->Counter = param_ptr->Filter_Time;
    275          					break;
    276          				}
    277          			}
    278              	}
    279          
    280              	ptr->Processed = ptr->Requested;
    281              }
    282          
    283          	return(retval);
    284          }
