   \   0000000A   0x2103             MOVS     R1,#+3
   \   0000000C   0x.... 0x....      BL       Uart__GetStatus
   \   00000010   0x4669             MOV      R1,SP
   \   00000012   0x7809             LDRB     R1,[R1, #+0]
