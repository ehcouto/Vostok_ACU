     23          
     24          //! constant = 1s update time for the acceleration manager.
     25          #define PWM_UPDATE_TIME_MS						1000
     26          //! Constant to emulate the pwm.
     27          #define PWMPILOT_EMULATED_BASE_FREQUENCY		1000		//!< in Hz
     28          /**
     29           * data structure from settings file.
     30           */
     31          typedef PACKED struct PWM_PARAMETER_STRUCT
     32          {
     33              //Base frequency.
     34              uint16 Base_Frequency;
     35              uint16 Speed_Min;
     36              uint16 Delta_Max;
     37              uint16 Delta_Min;
     38              //Is Frequency or duty?
     39              uint8  Is_Frequency_Driven	:1;
     40              uint8  Acceleration_Feature :1;
     41              uint8  Unused1				:6;
     42              //One empty byte here
     43              uint8 Unused2;
     44          } PWMPILOT_PARAMETER_TYPE;
     45          
     46          /**
     47           * This is the data definition. Depending on the SF we can drive
     48           * the output on frequency or duty.
     49           */
     50          typedef PACKED struct
     51          {
     52              PWMPILOT_PARAMETER_TYPE *Parameters;
     53              TIMER_PARAMETER_TYPE Timer_Parameter;
     54              uint16 Timer_Counter;
     55              uint16 Number_Of_Steps;
     56              uint16 Number_Of_Steps_On;
     57              uint16 Steps_For_Emulation;
     58              uint8 Requested;
     59              uint8 Processed;
     60              uint8 Previous;
     61              PWMPILOT_STATUS_TYPE Pilot_Status;
     62          } PWMPILOT_DATA_TYPE;
