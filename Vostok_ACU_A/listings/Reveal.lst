    103          //---------------------------------------------------------------------------------------------------------------------
    104          // Default debounce is set to 30ms
    105          #ifndef REVEAL_QUEUE_DEBOUNCE_MS
    106              #define REVEAL_QUEUE_DEBOUNCE_MS      30
    107          #endif
    108          
    109          // Debounce counter is scaled to 5ms
    110          #define REVEAL_QUEUE_DEBOUNCE_COUNT         ((REVEAL_QUEUE_DEBOUNCE_MS + 4)/5)
    111          
    112          // Valid range is [1..253] or 5-1265ms
    113          #if((REVEAL_QUEUE_DEBOUNCE_COUNT > 253) || (REVEAL_QUEUE_DEBOUNCE_COUNT <= 0))
    114          #error "REVEAL_QUEUE_DEBOUNCE_MS value shall be in [1..1265] range"
    115          #endif
    116          
    117          // Reveal Debounce counter:
    118          //  0               - IDLE       - Free
    119          //  1               - QUEUED     - Ready to be sent
    120          //  2               - TIMEOUT     - Ready to be sent
    121          //  > 2             - RESERVED   - Wait to complete it ( Debounce-2 counts )
    122          #define REVEAL_QUEUE_IDLE                           (0)
    123          #define REVEAL_QUEUE_QUEUED                         (1)
    124          #define REVEAL_QUEUE_TIMEOUT                        (2)
    125          #define SET_DEBOUNCE()                              (REVEAL_QUEUE_DEBOUNCE_COUNT + 2)
    126          #define IS_IDLE(x)                                  ((x) == 0)
    127          #define IS_QUEUED(x)                                ((x) == 1)
    128          #define IS_TIMEOUT(x)                               ((x) == 2)
    129          #define IS_PENDING(x)                               ((x) > 2)
    130          
