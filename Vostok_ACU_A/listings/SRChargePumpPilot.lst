     37          //! Volatile data required for each instance of the pilot.
     38          PACKED typedef struct
     39          {
     40              //! The value requested by the application modules.
     41              ON_OFF_TYPE Requested;
     42          
     43              //! The value accepted and processed.
     44              ON_OFF_TYPE Processed;
     45          
     46              //! The current state of the pin
     47              BOOL_TYPE   Pin_State;
     48          }SR_CHARGEPUMPPILOT_INSTANCE_DATA_TYPE;
     49          
     50          
     51          //! Volatile data required for the pilot module.
     52          PACKED typedef struct
     53          {
     54              SR_CHARGEPUMPPILOT_INSTANCE_DATA_TYPE Data[HBL_PILOT_NUM_SRCHARGEPUMP];
     55          
     56              //! Tracks the number of digital output pilot allocations.
     57              uint8 Allocation;
     58          }SR_CHARGEPUMPPILOT_DATA_TYPE;
     59          
     60          
     61          //! All the volatile data used by this module.
     62          static SR_CHARGEPUMPPILOT_DATA_TYPE SRChargePumpPilot_Data;
     63          
     64          //! An inverted copy of the volatile data used by this module for data integrity purposes.
     65          static SR_CHARGEPUMPPILOT_DATA_TYPE N_SRChargePumpPilot_Data;
     66          
