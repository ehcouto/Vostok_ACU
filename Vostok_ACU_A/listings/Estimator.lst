   1137          #if (ESTIMATOR_TRACE == ENABLED)
   1138          //---------------------------------------------------------------------------------------------------------------------
   1139          /**
   1140           * Publish debug data related to the time estimation that just completed.
   1141           * Published as two OpCodes under API004.
   1142           *  OpCode 11 Payload:
   1143           *      1 byte with the phase number of the first estimated phase time in the payload.
   1144           *      2 big-endian bytes for each estimated phase time.
   1145           *          Phase times are the number of seconds estimated for a phase.
   1146           *          A value of 0xCCCC indicates that no time was estimated.
   1147           *          A value of 0x0000 indicates that a 0 seconds were estimated.
   1148           *  OpCode 12 Payload:
   1149           *      2 big-endian bytes with the statement index of the first statement entry.
   1150           *      2 bytes for each statement entry.
   1151           *          Statement entries consist of byte pairs that represent the predicted cycle execution.
   1152           *          Byte pair that specifies a cycle:
   1153           *              First byte will be 0xCC
   1154           *              Second byte will be the cycle number
   1155           *          Byte pair that specifies a change in phase and/or statement
   1156           *              First byte will be the phase number
   1157           *              Second byte will be the statement number
   1158           */
   1159          static void PublishDebugData(void)
   1160          {
   1161              uint8 phase = 0;
   1162              while (phase <= Estimator.Time_Index)
   1163              {
   1164                  uint8 entries_in_payload = ESTIMATOR_DEBUG_MAX_ENTRIES_PER_PAYLOAD;
   1165                  if (entries_in_payload > Estimator.Time_Index - phase + 1)
   1166                  {
   1167                      entries_in_payload = Estimator.Time_Index - phase + 1;
   1168                  }
   1169                  REVEAL_COMMAND_TYPE* fbk = Reveal__NewFeedback(ESTIMATOR_DEBUG_API, ESTIMATOR_DEBUG_OPCODE_PHASE_TIMES, WIN_BROADCAST,
   1170                                                                 sizeof(uint8) + sizeof(uint16) * entries_in_payload);
   1171                  Reveal__AddDataU8(fbk, phase);
   1172                  for (uint8 i = 0; i < entries_in_payload; i++)
   1173                  {
   1174                      Reveal__AddDataU16(fbk, Estimator.Times[phase + i]);
   1175                  }
   1176                  Reveal__QueueCommand(fbk);
   1177                  phase += entries_in_payload;
   1178              }
   1179          
   1180              uint16 index = 0;
   1181              while (index < Estimator.Statement_Index)
   1182              {
   1183                  uint16 entries_in_payload = Estimator.Statement_Index - index;
   1184                  if (entries_in_payload > (REVEAL_PAYLOAD_SIZE & 0xFFFE) - sizeof(uint16))
   1185                  {
   1186                      entries_in_payload = (REVEAL_PAYLOAD_SIZE & 0xFFFE) - sizeof(uint16);
   1187                  }
   1188                  REVEAL_COMMAND_TYPE* fbk = Reveal__NewFeedback(ESTIMATOR_DEBUG_API, ESTIMATOR_DEBUG_OPCODE_STATEMENTS, WIN_BROADCAST,
   1189                                                                 sizeof(uint16) + entries_in_payload);
   1190                  Reveal__AddDataU16(fbk, index);
   1191                  Reveal__AddDataU8Buffer(fbk, &Estimator.Statements[index], entries_in_payload);
   1192                  Reveal__QueueCommand(fbk);
   1193                  index += entries_in_payload;
   1194              }
   1195          }
   1196          #endif
