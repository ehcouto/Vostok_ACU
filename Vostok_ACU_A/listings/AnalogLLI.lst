     84          PACKED typedef struct
     85          {
     86              uint32 Sum;                     /* A/D samples's sum */
     87              uint16 Value;                   /* A/D current sample */
     88              uint16 Raw_Sample;              /* A/D raw sample */
     89              uint16 Last_Sample;             /* A/D old sample */
     90              uint16 Lower_Value;             /* A/D current min value */
     91              uint16 Higher_Value;            /* A/D current max value */
     92              uint8  Sample_Counter;          /* Number of Samples collected */
     93              uint8  Fast_Sample_Counter;     /* Number of Samples collected */
     94              uint8  Sync_Counter;            /* Counter used for max. variation between two samples */
     95              uint8  Fast_Sync_Counter;       /* Number of considered invalid value during 1ms process ATOD */
     96          } ANALOGLLI_DATA_TYPE;
