     34          /**
     35           * @brief Define invalid i2c channel value
     36           * @note  This value is always 0xFF since there will never be 255 i2c channels.\n
     37           * #define I2CMGR_CHANNEL_INVALID       (0xFF)
     38           *
     39           */
     40          #define I2CMGR_CHANNEL_INVALID       (0xFF)
     41          
     42          typedef struct _I2CMGR_QUEUE_TYPE
     43          {
     44              uint8 I2cMgr_TokenQueue[I2CMGR_QUEUE_SIZE];
     45              uint8 I2cMgr_WriteIndex;
     46              uint8 I2cMgr_ReadIndex;
     47          }I2CMGR_QUEUE_TYPE;
     48          
     49          typedef struct _I2CMGR_HANDLE_TYPE
     50          {
     51              I2C_ENUM_TYPE i2c_channel;
     52          }I2CMGR_HANDLE_TYPE;
     53          
     54          static I2CMGR_HANDLE_TYPE I2cMgr_DeviceHandle[I2CMGR_NUM_DEVICES];
     55          static MILLIS_TIMER_TYPE I2cMgr_TimeoutHandle[I2CMGR_NUM_CHANNELS];
     56          
     57          #if(I2CMGR_NUM_DEVICES > 1)
     58          static I2CMGR_QUEUE_TYPE I2cMgr_RequestQueue[I2CMGR_NUM_CHANNELS];
     59          #endif
     60          
     61          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     62          static void TimeoutAction(I2C_ENUM_TYPE i2c_channel);
     63          #if(I2CMGR_NUM_DEVICES > 1)
     64          static void AddItemToQueue(uint8 device_id);
     65          static void RemoveItemFromQueue(uint8 device_id);
     66          #endif
