    330          void MCUDebug__MeasTimeSlot(void)
    331          {
    332          #ifdef UC_STM32G0X_H_
    333          	    TIM_DEF_TYPE * tim;
    334          	    tim = (TIM_DEF_TYPE *) TIM7_BASE;
    335          
    336          	    uint32 get_time;
    337          
    338          	    get_time = (uint32)tim->CNT;
    339          
    340          	    Measured_Time_US = (uint16)((get_time)/TIMER_RESOLUTION_MHZ);
    341          	    tim->CNT = 0;
    342          #endif
    343          #ifdef UC_RX130_H
    344          	    uint32 get_time;
    345          
    346          	    get_time = (uint32)MTU5.TCNTU;
    347          
    348          	    Measured_Time_US = (uint16)((get_time+(TIMER_RESOLUTION_MHZ/2))/TIMER_RESOLUTION_MHZ);
    349          	    MTU5.TCNTU = 0;
    350          #endif
    351          }
    352          
    353          
    354          
    355          void MCUDebug__MeasTimeReset(void)
    356          {
    357          #ifdef UC_STM32G0X_H_
    358          	    TIM_DEF_TYPE * tim;
    359          	    tim = (TIM_DEF_TYPE *) TIM7_BASE;
    360          
    361          	    tim->CNT = 0;
    362          #endif
    363          
    364          #ifdef UC_RX130_H
    365          	    MTU5.TCNTU = 0;
    366          #endif
    367          }
    368          
    369          
    370          
    371          void MCUDebug__MeasTimeSet(void)
    372          {
    373          #ifdef UC_STM32G0X_H_
    374          	    TIM_DEF_TYPE * tim;
    375          	    tim = (TIM_DEF_TYPE *) TIM7_BASE;
    376          
    377          	    uint32 get_time;
    378          
    379          	    get_time = (uint32)tim->CNT;
    380          
    381          	    Measured_Time_US = (uint16)((uint32)(get_time+32)/TIMER_RESOLUTION_MHZ);
    382          	    tim->CNT = 0;
    383          
    384          	    if(Measured_Time_Temp < Measured_Time_US)
    385          	    {
    386          	    	Measured_Time_Temp = Measured_Time_US;
    387          	    }
    388          
    389          	    Measured_Time_Counter++;
    390          	    if(Measured_Time_Counter >= 5000)
    391          	    {
    392          	    	Measured_Time_Counter = 0;
    393          	    	Measured_Time_Max = Measured_Time_Temp;
    394          	    	Measured_Time_Temp = 0;
    395          	    }
    396          #endif
    397          
    398          #ifdef UC_RX130_H
    399          	    uint32 get_time;
    400          
    401          	    get_time = (uint32)MTU5.TCNTU;
    402          
    403          	    Measured_Time_US = (uint16)((uint32)(get_time)/TIMER_RESOLUTION_MHZ);
    404          	    MTU5.TCNTU = 0;
    405          
    406          	    if(Measured_Time_Temp < Measured_Time_US)
    407          	    {
    408          	    	Measured_Time_Temp = Measured_Time_US;
    409          	    }
    410          
    411          	    Measured_Time_Counter++;
    412          	    if(Measured_Time_Counter >= 5000)
    413          	    {
    414          	    	Measured_Time_Counter = 0;
    415          	    	Measured_Time_Max = Measured_Time_Temp;
    416          	    	Measured_Time_Temp = 0;
    417          	    }
    418          #endif
    419          }
    420          #endif

