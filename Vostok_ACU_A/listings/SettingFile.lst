    990          /**
    991           * @brief   Checks if the hard coded setting file is valid, if it exists
    992           * @param   sf_id: see SF_ID_TYPE
    993           * @return  TRUE if there is a hard coded setting file for the requested setting file ID and its CRC is valid, else FALSE
    994           */
    995          static BOOL_TYPE IsHardCodedSettingFileValid(SF_ID_TYPE sf_id)
    996          {
    997              BOOL_TYPE crc_matches = FALSE;
    998          
    999              if (SettingFile__IsValid() == TRUE)
   1000              {
   1001                  uint16 calculated_crc;
   1002                  uint16 * crc_address = NULL;
   1003                  uint16 * sf_start_address = NULL;
   1004                  uint16 stored_crc;
   1005          
   1006                  #if (USE_ACU_HARDCODED_SETTING_FILE == ENABLED) // Note: Intentionally not calling GetSettingFileStartByID() here because this function is limited
   1007                      if (sf_id == SF_ID_ACU)                     //       to hard-coded setting files only
   1008                      {
   1009                          sf_start_address = (void*)&__ACU_Hardcoded_SettingFile_Start;
   1010                      }
   1011                  #endif
   1012          
   1013                  #if (USE_HMI_HARDCODED_SETTING_FILE == ENABLED)
   1014                      if (sf_id == SF_ID_HMI)
   1015                      {
   1016                          sf_start_address = (void*)&__HMI_Hardcoded_SettingFile_Start;
   1017                      }
   1018                  #endif
   1019          
   1020                  if (sf_start_address != NULL)
   1021                  {
   1022                      if (((SF_SECTION_HEADER_TYPE*)(void*)sf_start_address)->Endianess == 0)
   1023                      {
   1024                          // The section endianess is incorrect. Treat the whole setting file as invalid.
   1025                          LOG_ADD_EXCEPTION(UNHANDLED_HARDCODED_ENDIANNESS, sf_id);
   1026                      }
   1027                      else
   1028                      {
   1029                          sf_start_address++;                     // Adjust pointer to skip over the word for the section ID and point to the End Of Section data
   1030          
   1031                          /**
   1032                           * This routine give absolute address in a big endian 16-bit pointers table
   1033                           */
   1034                          if (sf_start_address != NULL)
   1035                          {
   1036                              // Find the offset to apply to the start address
   1037                              uint16 pointer_offset = (sf_start_address[SF_PTR_ACU_CRC & 0x00FF]);   // Extract lower 8 bits to get the pointer
   1038          
   1039                              if ((SETTINGFILE_NULL_VALUE != pointer_offset) &&
   1040                                  (SF_PTR_INVALID_VALUE != pointer_offset))
   1041                              {
   1042                                  crc_address = sf_start_address + pointer_offset;
   1043                              }
   1044                          }
   1045          
   1046                          if (crc_address != NULL)
   1047                          {
   1048                              calculated_crc = SettingFile__CalculateCRC(sf_id);  // Calculate the CRC based on the data in the setting file memory location
   1049                              stored_crc = (*crc_address);        // Extract the CRC stored in the setting file
   1050          
   1051                              if (stored_crc == calculated_crc)
   1052                              {
   1053                                  crc_matches = TRUE;
   1054                              }
   1055                          }
