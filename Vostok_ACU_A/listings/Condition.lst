     25          
     26          //! ID for this module on the Log module.
     27          #define MODULE_NAME     MODULE_CONDITION
     28          
     29          //! IDs FOR LOG messages
     30          typedef enum MODULE_CONDITION_LOG_MESSAGE_ID_ENUM
     31          {
     32              EVAL_ERROR = 0,
     33              LOAD_CONDITION_TABLE,
     34              LOAD_VARIABLE_ERROR,
     35              LOAD_VARIABLE_AS_OPERAND_ERROR,
     36              OPERAND_ERROR,
     37              OPERATOR_ERROR
     38          } MODULE_CONDITION_LOG_MESSAGE_ID_TYPE;
     39          
     40          /**
     41           * Supported operators.
     42           */
     43          typedef enum OPERATOR_ENUM
     44          {
     45              OPERATOR_RESERVED_LOW        = 0,
     46              OPERATOR_MORE_THAN           = 1,               //!< TRUE if left > right.
     47              OPERATOR_LESS_THAN           = 2,               //!< TRUE if left < right.
     48              OPERATOR_NOT_EQUAL           = 3,               //!< TRUE if left != right.
     49              OPERATOR_EQUAL               = 4,               //!< TRUE if left = right.
     50              OPERATOR_MORE_THAN_OR_EQUAL  = 5,               //!< TRUE if left >= right.
     51              OPERATOR_LESS_THAN_OR_EQUAL  = 6,               //!< TRUE if left <= right.
     52              OPERATOR_RESERVED_UP         = 7
     53          } CONDITION_OPERATOR_TYPE;
     54          
     55          /**
     56           * Structure of a condition.
     57           * This is coming from the Setting File definition.
     58           */
     59          typedef struct CONDITION_STRUCT
     60          {
     61              // Byte #0
     62              CONDITION_OPERATOR_TYPE Operator    : 3;        //!< Operator to be used on the comparison.
     63              uint8 Unused                        : 3;        //!< 2 unused bits. Will be zero.
     64              BOOL_TYPE Is_Operand_A_Variable     : 1;        //!< Bool to tell the Operator will be applied to 2 variables so Operand holds another index to a Variable.
     65              BOOL_TYPE Is_Or                     : 1;        //!< Indicates how to combine this statement with the next one, if present.
     66              // Byte #1
     67              uint8 Length                        : 3;        //!< Indicates The length of 1 condition in order to find the number of conditions
     68              uint8 Free                          : 5;
     69              // Byte #2-3
     70              ACU_VARIABLE_ID_TYPE Variable_Index;                //!< Index to the Variable on the Variable module (Look at Variable_prm.h and Variable_prv.h)
     71              uint8 Variable_Offset;                          //!< Offset to access a Variable on the Variable Module. If Variable is an Array, the offset is the index of the Variable inside the Array. If it is a regulation, it is the position on the Regulation Array.
     72              // Bytes #3-4
     73              union
     74              {
     75                  sint16 Sint16;                              //!< access to signed word
     76                  uint16 Uint16;                              //!< access to unsigned word
     77                  //! access to the data as an index to variable.
     78                  struct OP_IS_VARIABLE_STRUCT
     79                  {
     80                      ACU_VARIABLE_ID_TYPE Second_Variable_Index; //!< Index to the Variable that will act as a Operand. Understanding also depends on the flag Is_Operand_A_Variable.
     81                      uint8 Second_Variable_Offset;           //!< Offset to access the Variable on the Variable module.
     82                  } Operand_Is_Variable;
     83              } Operand;                                      //!< Word operand
     84              // Bytes #5-6
     85              uint16 Mask;                                    //!< If bit Is_Mask_Needed is TRUE, Operands are masked.
     86          } CONDITION_TYPE;
