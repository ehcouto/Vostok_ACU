    242          //---------------------------------------------------------------------------------------------------------------------
    243          /**
    244           *  @brief      Get the expansion load index for the external load.
    245           *
    246           *  @param      HBL_LOAD_TYPE *load - Pointer to ice dispenser door load instance.
    247           *
    248           *  @return     uint8 expansion_load_index - value from setting file for load position in expansion ACU loads buffer.
    249           */
    250          static uint8 GetExpansionLoadIndex(HBL_LOAD_TYPE *load)
    251          {
    252              PASS_FAIL_TYPE load_success;
    253              uint8 expansion_load_index;
    254              SETTINGFILE_LOADER_TYPE sf_loader_data;
    255          
    256              expansion_load_index = 0;
    257              load_success = SettingFile__BasicLoader(SF_PTR_ACU_IO_DEVICE,
    258                                                      load->Pilot_Type_Params_Offset,
    259                                                      &sf_loader_data);
    260              if (load_success == PASS)
    261              {
    262                  if (sf_loader_data.Length > 0)
    263                  {
    264                      expansion_load_index = sf_loader_data.Data[0];
    265                  }
    266              }
    267          
    268              return (expansion_load_index);
    269          }
