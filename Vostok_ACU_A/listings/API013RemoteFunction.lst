    910          //---------------------------------------------------------------------------------------------------------------------
    911          /**
    912           * Send a feedback message with the data elements from a single background function.
    913           * @param server_function_id = The server-side function ID that identifies the remote function.
    914           */
    915          static void PublishSingleRemoteFunctionData(uint8 server_function_index)
    916          {
    917              REMOTE_FUNCTION_DATA_TYPE data_elements[API013_MAX_DATA_CHANNELS_PER_FUNCTION];
    918          
    919              // Get the data from the background function (if any).
    920              if (server_function_index < API013_NUM_OF_SERVER_FUNCTIONS)
    921              {
    922                  uint8 count = RemoteFunctionGetData(server_function_index, data_elements);
    923          
    924                  if ((0U < count) && (count <= API013_MAX_DATA_CHANNELS_PER_FUNCTION))
    925                  {
    926                      (void)PublishPreparedData(data_elements, count);
    927                  }
    928              }
    929          }
