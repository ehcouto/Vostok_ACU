    295           *  @retval     Address of processed instance data. Cast it using *((uint8 *)ptr) to get values.
    296           *  @retval     NULL - Invalid load index.
    297           */
    298          void * AnalogOutputPilot__GetProcessed(HBL_LOAD_TYPE * load)
    299          {
    300              void * processed = NULL;
