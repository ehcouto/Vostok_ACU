    363          /**
    364           * Get the status of the AccelBaseline module.
    365           * @return The status of the AccelBaseline module.
    366           */
    367          ACCEL_BASELINE_STATUS_TYPE AccelBaseline__GetStatus(void)
    368          {
    369              ACCEL_BASELINE_STATUS_TYPE status;
    370              switch (Accel_Baseline_State)
    371              {
    372                  case STATE_ACCEL_BASELINE_IDLE:
    373                      status = ACCEL_IDLE;
    374                      break;
    375                  case STATE_ACCEL_BASELINE_MEASURE_BASELINE:
    376                      status = ACCEL_MEASURING_BASELINE;
    377                      break;
    378                  case STATE_ACCEL_BASELINE_SELF_TEST_BASELINE:
    379                  case STATE_ACCEL_BASELINE_SELF_TEST0:
    380                  case STATE_ACCEL_BASELINE_SELF_TEST1:
    381                      status = ACCEL_RUNNING_SELF_TEST;
    382                      break;
    383                  default:
    384                      status = ACCEL_BASELINE_DISABLED;
    385                      break;
    386              }
    387          
    388              return(status);
    389          }
