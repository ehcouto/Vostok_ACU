     20          /**
     21           * @brief  - This macro defines the Systik interrupt priority.
     22           *
     23           *           Note - Its recommended to configure the systik at highest priority.
     24           *
     25           *
     26           * @param  - 0/1/2/3
     27           *          0 has highest priority and 3 has very low priority
     28           *
     29           * @note   - Following are the Examples\n
     30           *           "#define SYSTICK_PREEMPTION_PRIORITY 0"  //The Systik is having highest priority
     31           */
     32          //=====================================================================================================================
     33          #ifndef SYSTICK_PREEMPTION_PRIORITY
     34              #define SYSTICK_PREEMPTION_PRIORITY 3
     35          #elif (SYSTICK_PREEMPTION_PRIORITY > 3)
     36              #error : "SYSTICK_PREEMPTION_PRIORITY macro value should be either 0,1,2,3"
     37          #endif
     38          
     39          
     40          /**
     41           *    @brief  - Defines the Interrupt Interval in us
     42           *    @details- Due to the WIDE implementation it is strongly recommended to use the timer interrupt interval of 1000us.
     43           *              The macro value should not be changed
     44           *
     45           *    @param  - 1000 // Do not change the value
     46           *
     47           *    @note   - Following is the Example\n
     48           *              "#define INTERRUPT_INTERVAL   1000"
     49           */
     50          //=====================================================================================================================
     51          #ifndef INTERRUPT_INTERVAL
     52           #define INTERRUPT_INTERVAL          1000             //Interrupt interval in us
     53          #endif
     54          
     55          
     56          
     57          //=====================================================================================================================
     58          /**
     59           * @brief  - This macro defines long duration time interrupt
     60           * @details- The value should be in milli second.
     61           *            Long interval is configured only when the TimerInterrupt__SetLongInterval() is called during low power routine,
     62           *
     63           *           Note - User should take care of the long interval time and the watchdog time
     64           *
     65           * @param  - 1 to 1000
     66           *
     67           * @note   - Following are the Examples\n
     68           *           "#define TIMERITERUPT_LONG_INTERVAL_IN_MS 25"      //systik interval tick sets for every 25ms
     69           */
     70          //=====================================================================================================================
     71          #ifndef TIMERITERUPT_LONG_INTERVAL_IN_MS
     72              #define TIMERITERUPT_LONG_INTERVAL_IN_MS     25
     73          #endif
     74          
     75          #if (TIMERITERUPT_LONG_INTERVAL_IN_MS == 0)
     76              #error: "The value should be between 1 to 1000 for TIMERITERUPT_LONG_INTERVAL_IN_MS macro in the TimerInterrupt_prm.h file"
     77          #endif
     78          
     79          #define DEF_1MHZ                            1000000 //It generates a Timer clock freq = 1MHz
     80          #define DEF_1KHZ                            1000    //It generates a Timer clock freq = 1KHz
     81          
     82          
     83          #define TIMER_RELOAD_COUNT()            (Micro__GetClock()->HCLK_Frequency / (DEF_1MHZ/INTERRUPT_INTERVAL));
     84          #define TIMER_RELOAD_LONG_COUNT()       (Micro__GetClock()->HCLK_Frequency / (DEF_1KHZ/TIMERITERUPT_LONG_INTERVAL_IN_MS));
     85          #define HCLK_IN_MHZ()                   (Micro__GetClock()->HCLK_Frequency / DEF_1MHZ)
