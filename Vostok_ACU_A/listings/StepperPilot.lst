     23          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     24          //! Stepper pilot setting file parameters type definition.
     25          typedef struct STEPPER_PARAMETERS_STRUCT
     26          {
     27              uint8 Number_Of_Sequences;
     28              uint8 Sequences[8];
     29          } STEPPER_PARAMETERS_TYPE;
     30          
     31          //! Stepper pilot data type definition.
     32          PACKED typedef struct STEPPER_PILOT_DATA_STRUCT
     33          {
     34              STEPPER_PILOT_REQUEST_TYPE Requested;
     35              STEPPER_PILOT_REQUEST_TYPE Processed;
     36              STEPPER_PARAMETERS_TYPE    Parameters;          //!< Stepper pilot parameters from the setting file.
     37              COMPLETE_TYPE Status;                           //!< Status of request.
     38              uint16 Step;                                    //!< Current Step.
     39              uint16 Pulse_Width;                             //!< Requested step pulse width (speed).
     40              uint16 Pulse_Counter;                           //!< Counter to control pulse width.
     41              uint8  Stepper_Array_Index;                     //!< Index into Sequence Array.
     42              BOOL_TYPE Request_Updated;                      //!< Flag to check for updated request.
     43          } STEPPER_PILOT_DATA_TYPE;
     44          
     45          //! Tracks the number of ice dispenser door load allocations.
     46          static uint8 Stepper_Pilot_Allocation;
     47          
     48          //! Stepper pilot data array. One entry per stepper instance.
     49          static STEPPER_PILOT_DATA_TYPE Stepper_Pilot_Data[HBL_PILOT_NUM_STEPPER];
     50          
     51          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     52          static void StepperPilotReadParameters(HBL_LOAD_TYPE *load);
     53          
     54          //-------------------------------------- PUBLIC (Variables) -----------------------------------------------------------
     55          
