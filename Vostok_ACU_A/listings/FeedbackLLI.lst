     42          } FEEDBACKLLI_PARAM_TYPE;
     43          
     44          typedef struct
     45          {
     46              // Buffer of Gpio samples collected
     47              uint16 Pin_Buffer;
     48              // Sampling Sequence counter - updated on each 1ms sample
     49              uint8 Sampling_Counter;
     50              // last Sampling Sequence counter reference of the last Asynch iteration
     51              uint8 Async_Sampling_Reference;
     52              // Frequency detection in progress
     53              BOOL_TYPE Is_Detecting_Frequency;
     54              // Sampling Sequence counter reference of the last frequency event detected
     55              uint8 Last_Frequency_Event_Reference;
     56              // Time (in ms) between last two frequency events detected
     57              uint8 Time_Between_Frequency_Events;
     58              // Counter of High / Low pin level event detected: it increments on a new High value event, decrements on a new Low value event
     59              sint8 Level_Counter;
     60              // Counter of valid Frequency event detected: it increments when valid Frequency events have been detected
     61              uint8 Frequency_Counter;
     62              // Counter of Frequency an in phase with ZeroCross (phase shift around +/- 90 degrees) event detected
     63              uint8 Phase_Counter;
     64              // Current Feedback LLI value (0, 1, 2, 3)
     65              FEEDBACKLLI_VALUE_ENUM_TYPE Value;
     66              // Current AC LLI value (0, 1)
     67              uint8 Ac_Is_Present;
     68              // Last phase shift (in ms) between Frequency signal and ZeroCross - 0 if channel or ZeroCross signals are not valid frequency ones
     69              uint8 Phase_Shift;
     70          } FEEDBACKLLI_DATA_TYPE;
