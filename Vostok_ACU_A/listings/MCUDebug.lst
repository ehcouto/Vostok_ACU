    100          /**
    101           *  @brief      It Initializes the module MCUDebug and its variables
    102           *
    103           */

   \                                 In section .text, align 2, keep-with-next
    104          void MCUDebug__Initialize(void)
    105          {
    106          #if (MCL_DEBUG_MODE == ENABLED)
    107          #ifdef INITIALIZE_WASH_MOTOR
    108          	Mci__SetWashMotorType(WM_SINGLE_SPEED_SYNCH_SPH_AW);
    109          #endif
    110          
    111          #ifdef ENABLE_PILOT_MCI
    112              Pilot_Relay_Drive_Status = DISABLED;
    113              Pilot_Relay_Timer = 0;
    114              Pilot_Relay_Request = FALSE;
    115          
    116              Gpio__PinConfig(PILOT_RELAY_PORT,PILOT_RELAY_PIN,OUTPUT_PUSHPULL);
    117              Gpio__PinConfig(PILOT_DRIVE_PORT,PILOT_DRIVE_PIN,OUTPUT_PUSHPULL);
    118          
    119              // Default state of the pin
    120              GPIO__PIN_CLR(PILOT_RELAY_PORT, PILOT_RELAY_PIN); //Pilot Relay OFF
    121              GPIO__PIN_CLR(PILOT_DRIVE_PORT, PILOT_DRIVE_PIN); //Disable Pilot
    122          
    123              BD_MotorControl = 0;
    124          #endif
    125          
    126          #ifdef MCI_AUTOTESTING
    127              My_Mcislfac_Fault = 0;
    128          #endif
    129          
    130          #ifdef TIME_MEASUREMENT
    131          #ifdef UC_STM32G0X_H_
    132          	    TIM_DEF_TYPE * tim;
    133          	    tim = (TIM_DEF_TYPE *) TIM7_BASE;
    134          
    135          	    uint32 bus_freq;
    136          	    bus_freq = Micro__GetClock()->PCLK1_Frequency;
    137          
    138          	    // 1. If the APB prescaler is set to 1, TIMPCLK frequency is equal to PCLK frequency.
    139          	    // 2. Otherwise, the TIMPCLK frequency is set to twice the PCLK frequency.
    140          	    if ((RCC.CFGR & RCC_CFGR_PPRE) != 0)
    141          	    {
    142          	        bus_freq = bus_freq * 2;
    143          	    }
    144          
    145          	    //Enable the clock for TIM7 module
    146          	    RCC.APBENR1 |= RCC_APBENR1_TIM7EN;
    147          
    148          	    tim->ARR = (uint16)(0xFFFF);
    149          	    tim->PSC = (uint16)((bus_freq / (TIMER_RESOLUTION_MHZ*1000000)) - 1);
    150          
    151          
    152          	    //Up-counter , edge-aligned
    153          	    tim->CR1 = (uint16)0x0000; //Clear CR1 Register
    154          	    tim->CR1  |= TIM_CR1_ARPE; //Enable the auto reload feature
    155          	    tim->CR1  |= TIM_CR1_CEN;  //Enable the Timer
    156          #endif
    157          #ifdef UC_RX130_H
    158          	    MSTP_MTU5 = 0;                            /*lint !e923 cast from int to pointer */
    159          	    /*
    160          	     *   PCLK/1   (32Mhz)   ----   0x00
    161          	     *   PCLK/4   (16Mhz)   ----   0x01
    162          	     *   PCLK/16  (2Mhz)    ----   0x02
    163          	     *   PCLK/64  (500khz)  ----   0x03
    164          	     */
    165          	    MTU5.TCRU.BYTE        = 0x00;               //Rising Edge + PCLK (32Mhz) + No Clearing.
    166          	    MTU5.TSTR.BIT.CSTU5   = 1;                  /*lint !e923 cast from int to pointer */
    167          #endif
    168          #endif
    169          
    170          #if (SIL_MODE == ENABLED)
    171          	    Slow_Handler_Counter = 125;
    172          #endif
    173          #endif
    174          }
