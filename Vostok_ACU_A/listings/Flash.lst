     44          
     45          #define FLASH_FLAG_BSY              FLASH_SR_BSY     //! FLASH Busy flag
     46          #define FLASH_FLAG_PGERR            FLASH_SR_PGERR   //! FLASH Programming error flag
     47          #define FLASH_FLAG_WRPERR           FLASH_SR_WRPERR  //! FLASH Write protected error flag
     48          #define FLASH_FLAG_EOP              FLASH_SR_EOP     //! FLASH End of Programming flag
     49          
