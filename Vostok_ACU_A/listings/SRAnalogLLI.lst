    454          //=====================================================================================================================
    455          //-------------------------------------- Private Functions ------------------------------------------------------------
    456          //=====================================================================================================================
    457          //---------------------------------------------------------------------------------------------------------------------
    458          /**
    459           * @brief		Algorithm to update and filter a new sample
    460           * @param input		pointer to HBL_LLI_TYPE structure instance
    461           * @param status
    462           * @return	PASS if a new sample is ready, FAIL otherwise
    463           */
    464          static BOOL_TYPE AnalogInputDoRead(HBL_LLI_TYPE * input, SRANALOGLLI_READ_TYPE read_type, BOOL_TYPE is_peak_to_peak)
    465          {
    466              BOOL_TYPE ret_value = FALSE;
    467              SRANALOGLLI_DATA_TYPE *data = &SRAnalogLLI_Data[input->Data_Index];
    468              SRANALOGLLI_DATA_TYPE *n_data = &N_SRAnalogLLI_Data[input->Data_Index];
    469          
    470          	if (SRData__CheckArrayNonBlocking((void *) data, (void *) n_data, sizeof(SRAnalogLLI_Data[0])) == SRDATA_OK)
    471          	{
    472                  uint8 virtual_pin = input->Pin_Ptr[0];
    473          
    474                  if (VIRTUALPIN_TABLE[virtual_pin].pin_config == (uint8) INPUT_ANALOG)
    475                  {
    476                      SRANALOGLLI_PARAM_TYPE *param_ptr = (void *)input->Parameter_Ptr.Data;
    477                      uint8 filter_value = 1;
    478                      uint8 n_samples = 1;
    479          
    480                      uint16 new_ad_sample = Atod__Convert((ATOD_CHANNEL_DEF) VIRTUALPIN_TABLE[virtual_pin].device, (ATOD_CHANNEL_RESOLUTION_DEF) VIRTUALPIN_TABLE[virtual_pin].param0);
    481                      uint16 new_raw_sample = new_ad_sample;
    482          
    483                      if (param_ptr != NULL)
    484                      {
    485                          n_samples = 1 << (param_ptr->Config.N_Read);
    486                          filter_value = 1 << (param_ptr->Config.Filter_Reading);
    487                      }
    488          
    489                      if((read_type == SRANALOGLLI_FAST_READ) &&
    490                          (new_ad_sample != ATOD_INVALID_CONVERSION))
    491                      {
    492                          uint8 fast_max_sample_count;
    493                          uint8 one_ms_filter = (SRANALOG_ONEMS_FIXED_DELTA_FILTER == 0) ? filter_value : SRANALOG_ONEMS_FIXED_DELTA_FILTER;
    494                          if((one_ms_filter > 1) &&
    495                              (FAIL == AnalogInputCheckSample(new_ad_sample, data->Raw_Sample, one_ms_filter)))
    496                          {
    497                              SRData__UpdateByte(&data->Fast_Sync_Counter, &n_data->Fast_Sync_Counter, data->Fast_Sync_Counter+1);
    498          
    499                              if (data->Fast_Sync_Counter < SRANALOGLLI_FILTER_SAMPLES)
    500                              {
    501                                  new_ad_sample = data->Raw_Sample;
    502                              }
    503                              else
    504                              {
    505                                  SRData__UpdateByte(&data->Fast_Sync_Counter, &n_data->Fast_Sync_Counter, 0);
    506                              }
    507                          }
    508                          else
    509                          {
    510                              SRData__UpdateByte(&data->Fast_Sync_Counter, &n_data->Fast_Sync_Counter, 0);
    511                          }
    512          
    513                          // Store the maximum Value acquired during the NUMBER_OF_A2D_SAMPLES samples
    514                          if(new_ad_sample > data->Higher_Value)
    515                          {
    516                             SRData__UpdateShort(&data->Higher_Value, &n_data->Higher_Value, new_ad_sample);
    517                          }
    518          
    519                          // Store the minimum Value acquired during the NUMBER_OF_A2D_SAMPLES samples
    520                          if(new_ad_sample < data->Lower_Value)
    521                          {
    522                              SRData__UpdateShort(&data->Lower_Value, &n_data->Lower_Value, new_ad_sample);
    523                          }
    524          
    525                          // increment counter
    526          
    527                          SRData__UpdateByte(&data->Fast_Sample_Counter, &n_data->Fast_Sample_Counter, data->Fast_Sample_Counter+1);
    528                          fast_max_sample_count = (SRANALOG_ONEMS_NUM_READS > 0) ? SRANALOG_ONEMS_NUM_READS : n_samples;
    529          
    530                          if( data->Fast_Sample_Counter >= fast_max_sample_count)
    531                          {
    532                              if(is_peak_to_peak == TRUE)
    533                              {
    534                                new_ad_sample = (data->Higher_Value - data->Lower_Value);
    535                              }
    536                              else if(param_ptr->Config.Ac_Line == TRUE)
    537                              {
    538                                new_ad_sample = data->Higher_Value;
    539                              }
    540                              else
    541                              {
    542                                new_ad_sample = data->Lower_Value;
    543                              }
    544                              SRData__UpdateByte(&data->Fast_Sample_Counter, &n_data->Fast_Sample_Counter, 0);
    545                              SRData__UpdateShort(&data->Lower_Value, &n_data->Lower_Value, ATOD_INVALID_CONVERSION);
    546                              SRData__UpdateShort(&data->Higher_Value, &n_data->Higher_Value, 0);
    547                          }
    548                          else
    549                          {
    550                              new_ad_sample = ATOD_INVALID_CONVERSION;
    551                          }
    552                      }
    553          
    554                      if((is_peak_to_peak == TRUE) &&
    555                          (new_ad_sample != ATOD_INVALID_CONVERSION) &&
    556                          ((read_type == SRANALOGLLI_HI_PEAK_READ) ||
    557                              (read_type == SRANALOGLLI_LO_PEAK_READ)) )
    558                      {
    559                          if(read_type == SRANALOGLLI_HI_PEAK_READ)
    560                          {
    561                              SRData__UpdateShort(&data->Higher_Value, &n_data->Higher_Value, new_ad_sample);
    562                          }
    563                          else
    564                          {
    565                              SRData__UpdateShort(&data->Lower_Value, &n_data->Lower_Value, new_ad_sample);
    566                          }
    567          
    568                          if((data->Higher_Value != 0) &&
    569                              (data->Lower_Value != ATOD_INVALID_CONVERSION))
    570                          {
    571                              if(data->Higher_Value > data->Lower_Value)
    572                              {
    573                                  new_ad_sample = data->Higher_Value - data->Lower_Value;
    574          
    575                              }
    576                              else
    577                              {
    578                                  new_ad_sample = data->Lower_Value - data->Higher_Value;
    579                              }
    580                              SRData__UpdateShort(&data->Lower_Value, &n_data->Lower_Value, ATOD_INVALID_CONVERSION);
    581                              SRData__UpdateShort(&data->Higher_Value, &n_data->Higher_Value, 0);
    582                          }
    583                          else
    584                          {
    585                              new_ad_sample = ATOD_INVALID_CONVERSION;
    586                          }
    587                      }
    588          
    589                          SRData__UpdateShort(&data->Raw_Sample, &n_data->Raw_Sample , new_raw_sample);
    590          
    591                      // If Compensation reference is set, apply compensation algorithm
    592                      if ((SRAnalogLLI_Compensation.Reference_Value > 0) &&
    593                          (new_ad_sample != ATOD_INVALID_CONVERSION) &&
    594                          (param_ptr->Config.Compensation != 0) &&
    595                          (input->Parameter_Ptr.Length > 2))
    596                      {
    597                          uint16 max_sample;
    598                          new_ad_sample = DoCompensation(param_ptr, new_ad_sample);
    599          
    600                          switch(VIRTUALPIN_TABLE[virtual_pin].param0)
    601                          {
    602                              case ATOD_RESOLUTION_04BITS:
    603                                  max_sample = 0x000F;
    604                                  break;
    605                              case ATOD_RESOLUTION_08BITS:
    606                                  max_sample = 0x00FF;
    607                                  break;
    608                              case ATOD_RESOLUTION_10BITS:
    609                                  max_sample = 0x03FF;
    610                                  break;
    611                              case ATOD_RESOLUTION_12BITS:
    612                                  max_sample = 0x0FFF;
    613                                  break;
    614                              case ATOD_RESOLUTION_14BITS:
    615                                  max_sample = 0x3FFF;
    616                                  break;
    617                              default:
    618                                  max_sample = 0xFFFE;
    619                          }
    620                          if(new_ad_sample > max_sample)
    621                          {
    622                              new_ad_sample = max_sample;
    623                          }
    624                      }
    625          
    626                      if(read_type == SRANALOGLLI_FAST_READ)
    627                      {
    628                          #if(SRANALOG_ONEMS_FIXED_DELTA_FILTER == 0)
    629                          // This check skips Sample Delta filtering on OneMs readings - it's performed at 1ms level
    630                              filter_value = 1;
    631                          #endif
    632                          #if(SRANALOG_ONEMS_NUM_READS == 0)
    633                              // If N_Samples is used on 1ms readings, force it to 1
    634                              n_samples = 1;
    635                          #elif(SRANALOG_ONEMS_NUM_READS_DIVIDER > 1)
    636                              // Applies SRANALOG_ONEMS_NUM_READS_DIVIDER into N_Samples, if set
    637                              if(n_samples > SRANALOG_ONEMS_NUM_READS_DIVIDER)
    638                              {
    639                                  n_samples /= SRANALOG_ONEMS_NUM_READS_DIVIDER;
    640                              }
    641                              else
    642                              {
    643                                  n_samples = 1;
    644                              }
    645                          #endif
    646                      }
    647          
    648                      // Delta filter of a new sample compared to last one
    649                      if ((new_ad_sample != ATOD_INVALID_CONVERSION) &&
    650                          (filter_value > 1))
    651                      {
    652                          if (FAIL == AnalogInputCheckSample(new_ad_sample, data->Last_Sample, filter_value))
    653                          {
    654                              if (data->Sync_Counter == 0)
    655                              {
    656                                  SRData__UpdateShort(&data->Last_Sample, &n_data->Last_Sample, new_ad_sample);
    657                              }
    658                              else
    659                              {
    660                                  SRData__UpdateByte(&data->Sync_Counter, &n_data->Sync_Counter, 0);
    661                              }
    662                              SRData__UpdateByte(&data->Sample_Counter, &n_data->Sample_Counter, 0);
    663                              SRData__UpdateLong(&data->Sum, &n_data->Sum, 0);
    664                              new_ad_sample = ATOD_INVALID_CONVERSION;
    665                          }
    666                          else
    667                          {
    668                              SRData__UpdateShort(&data->Last_Sample, &n_data->Last_Sample, new_ad_sample);
    669                              if (data->Sync_Counter < SRANALOGLLI_FILTER_SAMPLES)
    670                              {
    671                                  new_ad_sample = ATOD_INVALID_CONVERSION;
    672                                  SRData__UpdateByte(&data->Sync_Counter, &n_data->Sync_Counter, data->Sync_Counter+1);
    673                              }
    674                          }
    675                      }
    676          
    677                      // Process new valid sample and update average (if ready)
    678                      if (new_ad_sample != ATOD_INVALID_CONVERSION)
    679                      {
    680                          SRData__UpdateLong(&data->Sum, &n_data->Sum, data->Sum + new_ad_sample);
    681                          SRData__UpdateByte(&data->Sample_Counter, &n_data->Sample_Counter, data->Sample_Counter + 1);
    682          
    683                          if (data->Sample_Counter >= n_samples)
    684                          {
    685                              SRData__UpdateShort(&data->Value, &n_data->Value, data->Sum / n_samples);
    686                              SRData__UpdateLong(&data->Sum, &n_data->Sum, 0);
    687                              SRData__UpdateByte(&data->Sample_Counter, &n_data->Sample_Counter, 0);
    688                              ret_value = TRUE;
    689                          }
    690          
    691                          // If it's compensation reference, check and updates
    692                          if  ((param_ptr->Config.Reference != 0) &&
    693                                  (input->Parameter_Ptr.Length > 2))
    694                          {
    695                              UpdateReference(param_ptr, new_ad_sample);
    696                          }
    697                      }
    698                  }
    699          	}
    700          	else
    701          	{
    702          		SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, input->LLI_Handler_Index, input->Data_Index);
    703          	}
    704          
    705          
    706              return (ret_value);
    707          }
    708          
    709          //---------------------------------------------------------------------------------------------------------------------
    710          /**
    711           * @brief		Check new sample with filter value
    712           * @param sample new AD sample read
    713           * @param ref last AD value refrence
    714           * @param delta maximum delta between new and last values
    715           * @return PASS if new sample differs from reference less than delta, FAIL otherwise
    716           */
    717          static PASS_FAIL_TYPE AnalogInputCheckSample(uint16 sample, uint16 ref, uint8 delta)
    718          {
    719              PASS_FAIL_TYPE ret_value;
    720          
    721              ret_value = PASS;
    722          
    723              if (ref != ATOD_INVALID_CONVERSION)
    724              {
    725                  if (sample > (ref + delta))
    726                  {
    727                      ret_value = FAIL;
    728                  }
    729          
    730                  if (ref > delta)
    731                  {
    732                      if (sample < (ref - delta))
    733                      {
    734                          ret_value = FAIL;
    735                      }
    736                  }
    737              }
    738          
    739              return (ret_value);
    740          }
    741          
    742          //---------------------------------------------------------------------------------------------------------------------
    743          /**
    744           * @brief		Compensation algorithm
    745           * @param input_param	Configuration parameters related to a channel
    746           * @param ad_value		AD Value to compensate
    747           * @return AD Value compensated; ad_value if not applied
    748           */
    749          static uint16 DoCompensation(SRANALOGLLI_PARAM_TYPE *input_param, uint16 ad_value)
    750          {
    751          	sint32 temp_value = ad_value;
    752          
    753          	if (SRData__CheckArrayNonBlocking(&SRAnalogLLI_Compensation, &N_SRAnalogLLI_Compensation, sizeof(SRAnalogLLI_Compensation)) == SRDATA_OK)
    754          	{
    755          		if (SRAnalogLLI_Compensation.Reference_Value > SRAnalogLLI_Compensation.Nominal_Offset)
    756          		{
    757          			temp_value -= (sint32) input_param->Config_param.Compensated.Comp_Pre_Offset;
    758          			temp_value -= ENDIANU16_STON(input_param->Config_param.Compensated.Zero_Level_Ref);
    759          			temp_value *= (SRAnalogLLI_Compensation.Nominal_Value - SRAnalogLLI_Compensation.Nominal_Offset);
    760          			temp_value /= (SRAnalogLLI_Compensation.Reference_Value - SRAnalogLLI_Compensation.Nominal_Offset);
    761          			temp_value += ENDIANU16_STON(input_param->Config_param.Compensated.Zero_Level_Ref);
    762          			temp_value += (sint32) input_param->Config_param.Compensated.Comp_Post_Offset;
    763          
    764          			if (temp_value < 0)
    765          			{
    766          				temp_value = 0;
    767          			}
    768          		}
    769          	}
    770          	else
    771          	{
    772          		SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0xFF, 0xFF);
    773          	}
    774          
    775          	return((uint16) temp_value);
    776          
    777          }
    778          
    779          /**
    780           * @brief		Check and update reference value
    781           * @param input_param	Configuration parameters related to a channel
    782           * @param ad_value		AD Value of reference read
    783           */
    784          static void UpdateReference(SRANALOGLLI_PARAM_TYPE *input_param, uint16 advalue)
    785          {
    786          	if (SRData__CheckArrayNonBlocking(&SRAnalogLLI_Compensation, &N_SRAnalogLLI_Compensation,
    787          		sizeof(SRAnalogLLI_Compensation)) == SRDATA_OK)
    788          	{
    789          		uint16 min_val = ENDIANU16_STON(input_param->Config_param.Reference.Min);
    790          		uint16 max_val = ENDIANU16_STON(input_param->Config_param.Reference.Max);
    791          
    792          		// If a reference Value is set, applies an hysteresis to Min and Max thresholds
    793          		if (SRAnalogLLI_Compensation.Reference_Value > 0)
    794          		{
    795          			if (min_val > input_param->Config_param.Reference.Hysteresis)
    796          			{
    797          				min_val -= input_param->Config_param.Reference.Hysteresis;
    798          			}
    799          			else
    800          			{
    801          				min_val = 0;
    802          			}
    803          
    804          			max_val += input_param->Config_param.Reference.Hysteresis;
    805          		}
    806          
    807          		// Check and update reference values
    808          		if ( (advalue >= min_val) &&
    809          				(advalue <= max_val) )
    810          		{
    811          			SRData__UpdateShort(&SRAnalogLLI_Compensation.Reference_Value, &N_SRAnalogLLI_Compensation.Reference_Value, advalue);
    812          			SRData__UpdateShort(&SRAnalogLLI_Compensation.Nominal_Value, &N_SRAnalogLLI_Compensation.Nominal_Value, ENDIANU16_STON(input_param->Config_param.Reference.Nominal));
    813          			SRData__UpdateByte((void *) &SRAnalogLLI_Compensation.Nominal_Offset,(void *) &N_SRAnalogLLI_Compensation.Nominal_Offset, input_param->Config_param.Reference.Pre_Offset);
    814          		}
    815          		else
    816          		{
    817          			SRData__UpdateShort(&SRAnalogLLI_Compensation.Reference_Value, &N_SRAnalogLLI_Compensation.Reference_Value, 0);
    818          		}
    819          	}
    820          	else
    821          	{
    822          		SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0xFF, 0xFF);
    823          	}
    824          
    825          }
    826          
    827          uint8 FindCheckGpio(uint8 channel)
    828          {
    829          #if (SRANALOG_EXTERNAL_CHECK_GPIO_FEATURE == ENABLED)
    830              uint8 index;
    831          
    832              for (index = 0; index < ELEMENTS_IN_ARRAY(CHECK_PIN_TABLE); index++)
    833              {
    834                  if(CHECK_PIN_TABLE[index].Atod_Channel == channel)
    835                  {
    836                      // Found index - break the loop
    837                      break;
    838                  }
    839              }
    840              return index;
    841          
    842          #else
    843              return 0;
    844          #endif
    845          }
    846          
    847          #endif


 

 


