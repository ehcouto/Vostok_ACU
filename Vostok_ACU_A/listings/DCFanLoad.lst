     26          typedef enum
     27          {
     28              DCFANLOAD_STATE_OFF = 0,
     29              DCFANLOAD_STATE_RAMPING_UP,
     30              DCFANLOAD_STATE_ON
     31          }DCFANLOAD_STATE_TYPE;
     32          
     33          typedef struct
     34          {
