    408          //---------------------------------------------------------------------------------------------------------------------
    409          /**
    410           *  @brief      Handler called at every 200us.
    411           */
    412          void MagnetronPilot__200usHandler(void)
    413          {
    414              //! Save Pilot_Index before entering interrupt handler
    415              uint8 Pilot_Index_Bak = Pilot_Index;
    416          
    417              for(Pilot_Index = 0; Pilot_Index < Magnetron_Pilot_Allocation; Pilot_Index++)
    418              {
    419                  if(Magnetron_Pilot_Data[Pilot_Index].Pilot_Enable == TRUE)
    420                  {
    421                      MagnetronPilotMainsSampler__200usHandler(Pilot_Index);
    422                      MagnetronPilotRelaySync__200usHandler(Pilot_Index);
    423                  }
    424              }
    425          
    426              //! Restore Pilot_Index before exiting interrupt handler
    427              Pilot_Index = Pilot_Index_Bak;
    428          }
    429          
    430          //---------------------------------------------------------------------------------------------------------------------
    431          /**
    432           * @brief      Handler called at every 5ms.
    433           * @param      load
    434           * @return
    435           */
    436          //---------------------------------------------------------------------------------------------------------------------
    437          PASS_FAIL_TYPE MagnetronPilot__AsynchHandler(HBL_LOAD_TYPE * load)
    438          {
    439              PASS_FAIL_TYPE retval = FAIL;
    440          
    441              if (load->Pilot_Data_Index < Magnetron_Pilot_Allocation)
    442              {
    443                  Pilot_Index = load->Pilot_Data_Index;
    444          
    445                  if(Magnetron_Pilot_Data[Pilot_Index].Pilot_Enable == TRUE)
    446                  {
    447                      MagnetronPilotMainsSampler__AsynchHandler(Pilot_Index);
    448                      MagnetronPilotRelaySync__AsynchHandler(Pilot_Index, Magnetron_Pilot_Data[Pilot_Index].Processed);
    449          
    450                      retval = PASS;
    451                  }
    452              }
    453          
    454              return (retval);
    455          }
