     35          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     36          
     37          //! Hold initial value of the filter
     38          #define PRESURE_SENSOR_INITIAL_FILTER_VALUE     0
     39          
     40          //! Holds the LLI Output value while the filter is stabilizing;
     41          static const sint32 STABILIZING_PRESSURE = SRI2CPRESSURESENSOR_STABILIZING;
     42          
     43          //! Holds the LLI Output value if there is an active I2C communication failure
     44          static const sint32 I2C_COMM_FAILURE_PRESSURE = SRI2CPRESSURESENSOR_I2C_FAILURE;
     45          
     46          //! The maximum bit value for the Alpha used on the IIR filter.
     47          //! A maximum bit value of 15 results in the heaviest filtering provided by an alpha of 1/32768.
     48          #define IIRFILTER_MAX_COEFFICIENT_BIT   15
     49          
     50          //! Rate at which the Asynchronous function is called. This is used for stabilizing time.
     51          #define ASYNCH_CALL_RATE 5U
     52          
     53          //! Identifies the format of the raw and filtered values in the IIR filter.
     54          typedef sint32 FILTER_DATA_TYPE;
     55          
     56          //! A structure that holds the variables required for the IIR filter functionality.
     57          PACKED typedef struct IIR_FILTER_MEASURE_STRUCT
     58          {
     59              //! The filtered value provided by the filter. This value is always available after initialization.
     60                  sint32 Filtered_Value;
     61          
     62              //! The accumulator value contains a fixed-point version of the filtered value.
     63              //! This fixed-point value uses higher precision based on the alpha coefficient used.
     64                  sint32 Accumulator;
     65          
     66              //! This value is initially the inverted alpha coefficient. After the Filter__Initialize()
     67              //! function is called, this value is converted to the number of bits to shift between the
     68              //! accumulator and the filtered value.
     69              uint16 Inverted_Alpha;
     70          } IIR_FILTER_MEASURE_TYPE;
     71          
     72          typedef enum
     73          {
     74              I2C_PRESSURE_SENSOR_REQUEST = 0,
     75              I2C_PRESSURE_SENSOR_READ
     76          }I2C_PRESSURE_SENSOR_STATE_TYPE;
     77          
     78          //! Definition of setting file parameters for the module
     79          PACKED typedef struct
     80          {
     81              uint16 Unused_1;                        // 2 bytes reserved for all LLI modules (none of the data applies to this LLI)
     82              uint8  Unused_2;                        // Currently not used (previously Device Type, but this is configured by hardware in the device); kept for backwards compatibility
     83              uint8  Inverted_Alpha;                  // Feedback filter coefficient for IIR filter
     84              uint16 Initial_Time;
     85              uint8  Communication_Fault_Debounce;    // Amount of time for the I2C communication failure to be present before a recovery/retry
     86              uint8  Communication_Fault_Retries;     // Number of recovery retries to attempt before reporting a failure to the application
     87          }I2C_PRESSURE_SENSOR_PARAM_TYPE;
     88          
     89          //! Definition of variables used by the module
     90          PACKED typedef struct
     91          {
     92              I2C_PRESSURE_SENSOR_STATE_TYPE State;
     93              IIR_FILTER_MEASURE_TYPE Filter;
     94              uint16 Settling_Timer;
     95              uint16 Pressure;
     96              uint8 Communication_Fault_Debounce;             // Hold the debounce limit configure in setting file
     97              uint8 Communication_Fault_Retries;              // Hold the retires limit configure in setting file
     98              uint8 Communication_Fault_Debounce_Counter;     // This counter counts till Communication_Fault_Debounce value then retry to recovery from I2C communication failure
     99              uint8 Communication_Fault_Retry_Counter;        // This counter counts till Communication_Fault_Retries value then report I2C communication failure
    100              uint8 Buffer[4];
    101          }I2C_PRESSURE_SENSOR_DATA_TYPE;
    102          
    103          
    104          //! CRC of the data for the module to be used when checking the integrity of the data
    105          static uint8 SRI2CPressureSensorLLI_Crc[HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR];
    106          
    107          //! Module data used to request and process I2C Pressure Sensor data
    108          static I2C_PRESSURE_SENSOR_DATA_TYPE Sr_I2c_Pressure_Data[HBL_LLI_NUM_SRI2C_PRESSURE_SENSOR];
    109          
    110          //! Tracks the number of SR I2C Pressure Sensors Configured in the Setting file.
    111          static uint8 Sr_I2CPressure_Sensor_LLI_Allocation;
    112          
    113          //! Inverted variable for Class B verification
    114          static uint8 N_Sr_I2CPressure_Sensor_LLI_Allocation;
