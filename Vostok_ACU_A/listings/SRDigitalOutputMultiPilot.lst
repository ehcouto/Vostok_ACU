    279          //---------------------------------------------------------------------------------------------------------------------
    280          /**
    281           *  @brief      Asynchronous process for SRDigitalOutputMultiPilot.
    282           *
    283           *	@detail     Asynchronous process handles status transition and consistency check for door lock status
    284           *
    285           *  @param      HBL_LOAD_TYPE *load - Pointer to SRDigitalOutputMultiPilot instance.
    286           *
    287           *  @return     PASS_FAIL_TYPE result - Result of SRDigitalOutputMultiPilot asynch execution.
    288           *  @retval     PASS - Execution succeeded.
    289           *  @retval     FAIL - Execution failed.
    290           */
    291          PASS_FAIL_TYPE SRDigitalOutputMultiPilot__AsynchProcess(HBL_LOAD_TYPE * load)
    292          {
    293              PASS_FAIL_TYPE retval = FAIL;
    294          
    295              if (CheckItem(load->Pilot_Data_Index))
    296              {
    297                  SRDIGITALOUTPUTMULTIPILOT_DATA_TYPE *ptr = &SRDigitalOutputMultiPilot_Data[load->Pilot_Data_Index];
    298                  uint8 virtual_pin = load->Pin_Ptr[0];
    299                  uint8 virtual_pin2 = load->Pin_Ptr[1];
    300          
    301                  if ((VIRTUALPIN_TABLE[virtual_pin].port != 0xFF) &&
    302                      (VIRTUALPIN_TABLE[virtual_pin2].port != 0xFF))
    303                  {
    304                      BOOL_TYPE pin1_val = (BOOL_TYPE) ptr->Last_Pin_1_Value;
    305                      BOOL_TYPE pin2_val = (BOOL_TYPE) ptr->Last_Pin_2_Value;
    306          
    307                      if ((Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config, pin1_val) == TRUE) &&
    308                          (Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin2].port,VIRTUALPIN_TABLE[virtual_pin2].pin,VIRTUALPIN_TABLE[virtual_pin2].pin_config, pin2_val)	== TRUE))
    309                      {
    310                          DoPinsUpdate(load);
    311                          retval = PASS;
    312                      }
    313              		else
    314              		{
    315                          SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, HBL_PILOT_DIGITAL_OUTPUT_MULTI_2_PIN, load->Pilot_Data_Index);
    316              		}
    317                  }
    318              }
    319              return(retval);
    320          }
