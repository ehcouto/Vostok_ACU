     69          /**
     70           *  @brief       It Initializes the module MotorPilot and its variables.
     71           */
     72          void MotorPilot__Initialize(void)
     73          {
     74              Motor_Pilot_Allocation = 0;
     75              memset(&Motor_Pilot_Data, 0, sizeof(Motor_Pilot_Data));
     76          }
     77          
     78          //---------------------------------------------------------------------------------------------------------------------
     79          /**
     80           *  @brief      Allocate instance for Motor pilot.
     81           *
     82           *  @return     uint8 retval - Allocation result.
     83           *  @retval     0-254 - Pilot allocation instance.
     84           *  @retval     0xFF - Allocation failed.
     85           */
     86          uint8 MotorPilot__Allocate(void)
     87          {
     88              uint8 retval;
     89          
     90              retval = 0xFF;
     91          
     92              if (Motor_Pilot_Allocation < HBL_PILOT_NUM_MOTOR)
     93              {
     94                  retval = Motor_Pilot_Allocation;
     95                  Motor_Pilot_Allocation++;
     96              }
     97          
     98              return (retval);
     99          }
