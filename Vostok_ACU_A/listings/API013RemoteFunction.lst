    242          /**
    243           * Background function for the API013RemoteFunction module.
    244           * Periodically publish data elements from any background function that have data elements ready.
    245           */

   \                                 In section .text, align 2, keep-with-next
    246          void API013RemoteFunction__Background(void)
    247          {
    248              #if (API013_SERVER_FEATURE == ENABLED)
    249                  uint8 index;
    250                  REMOTE_FUNCTION_BACKGROUND_TYPE background;
    251          
    252                  // Handle all active remote functions.
    253                  for (index = 0; index < API013_NUM_OF_SERVER_FUNCTIONS; index++)
    254                  {
    255                      // Check if the remote function is active.
    256                      if (Utilities__GetBitInArray(Api013.Functions_Active, index) == (uint8)ACTIVE)
    257                      {
    258                          // Check if the remote function has a background function.
    259                          background = API013_SERVER_FUNCTIONS[index].Background_Function;
    260                          if (background != REMOTE_FUNCTION_BACKGROUND_NULL)
    261                          {
    262                              // Call the background function. Check if it self-terminated.
    263                              if (background() == INACTIVE)
    264                              {
    265                                  PublishSingleRemoteFunctionData((uint8)index);
    266                                  Utilities__SetBitInArray(Api013.Functions_Active, index, (uint8)INACTIVE);
    267                              }
    268                          }
    269                      }
    270                  }
    271          
    272                  // Periodically publish data from active remote functions.
    273                  if (Api013.Publication_Period > 0U)
    274                  {
    275                      if (Api013.Publication_Counter > 0U)
    276                      {
    277                          Api013.Publication_Counter--;
    278                      }
    279                      if (Api013.Publication_Counter == 0U)
    280                      {
    281                          // Publish data for all active remote functions.
    282                          PublishAllRemoteFunctionData();
    283                          Api013.Publication_Counter = Api013.Publication_Period;
    284                      }
    285                  }
    286              #endif      // #if (API013_SERVER_FEATURE == ENABLED)
    287          }
   \                     API013RemoteFunction__Background: (+1)
   \   00000000   0x4770             BX       LR               ;; return
