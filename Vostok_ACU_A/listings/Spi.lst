    753          
    754                                  Dma__Initialize(SPI_1_TX_DMA_ENGINE, SPI_1_TX_DMA_CHANNEL, (DMA_INIT_TYPE*)(&SPI_1_TX_DMA_CONFIG));
    755          
    756                                  #if (SPI_1_TX_ONLY == DISABLED)
    757                                      Dma__Initialize(SPI_1_RX_DMA_ENGINE, SPI_1_RX_DMA_CHANNEL, (DMA_INIT_TYPE*)(&SPI_1_RX_DMA_CONFIG));
    758                                  #endif
    759          
    760                                  if (Dma__StartTransfer(SPI_1_TX_DMA_ENGINE, SPI_1_TX_DMA_CHANNEL, size) == TRUE)
    761                                  {
    762                                      #if (SPI_1_TX_ONLY == DISABLED)
    763                                      if (Dma__StartTransfer(SPI_1_RX_DMA_ENGINE, SPI_1_RX_DMA_CHANNEL, size) == TRUE)
    764                                      #endif
    765                                      {
    766                                          #if (SPI_1_TX_ONLY == DISABLED)
