    545          //=====================================================================================================================
    546          //-------------------------------------- Private Functions ------------------------------------------------------------
    547          //=====================================================================================================================
    548          static void MclZeroCrossControlLoop(void)
    549          {
    550          	Mcl_Quantities.Zero_Cross_Event = FALSE; 	//Clear ZC Flag
    551          
    552              // Any ZC event before MCISLFAC_KEEP_OUT_WINDOW is noise
    553              if(Mcl_Quantities.Semi_Period_Time_Raw > MCISLFAC_KEEP_OUT_WINDOW)
    554              {
    555                  Mcl_Quantities.Triac_Trigger_Event = FALSE;
    556              	MclZeroCross__SemiPeriodFilter(&Mcl_Zero_Cross_IO, Mcl_Params); //Filter the Zero Cross Period
    557          
    558                  if(TRUE == Mcl_Quantities.MciSlfac_Prev_VZC_State)
    559                  {
    560                  	MclObserver__ActivePowerEstimation(&Mcl_Observer_IO, Mcl_Params);
    561                  }
    562          
    563          #ifdef PW_MOTOR_ENABLED
    564                  if(TRUE == Mcl_Quantities.MciSlfac_Prev_VZC_State)
    565                  {
    566                  	Mcl_Quantities.VZC_Time_P = Mcl_Cs.Mcl_Main_Counter;
    567                  }
    568                  else
    569                  {
    570                  	Mcl_Quantities.VZC_Time_N = Mcl_Cs.Mcl_Main_Counter;
    571                  }
    572          #endif
    573          
    574                  //Motor Control at Zero Cross event
    575                  MclFireAngleCtrl__ZeroCrossHandler(&Mcl_FireAngle_Ctrl_IO, Mcl_Params);
    576              }
    577              else
    578              {
    579              	//If timer reads zero, raise a fault
    580              	if(Mcl_Quantities.Semi_Period_Time_Raw == 0)
    581              	{
    582              		Mcl_Quantities.Mcl_Fault = ZERO_CROSS_NOT_DETECTED;
    583              	}
    584              }
    585          }
    586          
    587          
    588          
    589          
    590          static void MclCheckErrorsFastHandler(void)
    591          {
    592          	MCI_ERROR_TYPE error;
    593          
    594          	error = (MCI_ERROR_TYPE)Mcl_Quantities.Mcl_Fault;
    595          
    596          	if(error >= UNDER_VOLTAGE)
    597          	{
    598          		// If error is one of these...
    599          		//UNDER_VOLTAGE
    600          		//UNDER_VOLTAGE_SHORT_CIRCUIT
    601          		//ZERO_CROSS_NOT_DETECTED
    602          		//POWER_DROP
    603          		FailureHandlerRecover(error);
    604          	}
    605          	else
    606          	{
    607          		FailureHandler();
    608          	}
    609          
    610          	//Manage Flags
    611          	Mcl_Quantities.MciSlfac_Last_Failure = error;
    612          	Mcl_Quantities.Mcl_Fault = 0;
    613          }
