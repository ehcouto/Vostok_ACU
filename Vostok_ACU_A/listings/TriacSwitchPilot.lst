     63          //---------------------------------------------------------------------------------------------------------------------
     64          /**
     65           *  @brief      It Initializes the module TriacSwitchPilot and its variables
     66           *
     67           */
     68          void TriacSwitchPilot__Initialize(void)
     69          {
     70              Triac_Switch_Allocation = 0;
     71              memset(Triac_Switch_Data,0,sizeof(Triac_Switch_Data));
     72          }
     73          
     74          
     75          //---------------------------------------------------------------------------------------------------------------------
     76          /**
     77           *  @brief      Allocate pilot instance for TriacSwitchPilot.
     78           *
     79           *  @return     uint8 result - Allocation result.
     80           *  @retval     0-254 - Pilot allocation instance.
     81           *  @retval     0xFF - Allocation failed.
     82           */
     83          uint8 TriacSwitchPilot__Allocate(void)
     84          {
     85              uint8 retval = 0xFF;
     86              if (Triac_Switch_Allocation < (uint8) HBL_PILOT_NUM_TRIACSWITCH)
     87              {
     88                  retval = Triac_Switch_Allocation;
     89                  Triac_Switch_Allocation++;
     90              }
     91              return (retval);
     92          }
     93          
     94          //---------------------------------------------------------------------------------------------------------------------
     95          /**
     96           *  @brief      Initialize TriacSwitchPilot instance.
     97           *
     98           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
     99           *
    100           *  @return     PASS_FAIL_TYPE result - Result of TriacSwitchPilot instance initialization.
    101           *  @retval     PASS - Instance initialization succeeded.
    102           *  @retval     FAIL - Instance initialization failed.
    103           */
    104          PASS_FAIL_TYPE TriacSwitchPilot__InitializeInstance(HBL_LOAD_TYPE * load)
    105          {
    106              PASS_FAIL_TYPE retval;
    107              retval = FAIL;
    108              uint8 virtual_pin = load->Pin_Ptr[0];
    109          
    110              if ((load->Pilot_Data_Index < Triac_Switch_Allocation) &&
    111                  (virtual_pin < VirtualPin__GetNumOf()))
    112              {
    113                  uint8 pin_val = Triac_Switch_Data[load->Pilot_Data_Index].Processed;
    114          
    115                  Triac_Switch_Data[load->Pilot_Data_Index].State = TRIACSWITCH_OFF_STATE;
    116          
    117                  // Invert pin value according to Hi Low Activation Bitmap
    118                  pin_val ^= ~load->Hi_Low_Activation_Bitmap;
    119                  pin_val &= 0x01U;
    120          
    121                  if (VIRTUALPIN_TABLE[virtual_pin].port != PORT_NULL)
    122                  {
    123                      Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) pin_val);
    124                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    125                      Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    126                      Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Cur_Reg = 0U;
    127                      Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Pin_Value = 0U;
    128                      retval = PASS;
    129                  }
    130              }
    131          
    132              return (retval);
    133          }
    134          
    135          //---------------------------------------------------------------------------------------------------------------------
    136          /**
    137           *  @brief      Set TriacSwitchPilot instance request.
    138           *
    139           *  @param      HBL_LOAD_TYPE *load - Pointer to associated TriacSwitchPilot instance.
    140           *
    141           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    142           *
    143           *  @return     PASS_FAIL_TYPE result - Result of TriacSwitchPilot request.
    144           *  @retval     PASS - Instance request succeeded.
    145           *  @retval     FAIL - Instance request failed.
    146           */
    147          PASS_FAIL_TYPE TriacSwitchPilot__Request(HBL_LOAD_TYPE * load, void * data)
    148          {
    149              PASS_FAIL_TYPE retval = FAIL;
    150              if (load->Pilot_Data_Index < Triac_Switch_Allocation)
    151              {
    152                  Triac_Switch_Data[load->Pilot_Data_Index].Requested = *((uint8 *)data);
    153                  retval = PASS;
    154              }
    155              return(retval);
    156          }
    157          
    158          //---------------------------------------------------------------------------------------------------------------------
    159          /**
    160           *  @brief      Process TriacSwitchPilot instance.
    161           *
    162           *  @param      HBL_LOAD_TYPE *load - Pointer to TriacSwitchPilot instance.
    163           *
    164           *  @return     PASS_FAIL_TYPE result - Result of TriacSwitchPilot instance process.
    165           *  @retval     PASS - Instance process succeeded.
    166           *  @retval     FAIL - Instance process failed.
    167           */
    168          PASS_FAIL_TYPE TriacSwitchPilot__Process(HBL_LOAD_TYPE * load)
    169          {
    170              PASS_FAIL_TYPE retval = FAIL;
    171              if (load->Pilot_Data_Index < Triac_Switch_Allocation)
    172              {
    173                  // Transition to a new state
    174                  if (Triac_Switch_Data[load->Pilot_Data_Index].Requested != Triac_Switch_Data[load->Pilot_Data_Index].Processed)
    175                  {
    176                      //if(Triac_Switch_Data[load->Pilot_Data_Index].Requested)
    177                      Triac_Switch_Data[load->Pilot_Data_Index].Processed = Triac_Switch_Data[load->Pilot_Data_Index].Requested;
    178                      Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    179                      Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Cur_Reg = Triac_Switch_Data[load->Pilot_Data_Index].Requested;
    180                  }
    181                  retval = PASS;
    182              }
    183          
    184              return (retval);
    185          }
    186          
    187          //---------------------------------------------------------------------------------------------------------------------
    188          /**
    189           *  @brief      Zero-Cross triggered process for TriacSwitchPilot.
    190           *
    191           *  @detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    192           *
    193           *  @param      HBL_LOAD_TYPE *load - Pointer to TriacSwitchPilot instance.
    194           *
    195           *  @return     PASS_FAIL_TYPE result - Result of TriacSwitchPilot ZC execution.
    196           *  @retval     PASS - Execution succeeded.
    197           *  @retval     FAIL - Execution failed.
    198           */
    199          PASS_FAIL_TYPE TriacSwitchPilot__ZCProcess(HBL_LOAD_TYPE * load)
    200          {
    201              PASS_FAIL_TYPE retval = FAIL;
    202          
    203              if (load->Pilot_Data_Index < Triac_Switch_Allocation)
    204              {
    205                  uint8 active_pin_value = load->Hi_Low_Activation_Bitmap & 0x01U;
    206                  uint8 virtual_pin = load->Pin_Ptr[0];
    207          
    208                  //Read the current zero cross angle
    209                  switch(Triac_Switch_Data[load->Pilot_Data_Index].State)
    210                  {
    211          
    212                      case TRIACSWITCH_OFF_STATE:
    213                          if(Triac_Switch_Data[load->Pilot_Data_Index].Processed != 0U)
    214                          {
    215                              Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE)((load->Hi_Low_Activation_Bitmap) & 0x01U));
    216                              Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    217                              Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    218                              Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Pin_Value = 1U;
    219                              Triac_Switch_Data[load->Pilot_Data_Index].State = TRIACSWITCH_ON_STATE;
    220                          }
    221                          break;
    222          
    223                      case TRIACSWITCH_ON_STATE:
    224                          if(Triac_Switch_Data[load->Pilot_Data_Index].Processed == 0U)
    225                          {
    226                              Triac_Switch_Data[load->Pilot_Data_Index].Timer_Counter = TRIAC_SWITCH_OFF_DELAY_MS;
    227                              Triac_Switch_Data[load->Pilot_Data_Index].State = TRIACSWITCH_TURNING_OFF;
    228                          }
    229                          break;
    230          
    231                      case TRIACSWITCH_TURNING_OFF:
    232                          break;
    233          
    234                      default:
    235                          // Force pin OFF
    236                          active_pin_value ^= 0x01U;
    237                          Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) active_pin_value);
    238                          Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    239                          Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    240                          Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Cur_Reg = 0U;
    241                          Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Pin_Value = 0U;
    242                          break;
    243          
    244                  }
    245                  retval = PASS;
    246              }
    247          
    248              return (retval);
    249          }
    250          
    251          //---------------------------------------------------------------------------------------------------------------------
    252          /**
    253           *  @brief      One millisecond process for TriacSwitchPilot.
    254           *
    255           *  @detail     Low level feedback probe to detect frequency and pin activation in sync with feedback
    256           *
    257           *  @param      HBL_LOAD_TYPE *load - Pointer to TriacSwitchPilot instance.
    258           *
    259           *  @return     PASS_FAIL_TYPE result - Result of TriacSwitchPilot 1ms execution.
    260           *  @retval     PASS - Execution succeeded.
    261           *  @retval     FAIL - Execution failed.
    262           */
    263          PASS_FAIL_TYPE TriacSwitchPilot__OneMsHandler(HBL_LOAD_TYPE * load)
    264          {
    265              PASS_FAIL_TYPE retval = FAIL;
    266          
    267              if (load->Pilot_Data_Index < Triac_Switch_Allocation)
    268              {
    269                  switch(Triac_Switch_Data[load->Pilot_Data_Index].State)
    270                  {
    271                      case TRIACSWITCH_TURNING_OFF:
    272                          if(Triac_Switch_Data[load->Pilot_Data_Index].Timer_Counter == 0U)
    273                          {
    274                              uint8 virtual_pin = load->Pin_Ptr[0];
    275                              uint8 active_pin_value = load->Hi_Low_Activation_Bitmap & 0x01U;
    276                              active_pin_value ^= 0x01U;
    277                              Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) active_pin_value);
    278                              Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,VIRTUALPIN_TABLE[virtual_pin].pin_config);
    279                              Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Hbl_Status.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    280                              Triac_Switch_Data[load->Pilot_Data_Index].Pilot_Status.Pin_Value = 0U;
    281                              Triac_Switch_Data[load->Pilot_Data_Index].State = TRIACSWITCH_OFF_STATE;
    282                          }
    283                          else
    284                          {
    285                              Triac_Switch_Data[load->Pilot_Data_Index].Timer_Counter--;
    286                          }
    287                          break;
    288                      default:
    289                          // Nothing to do
    290                          break;
    291                  }
    292                  retval = PASS;
    293              }
    294              return(retval);
    295          }
