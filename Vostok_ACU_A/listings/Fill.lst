     87          
     88          //! Displacement value that indicates that the feature is not used.
     89          #define UNUSED_FEATURE 0xFF
     90          
     91          #define FLOW_RATE_SAMPLES_TO_SAVE		12U
     92          
     93          #define FLOW_RATE_SAMPLES_TO_REJECT		2U
     94          
     95          // DishAuxVar_AverageWithRejection(), used in Class A Fill and in Tank fill, support a maximum of AVEARAGE_WITH_REJ_MAX_SUPPORTED_SAMPLES_NUM,
     96          // so the number of samples on which calculate Flow Rate Calibrated has to be less than or equal to that limit.
     97          CT_ASSERT(FLOW_RATE_SAMPLES_TO_SAVE <= AVEARAGE_WITH_REJ_MAX_SUPPORTED_SAMPLES_NUM);
     98          
     99          // Average with rejection can only be calculated if number of samples to reject is less than total number of samples
    100          CT_ASSERT(FLOW_RATE_SAMPLES_TO_REJECT < FLOW_RATE_SAMPLES_TO_SAVE);
