    236          //---------------------------------------------------------------------------------------------------------------------
    237          /**
    238           *  @brief      Executes SRFeedbackLLI 1ms sampling
    239           * @param       input - Hbl LLI Data structure of the instance to process
    240           * @return      FALSE    this process never updates LLI Sequence ID
    241           */
    242          BOOL_TYPE SRFeedbackLLI__OneMsProcess(HBL_LLI_TYPE * input)
    243          {
    244              (void) SRData__CheckByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation);
    245              if (input->Data_Index < SRFeedbackLLI_Allocation)
    246              {
    247                  SRFEEDBACKLLI_DATA_TYPE *data = &SRFeedbackLLI_Data[input->Data_Index];
    248                  SRFEEDBACKLLI_DATA_TYPE *n_data = &N_SRFeedbackLLI_Data[input->Data_Index];
    249                  SRFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *) input->Parameter_Ptr.Data;
    250                  uint8 virtual_pin = input->Pin_Ptr[0];
    251                  GPIO_PIN_MODE_TYPE type = INPUT_FLOAT;
    252          
    253                  // Check if Pull up configuration to match Gpio__CheckConfig
    254                  if((feedback_param != NULL) &&
    255                      ((uint8) feedback_param->Pull_Up != 0U))
    256                  {
    257                      type = INPUT_PULLUP;
    258                  }
    259          
    260                  if(Gpio__CheckConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin, type, FALSE))
    261                  {
    262                      uint8 pin_value = (uint8) Gpio__PinRead(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin);
    263                      uint16 pin_buffer;
    264          
    265                      // Inverted logic flag enabled
    266                      if((feedback_param != NULL) &&
    267                          ((uint8) feedback_param->Inverted != 0U))
    268                      {
    269                          pin_value = (pin_value == 0U) ? 1U : 0U;
    270                      }
    271          
    272                      // Update pin buffer with a new sample
    273                      (void) SRData__CheckShort(&data->Pin_Buffer, &n_data->Pin_Buffer);
    274                      pin_buffer = data->Pin_Buffer;
    275                      pin_buffer  <<= 1U;
    276                      pin_buffer |= (uint16) pin_value & 0x01U;
    277                      SRData__UpdateShort(&data->Pin_Buffer, &n_data->Pin_Buffer, pin_buffer);
    278          
    279                      // Update sampling counter
    280                      (void) SRData__CheckByte(&data->Sampling_Counter, &n_data->Sampling_Counter);
    281                      SRData__UpdateByte(&data->Sampling_Counter, &n_data->Sampling_Counter, data->Sampling_Counter + 1U);
    282                  }
    283              }
    284              return(FALSE);
    285          }
    286          
    287          
    288          //---------------------------------------------------------------------------------------------------------------------
    289          /**
    290           * @brief       Executes SRFeedbackLLI Asynchronous handler to update LLI value depending on 1ms sampling
    291           * @param       input - Hbl LLI Data structure of the instance to process
    292           * @return      TRUE if a new LLI value is available to update sequence ID, FALSE otherwise
    293           */
    294          BOOL_TYPE SRFeedbackLLI__AsynchProcess(HBL_LLI_TYPE * input)
    295          {
    296              BOOL_TYPE retval = FALSE;
    297          
    298              (void)SRData__CheckByte(&SRFeedbackLLI_Allocation, &N_SRFeedbackLLI_Allocation);
    299              if (input->Data_Index < SRFeedbackLLI_Allocation)
    300              {
    301                  SRFEEDBACKLLI_DATA_TYPE *data = &SRFeedbackLLI_Data[input->Data_Index];
    302                  SRFEEDBACKLLI_DATA_TYPE *n_data = &N_SRFeedbackLLI_Data[input->Data_Index];
    303                  SRFEEDBACKLLI_PARAM_TYPE *feedback_param = (void *) input->Parameter_Ptr.Data;
    304                  uint8 n_read = DEFAULT_NUM_SAMPLES;
    305                  // Minimum number of samples to give priority between level (High / Low) or Frequency detection
    306                  uint8 level_freq_threshold = (uint8) (DEFAULT_NUM_SAMPLES / 2);
    307          
    308                  if(feedback_param != NULL)
    309                  {
    310                      uint8 param_read = 1U << ((uint8) feedback_param->N_Read);
    311                      if (param_read <= (uint8) MIN_NUM_SAMPLES)
    312                      {
    313                          param_read = (uint8) MIN_NUM_SAMPLES;
    314                      }
    315                      n_read = param_read;
    316                      level_freq_threshold = param_read / 2U;
    317                  }
    318          
    319                  (void) SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRFeedbackLLI_Data[0]));
    320                  // Update Feedback values if there are new samples coming from  1ms Process
    321                  if(data->Async_Sampling_Reference != data->Sampling_Counter)
    322                  {
    323                      MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    324                      uint16 local_pin_buffer;
    325                      BOOL_TYPE valid_freq_detected = FALSE;
    326                      BOOL_TYPE is_charge_pump = FALSE;
    327                      sint8 pin_value_counter = 0;
    328                      sint8 local_level_counter;
    329                      uint8 local_sampling_counter;
    330                      uint8 local_phase_counter;
    331                      uint8 local_phase_shift;
    332                      uint8 local_freq_counter;
    333                      uint8 num_samples;
    334                      uint8 sample_reference;
    335          
    336                      // Take a snapshot of pin buffer and sample counter to prevent concurrent updates from OneMsProcess function
    337                      MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    338                      local_sampling_counter = data->Sampling_Counter;
    339                      local_pin_buffer = data->Pin_Buffer;
    340                      MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    341          
    342                      // Get number of samples to process with a limit to 10 samples
    343                      // This limit comes from the falling edge transition pattern checks
    344                      num_samples = (uint8) (local_sampling_counter - data->Async_Sampling_Reference);
    345                      if(num_samples > 10U)
    346                      {
    347                          num_samples = 10U;
    348                      }
    349                      sample_reference = data->Async_Sampling_Reference + num_samples;
    350          
    351                      // Collects high, low pin value occurrences and detects a frequency signal through falling edge transitions:
    352                      // - It counts number of High and Low new samples collected
    353                      // - It detects a falling edge transition through a pattern detection:
    354                      //   - last 4 ms for a clean falling edge transition with a 2ms debounce for each edge (2ms ON, 2ms OFF)
    355                      //   - last 6 ms for a clean Charge pump signal (3 times: 1ms ON, 1ms OFF)
    356                      //   - last 6 ms for a noisy falling edge transition with a 2ms debounce for each steady edge (2ms ON, 1ms OFF, 1 ms ON, 2ms OFF)
    357                      //   - last 8 ms for a very noisy falling edge transition with a 2ms debounce for each steady edge (2ms ON, 1ms OFF, 1 ms ON, 1ms OFF, 1 ms ON, 2ms OFF)
    358                      // - When a frequency signal has been detected:
    359                      //   - it saves frequency time reference
    360                      //   - it updates the time between frequency event to estimate the cycle (period) time
    361                      for(uint8 i = 0; i < num_samples; i++)
    362                      {
    363                          uint16 pin_value = (local_pin_buffer & 0x01U);
    364          
    365                          // Update Level counter: increment if High pin value, decrement if Low pin value
    366                          if(pin_value != 0U)
    367                          {
    368                              pin_value_counter++;
    369                          }
    370                          else
    371                          {
    372                              pin_value_counter--;
    373                          }
    374          
    375                          // Find a frequency event based to a falling edge transition patterns, including noisy ones
    376                          if ((local_pin_buffer & 0x0FU) == 0x0CU)          // Check if a falling edge event occur with 2ms debounce (2 ON - 2 OFF)
    377                          {
    378                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 2U);
    379                          }
    380                          else if(((local_pin_buffer & 0x3FU) == 0x2AU) &&    // Check if there is a Charge pump signal and keep the last frequency event
    381                              !is_charge_pump )
    382                          {
    383                              is_charge_pump = TRUE;
    384                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 1U);
    385                          }
    386                          else if  ((local_pin_buffer & 0x3FU) == 0x34U)      // Check if a falling edge event occur with 2ms debounce and 1 ms spikes (2 ON, 1 OFF, 1 ON, 2 OFF)
    387                          {
    388                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 3U);
    389                          }
    390                          else if ((local_pin_buffer & 0xFFU) == 0xD4U)         // Check if a falling edge event occur with 2ms debounce and 1 ms spikes (2 ON, 1 OFF,1 ON, 1 OFF, 1 ON, 2 OFF)
    391                          {
    392                              UpdateLastFrequencyTimingEvents(data, n_data, sample_reference - 4U);
    393                          }
    394          
    395                          sample_reference--;
    396                          local_pin_buffer >>= 1U;
    397                      }
    398                      // Update Async Sampling Reference for the next execution
    399                      SRData__UpdateByte(&data->Async_Sampling_Reference, &n_data->Async_Sampling_Reference, local_sampling_counter);
    400          
    401                      // Check if no frequency signal detected after LAST_FREQUENCY_EVENT_TIMEOUT
    402                      // If no frequency events for more than timeout, switch to level detection
    403                     if((uint8) (local_sampling_counter - data->Last_Frequency_Event_Reference) >= (uint8) LAST_FREQUENCY_EVENT_TIMEOUT)
    404                      {
    405                          SRData__UpdateByte((void *) &data->Is_Detecting_Frequency,(void *)  &n_data->Is_Detecting_Frequency,(uint8) FALSE);
    406                      }
    407          
    408                     // Take a snapshot of Frequency, Phase, Level event counters to
    409                     local_freq_counter = data->Frequency_Counter;
    410                     local_phase_counter = data->Phase_Counter;
    411                     local_level_counter = data->Level_Counter;
    412                     local_phase_shift = data->Phase_Shift;
    413          
    414                      // Frequency detection: it checks if a valid frequency signal has been detected
    415                      // Valid frequency signals are Charge Pump and Mains (AC Signal) like frequency signal
    416                      if(data->Is_Detecting_Frequency)
    417                      {
    418                          BOOL_TYPE is_ac_signal;
    419                          // Valid Charge pump is detected around every Asynchronous iteration (at least 150% of 5ms)
    420                          // Last frequency event is detected starting from the latest sample, so an average of 5ms shift is expected
    421                          is_charge_pump = (BOOL_TYPE) (is_charge_pump && (data->Time_Between_Frequency_Events > 0U));
    422                          is_charge_pump = (BOOL_TYPE) (is_charge_pump && (data->Time_Between_Frequency_Events <= 8U));
    423                          // Valid AC Signal frequency events happen within  45 Hz (22.22ms) - 65 Hz (15.38ms) range
    424                          is_ac_signal = (BOOL_TYPE) (data->Time_Between_Frequency_Events >= 15U);
    425                          is_ac_signal = (BOOL_TYPE) (is_ac_signal && (data->Time_Between_Frequency_Events <= 23U));
    426          
    427                          // Evaluate only if frequency is a Charge pump or is in the AC range
    428                          // Criteria between AC signal and Charge pump are mutually exclusive, they cannot be TRUE at the same time
    429                          if(is_charge_pump || is_ac_signal)
    430                          {
    431                              BOOL_TYPE is_phase_signal = TRUE;
    432          
    433                              valid_freq_detected = TRUE;
    434                              local_freq_counter++;
    435          
    436                              // If SRZeroCross LLI has been registered by this module, an AC detected signal shall be compared to ZeroCross signal
    437                              // to check if they are in phase or not
    438                              // This check is performed only when Frequency detection should be running on both signal:
    439                              // - It evaluates phase shift in milliseconds from ZeroCross through Last Frequency event detected of both signals
    440                              // - If phase shift is more than half of ZeroCross cycle, phase shift is decremented by one cycle
    441                              //   - This discrepancy is due to also take care a different duty cycle on Frequency signals
    442                              // - Phase shift evaluation is done on absolute value
    443                              // - If phase shift is more than 90 degrees equivalent time, signal will be considered opposite / out of phase
    444                              (void) SRData__CheckByte(&SRZeroCross_Index, &N_SRZeroCross_Index);
    445                              if(is_ac_signal &&
    446                                  (SRZeroCross_Index < SRFeedbackLLI_Allocation) &&
    447                                  (SRZeroCross_Index != input->Data_Index))
    448                              {
    449                                  (void) SRData__CheckByte((void *) &SRFeedbackLLI_Data[SRZeroCross_Index].Is_Detecting_Frequency,
    450                                      (void *) &N_SRFeedbackLLI_Data[SRZeroCross_Index].Is_Detecting_Frequency);
    451                                  if(SRFeedbackLLI_Data[SRZeroCross_Index].Is_Detecting_Frequency &&
    452                                      (SRFeedbackLLI_Data[SRZeroCross_Index].Time_Between_Frequency_Events > 0U))
    453                                  {
    454                                      // Maximum phase shift accepted is 90 degrees equivalent
    455                                      sint16 quarter_cycle = (sint16) data->Time_Between_Frequency_Events / 4;
    456                                      sint16 phase_shift;
    457                                      uint8 zc_timeout;
    458          
    459                                      (void) SRData__CheckByte(&SRFeedbackLLI_Data[SRZeroCross_Index].Last_Frequency_Event_Reference,
    460                                          &N_SRFeedbackLLI_Data[SRZeroCross_Index].Last_Frequency_Event_Reference);
    461                                      phase_shift = data->Last_Frequency_Event_Reference;
    462                                      phase_shift -= (sint16) SRFeedbackLLI_Data[SRZeroCross_Index].Last_Frequency_Event_Reference;
    463                                      // Consider ZeroCross half cycle margin between frequency signal timeouts
    464                                      // if that distance is higher than half cycle, phase shift should be decremented by one cycle
    465                                      zc_timeout = SRFeedbackLLI_Data[SRZeroCross_Index].Last_Frequency_Event_Reference;
    466                                      zc_timeout += (SRFeedbackLLI_Data[SRZeroCross_Index].Time_Between_Frequency_Events / 2U);
    467                                      if(zc_timeout < data->Last_Frequency_Event_Reference)
    468                                      {
    469                                          phase_shift -= (sint16) SRFeedbackLLI_Data[SRZeroCross_Index].Time_Between_Frequency_Events;
    470                                      }
    471                                      if(phase_shift < 0)
    472                                      {
    473                                          phase_shift = -phase_shift;
    474                                      }
    475          
    476                                      // Signal out of phase if phase shift is more than 90 degrees
    477                                      // this limit takes care of a possible different duty cycle between Feedback signals
    478                                      if(phase_shift > quarter_cycle)
    479                                      {
    480                                          is_phase_signal = FALSE;
    481                                      }
    482                                      local_phase_shift = (uint8) phase_shift;
    483                                  }
    484                              }
    485                              else
    486                              {
    487                                  local_phase_shift = 0;
    488                              }
    489          
    490                              // Increment the Phase counter if no out of phase condition has been detected on that signal
    491                              if(is_charge_pump || is_phase_signal)
    492                              {
    493                                  local_phase_counter++;
    494                              }
    495          
    496                              // If the number of Frequency event occurrences becomes higher than the half of valid samples to collect
    497                              // Frequency detection takes precedence over Level detection
    498                              if(local_freq_counter >= level_freq_threshold)
    499                              {
    500                                  local_level_counter = 0;
    501                              }
    502                              
    503                              // Update LLI value to Frequency (Phase / Opp.Phase) if number of valid samples have been collected
    504                              if(local_freq_counter >= n_read)
    505                              {
    506                                  SRFEEDBACKLLI_VALUE_ENUM_TYPE new_value = (local_phase_counter >= (n_read / 2U)) ? SRFEEDBACKLLI_PHASE : SRFEEDBACKLLI_OPP_PHASE;
    507                                  SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) new_value);
    508                                  SRData__UpdateByte(&data->Ac_Is_Present, &n_data->Ac_Is_Present, 1);
    509                                  local_freq_counter = 0;
    510                                  local_phase_counter = 0;
    511                                  retval = TRUE;
    512                              }
    513                          }
    514                      }
    515          
    516                      // If not valid Frequency signal has been detected, High / Low detection algorithm is performed
    517                      if(!valid_freq_detected)
    518                      {
    519                          // High value level event: Level counter is a positive number, higher than pin noise threshold
    520                          if(pin_value_counter >= SAMPLES_NOISE_THRESHOLD)
    521                          {
    522                              local_level_counter++;
    523                          }
    524                          // Low value level event: Level counter is a negative number, lower than pin noise threshold
    525                          else if(pin_value_counter <= -SAMPLES_NOISE_THRESHOLD)
    526                          {
    527                              local_level_counter--;
    528                          }
    529          
    530                          // If the number of High/Low value Level event occurrences becomes higher than the half of valid samples to collect
    531                          // Level detection takes precedence over Frequency detection
    532                          if((local_level_counter >= (sint8) level_freq_threshold) ||
    533                              (local_level_counter <= -((sint8) level_freq_threshold)))
    534                          {
    535                              local_freq_counter = 0;
    536                              local_phase_counter = 0;
    537                          }
    538          
    539                          // Update LLI value to High if number of valid samples have been collected
    540                          if(local_level_counter >= (sint8) n_read)
    541                          {
    542                              SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) SRFEEDBACKLLI_HIGH);
    543                              SRData__UpdateByte(&data->Ac_Is_Present, &n_data->Ac_Is_Present, 0);
    544                              local_level_counter = 0;
    545                              local_phase_shift = 0;
    546                              retval = TRUE;
    547                          }
    548                          
    549                          // Update LLI value to Low if number of valid samples have been collected
    550                          if(local_level_counter <= -((sint8) n_read))
    551                          {
    552                              SRData__UpdateByte((void *) &data->Value, (void *) &n_data->Value, (uint8) SRFEEDBACKLLI_LOW);
    553                              SRData__UpdateByte(&data->Ac_Is_Present, &n_data->Ac_Is_Present, 0);
    554                              local_level_counter = 0;
    555                              local_phase_shift = 0;
    556                              retval = TRUE;
    557                          }
    558                      }
    559          
    560                      SRData__UpdateByte(&data->Frequency_Counter, &n_data->Frequency_Counter, local_freq_counter);
    561                      SRData__UpdateByte((void *) &data->Level_Counter, (void *) &n_data->Level_Counter, (uint8) local_level_counter);
    562                      SRData__UpdateByte(&data->Phase_Counter, &n_data->Phase_Counter, local_phase_counter);
    563                      SRData__UpdateByte(&data->Phase_Shift, &n_data->Phase_Shift, local_phase_shift);
    564                  }
    565          
    566              }
    567          
    568              return (retval);
    569          }
    570          
    571          //=====================================================================================================================
    572          //-------------------------------------- Private Functions ------------------------------------------------------------
    573          //=====================================================================================================================
    574          
    575          /*
    576           *
    577           */
    578          static void UpdateLastFrequencyTimingEvents(SRFEEDBACKLLI_DATA_TYPE *data_ptr, SRFEEDBACKLLI_DATA_TYPE *n_data_ptr, uint8 new_frequency_reference)
    579          {
    580              if(data_ptr->Is_Detecting_Frequency)
    581              {
    582                  SRData__UpdateByte(&data_ptr->Time_Between_Frequency_Events, &n_data_ptr->Time_Between_Frequency_Events, new_frequency_reference - data_ptr->Last_Frequency_Event_Reference);
    583              }
    584              SRData__UpdateByte(&data_ptr->Last_Frequency_Event_Reference, &n_data_ptr->Last_Frequency_Event_Reference, new_frequency_reference);
    585              SRData__UpdateByte((void *) &data_ptr->Is_Detecting_Frequency,(void *)  &n_data_ptr->Is_Detecting_Frequency,(uint8) TRUE);
    586          }
    587          
    588          
    589          #endif


 

 


