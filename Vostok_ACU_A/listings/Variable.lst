     60          	/**
     61          	 * Defines how many different variables this module will manage.
     62          	 */
     63          	#define VARIABLE_MAX_NUMBER_OF_ACU_VARIABLES   ELEMENTS_IN_ARRAY(ACU_DATA_HOLDER)
