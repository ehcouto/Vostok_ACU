    241              }
    242          
    243              return(ret_val);
    244          }
    245          
    246          //---------------------------------------------------------------------------------------------------------------------
    247          /**
    248           *
    249           * @param input
    250           * @param status
    251           * @return
    252           */
    253          BOOL_TYPE SRInputCaptureLLI__AsynchProcess(HBL_LLI_TYPE * input)
    254          {
    255              if ((SRData__CheckByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation) == SRDATA_OK)
    256                  && (input->Data_Index < SRInputCaptureLLI_Allocation))
    257              {
    258                  uint32 current_time = SRTimerReference__GetTimer();
    259          
    260                  SRINPUTCAPTURE_DATA_TYPE *data = (void *)&SRInputCaptureLLI_Data[input->Data_Index];
    261                  SRINPUTCAPTURE_DATA_TYPE *n_data = (void *)&N_SRInputCaptureLLI_Data[input->Data_Index];
    262                  BOOL_TYPE crc_check = (BOOL_TYPE) (SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRInputCaptureLLI_Data[0])) == SRDATA_OK);
    263          
    264                  if (crc_check)
    265                  {
    266                      SRINPUTCAPTURELLI_PARAMETERS_TYPE *parameters = (SRINPUTCAPTURELLI_PARAMETERS_TYPE *)(input->Parameter_Ptr.Data);        //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    267                      MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    268          
    269                      //Enable Sampling only if Auto or Continuous reading is set
    270                      if ((data->Continue_mode == FALSE) &&
    271                          (data->Timer_Parameter.Mode == TIMER_MODE_DISABLE))
    272                      {
    273                          if (((sint32) (current_time - data->Sampling_Timeout)) > 0)
    274                          {
    275                              // Refresh sampling time
    276                              SRData__UpdateLong(&data->Sampling_Timeout, &n_data->Sampling_Timeout, current_time + (parameters->Sampling_Time * 5));
    277          
    278                              // Restart Timer in Input Capture mode
    279                              MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    280                              SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_INPUT_CAPTURE);
    281                              Timer__Config(&data->Timer_Parameter);
    282                              Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    283                              MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    284                          }
    285                      }
    286          
    287                      if (((sint32) (current_time - data->Timeout)) > 0)
    288                      {
    289                          // Stop Input Capture mode
    290                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    291                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_DISABLE);
    292                          Timer__Config(&data->Timer_Parameter);
    293                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    294                          // Reset filter
    295                          SRData__UpdateByte((void *) &data->Filter_Initialized, (void *) &n_data->Filter_Initialized, FALSE);
    296                          //Restart reading of samples
    297                          SRData__UpdateByte(&data->Private_Valid_Sample_Count, &n_data->Private_Valid_Sample_Count, 0);
    298                          SRData__UpdateByte(&data->Private_Invalid_Sample_Count, &n_data->Private_Invalid_Sample_Count, 0);
    299                          SRData__UpdateByte(&data->Private_Current_Count, &n_data->Private_Current_Count, 0);
    300                          //Refresh the Timeout
    301                          SRData__UpdateLong(&data->Timeout, &n_data->Timeout, current_time + (parameters->Time_Out * 5));
    302                          //Refresh sampling time
    303                          SRData__UpdateLong(&data->Sampling_Timeout, &n_data->Sampling_Timeout, current_time + (parameters->Sampling_Time * 5));
    304                          // Restart Timer in Input Capture mode
    305                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    306                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_INPUT_CAPTURE);
    307                          Timer__Config(&data->Timer_Parameter);
    308                          Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    309                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    310                      }
    311                  }
    312              }
    313          
    314              return(FALSE);
    315          }
    316          
    317          //---------------------------------------------------------------------------------------------------------------------
    318          /**
    319           *
    320           * @param input
    321           * @return
    322           */
    323          BOOL_TYPE SRInputCaptureLLI__ICProcess(HBL_LLI_TYPE * input)
    324          {
    325              BOOL_TYPE retval = FALSE;
    326          
    327              if ((SRData__CheckByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation) == SRDATA_OK)
    328                  && (input->Data_Index < SRInputCaptureLLI_Allocation))
    329              {
    330                  SRINPUTCAPTURE_DATA_TYPE *data = (void *)&SRInputCaptureLLI_Data[input->Data_Index];
    331                  SRINPUTCAPTURE_DATA_TYPE *n_data = (void *)&N_SRInputCaptureLLI_Data[input->Data_Index];
    332                  BOOL_TYPE crc_check = (BOOL_TYPE) (SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRInputCaptureLLI_Data[0])) == SRDATA_OK);
    333          
    334                  if (crc_check)
    335                  {
    336                      uint32 current_time = SRTimerReference__GetTimer();
    337                      SRINPUTCAPTURELLI_PARAMETERS_TYPE *parameters = (SRINPUTCAPTURELLI_PARAMETERS_TYPE *)input->Parameter_Ptr.Data; //lint !e927 cast from pointer to pointer [MISRA 2004 Rule 11.4]
    338                      uint32 captured_duration = 0;
    339                      uint16 captured_duty = 0;
    340                      MICRO_DECLARE_INTERRUPT_CONTEXT_LOCAL();
    341          
    342                      // Check the current Timer configuration of the Timer Channel (Gpio pin).
    343                      if ((Timer__ConfigCheck(&data->Timer_Parameter)) == PASS)
    344                      {
    345                          //Read the current captured duration and duty
    346                          captured_duration = Timer__GetCaptureDuration(&data->Timer_Parameter);
    347                          captured_duty = Timer__GetCaptureDuty(&data->Timer_Parameter);
    348                      }
    349                      else
    350                      {
    351                      	SRException__Queue(SREXCEPTION_TIMER_DATA_CORRUPTION, 0, 0xFF);
    352                      }
    353          
    354                      //Disable the Timer Input Capture if the Sampling Read is set
    355                      if (data->Continue_mode == FALSE)
    356                      {
    357                          //Discrete Sampling Mode
    358                          //Switch to Discrete sampling as Current captured duration is too small to do in continuous sampling
    359                          //Disable the Timer and let control the sampling from the InputCaptureLLI__AsynchProcess()
    360                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    361                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_DISABLE);
    362                          Timer__Config(&data->Timer_Parameter);
    363                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    364                      }
    365          
    366          
    367                      /*Latch_check to changing mode*/
    368                      if (((captured_duration) < (SRINPUTCAPTURELLI_AUTO_FEATURE_DOWN_PERIOD_HYS)) &&
    369                          (data->Continue_mode)) /*(f > MAX_FREQUENCY*)*/
    370                      {
    371                          //Change the mode and stop InputCapture
    372                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    373                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_DISABLE);
    374                          Timer__Config(&data->Timer_Parameter);
    375                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    376                          SRData__UpdateLong(&data->Sampling_Timeout, &n_data->Sampling_Timeout, current_time + (parameters->Sampling_Time * 5));
    377                          SRData__UpdateByte((void *) &data->Continue_mode, (void *) &n_data->Continue_mode, FALSE);
    378                      }
    379                      else if(((captured_duration) > (SRINPUTCAPTURELLI_AUTO_FEATURE_UP_PERIOD_HYS))&&
    380                          !(data->Continue_mode))/*((f > MAX_FREQUENCY-HYSTERESIS*))*/
    381                      {
    382                          //Change the mode and restart InputCapture
    383                          SRData__UpdateByte((void *) &data->Continue_mode, (void *) &n_data->Continue_mode, TRUE);
    384                          MICRO_SAVE_INTERRUPT_CONTEXT_LOCAL();
    385                          SRData__UpdateByte((void *) &data->Timer_Parameter.Mode, (void *) &n_data->Timer_Parameter.Mode, TIMER_MODE_INPUT_CAPTURE);
    386                          Timer__Config(&data->Timer_Parameter);
    387                          Timer__CaptureStart(&data->Timer_Parameter, TIMER_CAPTURE_CYCLE, TIMER_CAPTUREON_RISING_EDGE);
    388                          MICRO_RESTORE_INTERRUPT_CONTEXT_LOCAL();
    389                      }
    390          
    391                      SRData__UpdateByte(&data->Private_Current_Count, &n_data->Private_Current_Count, data->Private_Current_Count+1);
    392          
    393                      //validate the Cycle Period
    394                      if ((captured_duration >= (ENDIANU16_STON(parameters->Minimum_Period) << 3)) &&
    395                          (captured_duration <= (ENDIANU16_STON(parameters->Maximum_Period) << 3)) &&
    396                          //validate the captured_duty
    397                          (captured_duty >= ENDIANU16_STON(parameters->Minimum_Duty)) &&
    398                          (captured_duty <= ENDIANU16_STON(parameters->Maximum_Duty)))
    399                      {
    400                          uint8 delta = parameters->Delta;
    401                          // Use N_Read as delta if 1 for backward compatibility
    402                          if(delta == 1)
    403                          {
    404                              delta = parameters->N_Read;
    405                          }
    406          
    407                          SRData__UpdateByte(&data->Private_Valid_Sample_Count, &n_data->Private_Valid_Sample_Count, data->Private_Valid_Sample_Count+1);
    408          
    409                          //scale the period based on the base
    410                          captured_duration = captured_duration / parameters->Base_Period;
    411          
    412                          if (data->Filter_Initialized == TRUE)
    413                          {
    414                              uint32 temp_value;
    415          
    416                              // Update filtered value for Period
    417                              temp_value = data->Accumulator_Period;
    418                              temp_value += captured_duration;
    419                              temp_value -= data->Filtered_Period;
    420                              SRData__UpdateLong(&data->Accumulator_Period, &n_data->Accumulator_Period, temp_value);
    421                              if(delta > 1)
    422                              {
    423                                  temp_value >>= (delta - 1);
    424                              }
    425                              if (delta > 0)
    426                              {
    427                                  temp_value += 1;
    428                                  temp_value >>= 1;
    429                              }
    430                              SRData__UpdateShort(&data->Filtered_Period, &n_data->Filtered_Period, (uint16) temp_value);
    431          
    432                              // Update filtered value for Period
    433                              temp_value = data->Accumulator_Duty;
    434                              temp_value += captured_duty;
    435                              temp_value -= data->Filtered_Duty;
    436                              SRData__UpdateLong(&data->Accumulator_Duty, &n_data->Accumulator_Duty, temp_value);
    437                              if(delta > 1)
    438                              {
    439                                  temp_value >>= (delta - 1);
    440                              }
    441                              if (delta > 0)
    442                              {
    443                                  temp_value += 1;
    444                                  temp_value >>= 1;
    445                              }
    446                              SRData__UpdateShort(&data->Filtered_Duty, &n_data->Filtered_Duty, (uint16) temp_value);
    447                          }
    448                          else
    449                          {
    450                              SRData__UpdateLong(&data->Accumulator_Period, &n_data->Accumulator_Period, captured_duration << delta);
    451                              SRData__UpdateShort(&data->Filtered_Period, &n_data->Filtered_Period, captured_duration);
    452                              SRData__UpdateLong(&data->Accumulator_Duty, &n_data->Accumulator_Duty, captured_duty << delta);
    453                              SRData__UpdateShort(&data->Filtered_Duty, &n_data->Filtered_Duty, captured_duty);
    454                              SRData__UpdateByte((void *) &data->Filter_Initialized, (void *) &n_data->Filter_Initialized, TRUE);
    455                          }
    456          
    457                          //Refresh the Timeout timer
    458                          SRData__UpdateLong(&data->Timeout, &n_data->Timeout, current_time + (parameters->Time_Out * 5));
    459                      }
    460                      else
    461                      {
    462                          SRData__UpdateByte(&data->Private_Invalid_Sample_Count, &n_data->Private_Invalid_Sample_Count, data->Private_Invalid_Sample_Count+1);
    463                      }
    464          
    465                      //Check if there are too many invalid samples
    466                      if(data->Private_Invalid_Sample_Count == MAX_INVALID_SAMPLE_COUNT)
    467                      {
    468                          //Force Timer_Timeout to DONE state
    469                          SRData__UpdateLong(&data->Timeout, &n_data->Timeout, current_time);
    470                      }
    471          
    472                      //if its the new sampling
    473                      if(data->Private_Valid_Sample_Count >= (1 << parameters->N_Read))
    474                      {
    475                          uint8 new_seq_count;
    476                          //Copy previous sampling data
    477                          SRData__UpdateShort(&data->Public_Data.Period, &n_data->Public_Data.Period, data->Filtered_Period);
    478                          SRData__UpdateShort(&data->Public_Data.Duty, &n_data->Public_Data.Duty, data->Filtered_Duty);
    479                          SRData__UpdateByte(&data->Private_Valid_Sample_Count, &n_data->Private_Valid_Sample_Count, data->Private_Valid_Sample_Count);
    480                          SRData__UpdateByte(&data->Private_Invalid_Sample_Count, &n_data->Private_Invalid_Sample_Count, data->Private_Invalid_Sample_Count);
    481          
    482                      //new readings available
    483                          new_seq_count = data->Public_Data.Sequence_Count+1;
    484                          if (new_seq_count == 0)
    485                          {
    486                              new_seq_count++;
    487                          }
    488                          SRData__UpdateByte(&data->Public_Data.Sequence_Count, &n_data->Public_Data.Sequence_Count, new_seq_count);
    489          
    490                          //Prepare for reading new sampling
    491                          SRData__UpdateByte(&data->Private_Valid_Sample_Count, &n_data->Private_Valid_Sample_Count, 0);
    492                          SRData__UpdateByte(&data->Private_Invalid_Sample_Count, &n_data->Private_Invalid_Sample_Count, 0);
    493                          SRData__UpdateByte(&data->Private_Current_Count, &n_data->Private_Current_Count, 0);
    494          
    495                          //Data ready after the filter
    496                          retval = TRUE;
    497                      }
    498                  }
    499              }
    500          
    501              return (retval);
    502          }
    503          
    504          //=====================================================================================================================
    505          //-------------------------------------- Private Functions ------------------------------------------------------------
    506          //=====================================================================================================================
    507          
    508          #endif


 

 


