C:\Data\Nucleus_Dev\Vostok_ACU_A\source\XCategory\Common\all\Common\Callback\Callback.c
      1          /**
      2           *  @brief      Module to provide a standardized method of implementing callbacks.
      3           *
      4           *  @details    A callback is a function that is passed as an argument to another software module,
      5           *              which is expected to execute (call back) the argument at some convenient time.
      6           *
      7           *              This module implements synchronous callbacks. This means that when the event occurs,
      8           *              the callbacks are executed immediately. Because of the immediate nature,
      9           *              the designer should carefully consider what actions are taken at the time that the
     10           *              callback is executed. The user should avoid calling these functions from an interrupt service routine.
     11           *
     12           *              Register, Unregister and Notify functions call ChecksumOK to test the control registry
     13           *              before attempting any operations using the control. If ChecksumOK detects a corrupted
     14           *              registry it will re-intialize the registry and throw a CALLBACK_REGISTRY_CORRUPTED exception.
     15           *
     16           *
     17                          @startuml{Callback Sequence.jpg}
     18                              title Methodology For Using The Callback Module
     19          
     20                              hide footbox
     21                              autonumber
     22          
     23                              participant "Application Module" as Application
     24                              participant "Module With Callbacks" as mwc
     25                              participant Callback
     26          
     27                              ==Add Callback functionality to a module==
     28                              mwc -> mwc : typedef enum{MODULE_EVENT_ONE} MODULE_EVENT_TYPE
     29                              note left
     30                                  Define the callback events
     31                                  Range: 1 to 255
     32                              end note
     33          
     34                              mwc -> mwc : typedef void (*MODULE_EVENT_HANDLER_TYPE)(MODULE_EVENT_TYPE)
     35                              note left
     36                                  Define the event handler function prototype
     37                              end note
     38          
     39                              mwc -> mwc : void Module__RegisterForEvents(MODULE_EVENT_HANDLER_TYPE)
     40                              note left
     41                                  Define a public function prototype for registering event handler functions
     42                              end note
     43          
     44                              mwc -> mwc : void Module__UnregisterForEvents(MODULE_EVENT_HANDLER_TYPE)
     45                              note left
     46                                  Optional - define a public function prototype for unregistering event handler functions
     47                              end note
     48          
     49                              mwc -> Callback : DEFINE_CALLBACK_CONTROL_STRUCTURE(Callback_Registry, 2)
     50                              note left
     51                                  Declare dynamic RAM for storing event handler functions
     52                              end note
     53          
     54                              mwc -> Callback : Callback__Initialize(&Callback_Registry)
     55                              note left
     56                                  Initialize the dynamic RAM
     57                              end note
     58          
     59                              ==Adding capability to the Application to receive and process callback events==
     60                              Application -> Application : void ApplicationEventHandlerFunction(MODULE_EVENT_TYPE)
     61                              note left
     62                                  Define function for processing callback events
     63                              end note
     64          
     65                              Application -> mwc : Module__RegisterForEvents(&ApplicationEventHandlerFunction)
     66                              note left
     67                                  Register the event handler function
     68                              end note
     69                              activate mwc
     70                                  mwc -> Callback : Callback__Register(&Callback_Registry, (CALLBACK_HANDLER_TYPE)(void*)event_handler)
     71                              deactivate mwc
     72          
     73                              ==Post a Callback event==
     74                              loop
     75                                  mwc -> Callback : Callback__Notify(&Callback_Registry, (CALLBACK_EVENT_TYPE)MODULE_EVENT_ONE)
     76                                  activate Callback
     77                                      Application <- Callback : ApplicationEventHandlerFunction(MODULE_EVENT_ONE)
     78                                  deactivate Callback
     79          
     80                              ==Optional - unregister the event handler function==
     81                              Application -> mwc : Module__UnregisterForEvents(&ApplicationEventHandlerFunction)
     82                              activate mwc
     83                                  mwc -> Callback : Callback__Unregister(&Callback_Registry, (CALLBACK_HANDLER_TYPE)(void*)event_handler)
     84                              deactivate mwc
     85          
     86                        @enduml
