     60          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     61          
     62          
     63          //! Data for each SRDigital LLI
     64          static SRDIGITALLLI_DATA_TYPE SRDigitalLLI_Data[HBL_LLI_NUM_SRDIGITAL];
     65          //! Inverted memory for the Class B variable
     66          static SRDIGITALLLI_DATA_TYPE N_SRDigitalLLI_Data[HBL_LLI_NUM_SRDIGITAL];
     67          
     68          //! Keeps track of how many SRDigital LLIs have been allocated by the application
     69          static uint8 SRDigitalLLI_Allocation;
     70          //! Inverted memory for the Class B variable
     71          static uint8 N_SRDigitalLLI_Allocation;
     72          
     73          #define SRDIGITALLOWINPUT_CFG0_NREAD_MASK      0x07     //!< Mask to read the setting file configuration for the number of readings
     74          
     75          #define SRDIGITALLOWINPUT_CFG1_INVERT          0x80     //!< Mask to read the setting file configuration for the "Invert" flag, which inverts the value read from the input
     76          #define SRDIGITALLOWINPUT_CFG1_PULLUP          0x20     //!< Mask to read the setting file configuration for the "Pullup" flag; 1 = internal pullup resistor enabled, else no internal pullup resistor used
     77          
