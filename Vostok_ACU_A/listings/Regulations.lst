     48          //-------------------------------------- IDs FOR LOG messages----------------------------------------------------------
     49          //! IDs for Log messages
     50          typedef enum
     51          {
     52              GI_POSITION_AND_TYPE_DOES_NOT_EXIST = 0,    //data: Upper Byte: GI position, Lower Byte: GI Read Type
     53              POSITION_OUT_OF_RANGE,                      //data: Upper Byte: Source of message, Lower Byte: Regulation position that is out of range
     54              TOO_MANY_REGULATIONS_DEFINED,               //data: Upper Byte: Number of regulations handled by this module(REGULATION_MAX_NUM); Lower byte: Number of regulations defined in the setting file
     55              INDEX_OUT_OF_RANGE,                         //data: Upper Byte: out of boundary index, Lower Byte: Regulation position that is out of range
     56              CONFIG_NOT_FOUND                            //data: Regulation position that is out of range
     57          } MODULE_REGULATIONS_LOG_MESSAGE_ID_TYPE;
     58          //! ID for this module on the Log module.
     59          #define MODULE_NAME     MODULE_REGULATIONS
     60          
     61          
