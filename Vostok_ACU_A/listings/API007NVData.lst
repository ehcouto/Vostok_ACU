    784          //----------------------------------------------------------------------------------------------------------
    785          /**
    786           * @brief   This API is been called from the API007Data__CommandParser()
    787           *          Process the request for Read operation by the client
    788           *
    789           * @details Enabled only for Server side
    790           *          Sends the feedback message depending on weather the read operation is accepted or rejected
    791           *
    792           * @param client_node_id - Client Node ID
    793           * @param index - Data index
    794           * @param size  - Claim Size
    795           */
    796          void API007NVData__ProcessReadCmd(uint8 client_node_id, uint16 index, uint16 size)
    797          {
    798          	#if(API007NVDATA_SERVER_FEATURE == ENABLED)
    799          
    800          		CLIENT_DESCRIPT_TYPE *cdt_client = NVDataGetCDTByClientID(client_node_id);
    801          
    802          		if (cdt_client != NULL)
    803          		{
    804                      //make sure we are reading within the client memory area
    805          			if (((cdt_client->End_Index + 1) - cdt_client->Start_Index) >= (index+size))
    806          			{
    807          				API007Data__NVDataFbkReadData(client_node_id, index, size, &API007NVData_ServerData[cdt_client->Start_Index+index]);
    808          
    809          			}
    810          			else
    811          			{
    812          			    API007Data__NVDataFbkReadData(client_node_id, index, 0, NULL);    //Reading failed
    813          			}
    814          		}
    815          		else
    816          		{
    817          		    API007Data__NVDataFbkReadData(client_node_id, index, 0, NULL);    //Reading failed
    818          		}
    819          	#endif
    820          }
    821          
    822          
    823          //----------------------------------------------------------------------------------------------------------
    824          /**
    825           * @brief   This API is been called from the API007Data__CommandParser()
    826           *          Process the request for Write operation by the client
    827           *
    828           * @details Enabled only for Server side
    829           *          Sends the feedback message depending on weather the write operation is accepted or rejected
    830           *
    831           * @param client_node_id - Client Node ID
    832           * @param index - Data index
    833           * @param size  - Claim Size
    834           * @param *data - Address of data from which to be written
    835           */
    836          void API007NVData__ProcessWriteCmd(uint8 client_node_id, uint16 index ,uint16 size, uint8 * data_ptr)
    837          {
    838          	#if(API007NVDATA_SERVER_FEATURE == ENABLED)
    839              	CLIENT_DESCRIPT_TYPE *cdt_client = NULL;
    840          
    841          		cdt_client  = NVDataGetCDTByClientID(client_node_id);
    842          
    843          		if (cdt_client != NULL)
    844          		{
    845          		    //make sure we are writing within the client memory area
    846          			if (((cdt_client->End_Index + 1) - cdt_client->Start_Index) >= (index + size))
    847          			{
    848          				memcpy((void *)(&API007NVData_ServerData[cdt_client->Start_Index + index]), data_ptr, size);
    849          
    850          				API007Data__NVDataFbkWriteData(client_node_id , (index + size));	//send index which is currently pointing after the write cmd
    851          			}
    852          			else
    853          			{
    854          			    API007Data__NVDataFbkWriteData(client_node_id , index);    //writing failed
    855          			}
    856          		}
    857          		else
    858          		{
    859          		    API007Data__NVDataFbkWriteData(client_node_id , index);    //Client not found in CDT table
    860          		}
    861          	#endif
    862          }
