    866          /**
    867           * @brief   This API is been called from the API007Data__FeedbackParser() in response of API007_OP_REQ_CLAIM_NVDATA command from server
    868           *
    869           * @details Enabled only for client side
    870           *
    871           * @param size  - Claim Size
    872           */
    873          void API007NVData__ReceivedClaimSize(uint16 size)
    874          {
    875              #if(API007NVDATA_CLIENT_FEATURE == ENABLED)
    876                  if(size == API007NVDATA_DATA_SECTION_SIZE)
