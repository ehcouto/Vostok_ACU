     99          //---------------------------------------------------------------------------------------------------------------------
    100          /**
    101           *  @brief      Allocate pilot instance for DoorlockEMPilot.
    102           *
    103           *  @return     uint8 result - Allocation result.
    104           *  @retval     0-254 - Pilot allocation instance.
    105           *  @retval     0xFF - Allocation failed.
    106           */
    107          uint8 DoorLockEMPilot__Allocate(void )
    108          {
    109              uint8 retval = 0xFF;
    110          
    111              if (DoorLockEMPilot_Allocation < HBL_PILOT_NUM_DOORLOCKEM)
    112              {
    113                  retval = DoorLockEMPilot_Allocation;
    114                  DoorLockEMPilot_Allocation++;
    115              }
    116              return (retval);
    117          }
    118          
    119          //---------------------------------------------------------------------------------------------------------------------
    120          /**
    121           *  @brief      Initialize DoorLockEMPilot instance.
    122           *
    123           *  @param      HBL_LOAD_TYPE *load - Pointer to associated digital output load instance.
    124           *
    125           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot instance initialization.
    126           *  @retval     PASS - Instance initialization succeeded.
    127           *  @retval     FAIL - Instance initialization failed.
    128           */
    129          PASS_FAIL_TYPE DoorLockEMPilot__InitializeInstance(HBL_LOAD_TYPE * load )
    130          {
    131              PASS_FAIL_TYPE retval = FAIL;
    132              uint8 index = load->Pilot_Data_Index;
    133              DOORLOCKEMPILOT_PARAM_TYPE *param_ptr = (DOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    134              DOORLOCKEMPILOT_DATA_TYPE *ptr;
    135              uint8 *ptr_pin_table;
    136              uint8 fbk_index;
    137              uint8 virtual_pin;
    138          
    139              if ((index < DoorLockEMPilot_Allocation) && (param_ptr != NULL ))
    140              {
    141                  ptr = &DoorLockEMPilot_Data[index];
    142          
    143                  ptr->Status = DOORLOCKEM_STATUS_INIT;
    144                  ptr->Period = DOORLOCKEM_INITIAL_PERIOD;
    145                  ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_INITIALIZE;
    146                  ptr->PilotStatus.Load.Cur_Reg = 0;
    147                  ptr->Retries_Counter = 0;
    148          
    149                  // Check if a Feedback/SRFeedback LLI is configured for pin synchronization
    150                  fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_FEEDBACK);
    151                  if (fbk_index >= Hbl__GetNumLLI())
    152                  {
    153                      fbk_index = Hbl__GetLLIIndexByOwnLoadConsistencyType(load, HBL_LLI_SRFEEDBACK);
    154                  }
    155          
    156                  ptr_pin_table = Hbl__GetLLIPinTabPtr(fbk_index);
    157          
    158                  if (ptr_pin_table == NULL)
    159                  {
    160                      virtual_pin = VirtualPin__GetNumOf();
    161                  }
    162                  else
    163                  {
    164                      virtual_pin = ptr_pin_table[0];
    165                  }
    166                  ptr->Fbk_Pin = virtual_pin;
    167          
    168                  virtual_pin = load->Pin_Ptr[0];
    169                  if ((virtual_pin < VirtualPin__GetNumOf()) && (VIRTUALPIN_TABLE[virtual_pin].port != 0xFF))
    170                  {
    171                      uint8 pin_val = ~load->Hi_Low_Activation_Bitmap;
    172                      pin_val &= 0x01;
    173                      Gpio__PinWrite(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin, (BOOL_TYPE) pin_val);
    174                      Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port, VIRTUALPIN_TABLE[virtual_pin].pin,
    175                      VIRTUALPIN_TABLE[virtual_pin].pin_config);
    176                      retval = PASS;
    177                  }
    178          
    179              }
    180          
    181              return (retval);
    182          }
    183          
    184          //---------------------------------------------------------------------------------------------------------------------
    185          /**
    186           *  @brief      Set DoorLockEMPilot instance request.
    187           *
    188           *  @param      HBL_LOAD_TYPE *load - Pointer to associated DoorLockEMPilot instance.
    189           *
    190           *  @param      void *data - Pointer to request data. Pass argument as uint8 *.
    191           *
    192           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot request.
    193           *  @retval     PASS - Instance request succeeded.
    194           *  @retval     FAIL - Instance request failed.
    195           */
    196          PASS_FAIL_TYPE DoorLockEMPilot__Request(HBL_LOAD_TYPE * load ,void * data )
    197          {
    198              PASS_FAIL_TYPE retval = FAIL;
    199              uint8 index = load->Pilot_Data_Index;
    200          
    201              if (index < DoorLockEMPilot_Allocation)
    202              {
    203                  uint8 new_target = (*(uint8 *)data);
    204                  uint8 new_triac_on = (new_target & DOORLOCKEM_PROCESSED_KEEP_PIN_MASK) ? TRUE : FALSE;
    205                  new_target &= ~DOORLOCKEM_PROCESSED_KEEP_PIN_MASK;
    206          
    207                  DoorLockEMPilot_Data[index].Requested = new_target;
    208                  DoorLockEMPilot_Data[index].Request_Triac_On = new_triac_on;
    209                  retval = PASS;
    210              }
    211          
    212              return (retval);
    213          }
    214          
    215          //---------------------------------------------------------------------------------------------------------------------
    216          /**
    217           *  @brief      Process DoorLockEMPilot instance.
    218           *
    219           *  @param      HBL_LOAD_TYPE *load - Pointer to DoorLockEMPilot instance.
    220           *
    221           *  @return     PASS_FAIL_TYPE result - Result of DoorLockEMPilot instance process.
    222           *  @retval     PASS - Instance process succeeded.
    223           *  @retval     FAIL - Instance process failed.
    224           */
    225          PASS_FAIL_TYPE DoorLockEMPilot__Process(HBL_LOAD_TYPE * load )
    226          {
    227              PASS_FAIL_TYPE retval = FAIL;
    228              uint8 index = load->Pilot_Data_Index;
    229          
    230              if (index < DoorLockEMPilot_Allocation)
    231              {
    232                  DOORLOCKEMPILOT_PARAM_TYPE *param_ptr;
    233                  DOORLOCKEMPILOT_DATA_TYPE *ptr;
    234          
    235                  param_ptr = (DOORLOCKEMPILOT_PARAM_TYPE *) (load->Parameter_Ptr.Data); //lint !e927 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.4]
    236                  ptr = &DoorLockEMPilot_Data[index];
    237          
    238          		// Prevent any state update if Time_Spacing time has not been elapsed
    239                  if ((ptr->Retries_Counter >= (param_ptr->Time_Spacing * DOORLOCKEM_TIME_SPACING_UNIT_MS))
    240                      && (ptr->Requested != ptr->Processed))
    241                  {
    242                      HBL_LOAD_STATUS_TYPE tmp_load;
    243                      HBL_CONSISTENCY_TYPE requested_consistency;
    244          
    245                      tmp_load.Load.Status = HBL_LOAD_STATUS_TARGET_COMPLETED;
    246                      tmp_load.Load.Cur_Reg = ptr->Requested;
    247                      requested_consistency.Byte = Hbl__GetOwnLoadConsistency(load, tmp_load.Byte);
    248          
    249                      if (ptr->Requested == 0)
    250                      {
    251                          switch (ptr->Status)
    252                          {
    253                              case DOORLOCKEM_STATUS_DOOR_LOCKED:
    254                                  if (requested_consistency.Consistency.Value != HBL_CONSISTENCY_OK)
    255                                  {
    256                                      ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    257                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKING;
    258                                      ptr->Retries = param_ptr->Max_Retries;
    259                                  }
    260                                  else
    261                                  {
    262                                      // If current consistency related to Requested value already match, go directly to
    263                                      // new status - this prevents to change door lock status
    264                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_UNLOCKED;
    265                                  }
    266                                  retval = PASS;
    267                                  break;
    268          
    269                              case DOORLOCKEM_STATUS_DOOR_LOCKING_FAILED:
    270                                  ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    271                                  ptr->Status = DOORLOCKEM_STATUS_INIT;
    272                                  retval = PASS;
    273                                  break;
    274          
    275                              default:
    276                                  break;
    277                          }
    278                      }
    279                      else
    280                      {
    281                          switch (DoorLockEMPilot_Data[index].Status)
    282                          {
    283                              case DOORLOCKEM_STATUS_DOOR_UNLOCKED:
    284                                  if (requested_consistency.Consistency.Value != HBL_CONSISTENCY_OK)
    285                                  {
    286                                      ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    287                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKING;
    288                                      ptr->Retries = param_ptr->Max_Retries;
    289                                  }
    290                                  else
    291                                  {
    292                                      // If current consistency related to Requested value already match, go directly to
    293                                      // new status - this prevents to change door lock status
    294                                      ptr->Status = DOORLOCKEM_STATUS_DOOR_LOCKED;
    295                                  }
    296                                  retval = PASS;
    297                                  break;
    298          
    299                              case DOORLOCKEM_STATUS_DOOR_UNLOCKING_FAILED:
    300                                  ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    301                                  ptr->Status = DOORLOCKEM_STATUS_INIT;
    302                                  retval = PASS;
    303                                  break;
    304          
    305                              default:
    306                                  break;
    307                          }
    308                      }
    309                  }
    310                  else if ((ptr->Status == DOORLOCKEM_STATUS_INIT) ||
    311                      (ptr->Requested  == ptr->Processed))
    312                  {
    313                      retval = PASS;
    314                  }
    315          
    316                   // Update Processed data only when status has been updated
    317                  if (retval == PASS)
    318                  {
    319                     ptr->Processed = ptr->Requested;
    320                  }
    321                  // Check Request_Triac_On and Process_Triac_On changes
    322                  if (ptr->Request_Triac_On != ptr->Process_Triac_On)
    323                  {
    324                      /* If Process_Triac_On was set, pin has been forced ON and this could alter Door lock device status regardless of
    325                       * Status instance field value; in order to align it properly and initialize will be performed.
    326                       */
    327                      if(ptr->Process_Triac_On)
    328                      {
    329                          ptr->PilotStatus.Load.Status = HBL_LOAD_STATUS_WAITING_TARGET;
    330                          ptr->Status = DOORLOCKEM_STATUS_INIT;
    331                      }
    332                      ptr->Process_Triac_On = ptr->Request_Triac_On;
    333                      retval = PASS;
    334                  }
    335              }
    336          
    337              return (retval);
    338          }
    339          
