      1          /**
      2           *  @file       
      3           *
      4           *  @brief      The Virtual Digital LLI is used when there is unique processing to determine the
      5           *              value of a digital input. This module supports a virtual digital with 1 or 4
      6           *              input pins.
      7           *
      8           *  @details    The parameter file for this module should be used to link the project specific
      9           *              implementation that determines the value of a virtual digital input.
     10           *
     11           *  @copyright  Copyright 2016-$Date$. Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     12           */
     13          //---------------------------------------------------------------------------------------------------------------------
     14          //---------------------------------------------------------------------------------------------------------------------
     15          
     16          //-------------------------------------- Include Files ----------------------------------------------------------------
     17          #include "SystemConfig.h"
     18          #include "VirtualDigitalLLI.h"
     19          
     20          #if (HBL_LLI_NUM_VIRTUAL_DIGITAL > 0)
     21          #include "VirtualDigitalLLI_prv.h"
     22          #include <string.h>
     23          #include "VirtualPin.h"
     24          
     25          //-------------------------------------- PRIVATE (Variables, Constants & Defines) -------------------------------------
     26          static uint8 VirtualDigitalLLI_Allocation;
     27          
     28          //! Current state of the input(s) for the virtual digital low level input
     29          //! The number of inputs can be either 1 or 4, based on the LLI ID
     30          static uint8 VirtualDigitalLLI_Data[HBL_LLI_NUM_VIRTUAL_DIGITAL][4];
     31          
     32          #define VIRTUAL_DIGITALLOWINPUT_CFG1_INVERT          0x80
     33          
     34          //-------------------------------------- PRIVATE (Function Prototypes) ------------------------------------------------
     35          
     36          //=====================================================================================================================
     37          //-------------------------------------- Public Functions -------------------------------------------------------------
     38          //=====================================================================================================================
     39          
     40          //---------------------------------------------------------------------------------------------------------------------
     41          /**
     42           *  @brief  Initializes the module VirtualDigitalLLI and its variables
     43           */
     44          void VirtualDigitalLLI__Initialize(void)
     45          {
     46              VirtualDigitalLLI_Allocation = 0;
     47              memset (VirtualDigitalLLI_Data, 0, sizeof(VirtualDigitalLLI_Data));
     48          }
     49          
     50          //---------------------------------------------------------------------------------------------------------------------
     51          /**
     52           * @brief   Performs allocation for an LLI
     53           *
     54           * @return  TRUE if the LLI was allocated, else FALSE.
     55           */
     56          uint8 VirtualDigitalLLI__Allocate(void)
     57          {
     58              uint8 retval;
     59              retval = HBL_ALLOCATION_INVALID;
     60          
     61              if (VirtualDigitalLLI_Allocation < HBL_LLI_NUM_VIRTUAL_DIGITAL)
     62              {
     63                  retval = VirtualDigitalLLI_Allocation;
     64                  VirtualDigitalLLI_Allocation++;
     65              }
     66          
     67              return (retval);
     68          }
     69          
     70          //---------------------------------------------------------------------------------------------------------------------
     71          /**
     72           *  @brief  Initializes a single instance of an LLI
     73           *
     74           *  @return TRUE if the LLI can be initialized, else FALSE
     75           */
     76          PASS_FAIL_TYPE VirtualDigitalLLI__InitializeInstance(HBL_LLI_TYPE * input)
     77          {
     78              PASS_FAIL_TYPE retval;
     79          
     80              retval = FAIL;
     81          
     82              if (input->Data_Index < VirtualDigitalLLI_Allocation)
     83              {
     84                  retval = PASS;
     85              }
     86          
     87              return(retval);
     88          }
     89          
     90          //---------------------------------------------------------------------------------------------------------------------
     91          /**
     92           * @brief   Gets the value of an LLI
     93           * @param   input: See HBL_LLI_TYPE
     94           *
     95           * @return  value of the VirtualDigital LLI
     96           */
     97          void * VirtualDigitalLLI__Get(HBL_LLI_TYPE * input)
     98          {
     99              if (input->Data_Index < VirtualDigitalLLI_Allocation)
    100              {
    101                  switch(input->LLI_ID)
    102                  {
    103                      case HBL_LLI_VIRTUALDIGITAL:
    104                          if(input->Parameter_Ptr.Data[1] & VIRTUAL_DIGITALLOWINPUT_CFG1_INVERT)
    105                          {
    106                              VirtualDigitalLLI_Data[input->Data_Index][0] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[2]) & BIT0_MASK;
    107                              VirtualDigitalLLI_Data[input->Data_Index][0] ^= TRUE;
    108                          }
    109                          else
    110                          {
    111                              VirtualDigitalLLI_Data[input->Data_Index][0] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[2]) & BIT0_MASK;     // Referencing index 2 of the parameters because first 2 bytes are configurations flags common to all LLIs
    112                          }
    113                          break;
    114                      case HBL_LLI_VIRTUALDIGITAL_4:
    115                          VirtualDigitalLLI_Data[input->Data_Index][0] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[2]) & BIT0_MASK;   // Referencing index 2 of the parameters because first 2 bytes are configurations flags common to all LLIs
    116                          VirtualDigitalLLI_Data[input->Data_Index][1] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[3]) & BIT0_MASK;
    117                          VirtualDigitalLLI_Data[input->Data_Index][2] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[4]) & BIT0_MASK;
    118                          VirtualDigitalLLI_Data[input->Data_Index][3] = GET_VIRTUAL_DIGITAL_LLI(input->Parameter_Ptr.Data[5]) & BIT0_MASK;
    119                          break;
    120                      default:
    121                          break;
    122                  }
    123          
    124                  return((void *)VirtualDigitalLLI_Data[input->Data_Index]);         //lint !e923 Suppress Info: cast from pointer to pointer [MISRA 2004 Rule 11.1],[MISRA 2004 Rule 11.3]
    125              }
    126              else
    127              {
    128                  return (NULL);
    129              }
    130          }
    131          
    132          //---------------------------------------------------------------------------------------------------------------------
    133          /**
    134           * @brief   Asynchronous processing of the LLI
    135           * @param   input: see HBL_LLI_TYPE
    136           * @return  Always TRUE since there is no processing to do
    137           */
    138          BOOL_TYPE VirtualDigitalLLI__AsynchProcess(HBL_LLI_TYPE * input)
    139          {
    140              // Function needs to return TRUE to increment the LLI sequence number (indicating new sample is available)
    141              return (TRUE);
    142          }
    143          
    144          //=====================================================================================================================
    145          //-------------------------------------- Private Functions ------------------------------------------------------------
    146          //=====================================================================================================================
    147          
    148          #endif //#if (HBL_LLI_NUM_VIRTUAL_DIGITAL > 0)


 

 


