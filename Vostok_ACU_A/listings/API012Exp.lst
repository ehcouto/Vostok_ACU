   1044          static BOOL_TYPE UpdateAcuGiStatus(void)
   1045          {
   1046              uint8 compare_buffer[ACU_EXP_GI_BUFFER_SIZE];
   1047          
   1048              memcpy(compare_buffer, API12_Expansion_ACU_GI_Buffer, AP12_ACU_GI_Data_Size);
