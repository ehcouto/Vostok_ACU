   1379          //---------------------------------------------------------------------------------------------------------------------
   1380          /**
   1381           * @brief  Butterworth filter implementation
   1382           *
   1383           */
   1384          static void ZeroCrossButterworthFilter(void)
   1385          {
   1386              sint64 divider;
   1387              sint32 accumulator;
   1388              uint8 pin_value = (uint8) ZeroCross__GetPinValue();
   1389          
   1390              #if(ZC_INVERT_PIN_VALUE == ENABLED)
   1391                  pin_value ^= 0x01U;
   1392              #endif
   1393              accumulator = ZEROCROSS_FLT_NUM_COEFFICIENTS[0] * (sint32) pin_value;
   1394              accumulator += ZEROCROSS_FLT_NUM_COEFFICIENTS[1] * (sint32) ZeroCross_Filter_In[0];
