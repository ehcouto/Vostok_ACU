    467          #if (BD_ADC_NOISE_ASSESSMENT == ENABLED)
    468          static void AdcNoiseInit()
    469          {
    470              //Adc Noise counters initialization
    471              Current_A.Signal_K_1     = 0;
    472              Current_B.Signal_K_1     = 0;
    473              Current_C.Signal_K_1     = 0;
    474              DcBus.Signal_K_1         = 0;
    475          
    476              Current_A.Signal_K_2     = 0;
    477              Current_B.Signal_K_2     = 0;
    478              Current_C.Signal_K_2     = 0;
    479              DcBus.Signal_K_2         = 0;
    480          
    481          
    482              Current_A.Noise_Ampl_Max = 0;
    483              Current_B.Noise_Ampl_Max = 0;
    484              Current_C.Noise_Ampl_Max = 0;
    485              DcBus.Noise_Ampl_Max     = 0;
    486          
    487              Current_A.Noise_Cnt      = 0;
    488              Current_B.Noise_Cnt      = 0;
    489              Current_C.Noise_Cnt      = 0;
    490              DcBus.Noise_Cnt          = 0;
    491          
    492              Current_Noise_Thr = BD_CURRENT_NOISE_THR;
    493              DcBus_Noise_Thr = BD_DC_BUS_NOISE_THR;
    494          
    495              Noise_Measure_Window = BD_NOISE_WINDOW;
    496              Noise_Measure_Window_Cnt = 0;
    497          
    498          }
    499          
    500          static void AdcNoiseHandler()
    501          {
    502              sint16 current_a;
    503              sint16 current_b;
    504              sint16 current_c;
    505              sint16 dc_bus;
    506          
    507              // convert floating point mcl currents and DCbus voltage back to 1.15 notation
    508              // (to be used, for instance, in case of third current reconstruction)
    509              current_a = (sint16) BD_CURRENT(Mcl_IO.Is_ABC.A);
    510              current_b = (sint16) BD_CURRENT(Mcl_IO.Is_ABC.B);
    511              current_c = (sint16) BD_CURRENT(Mcl_IO.Is_ABC.C);
    512              dc_bus    = (sint16) BD_VOLTAGE(Mcl_IO.Vdc);
    513          
    514          
    515              //--------------- Motor Current Adc Noise measurement -----------------------
    516              AdcNoiseMeasure(current_a, &Current_A, Current_Noise_Thr);
    517              AdcNoiseMeasure(current_b, &Current_B, Current_Noise_Thr);
    518              AdcNoiseMeasure(current_c, &Current_C, Current_Noise_Thr);
    519          
    520              //--------------- Dc Bus  Noise measurement -------------------------
    521              AdcNoiseMeasure(dc_bus, &DcBus, DcBus_Noise_Thr);
    522          
    523          }
    524          
    525          
    526          static void AdcNoiseMeasure(sint16 signal, NOISE_SIGNAL_TYPE* noise_signal, uint16 noise_thr)
    527          {
    528              sint16 signal_mean;
    529              sint16 signal_delta;
    530          
    531          
    532              signal_mean = (signal>>1) + (noise_signal->Signal_K_2 >>1);
    533          
    534              signal_delta = MATHCALC__ABS(noise_signal->Signal_K_1 - signal_mean);
    535          
    536              if(signal_delta > noise_thr)
    537              {
    538                  if(noise_signal->Noise_Ampl_Max < signal_delta)
    539                  {
    540                      noise_signal->Noise_Ampl_Max = signal_delta;
    541                  }
    542          
    543                  noise_signal->Noise_Cnt++;
    544              }
    545          
    546              noise_signal->Signal_K_2 = noise_signal->Signal_K_1;
    547              noise_signal->Signal_K_1 = signal;
    548          
    549          }
    550          
    551          
    552          #endif

