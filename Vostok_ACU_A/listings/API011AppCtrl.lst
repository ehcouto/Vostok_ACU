    367          void API011AppCtrl__Handler(void)
    368          {
   \                     API011AppCtrl__Handler: (+1)
   \   00000000   0xB510             PUSH     {R4,LR}
    369              #if (SYSTEM_HMI_HANDLING == ENABLED)
    370          
    371                  if(FALSE == First_Status_Regulations_Requested)
    372                  {
    373                      if ((((Reveal__GetNodestatus()) >> ((uint16)WIN_ACU_ADDRESS)) & (1U)) == 1U)
    374                      {
    375                          /*
    376                             Request status and regulations once ACU is detected alive.
    377                             Reset API011_Comm_Handle timer to avoid multiple, redundant requests at the same time.
    378                             Set API011AppCtrl_Request_Message_Content to API011APPCTRL_MESSAGE_REQUEST_REGULATIONS
    379                             to reinitialize standard request mechanism.
    380                           */
    381                          (void)API011AppCtrl__RequestStatus(WIN_ACU_ADDRESS);
    382                          (void)API011AppCtrl__RequestRegulations(WIN_ACU_ADDRESS);
    383                          First_Status_Regulations_Requested = TRUE;
    384                          Millis__RestartPeriod(&API011_Elapsed_Time, API011APPCTRL_STANDARD_REQUEST_PERIOD);
    385                          API011AppCtrl_Request_Message_Content = API011APPCTRL_MESSAGE_REQUEST_REGULATIONS;
    386                      }
    387                  }
    388          
    389                  if (API011_Poll_Timeout > 0U)
    390                  {
    391                      API011_Poll_Timeout--;
    392                  }
    393                  else
    394                  {
    395                      API011_Hmi_Poll_Reg_Status = ON;
    396                  }
    397          
    398                  if ((Mode__GetRemoteMode() == MODE_NORMAL) &&
    399                      (Mode__GetMode() == MODE_NORMAL) &&
    400                      (Mode__GetSubMode() != SUBMODE_NORMAL_EXT_CONTROL_ENGAGED) &&
    401                      (API011_Hmi_Poll_Reg_Status == ON))
    402                  {
    403                      if(Millis__ReachedTarget(&API011_Elapsed_Time, API011APPCTRL_STANDARD_REQUEST_PERIOD))
    404                      {
    405                          Millis__RestartPeriod(&API011_Elapsed_Time,API011APPCTRL_STANDARD_REQUEST_PERIOD);
    406                          // Checking the flag to decide if it is time to request Regulations or Status.
    407                          if(API011AppCtrl_Request_Message_Content == API011APPCTRL_MESSAGE_REQUEST_REGULATIONS)
    408                          {
    409                              API011_Num_Of_Consecutive_Regulations_Requests++;   // Increment number of regulations requests.
    410                              API011_Num_Of_Consecutive_Status_Requests = 0;      // Clear counter for status requests.
    411                              API011_Num_Of_Consecutive_Regulations_Sets = 0;     // Clear counter for regulations sets.
