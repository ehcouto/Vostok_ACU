     69          PASS_FAIL_TYPE ProbeLpsGI_InitializeInstance(HBL_GI_TYPE * generic_input, uint8 lli_sequence)
     70          {
     71              PASS_FAIL_TYPE retval;
     72          
     73          	retval = FAIL;
     74          
     75          	if(generic_input->Data_Index < ProbeLpsGI_Allocation)
     76          	{
     77          		ProbeLpsGI_LLI_Sequence[generic_input->Data_Index] = lli_sequence;
     78          		retval = PASS;
     79          	}
     80              return(retval);
     81          }
