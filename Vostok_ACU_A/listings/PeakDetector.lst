     46          //! Peak detector type definition - Contain all required variables for one channel
     47          typedef struct
     48          {
     49          	uint16   Min_Peak_Out;    //!< Min peaks value (taken from Period_Counter_Reload number of samples)
     50          	uint16   Max_Peak_Out;    //!< Max peaks value (taken from Period_Counter_Reload number of samples)
     51          	uint16   Min_Peak_Rough;  //!< Min rough sample values use for calculation
     52          	uint16   Max_Peak_Rough;  //!< Max rough sample value use for calculation
     53          	uint16   Period_Counter_Reload;//!< Number of samples needed for calculate min/max value
     54          	uint16   Period_Counter_Rough; //!< Current number of used samples
     55          }PEAK_DETECTOR_TYPE;
