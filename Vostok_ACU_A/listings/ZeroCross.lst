    117              /*
    118               *  Butterworth filter coefficients - 2nd order filter, cutoff range 35..85 Hz
    119               *  Available for sampling rates 2KHz (500us), 4KHz (250us), 5KHz (200us), 8KHz (125uz), 10KHz (100us)
    120               *
    121               *  Filter coefficients can be customized using
    122               *  - ZC_BUTTERWORTH_NUM_COEFFICIENTS macro for b0, b1, b2, b3, b4
    123               *  - ZC_BUTTERWORTH_DEN_COEFFICIENTS macro for a1, a2, a3, a4
    124               *  Each coefficient should be provided using Q notation; use ZC_FILTER_Q() macro to convert a floating point value.
    125               */
    126                  #ifndef ZC_BUTTERWORTH_NUM_COEFFICIENTS
