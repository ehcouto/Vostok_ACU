    159          //! The name of this module for use by the Log module.
    160          #define MODULE_NAME MODULE_INTERPRETER
    161          
    162          //! A list of log message IDs that are generated by this module.
    163          typedef enum MODULE_INTERPRETER_LOG_MESSAGE_ID_ENUM
    164          {
    165              COMPARTMENT_OUT_OF_RANGE            = 1,            //!< Compartments start at zero.
    166              PROCESS_FUNCTION_NULL               = 2,            //!< All Process OpCodes shall have an associated function.
    167              NOP_PROCESS                         = 3,            //!< No Operation Process in phase step.
    168              FIRST_STATEMENT_OUT_OF_RANGE        = 4,            //!< Statement of the initial step out of range.
    169              NULL_POINTER                        = 5,            //!< NULL pointer argument passed to Interpreter function.
    170              INVALID_SET_STATE_FLAG              = 6,            //!< F1_F0 Flag has invalid value.
    171              INVALID_END_SUB_CYCLE               = 7,            //!< Set state end sub-cycle received while sub-cycle not running.
    172              INVALID_COMPLETION_CODE             = 8,            //!< Invalid completion code (set state end sub-cycle).
    173              SF_PTR_SUB_CYCLE_FAIL               = 9,            //!< Failed to find set state data in setting file.
    174              JUMP_OCCURRED                       = 10,           //!< Jump occurred (HiByte = new phase; new statement)
    175              STARTED_NEW_STEP                    = 11,           //!< Started a new step (Data = Step number)
    176              STARTED_NEW_PHASE                   = 12,           //!< Started a new phase (Data = Phase number)
    177              JUMP_TO_CYCLE_OCCURRED              = 13,           //!< Jump to cycle occurred (HiByte = new cycle; LoByte = from cycle)
    178              SUB_CYCLE_COMPLETION_INVALID_PHASE  = 14            //!< Attempt to skip to next phase in last phase of main cycle.
    179          } MODULE_INTERPRETER_LOG_MESSAGE_ID_TYPE;
