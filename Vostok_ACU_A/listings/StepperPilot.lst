    233          /**
    234           *  @brief      Get stepper pilot instance processed request.
    235           *
    236           *  @param      HBL_LOAD_TYPE *load - Pointer to associated stepper load instance.
    237           *
    238           *  @return     void * processed - Processed instance data.
    239           *  @retval     Address of processed instance data. Cast it using *((STEPPER_PILOT_REQUEST_TYPE *)ptr) to get values.
    240           *  @retval     NULL - Invalid load index.
    241           */
    242          void * StepperPilot__GetProcessed(HBL_LOAD_TYPE *load)
    243          {
    244              void *processed;
    245          
    246              processed = NULL;
    247          
    248              if (load->Pilot_Data_Index < Stepper_Pilot_Allocation)
    249              {
    250                  processed = &(Stepper_Pilot_Data[load->Pilot_Data_Index].Processed);
    251              }
    252          
    253              return (processed);
