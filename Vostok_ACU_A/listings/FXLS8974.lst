    169          
    170          //! The first Accelerometer register written that controls configuration
    171          #define ACCEL_REG_SENS_CONFIG_1     0x15U
    172          
    173          //! The Accelerometer register read to get the temperature data
    174          #define ACCEL_REG_OUT_TEMP          0x01U
    175          
    176          //! The Accelerometer register to get the device identification data
    177          #define ACCEL_REG_WHO_AM_I          0x13U
    178          
    179          //! The first Accelerometer register read to get the XYZ acceleration data.
    180          #define ACCEL_REG_OUT_X_L           0x04U
    181          
    182          //! The Accelerometer register to set the decimation factor for the self test feature
    183          #define ACCEL_REG_SELF_TEST_CFG_2   0x38U
    184          
    185          //! The time required for the Accelerometer to initialize itself.
    186          //! Each count represents 250 microseconds.
    187          #define ACCEL_TIME_BOOT_UP          25U  // 25 * 200us = 5ms
    188          
    189          //! The timeout after which the module decides that no XYZ data will ever be received.
    190          //! NOTE: This value is based on the call rate of FXLS8974__Background()
    191          #define ACCEL_TIMEOUT_NO_DATA       100U // 100 * 200us = 20ms
    192          
    193          //! The timeout after which the module decides that no XYZ data will ever be received.
    194          //! NOTE: This value is based on the call rate of FXLS8974__Background()
    195          #define ACCEL_TIMEOUT_SELF_TEST_NO_DATA 2000U    // 2000 * 200us = 400ms
    196          
    197          //! The timeout after which the module decides that the I2C bus will never become available.
    198          //! NOTE: This value is based on the call rate of FXLS8974__Background()
    199          #define I2C_TIMEOUT_READY           100U // 100 * 200us = 20ms
    200          
    201          //! The name of this module for use by the Log module.
    202          #define MODULE_NAME                 MODULE_FXLS8974
