    410          //---------------------------------------------------------------------------------------------------------------------
    411          /**
    412           *
    413           */
    414          static void FastProcess(void)
    415          {
    416              if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    417              {
    418                  LISxDH__Background();
    419                  AccelerometerLLI_Public.Status = LISxDH__GetStatus();
    420              }
    421              else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    422              {
    423                  FXLS8974__Background();
    424                  AccelerometerLLI_Public.Status = FXLS8974__GetStatus();
    425              }
    426              // else, do nothing if device is unknown
    427          
    428              if (AccelerometerLLI.Enabled == TRUE)
    429              {
    430                  BOOL_TYPE accelerometer_retval = FALSE;
    431                  if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_LISxDH)
    432                  {
    433                      accelerometer_retval = LISxDH__Read((sint16 *)(&(AccelerometerLLI.Point)));
    434                  }
    435                  else if (AccelerometerLLI_Public.Device == ACCELEROMETER_DEVICE_FXLS8974)
    436                  {
    437                      accelerometer_retval = FXLS8974__Read((sint16 *)(&(AccelerometerLLI.Point)));
    438                  }
    439          
    440                  if (accelerometer_retval == TRUE)
    441                  {
    442                      AccelerometerLLI_Public.Last_Written_Index++;                                   // Increment to write at next index
    443                      if (AccelerometerLLI_Public.Last_Written_Index >= ACCELEROMETER_BUFFER_SIZE) // Handle wrap around to beginning of buffer
    444                      {
    445                          AccelerometerLLI_Public.Last_Written_Index = 0;
    446                      }
    447          
    448                      uint8 index = AccelerometerLLI_Public.Last_Written_Index;                       // Local variable to increase readability
    449          
    450                      AccelerometerLLI_Public.Raw[index].X_Axis = AccelerometerLLI.Point.X_Axis;
    451                      AccelerometerLLI_Public.Raw[index].Y_Axis = AccelerometerLLI.Point.Y_Axis;
    452                      AccelerometerLLI_Public.Raw[index].Z_Axis = AccelerometerLLI.Point.Z_Axis;
    453                      AccelerometerLLI_Public.Raw[index].Timestamp = AccelerometerLLI.Timestamp;       // Set the timestamp of this new sample
    454                      AccelerometerLLI.Point.Timestamp = AccelerometerLLI.Timestamp;
    455                  }
    456              }
    457              AccelerometerLLI.Timestamp += FAST_HANDLER_TIMING_USEC;
    458          }
