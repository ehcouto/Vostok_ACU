     66          /**
     67           * @brief      It Initializes the module DigitalLowLevel and its variables
     68           */
     69          void ConductivityLLI__Initialize(void)
     70          {
     71              uint8 index;
     72              for (index=0; index< HBL_LLI_NUM_CONDUCTIVITY; index++)
     73              {
     74                  InitConductivityData(&ConductivityLLI_Data[index]);
     75              }
     76              ConductivityLLI_Allocation = 0;
     77          }
     78          
     79          
     80          
     81          //---------------------------------------------------------------------------------------------------------------------
     82          /**
     83           * @brief
     84           * @return
     85           */
     86          uint8 ConductivityLLI__Allocate(void)
     87          {
     88              uint8 retval;
     89              retval = 0xFF;
     90              if (ConductivityLLI_Allocation < HBL_LLI_NUM_CONDUCTIVITY)
     91              {
     92                  retval = ConductivityLLI_Allocation;
     93                  ConductivityLLI_Allocation++;
     94          
     95              }
     96              return (retval);
     97          }
