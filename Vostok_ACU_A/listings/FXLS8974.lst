    301          
    302              //! Counts the number of communication failures before publishing a fault over API 18
    303              uint8 Failure_Counter;
    304          
    305              FXLS8974_SF_PARAM_TYPE * SF_Param_Ptr;
    306          } FXLS8974_VARS_TYPE;
