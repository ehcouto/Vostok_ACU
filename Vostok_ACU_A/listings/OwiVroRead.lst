    123          CT_ASSERT((uint8)DUTYCYCLE_SAMPLES_MAX_NUM <= AVEARAGE_WITH_REJ_MAX_SUPPORTED_SAMPLES_NUM);
    124          
    125          //! The maximum number of compensation coefficients to be saved for each setpoint.
