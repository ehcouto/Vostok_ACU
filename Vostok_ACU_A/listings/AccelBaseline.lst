    274          /**
    275           * Initialize the AccelBaseline module variables.
    276           * Read setting file parameters.
    277           * Orient the Accelerometer axes coordinate system based on the configuration.
    278           * Start the AccelBaseline state machine if parameters are successfully read.
    279           */
    280          void AccelBaseline__Initialize(void)
    281          {
    282              // Set all module variables to 0.
    283              memset(&Accel_Baseline, 0, sizeof(Accel_Baseline));
    284              Accel_Baseline.Baseline[2] = ONE_GRAVITY;
    285              Accel_Baseline.Sf = (void*)&ACCEL_PARAMS;   // Implementation from HA used setting file pointer in MCU section only; The configuration will be done in this module until there is a reason to move it
    286              AccelBaselineInitialize();
    287          }
