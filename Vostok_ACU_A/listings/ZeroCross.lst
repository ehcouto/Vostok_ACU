   1203                              memcpy((void *)processing_ptr, (void *)req_ptr, sizeof(ZEROCROSS_GPIO_REQUEST_TYPE));
   1204                              req_ptr->Gpio_Id = ZEROCROSS_ID_INVALID;
   1205                              req_ptr->Active_Degree = 0U;
   1206                              req_ptr->Deactive_Degree = 0U;
