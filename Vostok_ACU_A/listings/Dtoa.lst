     55          #define DTOA_CHANNEL_1_PORT             PORTA
     56          #define DTOA_CHANNEL_1_PORTBIT          4
     57          
     58          #define DTOA_CHANNEL_2_PORT             PORTA
     59          #define DTOA_CHANNEL_2_PORTBIT          5
     60          
     61          #define DMA_CR_CHNL1_CLEAR              0xFFFF0000
     62          #define DMA_CR_CHNL2_CLEAR              0x0000FFFF
     63          
     64          #ifndef DTOA_CHANNEL_RESOLUTION_HARDCODED
     65              #define DTOA_CHANNEL_RESOLUTION_HARDCODED       0
     66          #elif ((DTOA_CHANNEL_RESOLUTION_HARDCODED != 0) && (DTOA_CHANNEL_RESOLUTION_HARDCODED != 8) && (DTOA_CHANNEL_RESOLUTION_HARDCODED != 12))
     67              #error:"STM32G0x micro-controller supports only 8 or 12 bit DTOA resolution";
     68          #endif
