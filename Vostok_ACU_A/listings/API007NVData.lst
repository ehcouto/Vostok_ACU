    344          /**
    345           *  @brief      It Initializes the module API007NVData and its variables
    346           *
    347           *  @details	Function is called from the API007Data module. Should not be called from the Application
    348           *
    349           */
    350          void API007NVData__Initialize(void)
    351          {
    352              #if(API007NVDATA_CLIENT_FEATURE == ENABLED)
    353          		if (API007NVDATA_CLIENT_NUM_BLOCKS >= COMPILE_TIME_CLIENT_NUM_BLOCKS)
    354          		{
    355          	        API007NVData_Client_State 			= REQUEST_WRITE_DATA;
    356          	        API007NVData_Client_Server_Fbk		= WAITING_FOR_FBK;
    357          
    358          	        API007NVData_Client_Msg_Retry_Count = 0;
    359          	        API007NVData_Client_Timeout_Count 	= 0;
    360          
    361          	        API007NVData_Client_Data_Index		= 0;
    362          
    363          	        if (Micro__GetResetMode() == MICRO_RESET_MODE_COLD)
    364          	        {
    365          		        for(uint8 index = 0; index < API007NVDATA_CLIENT_NUM_BLOCKS; index++)
    366          		        {
    367          		            API007NVData_Client_Seg_Crc[index] = INITIAL_CRC16_VALUE;
    368          		        }
    369          
    370          	            API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_IN_PROGRESS;
    371          
    372          	            //case REQUEST_DATA: This starts with requesting the data
    373          	            API007NVData_Client_State = REQUEST_NVDATA_INFO;
    374          	        }
    375          		}
    376          		else
    377          		{
    378          			API007NVData_Client_State = ERROR_IRRICOVERABLE_STATE;
    379          			LOG_ADD_ERROR(ERROR_INSUFFECIENT_API007NVDATA_CLIENT_NUM_BLOCKS, COMPILE_TIME_CLIENT_NUM_BLOCKS);	//data explains how many of them are required
    380          		}
    381              #endif //(API007NVDATA_CLIENT_FEATURE == ENABLED)
    382          
    383          	#if(API007NVDATA_SERVER_FEATURE == ENABLED)
    384                  if (Micro__GetResetMode() == MICRO_RESET_MODE_COLD)
    385                  {
    386                  	if(NVData__GetLastRestoreStatus()->Bit.Appliance_Data_Recovered != NVDATA_RESTORE_OKAY)
    387                  	{
    388                  		//Initialize CDT if the NVData is corrupted
    389                  		for (uint8 index = 0; index < API007NVDATA_SERVER_NUM_CLIENTS_SUPPORT; index++)
    390                  		{
    391                  			API007NVData_CDTable[index].Node_ID 	= EMPTY_NODE_ID;
    392                  			API007NVData_CDTable[index].Start_Index = 0;
    393                  		}
    394                  	}
    395                  }
    396          	#endif
    397          }
    398          
    399          //----------------------------------------------------------------------------------------------------------
    400          /**
    401           * 	@brief 		Writing and Reading handlers
    402           *
    403           *  @details	Function is called from the API007Data module. Should not be called from the Application
    404           *
    405           * 				Shall be called at 5ms
    406           * 				If the call rate is changed then should update the API007NVDATA_HANDLER_CALL_RATE_MS macro
    407           *
    408           */
    409          void API007NVData__Handler(void)
    410          {
    411              #if(API007NVDATA_CLIENT_FEATURE == ENABLED)
    412          		uint16 crc_seg;
    413          		uint16 crc_index = 0;
    414          		uint16 block_size = 0;
    415          
    416          		API007NVData_Client_Timeout_Count++;
    417          
    418                  switch(API007NVData_Client_State)
    419                  {
    420          			case REQUEST_NVDATA_INFO:
    421          				//Wait for the Server to participate in communication
    422          				if ((Reveal__GetNodestatus() & (1 << API007NVDATA_SERVER_NODE_ID) ) != 0)
    423                          {
    424          					API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_IN_PROGRESS;
    425                              API007NVData_Client_Timeout_Count 		= 0;
    426                              API007NVData_Client_Server_Fbk			= WAITING_FOR_FBK;
    427          					API007NVData_Client_State 				= CHECK_RECEIVED_NVDATA_INFO;
    428          
    429                              API007Data__NVDataCmdClaimSizeRequest(API007NVDATA_DATA_SECTION_SIZE);
    430                          }
    431          				break;
    432          
    433          			case CHECK_RECEIVED_NVDATA_INFO:
    434          				if (API007NVData_Client_Timeout_Count < API007NVDATA_CLIENT_MSG_REPLY_TIMEOUT_MS)
    435          				{
    436          					if (API007NVData_Client_Server_Fbk == RECEIVED_NODE_INFO_FBK_PASS)
    437          					{
    438          						API007NVData_Client_State = REQUEST_READ_DATA;
    439          					}
    440          					else if (API007NVData_Client_Server_Fbk == RECEIVED_NODE_INFO_FBK_FAILED)
    441          					{
    442          						//Their is no use of continuing as we were not able to claim the required size
    443          						API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_ERROR;
    444          						API007NVData_Client_State = ERROR_IRRICOVERABLE_STATE;
    445          						LOG_ADD_ERROR(ERROR_UNABLE_TO_ALLOCATE_CLAIMED_SIZE_IN_SERVER, API007NVDATA_DATA_SECTION_SIZE);	//data explains how much memory its trying to claim in server
    446          					}
    447          				}
    448          				else
    449          				{
    450                              API007NVData_Client_Msg_Retry_Count++;
    451          
    452                              if (API007NVData_Client_Msg_Retry_Count >= API007NVDATA_CLIENT_MSG_RETRY_COUNT)
    453                              {
    454          						//Failed to receive feedback from server even though its active
    455                              	//Diagnosis :Check is Server configured
    456          						API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_ERROR;
    457          						API007NVData_Client_State = ERROR_IRRICOVERABLE_STATE;
    458          						LOG_ADD_ERROR(ERROR_SERVER_NOT_SENDING_FEEDBACK, API007NVDATA_CLIENT_MSG_RETRY_COUNT);	//data explains how many times it retried
    459                              }
    460                              else
    461                              {
    462                                  API007NVData_Client_State = REQUEST_NVDATA_INFO;
    463                              }
    464          				}
    465          
    466          				//Preparation before transit to next state
    467          				if (API007NVData_Client_State == REQUEST_READ_DATA)
    468          				{
    469          					API007NVData_Client_Msg_Retry_Count = 0;
    470          			        API007NVData_Client_Data_Index		= 0;
    471          				}
    472          				break;
    473          
    474          
    475          
    476          
    477          
    478          
    479          
    480                      case REQUEST_READ_DATA:
    481                          API007NVData_Client_Server_Fbk			= WAITING_FOR_FBK;
    482                          API007NVData_Client_Timeout_Count		= 0;
    483          
    484                          //Calculate how much read data we need to request
    485                      	block_size = DATA_TRANSFER_SEGMENT_SIZE;
    486                      	if ((API007NVData_Client_Data_Index + DATA_TRANSFER_SEGMENT_SIZE) >= API007NVDATA_DATA_SECTION_SIZE)
    487                      	{
    488                      		block_size = API007NVDATA_DATA_SECTION_SIZE - API007NVData_Client_Data_Index;
    489                      	}
    490          
    491          				API007Data__NVDataCmdReadRequest(API007NVData_Client_Data_Index, block_size);
    492          
    493          				API007NVData_Client_State = WAIT_FOR_DATA_RECEPTION;
    494                          break;
    495          
    496                      case WAIT_FOR_DATA_RECEPTION:
    497                      	if (API007NVData_Client_Timeout_Count < API007NVDATA_CLIENT_MSG_REPLY_TIMEOUT_MS)
    498          				{
    499          					if (API007NVData_Client_Server_Fbk == RECEIVED_READ_NVDATA_FBK_PASS)
    500          					{
    501          	                	//All data received
    502          	                	if (API007NVData_Client_Data_Index == API007NVDATA_DATA_SECTION_SIZE)
    503          	                	{
    504          	                		if (API007NVData_Client_Stored_Crc == Crc16__RangeProcess(API007NVDATA_CRC_SECTION_START, INITIAL_CRC16_VALUE, API007NVDATA_CRC_SECTION_SIZE))
    505          	                		{
    506          		                        API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_OKAY;
    507          
    508          								//Update CRC if all segments are received
    509          		                        API007NVData_Client_Data_Index			= 0;
    510          
    511          		                        for(crc_index = 0; API007NVData_Client_Data_Index < API007NVDATA_DATA_SECTION_SIZE; crc_index++)
    512          		                        {
    513          		                        	block_size = DATA_TRANSFER_SEGMENT_SIZE;
    514          
    515          			                        //Calculate for remains
    516          					            	if ((API007NVData_Client_Data_Index + DATA_TRANSFER_SEGMENT_SIZE) >= API007NVDATA_DATA_SECTION_SIZE)
    517          					            	{
    518          					            		block_size = API007NVDATA_DATA_SECTION_SIZE - API007NVData_Client_Data_Index;
    519          					            	}
    520          
    521          									API007NVData_Client_Seg_Crc[crc_index] = Crc16__RangeProcess((API007NVDATA_DATA_SECTION_START + API007NVData_Client_Data_Index), INITIAL_CRC16_VALUE, block_size);
    522          
    523          									API007NVData_Client_Data_Index += block_size;
    524          		                        }
    525          	                		}
    526          	                		else
    527          	                		{
    528          		                        API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_CORRUPTED;
    529          	                		}
    530          
    531          	                        API007NVData_Client_State = REQUEST_WRITE_DATA;
    532          	                	}
    533          	                	else
    534          	                	{
    535          	                		//We still have more data to read
    536          	                        API007NVData_Client_State = REQUEST_READ_DATA;
    537          	                	}
    538          					}
    539          					else if(API007NVData_Client_Server_Fbk == RECEIVED_READ_NVDATA_FBK_FAILED)
    540          					{
    541          						//Restart from the beginning again
    542                                  API007NVData_Client_State 				= REQUEST_NVDATA_INFO;
    543          					}
    544          				}
    545          				else
    546          				{
    547          					API007NVData_Client_Msg_Retry_Count++;
    548          
    549          					if (API007NVData_Client_Msg_Retry_Count >= API007NVDATA_CLIENT_MSG_RETRY_COUNT)
    550          					{
    551          						//Failed to receive feedback from server even though its active
    552          						API007NVData_Client_Data_Restore_Status = API007NVDATA_RESTORE_ERROR;
    553          						API007NVData_Client_State = REQUEST_WRITE_DATA;
    554          
    555          						LOG_ADD_ERROR(ERROR_SERVER_NOT_SENDING_FEEDBACK, API007NVDATA_CLIENT_MSG_RETRY_COUNT);	//data explains how many times it retried
    556          					}
    557          					else
    558          					{
    559                                  API007NVData_Client_State = REQUEST_READ_DATA;
    560          					}
    561          				}
    562          
    563          				//Preparation before transit to next state
    564          				if (API007NVData_Client_State == REQUEST_WRITE_DATA)
    565          				{
    566          					API007NVData_Client_Msg_Retry_Count = 0;
    567          					API007NVData_Client_Data_Index		= 0;
    568          					API007NVData_Client_Timeout_Count   = 0;
    569          				}
    570                          break;
    571          
    572          
    573          
    574          
    575          
    576          
    577          
    578          
    579                      case REQUEST_WRITE_DATA:
    580                      	//Monitor or update the write data only after the API007NVDATA_CLIENT_DATA_UPDATE_RATE_MS time expires to ease on the communication bus
    581          				if (API007NVData_Client_Timeout_Count > API007NVDATA_CLIENT_DATA_UPDATE_RATE_MS)
    582          				{
    583          					//Data change is detected arbitrarily so that everyone get equal chance
    584          
    585          					crc_index = 0;
    586          
    587          					for (uint16 num_loops = 0; num_loops < COMPILE_TIME_CLIENT_NUM_BLOCKS; num_loops++)
    588          					{
    589          						if (API007NVData_Client_Data_Index >= API007NVDATA_DATA_SECTION_SIZE)
    590          						{
    591          							API007NVData_Client_Data_Index = 0;
    592          
    593          							//calculate data section crc as its stored in the _header_segment which is at the start
    594          	                		API007NVData_Client_Stored_Crc = Crc16__RangeProcess(API007NVDATA_CRC_SECTION_START, INITIAL_CRC16_VALUE, API007NVDATA_CRC_SECTION_SIZE);
    595          						}
    596          
    597          						block_size 	= DATA_TRANSFER_SEGMENT_SIZE;
    598          						crc_index 	= API007NVData_Client_Data_Index/DATA_TRANSFER_SEGMENT_SIZE;
    599          
    600          						//Calculate for remains
    601          						if ((API007NVData_Client_Data_Index + DATA_TRANSFER_SEGMENT_SIZE) > API007NVDATA_DATA_SECTION_SIZE)
    602          						{
    603          							block_size = API007NVDATA_DATA_SECTION_SIZE - API007NVData_Client_Data_Index;
    604          						}
    605          
    606          						crc_seg = Crc16__RangeProcess((API007NVDATA_DATA_SECTION_START + API007NVData_Client_Data_Index), INITIAL_CRC16_VALUE, block_size);
    607          
    608          						if(crc_seg != API007NVData_Client_Seg_Crc[crc_index]) // Detect data change
    609          						{
    610          							API007NVData_Client_Seg_Crc[crc_index] 	= crc_seg;
    611          		                    API007NVData_Client_Timeout_Count 		= 0;
    612          		                    API007NVData_Client_Server_Fbk			= WAITING_FOR_FBK;
    613          
    614          							//Send modified data
    615          							API007Data__NVDataCmdWriteRequest(API007NVData_Client_Data_Index, block_size, (API007NVDATA_DATA_SECTION_START + API007NVData_Client_Data_Index));
    616          
    617          							API007NVData_Client_State 				= WAITING_FOR_SERVER_COMPLETED_WRITING;
    618          
    619          							API007NVData_Client_Data_Index += block_size;
    620          							break;
    621          						}
    622          
    623          						API007NVData_Client_Data_Index += block_size;
    624          					}
    625          				}
    626                          break;
    627          
    628          
    629                      case WAITING_FOR_SERVER_COMPLETED_WRITING:
    630          				if (API007NVData_Client_Timeout_Count < API007NVDATA_CLIENT_MSG_REPLY_TIMEOUT_MS)
    631          				{
    632          					if (API007NVData_Client_Server_Fbk == RECEIVED_WRITE_NVDATA_FBK_PASS)
    633          					{
    634          						API007NVData_Client_Timeout_Count = 0;
    635          						API007NVData_Client_State = REQUEST_WRITE_DATA;
    636          					}
    637          				}
    638          				else
    639          				{
    640          					API007NVData_Client_Timeout_Count = 0;
    641          					API007NVData_Client_State = REQUEST_WRITE_DATA;
    642          				}
    643                          break;
    644          
    645                      case ERROR_IRRICOVERABLE_STATE :
    646                      	break;
    647          
    648                      default:
    649                          API007NVData_Client_State = REQUEST_NVDATA_INFO;
    650                          break;
    651                  }
    652              #endif //(API007NVDATA_CLIENT_FEATURE == ENABLED)
    653          }
