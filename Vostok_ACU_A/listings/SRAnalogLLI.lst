    185          //---------------------------------------------------------------------------------------------------------------------
    186          /**
    187           * @brief	Initializes the SRAnalogLLI module and its variables
    188           */
    189          void SRAnalogLLI__Initialize(void)
    190          {
    191          	SRData__UpdateByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation, 0);
    192          	SRData__Fill(SRAnalogLLI_Channel, N_SRAnalogLLI_Channel, 0xFF, sizeof(SRAnalogLLI_Channel));
    193          	SRData__Fill(SRAnalogLLI_Data, N_SRAnalogLLI_Data, 0, sizeof(SRAnalogLLI_Data));
    194          	SRData__Fill((void *) &SRAnalogLLI_Compensation,(void *) &N_SRAnalogLLI_Compensation, 0, sizeof(SRAnalogLLI_Compensation));
    195          
    196              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    197                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_INIT, SRTASKSEQUENCE_APPL_INIT_SRANALOG_LLI);
    198              #endif
    199          }
    200          
    201          //---------------------------------------------------------------------------------------------------------------------
    202          /**
    203           * @brief	Checks if there is free space and reserve a new instance
    204           * @return	index of AnalogLLI instance, 0xFF if all HBL_LLI_NUM_SRANALOG are already allocated
    205           */
    206          uint8 SRAnalogLLI__Allocate(void)
    207          {
    208              uint8 retval;
    209              retval = 0xFF;
    210          
    211              if ((SRData__CheckByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation) == SRDATA_OK) &&
    212              	(SRAnalogLLI_Allocation < HBL_LLI_NUM_SRANALOG))
    213              {
    214                  retval = SRAnalogLLI_Allocation;
    215              	SRData__UpdateByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation, SRAnalogLLI_Allocation+1);
    216              }
    217          
    218              return (retval);
    219          }
    220          
    221          //---------------------------------------------------------------------------------------------------------------------
    222          /**
    223           * @brief      Initializes a new instance of SRAnalogLLI
    224           * @param input		pointer to HBL_LLI_TYPE structure reserved for that instance
    225           */
    226          PASS_FAIL_TYPE SRAnalogLLI__InitializeInstance(HBL_LLI_TYPE *input)
    227          {
    228              PASS_FAIL_TYPE retval = FAIL;
    229          
    230          	if ((SRData__CheckByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation) == SRDATA_OK) &&
    231          			(input->Data_Index < SRAnalogLLI_Allocation))
    232              {
    233          	    SRANALOGLLI_DATA_TYPE *data = &SRAnalogLLI_Data[input->Data_Index];
    234          	    SRANALOGLLI_DATA_TYPE *n_data = &N_SRAnalogLLI_Data[input->Data_Index];
    235          	    uint8 virtual_pin = input->Pin_Ptr[0];
    236          
    237                  if((SRDATA_OK == SRData__CheckByte(&SRAnalogLLI_Channel[input->Data_Index], &N_SRAnalogLLI_Channel[input->Data_Index])) &&
    238                  		(SRDATA_OK == SRData__CheckArrayNonBlocking(data, n_data, sizeof(SRANALOGLLI_DATA_TYPE))))
    239                  {
    240              		if (VIRTUALPIN_TABLE[virtual_pin].pin_config == (uint8) INPUT_ANALOG)
    241                      {
    242                          SRData__UpdateByte(&SRAnalogLLI_Channel[input->Data_Index], &N_SRAnalogLLI_Channel[input->Data_Index], VIRTUALPIN_TABLE[virtual_pin].device);
    243                          Gpio__PinConfig(VIRTUALPIN_TABLE[virtual_pin].port,VIRTUALPIN_TABLE[virtual_pin].pin,INPUT_ANALOG);
    244                          retval = PASS;
    245                      }
    246          
    247                      SRData__UpdateLong(&data->Sum, &n_data->Sum, 0);
    248                      SRData__UpdateShort(&data->Value, &n_data->Value, ATOD_INVALID_CONVERSION);
    249                      SRData__UpdateShort(&data->Last_Sample, &n_data->Last_Sample,  ATOD_INVALID_CONVERSION);
    250                      SRData__UpdateShort(&data->Raw_Sample, &n_data->Raw_Sample, ATOD_INVALID_CONVERSION);
    251                      SRData__UpdateShort(&data->Higher_Value, &n_data->Higher_Value, 0);
    252                      SRData__UpdateShort(&data->Lower_Value, &n_data->Lower_Value , ATOD_INVALID_CONVERSION);
    253                      SRData__UpdateByte(&data->Sample_Counter, &n_data->Sample_Counter, 0);
    254                      SRData__UpdateByte(&data->Fast_Sample_Counter, &n_data->Fast_Sample_Counter, 0);
    255                      SRData__UpdateByte(&data->Sync_Counter, &n_data->Sync_Counter, 0);
    256                      SRData__UpdateByte(&data->Fast_Sync_Counter, &n_data->Fast_Sync_Counter, 0);
    257                  }
    258              }
    259          
    260              return (retval);
    261          
    262          }
    263          
    264          //---------------------------------------------------------------------------------------------------------------------
    265          /**
    266           * @brief	Handler for SRAnalogLLI execution
    267           */
    268          void SRAnalogLLI__Handler(void)
    269          {
    270          	BOOL_TYPE retval;
    271          	uint8 index;
    272          
    273          	retval = (BOOL_TYPE) (SRData__CheckByte(&SRAnalogLLI_Allocation, &N_SRAnalogLLI_Allocation) == SRDATA_OK);
    274          	retval &= (BOOL_TYPE) (SRData__CheckArrayNonBlocking((void *) &SRAnalogLLI_Compensation, (void *) &N_SRAnalogLLI_Compensation, sizeof(SRAnalogLLI_Compensation)) == SRDATA_OK);
    275              retval &= (BOOL_TYPE) (Atod__EngineClassBCheck() == PASS);
    276          
    277          	for (index = 0; index < HBL_LLI_NUM_SRANALOG; index++)
    278          	{
    279          	    uint8 channel;
    280          
    281          		retval &= (BOOL_TYPE) (SRData__CheckArrayNonBlocking((void *) &SRAnalogLLI_Data[index],(void *) &N_SRAnalogLLI_Data[index], sizeof(SRAnalogLLI_Data[0])) == SRDATA_OK);
    282          		retval &= (BOOL_TYPE) (SRData__CheckByte(&SRAnalogLLI_Channel[index], &N_SRAnalogLLI_Channel[index]) == SRDATA_OK);
    283          		channel = SRAnalogLLI_Channel[index];
    284          		if (channel != 0xFF)
    285          		{
    286          		    uint8 gpio_index = FindCheckGpio(channel);
    287          		    if (gpio_index < ELEMENTS_IN_ARRAY(CHECK_PIN_TABLE))
    288          		    {
    289          	            retval &= (BOOL_TYPE) (Atod__ChannelClassBCheck((ATOD_CHANNEL_DEF) channel, CHECK_PIN_TABLE[gpio_index].Gpio_Port, CHECK_PIN_TABLE[gpio_index].Gpio_Pin) == PASS);
    290          		    }
    291          		    else
    292          		    {
    293          		        retval = FALSE;
    294          		    }
    295          		}
    296          
    297          		if (retval == FALSE)
    298          		{
    299          			SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0, index);
    300          			break;
    301          		}
    302          	}
    303              #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    304                  SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRANALOG_CHECKS);
    305              #endif
    306          }
    307          
