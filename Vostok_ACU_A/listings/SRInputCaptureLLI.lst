    198          //---------------------------------------------------------------------------------------------------------------------
    199          /**
    200           * @brief	Handler for SRInputCaptureLLI execution; this call (and sequence) checks SRInputCaptureLLI
    201           * @detail
    202           */
    203          void SRInputCaptureLLI__Handler(void)
    204          {
    205              BOOL_TYPE retval;
    206              uint8 index;
    207          
    208              retval = (BOOL_TYPE) (SRData__CheckByte(&SRInputCaptureLLI_Allocation, &N_SRInputCaptureLLI_Allocation) == SRDATA_OK);
    209              for (index = 0; index < HBL_LLI_NUM_SRINPUTCAPTURE; index++)
    210              {
    211                  retval &= (BOOL_TYPE) (SRData__CheckArrayNonBlocking(&SRInputCaptureLLI_Data[index], &N_SRInputCaptureLLI_Data[index],
    212                      sizeof(SRInputCaptureLLI_Data[0])) == SRDATA_OK);
    213                  if (retval == FALSE)
    214                  {
    215                      SRException__Queue(SREXCEPTION_HBL_DATA_NOT_CONSISTENT, 0, index);
    216                      break;
    217                  }
    218              }
    219          #if (SYSTEM_ENABLE_TASKSEQUENCE == ENABLED)
    220              SRTaskSequence__SetSequenceStep(SRTASKSEQUENCE_APPL_SAFETY_THREAD, SRTASKSEQUENCE_APPL_SRINPUTCAPTURE_CHECKS);
    221          #endif
    222          
    223          }
    224          
    225          //---------------------------------------------------------------------------------------------------------------------
    226          /**
    227           *
    228           * @param input
    229           * @param data
    230           * @return
    231           */
    232          void *SRInputCaptureLLI__Get(HBL_LLI_TYPE * input)
    233          {
    234              void *ret_val;
    235          
    236              ret_val = NULL;
    237          
    238              if (input->Data_Index < SRInputCaptureLLI_Allocation)
    239              {
