    276          //=====================================================================================================================
    277          //-------------------------------------- Private Functions ------------------------------------------------------------
    278          //=====================================================================================================================
    279          //---------------------------------------------------------------------------------------------------------------------
    280          /**
    281           * @brief       FSM Module manager: processes the command (set point) and executes the state machine to drive the motor.
    282           * @details     attention: It is assumed that it's called every 5ms.
    283                          attention: Before calling this method, FSMPilot__InitializeInstance() must be executed.
    284                          attention: So that the state machine is properly executed.
    285                          note: state machine implements a protection against the inversion of the sense of rotation.
    286          
    287           * @param       load
    288           * @return 	    none
    289          */
    290          static void FSMPilotStateManager(HBL_LOAD_TYPE *load)
    291          {
    292              FSMPILOT_SPEED_SIGN_TYPE sign;
    293              FSMPILOT_PARAMETERS_TYPE *parameters_pointer;
    294              FSMPILOT_PIN_MAP_TYPE *pin_map_pointer;
    295              parameters_pointer = (FSMPILOT_PARAMETERS_TYPE*)load->Parameter_Ptr.Data;
    296              pin_map_pointer = (FSMPILOT_PIN_MAP_TYPE*)load->Pin_Ptr;
    297          	switch(FSMPilot_Data[load->Pilot_Data_Index].State)
    298          	{
    299          		case FSMPILOT_SM_IDLE:
    300          			break;
    301          
    302          		case FSMPILOT_SM_INIT:
    303          			FSMPilot_Data[load-> Pilot_Data_Index].State = FSMPILOT_SM_SET_POINT_MONITORING;
    304          			// LS3 OFF
    305          			FSMPilot_Data[load->Pilot_Data_Index].Sense_Of_Rotation_Pin_Value = INACTIVE;
    306          			FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_1_Value 	  = INACTIVE;
    307          			FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_2_Value 	  = INACTIVE;
    308          			break;
    309          
    310          		case FSMPILOT_SM_SET_POINT_MONITORING:
    311          			sign = FSMPILOT_VELOCITY_ZERO;
    312          
    313          			if(FSMPilot_Data[load->Pilot_Data_Index].Processed > 0)
    314          			{
    315          				sign = FSMPILOT_VELOCITY_POSITIVE;
    316          			}
    317          
    318          			if(FSMPilot_Data[load->Pilot_Data_Index].Processed < 0)
    319          			{
    320          				sign = FSMPILOT_VELOCITY_NEGATIVE;
    321          			}
    322          
    323          			if(FSMPilot_Data[load->Pilot_Data_Index].Current_Velocity != sign)
    324          			{
    325          				FSMPilot_Data[load->Pilot_Data_Index].Monitoring_Flag = TRUE;
    326          				FSMPilot_Data[load->Pilot_Data_Index].Current_Velocity = sign;
    327          
    328          				FSMPilot_Data[load->Pilot_Data_Index].State = FSMPILOT_SM_T3;
    329          
    330          				// Timing variable initialization
    331          				FSMPilot_Data[load->Pilot_Data_Index].T3_Cnt = (parameters_pointer->T3_Val) * 10 * 2;
    332          				FSMPilot_Data[load->Pilot_Data_Index].T2_Cnt = (parameters_pointer->T2_Val) * 2;
    333          
    334          				// LS3 (power supply) OFF
    335          				FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_1_Value = INACTIVE;
    336          				FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_2_Value = INACTIVE;
    337          			}
    338          			else
    339          			{
    340          				FSMPilot_Data[load->Pilot_Data_Index].Monitoring_Flag = FALSE;
    341          			}
    342          			break;
    343          
    344          		case FSMPILOT_SM_T3:
    345          			if(!FSMPilot_Data[load->Pilot_Data_Index].T3_Cnt)
    346          			{
    347          				// SET LS1
    348          				if(FSMPilot_Data[load->Pilot_Data_Index].Current_Velocity > 0)
    349          				{
    350          					FSMPilot_Data[load->Pilot_Data_Index].Sense_Of_Rotation_Pin_Value = ACTIVE;
    351          				}
    352          				else
    353          				{
    354          					FSMPilot_Data[load->Pilot_Data_Index].Sense_Of_Rotation_Pin_Value = INACTIVE;
    355          				}
    356          
    357          				if(FSMPilot_Data[load->Pilot_Data_Index].Current_Velocity)
    358          				{
    359          					FSMPilot_Data[load->Pilot_Data_Index].State = FSMPILOT_SM_T2;
    360          				}
    361          				else
    362          				{
    363          					FSMPilot_Data[load->Pilot_Data_Index].State = FSMPILOT_SM_SET_POINT_MONITORING;
    364          				}
    365          			}
    366          			else
    367          			{
    368          				FSMPilot_Data[load->Pilot_Data_Index].T3_Cnt--;;
    369          			}
    370          			break;
    371          
    372          		case FSMPILOT_SM_T2:
    373          
    374          			if(!FSMPilot_Data[load->Pilot_Data_Index].T2_Cnt)
    375          			{
    376          				// LS3 ON
    377          				FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_1_Value 	  = ACTIVE;
    378          				FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_2_Value 	  = ACTIVE;
    379          
    380          				FSMPilot_Data[load->Pilot_Data_Index].State = FSMPILOT_SM_SET_POINT_MONITORING;
    381          			}
    382          			else
    383          			{
    384          				FSMPilot_Data[load->Pilot_Data_Index].T2_Cnt--;
    385          			}
    386          			break;
    387          
    388          		default:
    389          			FSMPilot_Data[load->Pilot_Data_Index].State = FSMPILOT_SM_SET_POINT_MONITORING;
    390          			break;
    391          	}
    392          
    393          	Gpio__PinWrite(  VIRTUALPIN_TABLE[pin_map_pointer->Sense_Of_Rotation_Pin].port,
    394          					 VIRTUALPIN_TABLE[pin_map_pointer->Sense_Of_Rotation_Pin].pin,
    395          					 (BOOL_TYPE)((FSMPilot_Data[load->Pilot_Data_Index].Sense_Of_Rotation_Pin_Value
    396          					 ^ ((~load->Hi_Low_Activation_Bitmap) >> 0)) & 0x01));
    397          
    398          	Gpio__PinWrite(  VIRTUALPIN_TABLE[pin_map_pointer->Power_Enable_Pin_1].port,
    399          					 VIRTUALPIN_TABLE[pin_map_pointer->Power_Enable_Pin_1].pin,
    400          					 (BOOL_TYPE)((FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_1_Value
    401          					 ^ ((~load->Hi_Low_Activation_Bitmap) >> 1)) & 0x01));
    402          
    403          	Gpio__PinWrite(  VIRTUALPIN_TABLE[pin_map_pointer->Power_Enable_Pin_2].port,
    404          					 VIRTUALPIN_TABLE[pin_map_pointer->Power_Enable_Pin_2].pin,
    405          					 (BOOL_TYPE)((FSMPilot_Data[load->Pilot_Data_Index].Power_Enable_Pin_2_Value
    406          					 ^ ((~load->Hi_Low_Activation_Bitmap) >> 2)) & 0x01));
    407              return;
    408          }
    409          
    410          #endif


 

 


