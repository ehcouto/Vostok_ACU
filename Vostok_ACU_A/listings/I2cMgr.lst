      1          /**
      2           *  @file       
      3           *
      4           *  @brief      This module acts as the manager for all the I2c channels on the micro-controller
      5           *
      6           *  @details    The module will grant or deny an i2c driver module access to a specific I2c channel on the micro-controller\n
      7           *  This module will ensure that only one device can operate over the I2c module at a time. The module will also\n
      8           *  ensure that each device will only operate over the bus for a predefined time. If the device maintains control of\n
      9           *  the I2C channel for too long, this module will kick the device from the bus.\n
     10           *
     11           *  $Header: I2cMgr.c 1.1 2016/08/31 13:12:31EDT Seth Herndon (HERNDS) Exp  $
     12           *
     13           *  @copyright  Copyright 2016-$Date: 2016/08/31 13:12:31EDT$. Whirlpool Corporation. All rights reserved - CONFIDENTIAL
     14           */
     15          //---------------------------------------------------------------------------------------------------------------------
     16          //---------------------------------------------------------------------------------------------------------------------
     17          #include "SystemConfig.h"
